    <script>
      declare global {
        interface Window {
          __musikiCourseLayoutKeyHandler?: (event: KeyboardEvent) => void;
          __musikiCourseLayoutResizeHandler?: () => void;
        }
      }

      const mountCourseLayout = () => {
        const root = document.querySelector('[data-course-layout-root]');
        if (!(root instanceof HTMLElement)) return;

        const overlay = root.querySelector('[data-course-sidebar-overlay]');
        const leftButtons = Array.from(root.querySelectorAll('[data-sidebar-toggle="left"], [data-sidebar-handle="left"]'));
        const rightButtons = Array.from(root.querySelectorAll('[data-sidebar-toggle="right"], [data-sidebar-handle="right"]'));
        const rightMaximizeButtons = Array.from(root.querySelectorAll('[data-sidebar-maximize="right"]'));
        const hasRightSidebar = root.dataset.hasRightSidebar === 'true';

        const isMobileViewport = () => window.matchMedia('(max-width: 1024px)').matches;

        const coerceBoolean = (value: string | null, fallback: boolean): boolean => {
          if (value === 'true') return true;
          if (value === 'false') return false;
          return fallback;
        };

        let leftOpen = true;
        let rightOpen = hasRightSidebar && coerceBoolean(
          window.localStorage.getItem('musiki:course:right-open'),
          root.dataset.rightOpen !== 'false',
        );
        let rightMaximized = hasRightSidebar && coerceBoolean(
          window.localStorage.getItem('musiki:course:right-maximized'),
          root.dataset.rightMaximized === 'true',
        );

        const syncShellOffsets = () => {
          const rootRect = root.getBoundingClientRect();
          const viewportBottomGap = Math.max(0, Math.round(window.innerHeight - rootRect.bottom));
          root.style.removeProperty('--course-shell-top');
          root.style.setProperty('--course-shell-bottom-gap', `${viewportBottomGap}px`);
        };

        const syncLayoutState = () => {
          syncShellOffsets();

          if (!hasRightSidebar) {
            rightOpen = false;
            rightMaximized = false;
          }

          if (isMobileViewport()) {
            rightMaximized = false;
          }

          root.dataset.leftOpen = leftOpen ? 'true' : 'false';
          root.dataset.rightOpen = rightOpen ? 'true' : 'false';
          root.dataset.rightMaximized = rightOpen && rightMaximized ? 'true' : 'false';

          const overlayActive = isMobileViewport() && (leftOpen || rightOpen);
          root.classList.toggle('is-overlay-active', overlayActive);
          if (overlay instanceof HTMLElement) {
            overlay.toggleAttribute('hidden', !overlayActive);
          }

          document.documentElement.classList.toggle('course-sidebars-open', overlayActive);
          document.body.classList.toggle('course-sidebars-open', overlayActive);

          const leftHandle = root.querySelector('[data-sidebar-handle="left"]');
          if (leftHandle instanceof HTMLButtonElement) {
            const nextLabel = leftOpen ? 'Ocultar navegación del curso' : 'Mostrar navegación del curso';
            leftHandle.textContent = leftOpen ? '←' : '→';
            leftHandle.setAttribute('aria-label', nextLabel);
            leftHandle.title = `${nextLabel} (⌘/Ctrl + \\)`;
          }

          rightMaximizeButtons.forEach((button) => {
            if (!(button instanceof HTMLButtonElement)) return;
            const active = rightOpen && rightMaximized;
            button.dataset.active = active ? 'true' : 'false';
            button.setAttribute('aria-label', active ? 'Minimizar foros' : 'Maximizar foros');
            button.title = active ? 'Minimizar foros' : 'Maximizar foros';
            button.textContent = active ? '⤡' : '⤢';
          });
        };

        const persistLayoutState = () => {
          window.localStorage.setItem('musiki:course:left-open', leftOpen ? 'true' : 'false');
          window.localStorage.setItem('musiki:course:right-open', rightOpen ? 'true' : 'false');
          window.localStorage.setItem('musiki:course:right-maximized', rightMaximized ? 'true' : 'false');
        };

        const toggleSidebar = (side: 'left' | 'right') => {
          if (side === 'left') {
            leftOpen = !leftOpen;
          } else if (side === 'right' && hasRightSidebar) {
            rightOpen = !rightOpen;
            if (!rightOpen) {
              rightMaximized = false;
            }
          }

          persistLayoutState();
          syncLayoutState();
        };

        const toggleRightMaximized = () => {
          if (!hasRightSidebar || isMobileViewport()) return;
          rightOpen = true;
          rightMaximized = !rightMaximized;
          persistLayoutState();
          syncLayoutState();
        };

        leftButtons.forEach((button) => {
          if (!(button instanceof HTMLElement) || button.dataset.boundCourseSidebar === 'true') return;
          button.dataset.boundCourseSidebar = 'true';
          button.addEventListener('click', () => toggleSidebar('left'));
        });

        rightButtons.forEach((button) => {
          if (!(button instanceof HTMLElement) || button.dataset.boundCourseSidebar === 'true') return;
          button.dataset.boundCourseSidebar = 'true';
          button.addEventListener('click', () => toggleSidebar('right'));
        });

        rightMaximizeButtons.forEach((button) => {
          if (!(button instanceof HTMLElement) || button.dataset.boundCourseSidebar === 'true') return;
          button.dataset.boundCourseSidebar = 'true';
          button.addEventListener('click', () => toggleRightMaximized());
        });

        if (overlay instanceof HTMLElement && overlay.dataset.boundCourseSidebar !== 'true') {
          overlay.dataset.boundCourseSidebar = 'true';
          overlay.addEventListener('click', () => {
            leftOpen = false;
            rightOpen = false;
            rightMaximized = false;
            persistLayoutState();
            syncLayoutState();
          });
        }

        if (typeof window.__musikiCourseLayoutKeyHandler === 'function') {
          document.removeEventListener('keydown', window.__musikiCourseLayoutKeyHandler);
        }

        const keyHandler = (event: KeyboardEvent) => {
          if (event.defaultPrevented) return;
          if (!(event.metaKey || event.ctrlKey) || event.altKey) return;
          if (String(event.code || '').toLowerCase() !== 'backslash') return;

          const target = event.target;
          const isEditable =
            target instanceof HTMLElement &&
            (target.isContentEditable || /^(INPUT|TEXTAREA|SELECT)$/.test(target.tagName));
          if (isEditable) return;

          event.preventDefault();
          toggleSidebar('left');
        };

        document.addEventListener('keydown', keyHandler);
        window.__musikiCourseLayoutKeyHandler = keyHandler;

        if (typeof window.__musikiCourseLayoutResizeHandler === 'function') {
          window.removeEventListener('resize', window.__musikiCourseLayoutResizeHandler);
        }

        const resizeHandler = () => {
          syncLayoutState();
        };

        window.addEventListener('resize', resizeHandler);
        window.__musikiCourseLayoutResizeHandler = resizeHandler;

        syncLayoutState();
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', mountCourseLayout, { once: true });
      } else {
        mountCourseLayout();
      }

      document.addEventListener('astro:page-load', mountCourseLayout);
    </script>

    <script>
      import { subscribeToLive } from '../../lib/live/client.mjs';
      import { formatCountdown, getRemainingMs } from '../../lib/live/countdown.mjs';

      const courseLayoutRoot = document.querySelector('[data-course-layout-root]');
      const canManageLiveInteractions =
        courseLayoutRoot instanceof HTMLElement
          ? courseLayoutRoot.dataset.canManageLiveInteractions === 'true'
          : false;
      const canonicalLiveCourseId =
        courseLayoutRoot instanceof HTMLElement
          ? String(courseLayoutRoot.dataset.liveCourseId || '').trim()
          : '';
      const canonicalLivePageSlug =
        courseLayoutRoot instanceof HTMLElement
          ? String(courseLayoutRoot.dataset.livePageSlug || '').trim()
          : '';

      let userSubmissions = {};
      let hasEvalBlocks = false;
      const progressByEvalId = new Map();
      const pollWidgetsByEvalId = new Map();
      const wordcloudWidgetsByEvalId = new Map();
      const forumState = {
        courseId: '',
        isLessonPage: false,
        mode: 'lesson',
        lessonSlug: '',
        boardSlug: '',
        boards: [],
        threads: [],
        selectedThreadId: '',
        canWrite: false,
        canManageBoards: false,
      };
      let evalMathRendererPromise = null;
      let unsubscribeLivePolls = null;
      let livePollTickId = null;

      async function loadUserSubmissions() {
        try {
          const response = await fetch('/api/submissions/my-submissions');
          const data = await response.json();
          userSubmissions = data?.submissions || {};
        } catch (error) {
          console.error('Error loading submissions:', error);
          userSubmissions = {};
        }
      }

      function parseEvalData(wrapper) {
        try {
          const b64 = wrapper.dataset.evalB64;
          if (b64) {
            const binary = atob(b64);
            const bytes = Uint8Array.from(binary, (char) => char.charCodeAt(0));
            return JSON.parse(new TextDecoder().decode(bytes));
          }

          // Legacy fallback for old parser payload.
          const legacy = wrapper.dataset.eval;
          if (legacy) return JSON.parse(legacy.replace(/&apos;/g, "'"));
        } catch (error) {
          console.error('Error parsing eval wrapper:', error);
        }

        return null;
      }

      function loadScriptOnce(src, marker) {
        return new Promise((resolve, reject) => {
          const existing = document.querySelector(`script[${marker}]`);
          if (existing) {
            if (existing.dataset.loaded === 'true') {
              resolve();
              return;
            }
            existing.addEventListener('load', () => resolve(), { once: true });
            existing.addEventListener('error', () => reject(new Error(`Failed to load ${src}`)), { once: true });
            return;
          }

          const script = document.createElement('script');
          script.src = src;
          script.defer = true;
          script.setAttribute(marker, 'true');
          script.addEventListener('load', () => {
            script.dataset.loaded = 'true';
            resolve();
          }, { once: true });
          script.addEventListener('error', () => reject(new Error(`Failed to load ${src}`)), { once: true });
          document.head.appendChild(script);
        });
      }

      async function ensureEvalMathRenderer() {
        if (typeof window.renderMathInElement === 'function') {
          return window.renderMathInElement;
        }

        if (evalMathRendererPromise) return evalMathRendererPromise;

        evalMathRendererPromise = (async () => {
          if (!window.katex || typeof window.katex.render !== 'function') {
            await loadScriptOnce(
              'https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js',
              'data-eval-katex',
            );
          }

          if (typeof window.renderMathInElement !== 'function') {
            await loadScriptOnce(
              'https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/contrib/auto-render.min.js',
              'data-eval-katex-auto-render',
            );
          }

          return window.renderMathInElement;
        })().catch((error) => {
          console.error('Failed to initialize eval math renderer:', error);
          return null;
        });

        return evalMathRendererPromise;
      }

      function renderEvalMath(container) {
        if (!container) return;

        ensureEvalMathRenderer()
          .then((renderMathInElement) => {
            if (typeof renderMathInElement !== 'function') return;
            renderMathInElement(container, {
              delimiters: [
                { left: '$$', right: '$$', display: true },
                { left: '$', right: '$', display: false },
              ],
              throwOnError: false,
              strict: 'ignore',
              ignoredTags: ['script', 'noscript', 'style', 'textarea', 'pre', 'code'],
            });
          })
          .catch((error) => {
            console.error('Eval math render error:', error);
          });
      }

      function getSubmission(evalId) {
        return userSubmissions[evalId] || null;
      }

      function getSubmissionPayload(submission) {
        if (!submission) return null;
        return submission.answer ?? submission.payload ?? null;
      }

      function getPreviousMcqAnswer(submission) {
        const payload = getSubmissionPayload(submission);
        if (payload && typeof payload === 'object') return payload.answer;
        return payload;
      }

      function toAnswerArray(answer) {
        if (Array.isArray(answer)) {
          return answer
            .map((value) => String(value))
            .filter((value) => value.length > 0);
        }
        if (answer === undefined || answer === null || answer === '') return [];
        return [String(answer)];
      }

      function isSubmissionCorrect(submission) {
        const payload = getSubmissionPayload(submission);
        if (payload && typeof payload === 'object' && typeof payload.isCorrect === 'boolean') {
          return payload.isCorrect;
        }
        if (typeof submission?.score === 'number') return submission.score > 0;
        return false;
      }

      function isCompletionSubmission(submission) {
        const payload = getSubmissionPayload(submission);
        if (!payload || typeof payload !== 'object') return false;

        if (payload.type === 'mcc' && payload.completed === true) return true;
        if (payload.completed === true) return true;

        const nestedAnswer = payload.answer;
        if (nestedAnswer && typeof nestedAnswer === 'object') {
          if (nestedAnswer.type === 'mcc' && nestedAnswer.completed === true) return true;
          if (nestedAnswer.completed === true) return true;
        }

        return false;
      }

      function buildProgressLabel(evalData, position) {
        const preferred = (evalData.title || evalData.prompt || `${evalData.type} ${position + 1}`)
          .replace(/\s+/g, ' ')
          .trim();

        if (preferred.length <= 64) return preferred;
        return `${preferred.slice(0, 61)}...`;
      }

      function registerProgress(evalData, position, isComplete = false) {
        progressByEvalId.set(evalData.id, {
          label: buildProgressLabel(evalData, position),
          complete: Boolean(isComplete),
          type: evalData.type || 'unknown',
        });
        renderPageProgress();
      }

      function setProgressCompletion(evalId, isComplete) {
        const existing = progressByEvalId.get(evalId);
        if (!existing) return;
        existing.complete = Boolean(isComplete);
        progressByEvalId.set(evalId, existing);
        renderPageProgress();
      }

      function renderPageProgress() {
        const container = document.getElementById('page-progress');
        const list = document.getElementById('page-progress-list');
        const meter = document.getElementById('mcc-progress-meter');
        const meterFill = document.getElementById('mcc-progress-fill');
        const meterPercent = document.getElementById('mcc-progress-percent');
        if (!container || !list) return;

        const entries = Array.from(progressByEvalId.entries());
        if (entries.length === 0) {
          container.hidden = true;
          return;
        }

        container.hidden = false;
        list.innerHTML = '';

        const mccEntries = entries.filter(([, item]) => item.type === 'mcc');
        if (meter && meterFill && meterPercent) {
          if (mccEntries.length === 0) {
            meter.hidden = true;
          } else {
            const completedCount = mccEntries.filter(([, item]) => item.complete).length;
            const percent = Math.round((completedCount / mccEntries.length) * 100);
            meter.hidden = false;
            meterFill.style.width = `${percent}%`;
            meterPercent.textContent = `${percent}%`;
          }
        }

        entries.forEach(([evalId, item]) => {
          const li = document.createElement('li');
          li.className = 'progress-item';
          if (item.complete) li.classList.add('is-complete');
          li.dataset.evalId = evalId;

          const dot = document.createElement('span');
          dot.className = 'progress-dot';
          dot.textContent = item.complete ? '✓' : '•';

          const label = document.createElement('span');
          label.className = 'progress-label';
          label.textContent = item.label;

          li.appendChild(dot);
          li.appendChild(label);
          list.appendChild(li);
        });
      }

      function getPageContext() {
        const pathParts = window.location.pathname
          .split('/')
          .filter(Boolean)
          .map((part) => {
            try {
              return decodeURIComponent(part);
            } catch {
              return part;
            }
          });
        const fallbackCourseId = String(canonicalLiveCourseId || '').trim();
        const fallbackPageSlug = String(canonicalLivePageSlug || '').trim();
        return {
          courseId: fallbackCourseId || pathParts[1] || '',
          pageSlug: fallbackPageSlug || pathParts.slice(1).join('/'),
        };
      }

      function ensureLiveClientId() {
        try {
          const storageKey = 'live:client-id';
          const existing = window.localStorage.getItem(storageKey);
          if (existing) return existing;
          const created = crypto.randomUUID();
          window.localStorage.setItem(storageKey, created);
          return created;
        } catch {
          return crypto.randomUUID();
        }
      }

      function formatPollStatus(widget) {
        if (!widget.state.active) return 'Interacción no activa.';
        if (!widget.state.endsAt) return 'Interacción en vivo.';

        const remainingMs = getRemainingMs(widget.state.endsAt, Date.now());
        if (remainingMs === null) return 'Interacción en vivo.';
        if (remainingMs <= 10_000) {
          return `Cierra en ${formatCountdown(remainingMs)}.`;
        }
        return `Tiempo restante: ${formatCountdown(remainingMs)}.`;
      }

      function updatePollCountdown(widget) {
        if (!widget.countdownNode) return;
        if (!widget.state.active || !widget.state.endsAt) {
          widget.countdownNode.hidden = true;
          widget.countdownNode.textContent = '';
          widget.countdownNode.classList.remove('is-closing');
          return;
        }

        const remainingMs = getRemainingMs(widget.state.endsAt, Date.now());
        if (remainingMs === null) {
          widget.countdownNode.hidden = true;
          widget.countdownNode.textContent = '';
          widget.countdownNode.classList.remove('is-closing');
          return;
        }

        widget.countdownNode.hidden = false;
        widget.countdownNode.textContent = formatCountdown(remainingMs);
        widget.countdownNode.classList.toggle('is-closing', remainingMs <= 10_000);
      }

      function setPollFeedback(widget, message, isError = false) {
        if (!widget.feedbackNode) return;
        if (!message) {
          widget.feedbackNode.hidden = true;
          widget.feedbackNode.textContent = '';
          widget.feedbackNode.dataset.error = 'false';
          return;
        }

        widget.feedbackNode.hidden = false;
        widget.feedbackNode.textContent = message;
        widget.feedbackNode.dataset.error = isError ? 'true' : 'false';
      }

      function sanitizePollOptionCounts(rawCounts) {
        if (!rawCounts || typeof rawCounts !== 'object' || Array.isArray(rawCounts)) return {};

        return Object.entries(rawCounts).reduce((acc, [rawKey, rawValue]) => {
          const optionId = String(rawKey || '').trim();
          if (!optionId) return acc;
          const numeric = Number(rawValue);
          if (!Number.isFinite(numeric) || numeric < 0) return acc;
          acc[optionId] = Math.round(numeric);
          return acc;
        }, {});
      }

      function getPersistedPollResults(payload) {
        if (!payload || typeof payload !== 'object') return null;

        const candidates = [];
        const directCounts = sanitizePollOptionCounts(payload.pollOptionCounts);
        if (Object.keys(directCounts).length > 0 || Number.isFinite(Number(payload.pollTotalResponses))) {
          candidates.push({
            optionCounts: directCounts,
            totalResponses: payload.pollTotalResponses,
          });
        }

        if (payload.pollResults && typeof payload.pollResults === 'object') candidates.push(payload.pollResults);
        if (payload.pollSnapshot && typeof payload.pollSnapshot === 'object') candidates.push(payload.pollSnapshot);
        if (payload.snapshot && typeof payload.snapshot === 'object') candidates.push(payload.snapshot);

        if (payload.answer && typeof payload.answer === 'object') {
          if (payload.answer.pollResults && typeof payload.answer.pollResults === 'object') {
            candidates.push(payload.answer.pollResults);
          }
          if (payload.answer.pollSnapshot && typeof payload.answer.pollSnapshot === 'object') {
            candidates.push(payload.answer.pollSnapshot);
          }
        }

        for (const candidate of candidates) {
          if (!candidate || typeof candidate !== 'object') continue;

          const optionCounts = sanitizePollOptionCounts(candidate.optionCounts || candidate.pollOptionCounts);
          const rawTotal = Number(candidate.totalResponses ?? candidate.pollTotalResponses);
          const computedTotal = Object.values(optionCounts).reduce(
            (sum, value) => sum + Math.max(0, Number(value) || 0),
            0,
          );
          const totalResponses = Number.isFinite(rawTotal) ? Math.max(0, Math.round(rawTotal)) : computedTotal;

          if (Object.keys(optionCounts).length === 0 && totalResponses <= 0) continue;
          return {
            optionCounts,
            totalResponses,
          };
        }

        return null;
      }

      function getPersistedPollAnswerLabels(payload, selectedIds, options) {
        if (payload && typeof payload === 'object') {
          const directOptions = Array.isArray(payload.answerOptions) ? payload.answerOptions : null;
          const nestedOptions =
            payload.answer && typeof payload.answer === 'object' && Array.isArray(payload.answer.answerOptions)
              ? payload.answer.answerOptions
              : null;
          const rawOptions = directOptions || nestedOptions;
          if (Array.isArray(rawOptions)) {
            const labels = rawOptions
              .map((item) => String(item || '').trim())
              .filter(Boolean);
            if (labels.length > 0) return labels;
          }
        }

        return selectedIds
          .map((id) => options.find((option) => String(option.id) === String(id))?.text || '')
          .filter(Boolean);
      }

      function sanitizeWordCounts(rawCounts) {
        if (!rawCounts || typeof rawCounts !== 'object' || Array.isArray(rawCounts)) return {};

        return Object.entries(rawCounts).reduce((acc, [rawWord, rawValue]) => {
          const word = String(rawWord || '').trim().replace(/\s+/g, ' ');
          if (!word) return acc;
          const numeric = Number(rawValue);
          if (!Number.isFinite(numeric) || numeric <= 0) return acc;
          acc[word] = Math.max(1, Math.round(numeric));
          return acc;
        }, {});
      }

      function getPersistedWordcloudResults(payload) {
        if (!payload || typeof payload !== 'object') return null;

        const candidates = [];
        const directCounts = sanitizeWordCounts(payload.wordCounts);
        if (Object.keys(directCounts).length > 0 || Number.isFinite(Number(payload.wordTotalResponses))) {
          candidates.push({
            wordCounts: directCounts,
            totalResponses: payload.wordTotalResponses,
          });
        }

        if (payload.wordcloudResults && typeof payload.wordcloudResults === 'object') {
          candidates.push(payload.wordcloudResults);
        }
        if (payload.wordcloudSnapshot && typeof payload.wordcloudSnapshot === 'object') {
          candidates.push(payload.wordcloudSnapshot);
        }
        if (payload.snapshot && typeof payload.snapshot === 'object') {
          candidates.push(payload.snapshot);
        }

        if (payload.answer && typeof payload.answer === 'object') {
          if (payload.answer.wordcloudResults && typeof payload.answer.wordcloudResults === 'object') {
            candidates.push(payload.answer.wordcloudResults);
          }
          if (payload.answer.wordcloudSnapshot && typeof payload.answer.wordcloudSnapshot === 'object') {
            candidates.push(payload.answer.wordcloudSnapshot);
          }
        }

        for (const candidate of candidates) {
          if (!candidate || typeof candidate !== 'object') continue;
          const wordCounts = sanitizeWordCounts(candidate.wordCounts || candidate.cloud || {});
          const rawTotal = Number(candidate.totalResponses ?? candidate.wordTotalResponses);
          const computedTotal = Object.values(wordCounts).reduce((sum, value) => sum + value, 0);
          const totalResponses = Number.isFinite(rawTotal) ? Math.max(0, Math.round(rawTotal)) : computedTotal;
          if (Object.keys(wordCounts).length === 0 && totalResponses <= 0) continue;
          return {
            wordCounts,
            totalResponses,
          };
        }

        return null;
      }

      function getPersistedWordcloudAnswerText(payload) {
        if (!payload || typeof payload !== 'object') return '';

        const directWord = String(payload.answerWord || payload.answerText || '').trim();
        if (directWord) return directWord;

        if (payload.answer && typeof payload.answer === 'object') {
          const nested = String(
            payload.answer.text
            || payload.answer.word
            || payload.answer.answerWord
            || payload.answer.answerText
            || '',
          ).trim();
          if (nested) return nested;
        }

        return '';
      }

      function renderWordcloudCloud(targetNode, rawCounts, totalResponses = 0) {
        if (!(targetNode instanceof HTMLElement)) return;

        const entries = Object.entries(sanitizeWordCounts(rawCounts))
          .sort((a, b) => {
            if (b[1] !== a[1]) return b[1] - a[1];
            return a[0].localeCompare(b[0], 'es');
          });

        if (entries.length === 0) {
          targetNode.hidden = true;
          targetNode.innerHTML = '';
          return;
        }

        const maxCount = Math.max(...entries.map(([, count]) => count), 1);
        const minCount = Math.min(...entries.map(([, count]) => count), maxCount);
        const total = Math.max(0, Number(totalResponses || 0));

        const cloud = document.createElement('div');
        cloud.className = 'wordcloud-cloud';

        entries.forEach(([word, count], index) => {
          const ratio = maxCount === minCount
            ? 1
            : (count - minCount) / (maxCount - minCount);
          const sizeRem = 0.95 + ratio * 1.85;
          const hue = (index * 53 + 17) % 360;

          const chip = document.createElement('span');
          chip.className = 'wordcloud-term';
          chip.style.fontSize = `${sizeRem.toFixed(2)}rem`;
          chip.style.color = `hsl(${hue}deg 75% 58%)`;
          chip.style.fontWeight = ratio > 0.6 ? '700' : '500';
          chip.title = total > 0
            ? `${word}: ${count} (${Math.round((count / total) * 100)}%)`
            : `${word}: ${count}`;
          chip.textContent = word;
          cloud.appendChild(chip);
        });

        const summary = document.createElement('p');
        summary.className = 'wordcloud-summary';
        summary.textContent = total > 0
          ? `${total} aportes · ${entries.length} términos`
          : `${entries.length} términos`;

        targetNode.hidden = false;
        targetNode.innerHTML = '';
        targetNode.append(cloud, summary);
      }

      async function persistWordcloudImage(widget, payload) {
        if (!widget?.canManage || !payload?.active) return;

        const sessionId = String(payload?.sessionId || '').trim();
        const wordCounts = sanitizeWordCounts(payload?.wordCounts || {});
        if (!sessionId || Object.keys(wordCounts).length === 0) return;

        const saveKey = JSON.stringify([
          sessionId,
          Number(payload?.totalResponses || 0),
          Object.entries(wordCounts).sort((left, right) => left[0].localeCompare(right[0], 'es')),
        ]);

        if (widget.lastSavedWordcloudKey === saveKey) return;
        widget.lastSavedWordcloudKey = saveKey;

        const courseContext = getPageContext();
        try {
          const response = await fetch('/api/live/wordcloud-image', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              courseId: courseContext.courseId,
              pageSlug: courseContext.pageSlug,
              interactionId: widget.data?.id || '',
              prompt: widget.data?.prompt || '',
              sessionId,
              wordCounts,
            }),
          });

          const exportPayload = await response.json().catch(() => ({}));
          if (!response.ok) {
            widget.lastSavedWordcloudKey = '';
            return;
          }

          widget.lastSavedWordcloudUrl = String(exportPayload?.publicUrl || '').trim();
        } catch {
          widget.lastSavedWordcloudKey = '';
        }
      }

      function syncPollResults(widget) {
        if (!widget.resultsNode) return;

        const persisted = widget.state.persistedResults && typeof widget.state.persistedResults === 'object'
          ? widget.state.persistedResults
          : null;
        const hasPersistedResults = Boolean(persisted);
        const canShowResults = widget.canManage
          ? widget.data.showResults && (widget.state.active || hasPersistedResults)
          : widget.data.showResults && widget.state.hasSubmitted && (widget.state.active || hasPersistedResults);

        if (!canShowResults) {
          widget.resultsNode.hidden = true;
          widget.resultsNode.innerHTML = '';
          return;
        }

        const sourceOptionCounts = widget.state.active
          ? widget.state.optionCounts
          : (persisted?.optionCounts || widget.state.optionCounts || {});
        const normalizedOptionCounts = sanitizePollOptionCounts(sourceOptionCounts);
        const derivedTotal = Object.values(normalizedOptionCounts).reduce(
          (sum, value) => sum + Math.max(0, Number(value) || 0),
          0,
        );
        const explicitTotal = widget.state.active
          ? Number(widget.state.totalResponses || 0)
          : Number(persisted?.totalResponses ?? widget.state.totalResponses ?? 0);
        const totalResponses = Number.isFinite(explicitTotal) && explicitTotal > 0
          ? Math.round(explicitTotal)
          : derivedTotal;

        if (Object.keys(normalizedOptionCounts).length === 0 && totalResponses <= 0) {
          widget.resultsNode.hidden = true;
          widget.resultsNode.innerHTML = '';
          return;
        }

        widget.resultsNode.hidden = false;
        widget.resultsNode.innerHTML = '';
        widget.data.options.forEach((option) => {
          const optionId = String(option.id || '');
          const count = Math.max(0, Number(normalizedOptionCounts?.[optionId] || 0));
          const percentage = totalResponses > 0 ? Math.round((count / totalResponses) * 100) : 0;

          const row = document.createElement('div');
          row.className = 'poll-result-row';

          const meta = document.createElement('div');
          meta.className = 'poll-result-meta';
          const optionText = document.createElement('span');
          optionText.className = 'poll-result-label';
          optionText.textContent = option.text;
          const optionCount = document.createElement('span');
          optionCount.className = 'poll-result-count';
          optionCount.textContent = `${count} (${percentage}%)`;
          meta.append(optionText, optionCount);

          const track = document.createElement('div');
          track.className = 'poll-result-track';
          const fill = document.createElement('div');
          fill.className = 'poll-result-fill';
          fill.style.width = `${percentage}%`;
          track.appendChild(fill);

          row.append(meta, track);
          widget.resultsNode.appendChild(row);
        });
      }

      function renderPollState(widget) {
        const canRespond = widget.state.active;
        const submissionDone = Boolean(widget.state.hasSubmitted);
        const { courseId } = getPageContext();
        const needsManualSubmit = Boolean(widget.data?.allowMultiple);

        if (widget.submitButton) {
          widget.submitButton.hidden = !canRespond || !needsManualSubmit;
          widget.submitButton.disabled = !canRespond;
          widget.submitButton.textContent = 'Enviar';
        }

        if (widget.startButton) {
          widget.startButton.hidden = !widget.canManage;
          widget.startButton.disabled = widget.state.active;
        }
        if (widget.endButton) {
          widget.endButton.hidden = !widget.canManage;
          widget.endButton.disabled = !widget.state.active || !widget.state.sessionId;
        }
        if (widget.openLink) {
          if (widget.canManage && widget.state.active && widget.state.sessionId) {
            const url = new URL(`/live/${encodeURIComponent(widget.state.sessionId)}`, window.location.origin);
            if (courseId) url.searchParams.set('courseId', courseId);
            widget.openLink.href = `${url.pathname}${url.search}`;
            widget.openLink.hidden = false;
          } else {
            widget.openLink.hidden = true;
          }
        }

        if (widget.formNode) {
          widget.formNode.hidden = !canRespond;
          widget.formNode.querySelectorAll('input').forEach((input) => {
            input.disabled = !canRespond;
          });
        }

        if (widget.statusNode) {
          if (!widget.state.active && submissionDone) {
            widget.statusNode.textContent = 'Interacción finalizada. Tu respuesta fue registrada.';
          } else {
            widget.statusNode.textContent = formatPollStatus(widget);
          }
        }

        updatePollCountdown(widget);
        syncPollResults(widget);
      }

      function emitLiveEvent(eventName, payload) {
        window.dispatchEvent(
          new CustomEvent('live:event', {
            detail: {
              eventName: String(eventName || '').trim(),
              payload: payload && typeof payload === 'object' ? payload : null,
            },
          }),
        );
      }

      function applyLivePayloadToPollWidgets(payload, sourceEvent) {
        if (sourceEvent === 'live.snapshot' && (!payload || !payload.active)) {
          pollWidgetsByEvalId.forEach((widget) => {
            widget.state.active = false;
            widget.state.sessionId = '';
            widget.state.endsAt = null;
            widget.state.totalResponses = 0;
            widget.state.optionCounts = {};
            renderPollState(widget);
          });
          return;
        }

        if (!payload || typeof payload !== 'object') return;

        if (sourceEvent === 'live.ended') {
          const endedInteractionId = String(payload.interactionId || '');
          pollWidgetsByEvalId.forEach((widget) => {
            if (widget.data.id !== endedInteractionId) return;
            widget.state.active = false;
            widget.state.sessionId = '';
            widget.state.endsAt = null;
            setPollFeedback(widget, 'La interacción fue cerrada.');
            renderPollState(widget);
          });
          return;
        }

        if (!payload.active) return;
        const interactionId = String(payload.interactionId || '');

        pollWidgetsByEvalId.forEach((widget) => {
          const isActiveWidget = widget.data.id === interactionId;
          if (!isActiveWidget && (sourceEvent === 'live.started' || sourceEvent === 'live.snapshot')) {
            widget.state.active = false;
            widget.state.sessionId = '';
            widget.state.endsAt = null;
            widget.state.totalResponses = 0;
            widget.state.optionCounts = {};
          }
          if (!isActiveWidget) {
            renderPollState(widget);
            return;
          }

          const nextSessionId = String(payload.sessionId || '');
          const isNewSession = Boolean(nextSessionId) && nextSessionId !== String(widget.state.sessionId || '');
          if (isNewSession) {
            widget.state.hasSubmitted = false;
            widget.state.persistedResults = null;
            try {
              window.localStorage.removeItem(`live:submitted:${widget.data.id}`);
            } catch {
              // ignore storage restrictions
            }
            if (widget.formNode instanceof HTMLElement) {
              widget.formNode.querySelectorAll('input').forEach((field) => {
                if (field instanceof HTMLInputElement) {
                  if (field.type === 'checkbox' || field.type === 'radio') {
                    field.checked = false;
                  } else if (field.type !== 'hidden') {
                    field.value = '';
                  }
                }
              });
            }
          }

          widget.state.active = true;
          widget.state.sessionId = nextSessionId;
          widget.state.endsAt = payload.endsAt || null;
          widget.state.totalResponses = Math.max(0, Number(payload.totalResponses || 0));
          widget.state.optionCounts = payload.optionCounts && typeof payload.optionCounts === 'object'
            ? payload.optionCounts
            : {};
          renderPollState(widget);
        });
      }

      function mountLivePollTransport() {
        if (pollWidgetsByEvalId.size === 0 && wordcloudWidgetsByEvalId.size === 0) return;
        const { courseId } = getPageContext();
        if (!courseId) return;

        unsubscribeLivePolls?.();
        unsubscribeLivePolls = subscribeToLive({
          courseId,
          onEvent: (eventName, payload) => {
            emitLiveEvent(eventName, payload);
            applyLivePayloadToPollWidgets(payload, eventName);
            applyLivePayloadToWordcloudWidgets(payload, eventName);
          },
        });

        if (livePollTickId) {
          window.clearInterval(livePollTickId);
        }
        livePollTickId = window.setInterval(() => {
          pollWidgetsByEvalId.forEach((widget) => {
            updatePollCountdown(widget);
          });
          wordcloudWidgetsByEvalId.forEach((widget) => {
            updatePollCountdown(widget);
          });
        }, 1000);
      }

      function ensureEvalText(value) {
        if (typeof value === 'string') return value.trim();
        if (value === undefined || value === null) return '';
        return String(value).trim();
      }

      function ensureEvalBool(value) {
        if (typeof value === 'boolean') return value;
        if (typeof value === 'string') {
          const normalized = value.trim().toLowerCase();
          if (['true', 'si', 'sí', 'yes', 'clara', 'claro'].includes(normalized)) return true;
          if (['false', 'no', 'unclear', 'difusa'].includes(normalized)) return false;
        }
        return false;
      }

      function clampEvalScore(value) {
        return Math.min(10, Math.max(0, value));
      }

      function parseEvalScore(value) {
        if (typeof value === 'number' && Number.isFinite(value)) return clampEvalScore(value);
        if (typeof value === 'string') {
          const match = value.match(/(\d+(?:[.,]\d+)?)\s*(?:\/\s*10)?/);
          if (!match?.[1]) return null;
          const parsed = Number(match[1].replace(',', '.'));
          if (!Number.isFinite(parsed)) return null;
          return clampEvalScore(parsed);
        }
        return null;
      }

      function ensureEvalPair(value) {
        let items = [];
        if (Array.isArray(value)) {
          items = value.map((item) => ensureEvalText(item)).filter(Boolean);
        } else if (typeof value === 'string') {
          items = value
            .split(/\n|;|\u2022|\-/g)
            .map((item) => item.trim())
            .filter(Boolean);
        }
        const out = items.slice(0, 2);
        while (out.length < 2) out.push('');
        return out;
      }

      function cleanupEvalJsonCandidate(text) {
        if (typeof text !== 'string') return '';
        return text
          .trim()
          .replace(/^```json/i, '')
          .replace(/^```/i, '')
          .replace(/```$/i, '')
          .replace(/,\s*([}\]])/g, '$1')
          .trim();
      }

      function parseEvalJsonLoosely(rawText) {
        const cleaned = cleanupEvalJsonCandidate(rawText);
        const firstBrace = cleaned.indexOf('{');
        if (firstBrace === -1) return null;

        const source = cleaned.slice(firstBrace);

        const tryParse = (candidate) => {
          try {
            const parsed = JSON.parse(candidate);
            return parsed && typeof parsed === 'object' ? parsed : null;
          } catch {
            return null;
          }
        };

        const direct = tryParse(source);
        if (direct) return direct;

        let depth = 0;
        let inString = false;
        let escaped = false;
        let endIndex = -1;

        for (let i = 0; i < source.length; i += 1) {
          const ch = source[i];

          if (inString) {
            if (escaped) {
              escaped = false;
            } else if (ch === '\\') {
              escaped = true;
            } else if (ch === '"') {
              inString = false;
            }
            continue;
          }

          if (ch === '"') {
            inString = true;
            continue;
          }

          if (ch === '{') depth += 1;
          if (ch === '}') depth -= 1;

          if (depth === 0) {
            endIndex = i;
            break;
          }
        }

        if (endIndex !== -1) {
          const balanced = cleanupEvalJsonCandidate(source.slice(0, endIndex + 1));
          const parsedBalanced = tryParse(balanced);
          if (parsedBalanced) return parsedBalanced;
        }

        if (depth > 0) {
          const repaired = cleanupEvalJsonCandidate(`${source}${'}'.repeat(depth)}`);
          const parsedRepaired = tryParse(repaired);
          if (parsedRepaired) return parsedRepaired;
        }

        const lastBrace = source.lastIndexOf('}');
        if (lastBrace !== -1) {
          const sliced = cleanupEvalJsonCandidate(source.slice(0, lastBrace + 1));
          const parsedSliced = tryParse(sliced);
          if (parsedSliced) return parsedSliced;
        }

        return null;
      }

      function deriveAiScore({ tesisClara, fortalezas, debilidades, sugerencia }) {
        let score = 5;
        score += tesisClara ? 1.5 : -1;
        score += fortalezas.filter(Boolean).length * 1.2;
        score -= debilidades.filter(Boolean).length * 0.8;
        if (sugerencia.length >= 30) score += 0.6;
        return Math.round(clampEvalScore(score) * 10) / 10;
      }

      function normalizeAiEvaluation(rawEvaluation) {
        const base = rawEvaluation && typeof rawEvaluation === 'object' ? rawEvaluation : {};
        const recovered = parseEvalJsonLoosely(base.raw || rawEvaluation) || {};

        const baseTesis = base.tesis && typeof base.tesis === 'object' ? base.tesis : {};
        const recoveredTesis = recovered.tesis && typeof recovered.tesis === 'object' ? recovered.tesis : {};
        const baseCal = base.calificacion && typeof base.calificacion === 'object' ? base.calificacion : {};
        const recCal = recovered.calificacion && typeof recovered.calificacion === 'object' ? recovered.calificacion : {};

        const resumen = ensureEvalText(base.resumen) || ensureEvalText(recovered.resumen);
        const tesisClara = ensureEvalBool(baseTesis.clara ?? recoveredTesis.clara ?? base.tesis_clara ?? recovered.tesis_clara);
        const tesisExplicacion =
          ensureEvalText(baseTesis.explicacion) ||
          ensureEvalText(recoveredTesis.explicacion) ||
          ensureEvalText(base.tesis_explicacion) ||
          ensureEvalText(recovered.tesis_explicacion);

        const fortalezas = ensureEvalPair(base.fortalezas ?? recovered.fortalezas);
        const debilidades = ensureEvalPair(base.debilidades ?? recovered.debilidades);
        const sugerencia = ensureEvalText(base.sugerencia) || ensureEvalText(recovered.sugerencia);

        let nota = parseEvalScore(baseCal.nota ?? recCal.nota ?? base.nota ?? recovered.nota);
        if (nota === null) nota = parseEvalScore(sugerencia);
        if (nota === null) {
          nota = deriveAiScore({
            tesisClara,
            fortalezas,
            debilidades,
            sugerencia,
          });
        }

        const justificacion =
          ensureEvalText(baseCal.justificacion) ||
          ensureEvalText(recCal.justificacion) ||
          `Nota sugerida ${nota}/10 según criterios de la rúbrica.`;

        return {
          resumen,
          tesis: {
            clara: tesisClara,
            explicacion: tesisExplicacion,
          },
          fortalezas,
          debilidades,
          sugerencia,
          calificacion: {
            nota,
            justificacion,
          },
          raw: ensureEvalText(base.raw) || ensureEvalText(rawEvaluation),
        };
      }

      function hasAiEvaluation(evaluation) {
        if (!evaluation || typeof evaluation !== 'object') return false;
        return Boolean(
          ensureEvalText(evaluation.resumen)
          || ensureEvalText(evaluation.sugerencia)
          || parseEvalScore(evaluation?.calificacion?.nota) !== null
          || ensureEvalPair(evaluation.fortalezas).some(Boolean)
          || ensureEvalPair(evaluation.debilidades).some(Boolean),
        );
      }

      async function saveSubmission({
        evalId,
        answer,
        isCorrect,
        meta = {},
        score = null,
        feedback = '',
        markAsGraded = false,
      }) {
        try {
          const { courseId, pageSlug } = getPageContext();
          const numericScore = typeof score === 'number' && Number.isFinite(score) ? score : null;
          const response = await fetch('/api/eval/submit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              evalId,
              answer,
              isCorrect,
              payload: {
                answer,
                isCorrect,
                ...(meta && typeof meta === 'object' ? meta : {}),
              },
              score: numericScore,
              feedback: ensureEvalText(feedback) || undefined,
              markAsGraded: Boolean(markAsGraded) || numericScore !== null,
              courseId,
              pageSlug,
            }),
          });

          if (!response.ok) return false;
          await loadUserSubmissions();

          return true;
        } catch (error) {
          console.error('Error saving submission:', error);
          return false;
        }
      }

      function renderMCQ(wrapper, data, position) {
        const previousSubmission = getSubmission(data.id);
        const previousAnswer = getPreviousMcqAnswer(previousSubmission);
        const previousAnswers = toAnswerArray(previousAnswer);
        const wasCorrect = isSubmissionCorrect(previousSubmission);
        const allowsMultiple = Boolean(data.allowMultiple);
        const allowEdit = Boolean(data.allowEdit);
        const correctOptionIndexes = data.options.reduce((acc, option, index) => {
          const optionCorrect = typeof option === 'string'
            ? /^\[(x|X)\]/.test(option.trim())
            : Boolean(option.isCorrect);
          if (optionCorrect) acc.push(String(index));
          return acc;
        }, []);

        registerProgress(data, position, wasCorrect);

        const container = document.createElement('div');
        container.className = 'eval-block';
        container.dataset.evalId = data.id;
        container.id = `eval-${data.id}`;

        const prompt = document.createElement('h4');
        prompt.className = 'eval-prompt';
        prompt.textContent = data.prompt;
        container.appendChild(prompt);

        if (allowsMultiple) {
          const modeHint = document.createElement('p');
          modeHint.className = 'feedback-explanation';
          modeHint.textContent = 'Selecciona todas las opciones correctas.';
          container.appendChild(modeHint);
        }

        if (allowEdit) {
          const editableHint = document.createElement('p');
          editableHint.className = 'feedback-explanation';
          editableHint.textContent = 'Puedes editar y reenviar tu respuesta.';
          container.appendChild(editableHint);
        }

        const form = document.createElement('form');
        form.className = 'mcq-form';

        data.options.forEach((option, index) => {
          const optionText = typeof option === 'string'
            ? option.replace(/^\[(x|X|\s)\]\s*/, '')
            : option.text;
          const optionCorrect = typeof option === 'string'
            ? /^\[(x|X)\]/.test(option.trim())
            : Boolean(option.isCorrect);

          const label = document.createElement('label');
          label.className = 'mcq-option';

          const input = document.createElement('input');
          input.type = allowsMultiple ? 'checkbox' : 'radio';
          input.name = allowsMultiple ? `${data.id}[]` : data.id;
          input.value = String(index);
          input.dataset.correct = optionCorrect ? 'true' : 'false';

          if (previousAnswers.includes(String(index))) {
            input.checked = true;
          }

          const span = document.createElement('span');
          span.textContent = optionText;

          label.appendChild(input);
          label.appendChild(span);
          form.appendChild(label);
        });

        const submitButton = document.createElement('button');
        submitButton.type = 'submit';
        submitButton.className = 'eval-submit';
        submitButton.textContent = previousSubmission && allowEdit ? 'Guardar cambios' : 'Enviar respuesta';
        form.appendChild(submitButton);
        container.appendChild(form);

        const feedback = document.createElement('div');
        feedback.className = 'eval-feedback';
        feedback.style.display = 'none';

        const message = document.createElement('p');
        message.className = 'feedback-message';
        feedback.appendChild(message);

        if (data.explanation) {
          const explanation = document.createElement('p');
          explanation.className = 'feedback-explanation';
          explanation.textContent = data.explanation;
          feedback.appendChild(explanation);
        }

        container.appendChild(feedback);

        if (previousSubmission) {
          message.textContent = wasCorrect ? '✅ ¡Correcto!' : '❌ Incorrecto, intenta de nuevo';
          message.className = `feedback-message ${wasCorrect ? 'correct' : 'incorrect'}`;
          feedback.style.display = 'block';

          if (wasCorrect && !allowEdit) {
            form.querySelectorAll('input').forEach((input) => {
              input.disabled = true;
            });
            submitButton.disabled = true;
          }
        }

        form.addEventListener('submit', async (event) => {
          event.preventDefault();

          const selectedInputs = Array.from(form.querySelectorAll('input:checked'));
          if (selectedInputs.length === 0) {
            alert(allowsMultiple ? 'Selecciona al menos una opción.' : 'Por favor selecciona una opción');
            return;
          }

          const selectedValues = selectedInputs.map((input) => String(input.value));
          const normalizedSelected = Array.from(new Set(selectedValues)).sort();
          const normalizedCorrect = Array.from(new Set(correctOptionIndexes)).sort();
          const isCorrect = normalizedSelected.length === normalizedCorrect.length
            && normalizedSelected.every((value, idx) => value === normalizedCorrect[idx]);
          const selectedOptionTexts = normalizedSelected
            .map((selectedIndex) => {
              const idx = Number(selectedIndex);
              const option = data.options[idx];
              if (typeof option === 'string') return option.replace(/^\[(x|X|\s)\]\s*/, '').trim();
              return String(option?.text || '').trim();
            })
            .filter(Boolean);

          message.textContent = isCorrect ? '✅ ¡Correcto!' : '❌ Incorrecto, intenta de nuevo';
          message.className = `feedback-message ${isCorrect ? 'correct' : 'incorrect'}`;
          feedback.style.display = 'block';

          const saved = await saveSubmission({
            evalId: data.id,
            answer: allowsMultiple ? normalizedSelected : normalizedSelected[0],
            isCorrect,
            meta: {
              answerText: selectedOptionTexts.join(' | '),
              answerOptions: selectedOptionTexts,
              answerIndexes: normalizedSelected,
              selectionMode: allowsMultiple ? 'multiple' : 'single',
            },
          });

          if (!saved) {
            alert('No se pudo guardar tu respuesta. Intenta nuevamente.');
            return;
          }

          setProgressCompletion(data.id, isCorrect);

          if (isCorrect && !allowEdit) {
            form.querySelectorAll('input').forEach((input) => {
              input.disabled = true;
            });
            submitButton.disabled = true;
          } else if (allowEdit) {
            submitButton.textContent = 'Guardar cambios';
          }
        });

        wrapper.appendChild(container);
        renderEvalMath(container);
      }

      function renderMCC(wrapper, data, position) {
        const previousSubmission = getSubmission(data.id);
        const isCompleted = isCompletionSubmission(previousSubmission);

        registerProgress(data, position, isCompleted);

        const container = document.createElement('div');
        container.className = 'eval-block mcc-block';
        container.dataset.evalId = data.id;
        container.id = `eval-${data.id}`;

        const prompt = document.createElement('h4');
        prompt.className = 'eval-prompt';
        prompt.textContent = data.prompt || 'Marca esta sección como completada.';
        container.appendChild(prompt);

        if (data.summary) {
          const summary = document.createElement('p');
          summary.className = 'mcc-summary';
          summary.textContent = data.summary;
          container.appendChild(summary);
        }

        if (Array.isArray(data.objectives) && data.objectives.length > 0) {
          const goalsLabel = document.createElement('p');
          goalsLabel.className = 'mcc-objectives-label';
          goalsLabel.textContent = 'Al finalizar esta sección serás capaz de:';
          container.appendChild(goalsLabel);

          const list = document.createElement('ul');
          list.className = 'mcc-objectives';
          data.objectives.forEach((objective) => {
            const li = document.createElement('li');
            li.textContent = objective;
            list.appendChild(li);
          });
          container.appendChild(list);
        }

        const button = document.createElement('button');
        button.type = 'button';
        button.className = 'eval-submit mcc-submit';
        button.textContent = isCompleted ? (data.successLabel || 'Sección completada') : (data.buttonLabel || 'Marcar como completado');
        button.disabled = isCompleted;
        container.appendChild(button);

        const feedback = document.createElement('div');
        feedback.className = 'eval-feedback';
        feedback.style.display = isCompleted ? 'block' : 'none';
        const message = document.createElement('p');
        message.className = 'feedback-message correct';
        message.textContent = data.successLabel || 'Sección completada';
        feedback.appendChild(message);
        container.appendChild(feedback);

        button.addEventListener('click', async () => {
          const saved = await saveSubmission({
            evalId: data.id,
            answer: {
              type: 'mcc',
              completed: true,
              completedAt: new Date().toISOString(),
            },
            isCorrect: true,
          });

          if (!saved) {
            alert('No se pudo guardar el estado de completado. Intenta nuevamente.');
            return;
          }

          button.disabled = true;
          button.textContent = data.successLabel || 'Sección completada';
          message.textContent = data.successLabel || 'Sección completada';
          feedback.style.display = 'block';
          setProgressCompletion(data.id, true);
        });

        wrapper.appendChild(container);
        renderEvalMath(container);
      }

      function renderPatchAI(wrapper, data, position) {
        const previousSubmission = getSubmission(data.id);
        const previousPayload = getSubmissionPayload(previousSubmission);
        const previousRecord = previousPayload && typeof previousPayload === 'object' ? previousPayload : {};
        const previousAnswer = previousRecord.answer && typeof previousRecord.answer === 'object'
          ? previousRecord.answer
          : previousRecord;
        const previousStudentPatch = ensureEvalText(
          previousAnswer.studentPatch
          || previousAnswer.student_patch
          || previousRecord.answerText
          || previousRecord.answerPreview,
        );
        const previousEvaluationSource =
          previousAnswer.evaluation
          || previousRecord.aiEvaluation
          || previousRecord.evaluation
          || null;
        const previousEvaluation = hasAiEvaluation(previousEvaluationSource)
          ? normalizeAiEvaluation(previousEvaluationSource)
          : null;
        const previousScore = previousEvaluation
          ? parseEvalScore(previousEvaluation?.calificacion?.nota)
          : null;
        const passScore = Number.isFinite(Number(data.passScore))
          ? Math.max(0, Number(data.passScore))
          : 6;
        const allowEdit = Boolean(data.allowEdit);
        const wasCorrect = previousScore !== null ? previousScore >= passScore : isSubmissionCorrect(previousSubmission);

        registerProgress(data, position, wasCorrect);

        const container = document.createElement('div');
        container.className = 'eval-block patch-ai-block';
        container.dataset.evalId = data.id;
        container.id = `eval-${data.id}`;

        const prompt = document.createElement('h4');
        prompt.className = 'eval-prompt';
        prompt.textContent = data.prompt || data.title || 'Compara tu patch con la consigna y el patch de referencia.';
        container.appendChild(prompt);

        const meta = document.createElement('p');
        meta.className = 'patch-ai-meta';
        const providerLabel = ensureEvalText(data.provider || 'ollama') || 'ollama';
        const modelLabel = ensureEvalText(data.model);
        meta.textContent = [
          `Proveedor: ${providerLabel}`,
          modelLabel ? `Modelo: ${modelLabel}` : '',
          `Aprobacion: ${passScore}/10`,
        ].filter(Boolean).join(' · ');
        container.appendChild(meta);

        if (Array.isArray(data.checks) && data.checks.length > 0) {
          const criteriaLabel = document.createElement('p');
          criteriaLabel.className = 'patch-ai-criteria-label';
          criteriaLabel.textContent = 'Criterios del bloque:';
          container.appendChild(criteriaLabel);

          const criteriaList = document.createElement('ul');
          criteriaList.className = 'patch-ai-criteria';
          data.checks.forEach((check) => {
            const item = document.createElement('li');
            item.textContent = String(check || '').trim();
            if (item.textContent) criteriaList.appendChild(item);
          });
          if (criteriaList.childElementCount > 0) {
            container.appendChild(criteriaList);
          }
        }

        if (ensureEvalText(data.referencePatch)) {
          const referenceDetails = document.createElement('details');
          referenceDetails.className = 'patch-ai-reference';
          if (!previousStudentPatch) referenceDetails.open = true;

          const referenceSummary = document.createElement('summary');
          referenceSummary.textContent = 'Ver patch guia';
          referenceDetails.appendChild(referenceSummary);

          const referencePre = document.createElement('pre');
          referencePre.className = 'patch-ai-code';
          referencePre.textContent = ensureEvalText(data.referencePatch);
          referenceDetails.appendChild(referencePre);

          container.appendChild(referenceDetails);
        }

        if (allowEdit) {
          const editableHint = document.createElement('p');
          editableHint.className = 'feedback-explanation';
          editableHint.textContent = 'Puedes corregir el patch y reenviarlo.';
          container.appendChild(editableHint);
        }

        const form = document.createElement('form');
        form.className = 'patch-ai-form';

        const textarea = document.createElement('textarea');
        textarea.className = 'patch-ai-textarea';
        textarea.placeholder = ensureEvalText(data.placeholder) || 'Pega aqui el patch del alumno.';
        textarea.spellcheck = false;
        textarea.autocomplete = 'off';
        textarea.autocapitalize = 'off';
        textarea.setAttribute('autocorrect', 'off');
        textarea.value = previousStudentPatch;
        form.appendChild(textarea);

        const submitButton = document.createElement('button');
        submitButton.type = 'submit';
        submitButton.className = 'eval-submit';
        submitButton.textContent = previousSubmission && allowEdit
          ? 'Reevaluar patch'
          : (ensureEvalText(data.submitLabel) || 'Evaluar patch');
        form.appendChild(submitButton);

        container.appendChild(form);

        const feedback = document.createElement('div');
        feedback.className = 'eval-feedback patch-ai-feedback';
        feedback.hidden = true;

        const status = document.createElement('p');
        status.className = 'feedback-message';
        feedback.appendChild(status);

        const explanation = document.createElement('p');
        explanation.className = 'feedback-explanation';
        feedback.appendChild(explanation);

        const cards = document.createElement('div');
        cards.className = 'patch-ai-cards';
        feedback.appendChild(cards);

        const rawDetails = document.createElement('details');
        rawDetails.className = 'patch-ai-raw';
        rawDetails.hidden = true;
        const rawSummary = document.createElement('summary');
        rawSummary.textContent = 'Ver salida cruda';
        rawDetails.appendChild(rawSummary);
        const rawPre = document.createElement('pre');
        rawPre.className = 'patch-ai-code';
        rawDetails.appendChild(rawPre);
        feedback.appendChild(rawDetails);

        container.appendChild(feedback);

        const renderEvaluationCard = (title, body) => {
          const text = ensureEvalText(body);
          if (!text) return;
          const card = document.createElement('article');
          card.className = 'patch-ai-card';
          const heading = document.createElement('h5');
          heading.className = 'patch-ai-card-title';
          heading.textContent = title;
          const content = document.createElement('p');
          content.className = 'patch-ai-card-body';
          content.textContent = text;
          card.append(heading, content);
          cards.appendChild(card);
        };

        const paintEvaluation = (evaluation, providerName = '', modelName = '') => {
          feedback.hidden = false;
          cards.innerHTML = '';

          const score = parseEvalScore(evaluation?.calificacion?.nota);
          const scoreLabel = score !== null ? `${score}/10` : 'sin nota';
          const passed = score !== null ? score >= passScore : false;
          status.textContent = passed
            ? `✅ Patch cercano al de referencia (${scoreLabel})`
            : `⚠️ Patch todavia lejos del de referencia (${scoreLabel})`;
          status.className = `feedback-message ${passed ? 'correct' : 'incorrect'}`;

          explanation.textContent = [
            ensureEvalText(evaluation?.calificacion?.justificacion),
            providerName ? `Proveedor: ${providerName}` : '',
            modelName ? `Modelo: ${modelName}` : '',
          ].filter(Boolean).join(' · ');

          renderEvaluationCard('Resumen', evaluation?.resumen);
          renderEvaluationCard('Logica principal', ensureEvalBool(evaluation?.tesis?.clara) ? 'Clara' : 'No clara');
          renderEvaluationCard('Lectura de la logica', evaluation?.tesis?.explicacion);
          renderEvaluationCard('Fortalezas', ensureEvalPair(evaluation?.fortalezas).filter(Boolean).join(' | '));
          renderEvaluationCard('Debilidades', ensureEvalPair(evaluation?.debilidades).filter(Boolean).join(' | '));
          renderEvaluationCard('Sugerencia', evaluation?.sugerencia);

          const rawText = ensureEvalText(evaluation?.raw);
          rawPre.textContent = rawText || '(sin salida cruda)';
          rawDetails.hidden = !rawText;
        };

        if (previousEvaluation) {
          paintEvaluation(
            previousEvaluation,
            ensureEvalText(previousAnswer.provider || previousRecord.provider || data.provider || 'ollama'),
            ensureEvalText(previousAnswer.model || previousRecord.model || data.model),
          );

          if (previousSubmission && !allowEdit) {
            textarea.disabled = true;
            submitButton.disabled = true;
          }
        }

        form.addEventListener('submit', async (event) => {
          event.preventDefault();

          const studentPatch = ensureEvalText(textarea.value);
          if (!studentPatch) {
            alert('Pega el patch del alumno antes de evaluar.');
            return;
          }

          const minChars = Number.isFinite(Number(data.minChars))
            ? Math.max(0, Math.round(Number(data.minChars)))
            : 0;
          if (minChars > 0 && studentPatch.length < minChars) {
            alert(`El patch debe tener al menos ${minChars} caracteres.`);
            return;
          }

          submitButton.disabled = true;
          submitButton.textContent = 'Evaluando patch...';
          status.textContent = 'Enviando patch al backend de correccion...';
          status.className = 'feedback-message';
          explanation.textContent = '';
          cards.innerHTML = '';
          rawDetails.hidden = true;
          rawPre.textContent = '';
          feedback.hidden = false;

          try {
            const response = await fetch('/api/ai/correct', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                taskType: 'patch',
                consigna: data.prompt || data.title || '',
                referencePatch: ensureEvalText(data.referencePatch),
                studentPatch,
                criteriaPrompts: Array.isArray(data.checks) ? data.checks : [],
                evaluationPrompt: ensureEvalText(data.evaluationPrompt),
                provider: ensureEvalText(data.provider || 'ollama') || 'ollama',
                model: ensureEvalText(data.model) || undefined,
              }),
            });

            const responseData = await response.json().catch(() => ({}));
            if (!response.ok || !responseData?.ok) {
              status.textContent = responseData?.error || 'No se pudo evaluar el patch.';
              status.className = 'feedback-message incorrect';
              rawPre.textContent = JSON.stringify(responseData || {}, null, 2);
              rawDetails.hidden = false;
              submitButton.disabled = false;
              submitButton.textContent = ensureEvalText(data.submitLabel) || 'Evaluar patch';
              return;
            }

            const normalizedEvaluation = normalizeAiEvaluation(responseData.evaluation || {});
            const providerName = ensureEvalText(responseData.provider || data.provider || 'ollama') || 'ollama';
            const modelName = ensureEvalText(responseData.model || data.model);
            const score = parseEvalScore(normalizedEvaluation?.calificacion?.nota);
            const isCorrect = score !== null ? score >= passScore : false;

            paintEvaluation(normalizedEvaluation, providerName, modelName);

            const answerPayload = {
              type: 'patch_ai',
              consigna: ensureEvalText(data.prompt || data.title),
              referencePatch: ensureEvalText(data.referencePatch),
              studentPatch,
              checks: Array.isArray(data.checks) ? data.checks : [],
              evaluationPrompt: ensureEvalText(data.evaluationPrompt),
              provider: providerName,
              model: modelName,
              evaluation: normalizedEvaluation,
              correctedAt: new Date().toISOString(),
            };

            const feedbackText =
              ensureEvalText(normalizedEvaluation?.calificacion?.justificacion)
              || ensureEvalText(normalizedEvaluation?.sugerencia);

            const saved = await saveSubmission({
              evalId: data.id,
              answer: answerPayload,
              isCorrect,
              score,
              feedback: feedbackText,
              markAsGraded: score !== null,
              meta: {
                type: 'patch_ai',
                answerText: studentPatch.slice(0, 160),
                answerPreview: studentPatch.slice(0, 320),
                provider: providerName,
                model: modelName,
                passScore,
                aiEvaluation: normalizedEvaluation,
              },
            });

            if (!saved) {
              alert('La evaluación salió bien, pero no se pudo guardar la entrega.');
              submitButton.disabled = false;
              submitButton.textContent = allowEdit
                ? 'Reevaluar patch'
                : (ensureEvalText(data.submitLabel) || 'Evaluar patch');
              return;
            }

            setProgressCompletion(data.id, isCorrect);

            if (!allowEdit) {
              textarea.disabled = true;
              submitButton.disabled = true;
            } else {
              submitButton.disabled = false;
              submitButton.textContent = 'Reevaluar patch';
            }
          } catch (error) {
            console.error('Error evaluating patch_ai block:', error);
            status.textContent = 'Fallo de red o backend no disponible.';
            status.className = 'feedback-message incorrect';
            submitButton.disabled = false;
            submitButton.textContent = ensureEvalText(data.submitLabel) || 'Evaluar patch';
          }
        });

        wrapper.appendChild(container);
        renderEvalMath(container);
      }

      function normalizePollOption(option, index) {
        if (option && typeof option === 'object') {
          const id = String(option.id || `opt-${index + 1}`).trim();
          const text = String(option.text || option.label || '').trim();
          if (!text) return null;
          return { id: id || `opt-${index + 1}`, text };
        }

        const text = String(option || '').trim();
        if (!text) return null;
        return { id: `opt-${index + 1}`, text };
      }

      function renderPoll(wrapper, data, position) {
        const options = Array.isArray(data.options)
          ? data.options.map((option, index) => normalizePollOption(option, index)).filter(Boolean)
          : [];

        if (options.length < 2) {
          renderUnsupported(wrapper, data, position);
          return;
        }

        const previousSubmission = getSubmission(data.id);
        const previousPayload = getSubmissionPayload(previousSubmission);
        const previousAnswer = previousPayload && typeof previousPayload === 'object'
          ? previousPayload.answerIndexes || previousPayload.answer || []
          : previousPayload;
        const previousAnswers = toAnswerArray(previousAnswer);
        const wasSubmitted = previousAnswers.length > 0;
        const previousResults = getPersistedPollResults(previousPayload);
        const previousAnswerLabels = getPersistedPollAnswerLabels(previousPayload, previousAnswers, options);
        registerProgress(data, position, wasSubmitted);

        const container = document.createElement('div');
        container.className = 'eval-block poll-block';
        container.dataset.evalId = data.id;
        container.id = `eval-${data.id}`;

        const prompt = document.createElement('h4');
        prompt.className = 'eval-prompt';
        prompt.textContent = data.prompt || 'Encuesta en vivo';
        container.appendChild(prompt);

        const meta = document.createElement('p');
        meta.className = 'poll-meta';
        const isAnonymous = data.anonymous !== false;
        const timing = data.timed
          ? ` · Tiempo: ${formatCountdown(Math.max(0, Number(data.timerSeconds || 0)) * 1000)}`
          : '';
        meta.textContent = `Respuestas: ${isAnonymous ? 'anónimas' : 'identificadas'}${timing}`;
        container.appendChild(meta);

        const status = document.createElement('p');
        status.className = 'poll-status';
        status.textContent = 'Interacción no activa.';
        container.appendChild(status);

        const countdown = document.createElement('p');
        countdown.className = 'poll-countdown';
        countdown.hidden = true;
        container.appendChild(countdown);

        let startButton = null;
        let endButton = null;
        let openLink = null;
        if (canManageLiveInteractions) {
          const controls = document.createElement('div');
          controls.className = 'poll-controls';

          startButton = document.createElement('button');
          startButton.type = 'button';
          startButton.className = 'eval-submit poll-control-button';
          startButton.textContent = 'Iniciar interacción';
          controls.appendChild(startButton);

          endButton = document.createElement('button');
          endButton.type = 'button';
          endButton.className = 'eval-submit poll-control-button poll-control-danger';
          endButton.textContent = 'Cerrar interacción';
          endButton.disabled = true;
          controls.appendChild(endButton);

          openLink = document.createElement('a');
          openLink.className = 'poll-live-link';
          openLink.hidden = true;
          openLink.textContent = 'Abrir vista /live';
          controls.appendChild(openLink);

          container.appendChild(controls);
        }

        const form = document.createElement('form');
        form.className = 'poll-form';
        form.hidden = true;

        options.forEach((option) => {
          const label = document.createElement('label');
          label.className = 'poll-option';

          const input = document.createElement('input');
          input.type = data.allowMultiple ? 'checkbox' : 'radio';
          input.name = data.allowMultiple ? `${data.id}[]` : data.id;
          input.value = option.id;
          if (previousAnswers.includes(option.id)) {
            input.checked = true;
          }

          const text = document.createElement('span');
          text.textContent = option.text;

          label.append(input, text);
          form.appendChild(label);
        });

        container.appendChild(form);

        const submitButton = document.createElement('button');
        submitButton.type = 'button';
        submitButton.className = 'eval-submit poll-submit';
        submitButton.hidden = true;
        submitButton.textContent = wasSubmitted ? 'Actualizar respuesta' : 'Enviar respuesta';
        container.appendChild(submitButton);

        const feedback = document.createElement('div');
        feedback.className = 'eval-feedback poll-feedback';
        feedback.hidden = true;
        container.appendChild(feedback);

        const results = document.createElement('div');
        results.className = 'poll-results';
        results.hidden = true;
        container.appendChild(results);

        const widget = {
          data: {
            ...data,
            options,
            showResults: data.showResults !== false,
          },
          canManage: canManageLiveInteractions,
          container,
          statusNode: status,
          countdownNode: countdown,
          formNode: form,
          submitButton,
          feedbackNode: feedback,
          startButton,
          endButton,
          openLink,
          resultsNode: results,
          state: {
            active: false,
            sessionId: '',
            endsAt: null,
            totalResponses: 0,
            optionCounts: {},
            hasSubmitted: wasSubmitted,
            persistedResults: previousResults,
          },
        };

        pollWidgetsByEvalId.set(data.id, widget);
        renderPollState(widget);
        if (wasSubmitted) {
          const answerText = previousAnswerLabels.length > 0 ? previousAnswerLabels.join(' | ') : 'respuesta enviada';
          setPollFeedback(widget, `Tu respuesta guardada: ${answerText}`);
        }

        const courseContext = getPageContext();
        const clientId = ensureLiveClientId();
        const submitLivePollResponse = async () => {
          if (!widget.state.active || !widget.state.sessionId) return false;

          const selected = Array.from(form.querySelectorAll('input:checked')).map((input) => String(input.value));
          if (selected.length === 0) {
            setPollFeedback(widget, 'Selecciona al menos una opción.', true);
            return false;
          }

          submitButton.disabled = true;
          setPollFeedback(widget, 'Enviando respuesta...');

          try {
            const response = await fetch('/api/live/respond', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                sessionId: widget.state.sessionId,
                answer: widget.data.allowMultiple ? selected : selected[0],
                clientId,
              }),
            });

            const payload = await response.json().catch(() => ({}));
            if (!response.ok) {
              setPollFeedback(widget, payload?.error || 'No se pudo guardar la respuesta.', true);
              submitButton.disabled = false;
              return false;
            }

            widget.state.hasSubmitted = true;
            try {
              window.localStorage.setItem(`live:submitted:${widget.data.id}`, 'true');
            } catch {
              // ignore storage restrictions
            }
            window.dispatchEvent(
              new CustomEvent('live:submission', {
                detail: { interactionId: widget.data.id },
              }),
            );
            renderPollState(widget);
            setProgressCompletion(widget.data.id, true);

            const selectedTexts = selected
              .map((answerId) => widget.data.options.find((option) => option.id === answerId)?.text || '')
              .filter(Boolean);
            const snapshot = payload?.snapshot && typeof payload.snapshot === 'object' ? payload.snapshot : null;
            const snapshotOptionCounts = sanitizePollOptionCounts(snapshot?.optionCounts || {});
            const snapshotTotalResponses = Number.isFinite(Number(snapshot?.totalResponses))
              ? Math.max(0, Math.round(Number(snapshot.totalResponses)))
              : 0;

            if (Object.keys(snapshotOptionCounts).length > 0 || snapshotTotalResponses > 0) {
              widget.state.persistedResults = {
                optionCounts: snapshotOptionCounts,
                totalResponses: snapshotTotalResponses,
              };
            }

            await saveSubmission({
              evalId: widget.data.id,
              answer: {
                type: 'poll',
                answerIndexes: selected,
                answerOptions: selectedTexts,
                sessionId: widget.state.sessionId,
                submittedAt: new Date().toISOString(),
              },
              isCorrect: true,
              meta: {
                answerText: selectedTexts.join(' | '),
                answerOptions: selectedTexts,
                answerIndexes: selected,
                selectionMode: widget.data.allowMultiple ? 'multiple' : 'single',
                type: widget.data.type || 'poll',
                mode: widget.data.mode || 'submission',
                ...(Object.keys(snapshotOptionCounts).length > 0 || snapshotTotalResponses > 0
                  ? {
                      pollOptionCounts: snapshotOptionCounts,
                      pollTotalResponses: snapshotTotalResponses,
                    }
                  : {}),
              },
            });

            if (payload?.snapshot) {
              applyLivePayloadToPollWidgets(payload.snapshot, 'live.updated');
              emitLiveEvent('live.updated', payload.snapshot);
            }
            setPollFeedback(widget, 'Respuesta registrada. Puedes actualizarla mientras la interacción siga activa.');
            return true;
          } catch (error) {
            setPollFeedback(widget, 'Error de red al enviar la respuesta.', true);
            submitButton.disabled = false;
            return false;
          }
        };

        if (widget.canManage) {
          startButton.addEventListener('click', async () => {
            startButton.disabled = true;
            setPollFeedback(widget, 'Iniciando interacción...');

            try {
              const response = await fetch('/api/live/start', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  courseId: courseContext.courseId,
                  pageSlug: courseContext.pageSlug,
                  interactionId: widget.data.id,
                  type: widget.data.type || 'poll',
                  prompt: widget.data.prompt,
                  options: widget.data.options,
                  anonymous: widget.data.anonymous,
                  allowMultiple: widget.data.allowMultiple,
                  showResults: widget.data.showResults,
                  timerSeconds: widget.data.timed ? Number(widget.data.timerSeconds || 0) : 0,
                }),
              });

              const payload = await response.json().catch(() => ({}));
              if (!response.ok) {
                setPollFeedback(widget, payload?.error || 'No se pudo iniciar la interacción.', true);
                startButton.disabled = false;
                return;
              }

              setPollFeedback(widget, 'Interacción iniciada.');
              applyLivePayloadToPollWidgets(payload, 'live.started');
              emitLiveEvent('live.started', payload);
            } catch (error) {
              setPollFeedback(widget, 'Error de red al iniciar interacción.', true);
              startButton.disabled = false;
            }
          });

          endButton.addEventListener('click', async () => {
            if (!widget.state.sessionId) return;
            endButton.disabled = true;
            setPollFeedback(widget, 'Cerrando interacción...');

            try {
              const response = await fetch('/api/live/end', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  sessionId: widget.state.sessionId,
                }),
              });

              const payload = await response.json().catch(() => ({}));
              if (!response.ok) {
                setPollFeedback(widget, payload?.error || 'No se pudo cerrar la interacción.', true);
                endButton.disabled = false;
                return;
              }

              applyLivePayloadToPollWidgets(payload, 'live.ended');
              emitLiveEvent('live.ended', payload);
            } catch (error) {
              setPollFeedback(widget, 'Error de red al cerrar interacción.', true);
              endButton.disabled = false;
            }
          });
        }

        submitButton.addEventListener('click', () => {
          void submitLivePollResponse();
        });
        form.addEventListener('change', (event) => {
          if (widget.data.allowMultiple) return;
          if (!(event.target instanceof HTMLInputElement)) return;
          void submitLivePollResponse();
        });

        if (data.autoStart && widget.canManage && widget.startButton) {
          setTimeout(() => {
            if (!widget.state.active) startButton.click();
          }, 0);
        }

        wrapper.appendChild(container);
        renderEvalMath(container);
      }

      function syncWordcloudResults(widget) {
        if (!widget.resultsNode) return;

        const persisted = widget.state.persistedResults && typeof widget.state.persistedResults === 'object'
          ? widget.state.persistedResults
          : null;
        const hasPersistedResults = Boolean(persisted);
        const canShowResults = widget.canManage
          ? widget.data.showResults && (widget.state.active || hasPersistedResults)
          : widget.data.showResults && widget.state.hasSubmitted && (widget.state.active || hasPersistedResults);

        if (!canShowResults) {
          widget.resultsNode.hidden = true;
          widget.resultsNode.innerHTML = '';
          return;
        }

        const sourceWordCounts = widget.state.active
          ? widget.state.wordCounts
          : (persisted?.wordCounts || widget.state.wordCounts || {});
        const normalizedWordCounts = sanitizeWordCounts(sourceWordCounts);
        const explicitTotal = widget.state.active
          ? Number(widget.state.totalResponses || 0)
          : Number(persisted?.totalResponses ?? widget.state.totalResponses ?? 0);
        const derivedTotal = Object.values(normalizedWordCounts).reduce((sum, value) => sum + value, 0);
        const totalResponses = Number.isFinite(explicitTotal) && explicitTotal > 0
          ? Math.round(explicitTotal)
          : derivedTotal;

        renderWordcloudCloud(widget.resultsNode, normalizedWordCounts, totalResponses);
      }

      function renderWordcloudState(widget) {
        const canRespond = widget.state.active;
        const submissionDone = Boolean(widget.state.hasSubmitted);
        const { courseId } = getPageContext();

        if (widget.submitButton) {
          widget.submitButton.hidden = !canRespond;
          widget.submitButton.disabled = !canRespond;
          widget.submitButton.textContent = 'Enviar';
        }

        if (widget.startButton) {
          widget.startButton.hidden = !widget.canManage;
          widget.startButton.disabled = widget.state.active;
        }
        if (widget.endButton) {
          widget.endButton.hidden = !widget.canManage;
          widget.endButton.disabled = !widget.state.active || !widget.state.sessionId;
        }
        if (widget.openLink) {
          if (widget.canManage && widget.state.active && widget.state.sessionId) {
            const url = new URL(`/live/${encodeURIComponent(widget.state.sessionId)}`, window.location.origin);
            if (courseId) url.searchParams.set('courseId', courseId);
            widget.openLink.href = `${url.pathname}${url.search}`;
            widget.openLink.hidden = false;
          } else {
            widget.openLink.hidden = true;
          }
        }

        if (widget.formNode) {
          widget.formNode.hidden = !canRespond;
          widget.formNode
            .querySelectorAll('input, button')
            .forEach((input) => {
              input.disabled = !canRespond;
            });
        }

        if (widget.statusNode) {
          if (!widget.state.active && submissionDone) {
            widget.statusNode.textContent = 'Interacción finalizada. Tu respuesta fue registrada.';
          } else {
            widget.statusNode.textContent = formatPollStatus(widget);
          }
        }

        updatePollCountdown(widget);
        syncWordcloudResults(widget);
      }

      function applyLivePayloadToWordcloudWidgets(payload, sourceEvent) {
        if (sourceEvent === 'live.snapshot' && (!payload || !payload.active)) {
          wordcloudWidgetsByEvalId.forEach((widget) => {
            widget.state.active = false;
            widget.state.sessionId = '';
            widget.state.endsAt = null;
            widget.state.totalResponses = 0;
            widget.state.wordCounts = {};
            renderWordcloudState(widget);
          });
          return;
        }

        if (!payload || typeof payload !== 'object') return;

        if (sourceEvent === 'live.ended') {
          const endedInteractionId = String(payload.interactionId || '');
          wordcloudWidgetsByEvalId.forEach((widget) => {
            if (widget.data.id !== endedInteractionId) return;
            widget.state.active = false;
            widget.state.sessionId = '';
            widget.state.endsAt = null;
            setPollFeedback(widget, 'La interacción fue cerrada.');
            renderWordcloudState(widget);
          });
          return;
        }

        if (!payload.active) return;
        const interactionId = String(payload.interactionId || '');

        wordcloudWidgetsByEvalId.forEach((widget) => {
          const isActiveWidget = widget.data.id === interactionId;
          if (!isActiveWidget && (sourceEvent === 'live.started' || sourceEvent === 'live.snapshot')) {
            widget.state.active = false;
            widget.state.sessionId = '';
            widget.state.endsAt = null;
            widget.state.totalResponses = 0;
            widget.state.wordCounts = {};
          }
          if (!isActiveWidget) {
            renderWordcloudState(widget);
            return;
          }

          const nextSessionId = String(payload.sessionId || '');
          const isNewSession = Boolean(nextSessionId) && nextSessionId !== String(widget.state.sessionId || '');
          if (isNewSession) {
            widget.state.hasSubmitted = false;
            widget.state.persistedResults = null;
            try {
              window.localStorage.removeItem(`live:submitted:${widget.data.id}`);
            } catch {
              // ignore storage restrictions
            }
            if (widget.inputNode instanceof HTMLInputElement) {
              widget.inputNode.value = '';
            }
            if (typeof widget.syncOptions === 'function') {
              widget.syncOptions(Array.isArray(payload.options) ? payload.options : widget.data.options || []);
            }
          }

          widget.state.active = true;
          widget.state.sessionId = nextSessionId;
          widget.state.endsAt = payload.endsAt || null;
          widget.state.totalResponses = Math.max(0, Number(payload.totalResponses || 0));
          if (Array.isArray(payload.options) && typeof widget.syncOptions === 'function') {
            widget.syncOptions(payload.options);
          }
          widget.state.wordCounts = payload.wordCounts && typeof payload.wordCounts === 'object'
            ? payload.wordCounts
            : {};
          renderWordcloudState(widget);
          void persistWordcloudImage(widget, payload);
        });
      }

      function renderWordcloud(wrapper, data, position) {
        let options = Array.isArray(data.options)
          ? data.options.map((option, index) => normalizePollOption(option, index)).filter(Boolean)
          : [];

        const previousSubmission = getSubmission(data.id);
        const previousPayload = getSubmissionPayload(previousSubmission);
        const previousWord = getPersistedWordcloudAnswerText(previousPayload);
        const wasSubmitted = previousWord.length > 0;
        const previousResults = getPersistedWordcloudResults(previousPayload);
        registerProgress(data, position, wasSubmitted);

        const container = document.createElement('div');
        container.className = 'eval-block wordcloud-block';
        container.dataset.evalId = data.id;
        container.id = `eval-${data.id}`;

        const prompt = document.createElement('h4');
        prompt.className = 'eval-prompt';
        prompt.textContent = data.prompt || 'Nube de palabras en vivo';
        container.appendChild(prompt);

        const meta = document.createElement('p');
        meta.className = 'poll-meta';
        const isAnonymous = data.anonymous !== false;
        const timing = data.timed
          ? ` · Tiempo: ${formatCountdown(Math.max(0, Number(data.timerSeconds || 0)) * 1000)}`
          : '';
        meta.textContent = `Respuestas: ${isAnonymous ? 'anónimas' : 'identificadas'}${timing}`;
        container.appendChild(meta);

        const status = document.createElement('p');
        status.className = 'poll-status';
        status.textContent = 'Interacción no activa.';
        container.appendChild(status);

        const countdown = document.createElement('p');
        countdown.className = 'poll-countdown';
        countdown.hidden = true;
        container.appendChild(countdown);

        let startButton = null;
        let endButton = null;
        let openLink = null;
        if (canManageLiveInteractions) {
          const controls = document.createElement('div');
          controls.className = 'poll-controls';

          startButton = document.createElement('button');
          startButton.type = 'button';
          startButton.className = 'eval-submit poll-control-button';
          startButton.textContent = 'Iniciar interacción';
          controls.appendChild(startButton);

          endButton = document.createElement('button');
          endButton.type = 'button';
          endButton.className = 'eval-submit poll-control-button poll-control-danger';
          endButton.textContent = 'Cerrar interacción';
          endButton.disabled = true;
          controls.appendChild(endButton);

          openLink = document.createElement('a');
          openLink.className = 'poll-live-link';
          openLink.hidden = true;
          openLink.textContent = 'Abrir vista /live';
          controls.appendChild(openLink);

          container.appendChild(controls);
        }

        const form = document.createElement('form');
        form.className = 'poll-form wordcloud-form';
        form.hidden = true;

        let selectedSuggestionId = '';
        const suggestionsWrap = document.createElement('div');
        suggestionsWrap.className = 'wordcloud-suggestions';
        const suggestionButtons = [];
        form.appendChild(suggestionsWrap);

        const input = document.createElement('input');
        input.type = 'text';
        input.className = 'wordcloud-input';
        input.placeholder = 'Escribe una palabra o frase corta';
        input.maxLength = 120;
        input.autocomplete = 'off';
        input.value = previousWord;
        form.appendChild(input);
        container.appendChild(form);

        const submitButton = document.createElement('button');
        submitButton.type = 'button';
        submitButton.className = 'eval-submit poll-submit';
        submitButton.hidden = true;
        submitButton.textContent = wasSubmitted ? 'Actualizar respuesta' : 'Enviar respuesta';
        container.appendChild(submitButton);

        const feedback = document.createElement('div');
        feedback.className = 'eval-feedback poll-feedback';
        feedback.hidden = true;
        container.appendChild(feedback);

        const results = document.createElement('div');
        results.className = 'poll-results wordcloud-results';
        results.hidden = true;
        container.appendChild(results);

        const setSelectedSuggestion = (optionId) => {
          selectedSuggestionId = String(optionId || '').trim();
          suggestionButtons.forEach((button) => {
            const isActive = button.dataset.optionId === selectedSuggestionId;
            button.classList.toggle('is-active', isActive);
          });
        };

        const addSuggestionButton = (option) => {
          const button = document.createElement('button');
          button.type = 'button';
          button.className = 'wordcloud-suggestion';
          button.textContent = option.text;
          button.dataset.optionId = option.id;
          button.addEventListener('click', () => {
            if (button.disabled) return;
            const optionId = String(button.dataset.optionId || '').trim();
            const currentOption = options.find((candidate) => candidate.id === optionId);
            if (!currentOption) return;
            input.value = currentOption.text;
            setSelectedSuggestion(optionId);
            if (widget.state.active) {
              void submitWordcloudResponse(currentOption.text, optionId);
            }
          });
          suggestionButtons.push(button);
          suggestionsWrap.appendChild(button);
        };

        const syncSuggestionButtons = (nextOptions) => {
          options = Array.isArray(nextOptions)
            ? nextOptions.map((option, index) => normalizePollOption(option, index)).filter(Boolean)
            : [];

          suggestionButtons.length = 0;
          suggestionsWrap.innerHTML = '';
          options.forEach((option) => addSuggestionButton(option));
          suggestionsWrap.hidden = options.length === 0;

          const currentText = String(input.value || '').trim();
          const matching = options.find((option) => option.text === currentText);
          setSelectedSuggestion(matching ? matching.id : '');
        };

        syncSuggestionButtons(options);

        input.addEventListener('input', () => {
          const currentText = String(input.value || '').trim();
          const matching = options.find((option) => option.text === currentText);
          setSelectedSuggestion(matching ? matching.id : '');
        });

        if (previousWord) {
          const matching = options.find((option) => option.text === previousWord);
          if (matching) setSelectedSuggestion(matching.id);
        }

        const widget = {
          data: {
            ...data,
            options,
            showResults: data.showResults !== false,
          },
          canManage: canManageLiveInteractions,
          container,
          statusNode: status,
          countdownNode: countdown,
          formNode: form,
          inputNode: input,
          submitButton,
          feedbackNode: feedback,
          startButton,
          endButton,
          openLink,
          resultsNode: results,
          state: {
            active: false,
            sessionId: '',
            endsAt: null,
            totalResponses: 0,
            wordCounts: {},
            hasSubmitted: wasSubmitted,
            persistedResults: previousResults,
          },
          getSuggestionId: () => selectedSuggestionId,
          syncOptions: (nextOptions) => {
            syncSuggestionButtons(nextOptions);
            widget.data.options = options;
          },
        };

        wordcloudWidgetsByEvalId.set(data.id, widget);
        renderWordcloudState(widget);
        if (wasSubmitted) {
          setPollFeedback(widget, `Tu respuesta guardada: ${previousWord}`);
        }

        const courseContext = getPageContext();
        const clientId = ensureLiveClientId();
        const submitWordcloudResponse = async (wordOverride = '', suggestionIdOverride = '') => {
          if (!widget.state.active || !widget.state.sessionId) return false;

          const word = String(wordOverride || input.value || '').trim();
          const suggestionId = String(suggestionIdOverride || widget.getSuggestionId?.() || '').trim();
          if (!word) {
            setPollFeedback(widget, 'Escribe una palabra para responder.', true);
            return false;
          }

          submitButton.disabled = true;
          setPollFeedback(widget, 'Enviando respuesta...');

          try {
            const response = await fetch('/api/live/respond', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                sessionId: widget.state.sessionId,
                answer: {
                  text: word,
                  suggestionId,
                },
                clientId,
              }),
            });

            const payload = await response.json().catch(() => ({}));
            if (!response.ok) {
              setPollFeedback(widget, payload?.error || 'No se pudo guardar la respuesta.', true);
              submitButton.disabled = false;
              return false;
            }

            widget.state.hasSubmitted = true;
            try {
              window.localStorage.setItem(`live:submitted:${widget.data.id}`, 'true');
            } catch {
              // ignore storage restrictions
            }
            window.dispatchEvent(
              new CustomEvent('live:submission', {
                detail: { interactionId: widget.data.id },
              }),
            );
            renderWordcloudState(widget);
            setProgressCompletion(widget.data.id, true);

            const snapshot = payload?.snapshot && typeof payload.snapshot === 'object' ? payload.snapshot : null;
            const snapshotWordCounts = sanitizeWordCounts(snapshot?.wordCounts || {});
            const snapshotTotalResponses = Number.isFinite(Number(snapshot?.totalResponses))
              ? Math.max(0, Math.round(Number(snapshot.totalResponses)))
              : 0;

            if (Object.keys(snapshotWordCounts).length > 0 || snapshotTotalResponses > 0) {
              widget.state.persistedResults = {
                wordCounts: snapshotWordCounts,
                totalResponses: snapshotTotalResponses,
              };
            }

            await saveSubmission({
              evalId: widget.data.id,
              answer: {
                type: 'wordcloud',
                text: word,
                suggestionId,
                sessionId: widget.state.sessionId,
                submittedAt: new Date().toISOString(),
              },
              isCorrect: true,
              meta: {
                answerText: word,
                answerWord: word,
                suggestionId,
                type: widget.data.type || 'wordcloud',
                mode: widget.data.mode || 'submission',
                ...(Object.keys(snapshotWordCounts).length > 0 || snapshotTotalResponses > 0
                  ? {
                      wordCounts: snapshotWordCounts,
                      wordTotalResponses: snapshotTotalResponses,
                    }
                  : {}),
              },
            });

            if (payload?.snapshot) {
              applyLivePayloadToWordcloudWidgets(payload.snapshot, 'live.updated');
            }
            setPollFeedback(widget, 'Respuesta registrada.');
            return true;
          } catch (error) {
            setPollFeedback(widget, 'Error de red al enviar la respuesta.', true);
            submitButton.disabled = false;
            return false;
          }
        };

        if (widget.canManage) {
          startButton.addEventListener('click', async () => {
            startButton.disabled = true;
            setPollFeedback(widget, 'Iniciando interacción...');

            try {
              const response = await fetch('/api/live/start', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  courseId: courseContext.courseId,
                  pageSlug: courseContext.pageSlug,
                  interactionId: widget.data.id,
                  type: widget.data.type || 'wordcloud',
                  prompt: widget.data.prompt,
                  options: widget.data.options,
                  anonymous: widget.data.anonymous,
                  allowMultiple: false,
                  showResults: widget.data.showResults,
                  timerSeconds: widget.data.timed ? Number(widget.data.timerSeconds || 0) : 0,
                }),
              });

              const payload = await response.json().catch(() => ({}));
              if (!response.ok) {
                setPollFeedback(widget, payload?.error || 'No se pudo iniciar la interacción.', true);
                startButton.disabled = false;
                return;
              }

              setPollFeedback(widget, 'Interacción iniciada.');
              applyLivePayloadToWordcloudWidgets(payload, 'live.started');
            } catch (error) {
              setPollFeedback(widget, 'Error de red al iniciar interacción.', true);
              startButton.disabled = false;
            }
          });

          endButton.addEventListener('click', async () => {
            if (!widget.state.sessionId) return;
            endButton.disabled = true;
            setPollFeedback(widget, 'Cerrando interacción...');

            try {
              const response = await fetch('/api/live/end', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  sessionId: widget.state.sessionId,
                }),
              });

              const payload = await response.json().catch(() => ({}));
              if (!response.ok) {
                setPollFeedback(widget, payload?.error || 'No se pudo cerrar la interacción.', true);
                endButton.disabled = false;
                return;
              }

              applyLivePayloadToWordcloudWidgets(payload, 'live.ended');
            } catch (error) {
              setPollFeedback(widget, 'Error de red al cerrar interacción.', true);
              endButton.disabled = false;
            }
          });
        }

        submitButton.addEventListener('click', async () => {
          await submitWordcloudResponse();
        });

        input.addEventListener('keydown', (event) => {
          if (event.key !== 'Enter' || event.shiftKey) return;
          event.preventDefault();
          void submitWordcloudResponse();
        });

        if (data.autoStart && widget.canManage && widget.startButton) {
          setTimeout(() => {
            if (!widget.state.active) startButton.click();
          }, 0);
        }

        wrapper.appendChild(container);
        renderEvalMath(container);
      }

      function renderUnsupported(wrapper, data, position) {
        registerProgress(data, position, false);

        const container = document.createElement('div');
        container.className = 'eval-block';
        container.dataset.evalId = data.id;
        container.id = `eval-${data.id}`;

        const prompt = document.createElement('h4');
        prompt.className = 'eval-prompt';
        prompt.textContent = data.prompt || 'Actividad';
        container.appendChild(prompt);

        const notice = document.createElement('p');
        notice.className = 'feedback-explanation';
        notice.textContent = `Tipo de evaluación no soportado todavía: ${data.type}`;
        container.appendChild(notice);

        wrapper.appendChild(container);
        renderEvalMath(container);
      }

      function formatForumDate(value) {
        if (!value) return 'sin fecha';
        const parsed = new Date(value);
        if (Number.isNaN(parsed.getTime())) return 'sin fecha';
        return parsed.toLocaleString('es-ES', {
          day: '2-digit',
          month: '2-digit',
          year: '2-digit',
          hour: '2-digit',
          minute: '2-digit',
        });
      }

      function normalizeForumBoardSlug(value) {
        return String(value || '').trim().toLowerCase() || 'general';
      }

      const forumSwitcherPalette = ['#16a34a', '#2563eb', '#d97706', '#7c3aed', '#dc2626', '#0f766e'];
      const FORUM_READ_PREFIX = 'forum:read:';

      function getForumSwitcherColor(index) {
        const paletteLength = forumSwitcherPalette.length;
        if (paletteLength === 0) return '#16a34a';
        return forumSwitcherPalette[((index % paletteLength) + paletteLength) % paletteLength];
      }

      function getForumSwitcherMarkParts(value) {
        const normalized = String(value || '').trim().replace(/\s+/g, ' ');
        if (!normalized) {
          return { primary: '?', secondary: '' };
        }

        const alphanumericChars = Array.from(normalized).filter((char) => /[\p{L}\p{N}]/u.test(char));
        const primary = String(alphanumericChars[0] || normalized[0] || '?').toUpperCase();
        const secondarySource = String(alphanumericChars[1] || '').trim();

        return {
          primary,
          secondary: secondarySource ? secondarySource.toLowerCase() : '',
        };
      }

      function createForumSwitcherMark(label) {
        const { primary, secondary } = getForumSwitcherMarkParts(label);
        const mark = document.createElement('span');
        mark.className = 'forum-switcher-mark';
        mark.textContent = primary;

        if (secondary) {
          const superscript = document.createElement('sup');
          superscript.className = 'forum-switcher-sup';
          superscript.textContent = secondary;
          mark.appendChild(superscript);
        }

        return mark;
      }

      function createForumSwitcherUnreadDot() {
        const dot = document.createElement('span');
        dot.className = 'forum-switcher-unread-dot';
        dot.setAttribute('aria-hidden', 'true');
        return dot;
      }

      function parseForumReadState(value) {
        if (!value) return null;
        try {
          return JSON.parse(value);
        } catch {
          return null;
        }
      }

      function computeForumUnreadCount(totalMessages, storedState) {
        const total = Number(totalMessages);
        if (!Number.isFinite(total) || total <= 0) return 0;

        if (!storedState || typeof storedState !== 'object') {
          return total;
        }

        const seen = Number(storedState.messageTotal);
        if (!Number.isFinite(seen) || seen < 0) return total;
        return Math.max(0, total - seen);
      }

      function setCourseForumScopeMetrics(scopeKey, { totalMessages = 0, lastActivityAt = '' } = {}) {
        const normalizedScopeKey = String(scopeKey || '').trim();
        if (!normalizedScopeKey) return;
        const normalizedTotalMessages = String(Math.max(0, Number(totalMessages) || 0));
        const normalizedLastActivityAt = String(lastActivityAt || '').trim();
        const subnav = document.getElementById('course-forum-subnav');
        if (
          subnav instanceof HTMLElement &&
          String(subnav.dataset.lessonScopeKey || '').trim() === normalizedScopeKey
        ) {
          subnav.dataset.lessonTotal = normalizedTotalMessages;
          if (normalizedLastActivityAt) {
            subnav.dataset.lessonLastActivity = normalizedLastActivityAt;
          } else {
            delete subnav.dataset.lessonLastActivity;
          }
        }

        const links = document.querySelectorAll('#course-forum-subnav [data-forum-scope-key]');
        links.forEach((link) => {
          if (!(link instanceof HTMLElement)) return;
          if (String(link.dataset.forumScopeKey || '').trim() !== normalizedScopeKey) return;
          link.dataset.forumTotal = normalizedTotalMessages;
          if (normalizedLastActivityAt) {
            link.dataset.forumLastActivity = normalizedLastActivityAt;
          } else {
            delete link.dataset.forumLastActivity;
          }
        });
      }

      function refreshCourseForumUnreadIndicators() {
        const links = document.querySelectorAll('#course-forum-subnav [data-forum-scope-key]');
        links.forEach((link) => {
          if (!(link instanceof HTMLElement)) return;
          const scopeKey = String(link.dataset.forumScopeKey || '').trim();
          if (!scopeKey) return;
          const totalMessages = Number(link.dataset.forumTotal || '0');
          let unread = 0;
          try {
            const storedState = parseForumReadState(localStorage.getItem(FORUM_READ_PREFIX + scopeKey));
            unread = computeForumUnreadCount(totalMessages, storedState);
          } catch (error) {
            console.error('Forum unread indicator error:', error);
            unread = 0;
          }
          link.classList.toggle('has-unread', unread > 0);
          link.dataset.forumUnread = unread > 0 ? 'true' : 'false';
        });
      }

      if (typeof window !== 'undefined' && window.__musikiCourseForumUnreadStorageBound !== true) {
        window.__musikiCourseForumUnreadStorageBound = true;
        window.addEventListener('storage', (event) => {
          if (event.key && !event.key.startsWith(FORUM_READ_PREFIX)) return;
          refreshCourseForumUnreadIndicators();
        });
      }

      function getCourseForumSubnavContext() {
        const subnav = document.getElementById('course-forum-subnav');
        if (!subnav) return null;

        return {
          node: subnav,
          courseId: subnav.dataset.courseId || '',
          baseHref: subnav.dataset.forumBaseHref || '',
          lessonHref: subnav.dataset.lessonHref || '',
          lessonSlug: subnav.dataset.lessonSlug || '',
          lessonScopeKey: subnav.dataset.lessonScopeKey || '',
          lessonTotalMessages: Number(subnav.dataset.lessonTotal || '0'),
          lessonLastActivityAt: subnav.dataset.lessonLastActivity || '',
          lessonTitle: subnav.dataset.lessonTitle || 'Lección',
          hasSession: subnav.dataset.hasSession === 'true',
          isLessonPage: subnav.dataset.isLessonPage === 'true',
          activeMode: subnav.dataset.activeMode === 'lesson' ? 'lesson' : 'board',
          activeBoardSlug: normalizeForumBoardSlug(subnav.dataset.activeBoardSlug || 'general'),
        };
      }

      function renderCourseForumSubnav(boards, options = {}) {
        const context = getCourseForumSubnavContext();
        if (!context) return;

        const {
          node,
          baseHref,
          lessonHref,
          lessonScopeKey,
          lessonTotalMessages,
          lessonLastActivityAt,
          lessonTitle,
          hasSession,
          isLessonPage,
          activeMode: initialActiveMode,
        } = context;

        if (!hasSession || !baseHref) return;

        const resolvedBoards = Array.isArray(boards) ? boards : [];
        const activeMode = options.activeMode === 'lesson' ? 'lesson' : (initialActiveMode === 'lesson' ? 'lesson' : 'board');
        const preferredBoardSlug = normalizeForumBoardSlug(
          options.preferredBoardSlug || context.activeBoardSlug || 'general',
        );
        const availableSlugs = resolvedBoards
          .map((board) => normalizeForumBoardSlug(board?.slug))
          .filter(Boolean);
        const activeBoardSlug = availableSlugs.includes(preferredBoardSlug)
          ? preferredBoardSlug
          : (availableSlugs[0] || 'general');
        const persistentAddButton = node.querySelector('#forum-new-board-toggle');

        node.dataset.activeMode = activeMode;
        node.dataset.activeBoardSlug = activeBoardSlug;
        node.innerHTML = '';

        if (isLessonPage && lessonHref) {
          const lessonLink = document.createElement('a');
          lessonLink.className = 'forum-switcher-link forum-switcher-link--lesson forum-subforum-link';
          lessonLink.dataset.boardSlug = 'lesson';
          if (lessonScopeKey) {
            lessonLink.dataset.forumScopeKey = lessonScopeKey;
            lessonLink.dataset.forumTotal = String(Math.max(0, Number(lessonTotalMessages) || 0));
            if (String(lessonLastActivityAt || '').trim()) {
              lessonLink.dataset.forumLastActivity = String(lessonLastActivityAt || '').trim();
            }
          }
          lessonLink.style.setProperty('--forum-switcher-color', '#7c3aed');
          lessonLink.title = lessonTitle;
          lessonLink.setAttribute('aria-label', 'Lección');
          lessonLink.href = `${lessonHref}#lesson-forum`;
          lessonLink.appendChild(createForumSwitcherMark('Lección'));
          lessonLink.appendChild(createForumSwitcherUnreadDot());

          if (activeMode === 'lesson') {
            lessonLink.classList.add('active');
            lessonLink.setAttribute('aria-current', 'page');
          }

          node.appendChild(lessonLink);
        }

        if (resolvedBoards.length === 0) {
          const emptyLink = document.createElement('span');
          emptyLink.className = 'forum-switcher-link forum-subforum-link is-disabled';
          emptyLink.title = 'Sin subforos disponibles';
          emptyLink.appendChild(createForumSwitcherMark('?'));
          node.appendChild(emptyLink);
          if (persistentAddButton instanceof HTMLElement) {
            node.appendChild(persistentAddButton);
          }
          return;
        }

        resolvedBoards.forEach((board, index) => {
          const slug = normalizeForumBoardSlug(board?.slug);
          if (!slug) return;

          const label = String(board?.title || slug);
          const totalMessages = Math.max(0, Number(board?.messageCount ?? board?.totalMessages ?? 0) || 0);
          const link = document.createElement('a');
          link.className = 'forum-switcher-link forum-switcher-link--board forum-subforum-link';
          link.dataset.boardSlug = slug;
          link.dataset.forumScopeKey = `board:${context.courseId}:${slug}`;
          link.dataset.forumTotal = String(totalMessages);
          if (String(board?.lastActivityAt || '').trim()) {
            link.dataset.forumLastActivity = String(board?.lastActivityAt || '').trim();
          }
          link.style.setProperty('--forum-switcher-color', getForumSwitcherColor(index));
          link.setAttribute('aria-label', label);
          link.title = label;
          link.href = `${baseHref}?board=${encodeURIComponent(slug)}#lesson-forum`;
          link.appendChild(createForumSwitcherMark(label));
          link.appendChild(createForumSwitcherUnreadDot());

          if (activeMode === 'board' && slug === activeBoardSlug) {
            link.classList.add('active');
            link.setAttribute('aria-current', 'page');
          }

          node.appendChild(link);
        });

        if (persistentAddButton instanceof HTMLElement) {
          node.appendChild(persistentAddButton);
        }

        refreshCourseForumUnreadIndicators();
      }

      async function refreshCourseForumSubnav({ preferredBoardSlug = '', boards = null, activeMode = '' } = {}) {
        const context = getCourseForumSubnavContext();
        if (!context) return;

        const { node, hasSession, courseId } = context;
        if (!hasSession || !courseId) return;

        if (Array.isArray(boards)) {
          renderCourseForumSubnav(boards, { preferredBoardSlug, activeMode });
          return;
        }

        try {
          const url = new URL('/api/forum/boards', window.location.origin);
          url.searchParams.set('courseId', courseId);

          const response = await fetch(url.toString());
          const payload = await response.json().catch(() => ({}));
          if (!response.ok) {
            throw new Error(payload?.error || 'No se pudieron cargar los subforos.');
          }

          const boardList = Array.isArray(payload?.boards) ? payload.boards : [];
          renderCourseForumSubnav(boardList, { preferredBoardSlug, activeMode });
        } catch (error) {
          console.error('Sidebar forum board load error:', error);
          node.innerHTML = '';
          const message = document.createElement('span');
          message.className = 'forum-switcher-link forum-subforum-link is-disabled';
          message.title = 'No se pudieron cargar subforos';
          message.appendChild(createForumSwitcherMark('!'));
          node.appendChild(message);
        }
      }

      function getPrimaryScroller() {
        const contentArea = document.querySelector('.content-area');
        if (contentArea instanceof HTMLElement) return contentArea;
        return null;
      }

      function scrollToTop(behavior = 'smooth') {
        const scroller = getPrimaryScroller();
        if (scroller) {
          scroller.scrollTo({
            top: 0,
            behavior,
          });
          return;
        }

        window.scrollTo({
          top: 0,
          behavior,
        });
      }

      function scrollToForum(behavior = 'smooth') {
        const forumRoot = document.getElementById('lesson-forum');
        if (forumRoot) {
          const forumSidebar = forumRoot.closest('.sidebar--right');
          if (forumSidebar && courseLayoutRoot instanceof HTMLElement && courseLayoutRoot.dataset.hasRightSidebar === 'true') {
            courseLayoutRoot.dataset.rightOpen = 'true';
            const overlay = courseLayoutRoot.querySelector('[data-course-sidebar-overlay]');
            const overlayActive = window.matchMedia('(max-width: 1024px)').matches;
            courseLayoutRoot.classList.toggle('is-overlay-active', overlayActive);
            if (overlay instanceof HTMLElement) {
              overlay.toggleAttribute('hidden', !overlayActive);
            }
            document.documentElement.classList.toggle('course-sidebars-open', overlayActive);
            document.body.classList.toggle('course-sidebars-open', overlayActive);
            try {
              window.localStorage.setItem('musiki:course:right-open', 'true');
            } catch {
              // ignore storage failures
            }
          }
          forumRoot.scrollIntoView({
            behavior,
            block: 'start',
          });
          return;
        }

        const scroller = getPrimaryScroller();
        if (scroller) {
          scroller.scrollTo({
            top: scroller.scrollHeight,
            behavior,
          });
          return;
        }

        window.scrollTo({
          top: document.body.scrollHeight,
          behavior,
        });
      }

      function slugifyTocText(value) {
        return String(value || '')
          .trim()
          .toLowerCase()
          .normalize('NFD')
          .replace(/[\u0300-\u036f]/g, '')
          .replace(/[^a-z0-9]+/g, '-')
          .replace(/^-+|-+$/g, '');
      }

      function getLessonStorageKeys() {
        const pageRoot = document.querySelector('[data-course-layout-root]');
        const userKey = pageRoot instanceof HTMLElement
          ? String(pageRoot.dataset.userKey || '').trim().toLowerCase() || 'guest'
          : 'guest';
        const pageKey = pageRoot instanceof HTMLElement
          ? String(pageRoot.dataset.livePageSlug || '').trim() || window.location.pathname
          : window.location.pathname;

        return {
          foldKey: `lesson:h2-folds:${userKey}:${pageKey}`,
          scrollKey: `lesson:scroll:${userKey}:${pageKey}`,
        };
      }

      function readStoredJson(key) {
        if (!key) return {};
        try {
          const raw = localStorage.getItem(key);
          if (!raw) return {};
          const parsed = JSON.parse(raw);
          return parsed && typeof parsed === 'object' ? parsed : {};
        } catch {
          return {};
        }
      }

      function writeStoredJson(key, value) {
        if (!key) return;
        try {
          localStorage.setItem(key, JSON.stringify(value));
        } catch {
          // ignore storage failures
        }
      }

      function getHeadingLevel(tagName) {
        const parsed = Number(String(tagName || '').replace('H', ''));
        if (!Number.isFinite(parsed)) return 2;
        if (parsed < 1) return 1;
        if (parsed > 6) return 6;
        return parsed;
      }

      function buildHeadingTree(nodes) {
        const roots = [];
        const stack = [];

        nodes.forEach((node) => {
          const entry = { ...node, children: [] };

          while (stack.length > 0 && stack[stack.length - 1].level >= entry.level) {
            stack.pop();
          }

          if (stack.length === 0) {
            roots.push(entry);
          } else {
            stack[stack.length - 1].children.push(entry);
          }

          stack.push(entry);
        });

        return roots;
      }

      function applyNoListMarker(element) {
        if (!(element instanceof HTMLElement)) return;
        element.dataset.musikiNoListMarker = 'true';
        element.style.setProperty('list-style', 'none');
        element.style.setProperty('padding-left', '0');
        element.style.setProperty('position', 'static');
      }

      function applyNoSummaryMarker(element) {
        if (!(element instanceof HTMLElement)) return;
        element.dataset.musikiNoSummaryMarker = 'true';
        element.style.setProperty('display', 'block');
        element.style.setProperty('list-style', 'none');
        element.style.setProperty('appearance', 'none');
        element.style.setProperty('-webkit-appearance', 'none');
        element.style.setProperty('padding-left', '0');
      }

      function createTocNodeElement(node) {
        const item = document.createElement('li');
        item.className = 'lesson-item class-toc-item';
        applyNoListMarker(item);

        const link = document.createElement('a');
        link.className = `class-toc-link level-${node.level}`;
        link.href = `#${node.id}`;
        link.textContent = node.text;
        link.addEventListener('click', (event) => {
          event.preventDefault();
          event.stopPropagation();
          navigateToContentHash(node.id, {
            behavior: 'smooth',
            updateHistory: true,
          });
        });

        if (!Array.isArray(node.children) || node.children.length === 0) {
          item.appendChild(link);
          return item;
        }

        const details = document.createElement('details');
        details.className = 'class-toc-branch';
        details.open = false;

        const summary = document.createElement('summary');
        summary.className = 'class-toc-summary';
        applyNoSummaryMarker(summary);
        summary.appendChild(link);
        details.appendChild(summary);

        const children = document.createElement('ul');
        children.className = 'lesson-list class-toc-children';
        node.children.forEach((child) => {
          children.appendChild(createTocNodeElement(child));
        });
        details.appendChild(children);
        item.appendChild(details);

        return item;
      }

      function setupFoldableH2Sections() {
        const contentArea = document.querySelector('.content-area');
        if (!(contentArea instanceof HTMLElement)) return;
        if (contentArea.querySelector('.content-fold[data-musiki-h2-fold="true"]')) return;

        const directChildren = Array.from(contentArea.children);
        const h2Nodes = directChildren.filter((node) =>
          node instanceof HTMLHeadingElement &&
          node.tagName === 'H2' &&
          !node.closest('#lesson-forum'),
        );

        if (h2Nodes.length === 0) return;

        const { foldKey } = getLessonStorageKeys();
        const storedState = readStoredJson(foldKey);
        const usedIds = new Set(
          Array.from(contentArea.querySelectorAll('[id]'))
            .map((node) => String((node as HTMLElement).id || '').trim())
            .filter(Boolean),
        );

        const isBoundaryNode = (node) => {
          if (!(node instanceof HTMLElement)) return false;
          if (node.id === 'lesson-forum') return true;
          if (node.classList.contains('course-nav')) return true;
          if (node.classList.contains('content-fold')) return true;
          return node.tagName === 'H2';
        };

        const persistOpenState = (sectionId, isOpen) => {
          const nextState = {
            ...readStoredJson(foldKey),
            [sectionId]: Boolean(isOpen),
          };
          writeStoredJson(foldKey, nextState);
        };

        [...h2Nodes].reverse().forEach((heading, index) => {
          let sectionId = String(heading.id || '').trim();
          if (!sectionId) {
            const base = slugifyTocText(heading.textContent || '') || `section-${index + 1}`;
            sectionId = base;
            let suffix = 2;
            while (usedIds.has(sectionId)) {
              sectionId = `${base}-${suffix}`;
              suffix += 1;
            }
            heading.id = sectionId;
          }
          usedIds.add(sectionId);

          const details = document.createElement('details');
          details.className = 'content-fold';
          details.dataset.musikiH2Fold = 'true';
          details.dataset.sectionId = sectionId;

          const summary = document.createElement('summary');
          summary.className = 'content-fold-summary';
          applyNoSummaryMarker(summary);
          const body = document.createElement('div');
          body.className = 'content-fold-body';

          heading.parentElement?.insertBefore(details, heading);
          summary.appendChild(heading);
          details.appendChild(summary);
          details.appendChild(body);

          while (details.nextSibling && !isBoundaryNode(details.nextSibling)) {
            body.appendChild(details.nextSibling);
          }

          details.open = typeof storedState[sectionId] === 'boolean'
            ? Boolean(storedState[sectionId])
            : false;

          if (window.location.hash) {
            const targetId = window.location.hash.replace(/^#/, '');
            const target = targetId ? document.getElementById(targetId) : null;
            if (target && details.contains(target)) {
              details.open = true;
            }
          }

          details.addEventListener('toggle', () => {
            persistOpenState(sectionId, details.open);
          });
        });
      }

      function getContentFoldNodes() {
        return Array.from(
          document.querySelectorAll('.content-fold[data-musiki-h2-fold="true"]'),
        ).filter((node) => node instanceof HTMLDetailsElement);
      }

      function setContentFoldState(nextOpen) {
        getContentFoldNodes().forEach((node) => {
          node.open = nextOpen;
        });
      }

      function openHeadingAncestors(target) {
        let current = target?.parentElement || null;
        while (current) {
          if (current instanceof HTMLDetailsElement) {
            current.open = true;
          }
          current = current.parentElement;
        }
      }

      function resolveHeadingScrollAnchor(target) {
        if (!(target instanceof HTMLElement)) return null;
        const summary = target.closest('.content-fold-summary');
        return summary instanceof HTMLElement ? summary : target;
      }

      function navigateToContentHash(targetId, options = {}) {
        const normalizedTargetId = String(targetId || '').replace(/^#/, '').trim();
        if (!normalizedTargetId) return false;

        const target = document.getElementById(normalizedTargetId);
        if (!(target instanceof HTMLElement)) return false;

        const behavior = options.behavior === 'smooth' ? 'smooth' : 'auto';
        const updateHistory = options.updateHistory !== false;
        openHeadingAncestors(target);

        const performScroll = () => {
          const anchor = resolveHeadingScrollAnchor(target);
          if (!(anchor instanceof HTMLElement)) return;

          const scroller = getPrimaryScroller();
          if (scroller instanceof HTMLElement && scroller.contains(anchor)) {
            const scrollerRect = scroller.getBoundingClientRect();
            const anchorRect = anchor.getBoundingClientRect();
            const top = Math.max(
              0,
              scroller.scrollTop + (anchorRect.top - scrollerRect.top) - 18,
            );
            scroller.scrollTo({
              top,
              behavior,
            });
          } else {
            anchor.scrollIntoView({
              behavior,
              block: 'start',
            });
          }

          if (updateHistory) {
            const nextUrl = new URL(window.location.href);
            nextUrl.hash = normalizedTargetId;
            window.history.replaceState({}, '', `${nextUrl.pathname}${nextUrl.search}${nextUrl.hash}`);
          }
        };

        window.requestAnimationFrame(performScroll);
        return true;
      }

      function buildClassToc() {
        const tocRoot = document.getElementById('class-toc');
        const tocDetails = document.getElementById('class-toc-details');
        const tocList = document.getElementById('class-toc-list');
        const contentArea = document.querySelector('.content-area');

        if (!tocRoot || !tocDetails || !tocList || !contentArea) return;

        const headings = Array.from(contentArea.querySelectorAll('h1, h2, h3, h4'))
          .filter((heading) => !heading.closest('#lesson-forum'));

        if (headings.length === 0) {
          tocRoot.hidden = true;
          tocList.innerHTML = '';
          return;
        }

        const usedIds = new Set(
          Array.from(document.querySelectorAll('[id]'))
            .map((node) => node.id)
            .filter(Boolean),
        );

        const normalizedHeadings = [];
        headings.forEach((heading) => {
          const text = (heading.textContent || '').trim();
          if (!text) return;

          let id = String(heading.id || '').trim();
          if (!id) {
            const base = slugifyTocText(text) || 'section';
            id = base;
            let suffix = 2;
            while (usedIds.has(id)) {
              id = `${base}-${suffix}`;
              suffix += 1;
            }
            heading.id = id;
          }
          usedIds.add(id);

          normalizedHeadings.push({
            id,
            text,
            level: getHeadingLevel(heading.tagName),
          });
        });

        tocList.innerHTML = '';
        const tocTree = buildHeadingTree(normalizedHeadings);
        tocTree.forEach((rootNode) => {
          tocList.appendChild(createTocNodeElement(rootNode));
        });

        tocDetails.open = true;
        tocRoot.hidden = tocList.children.length === 0;
      }

      async function initLessonForum() {
        const forumRoot = document.getElementById('lesson-forum');
        if (!forumRoot) return;

        const hasSession = forumRoot.dataset.hasSession === 'true';
        if (!hasSession) return;

        forumState.courseId = forumRoot.dataset.courseId || '';
        forumState.isLessonPage = forumRoot.dataset.isLessonPage === 'true';
        forumState.mode = forumRoot.dataset.forumMode === 'board' ? 'board' : 'lesson';
        forumState.lessonSlug = forumRoot.dataset.lessonSlug || '';
        forumState.boardSlug = forumRoot.dataset.initialBoardSlug || 'general';
        forumState.boards = [];
        forumState.canManageBoards = false;

        if (forumState.mode === 'board') {
          const boardQueryParam = new URL(window.location.href).searchParams.get('board');
          const normalizedBoardParam = String(boardQueryParam || '').trim().toLowerCase();
          if (normalizedBoardParam) {
            forumState.boardSlug = normalizedBoardParam;
          }
        }

        if (!forumState.courseId) return;
        if (forumState.isLessonPage && forumState.mode === 'lesson' && !forumState.lessonSlug) return;

        const statusEl = document.getElementById('forum-status');
        const threadListEl = document.getElementById('forum-thread-list');
        const newThreadContainer = document.getElementById('forum-new-thread');
        const newThreadForm = document.getElementById('forum-new-thread-form');
        const threadTitleInput = document.getElementById('forum-thread-title');
        const threadBodyInput = document.getElementById('forum-thread-body');
        const threadStageEl = document.getElementById('forum-thread-stage');
        const postListEl = document.getElementById('forum-post-list');
        const replyForm = document.getElementById('forum-reply-form');
        const replyBodyInput = document.getElementById('forum-reply-body');
        const parentPostInput = document.getElementById('forum-parent-post-id');
        const replyTargetEl = document.getElementById('forum-reply-target');
        const cancelReplyBtn = document.getElementById('forum-cancel-reply');
        const newBoardToggle = document.getElementById('forum-new-board-toggle');
        const newBoardPanel = document.getElementById('forum-new-board-panel');
        const newBoardForm = document.getElementById('forum-new-board-form');
        const boardTitleInput = document.getElementById('forum-board-title');
        const boardContextMenu = document.getElementById('forum-board-context-menu');
        const boardRenameAction = document.getElementById('forum-board-rename');
        const boardDeleteAction = document.getElementById('forum-board-delete');
        const mediaModalEl = document.getElementById('forum-media-modal');
        const mediaModalContentEl = document.getElementById('forum-media-modal-content');
        const mediaModalCloseBtn = document.getElementById('forum-media-modal-close');

        if (
          !statusEl ||
          !threadListEl ||
          !newThreadForm ||
          !threadTitleInput ||
          !threadBodyInput ||
          !threadStageEl ||
          !postListEl ||
          !replyForm ||
          !replyBodyInput ||
          !parentPostInput ||
          !replyTargetEl ||
          !cancelReplyBtn
        ) {
          return;
        }

        let latestPostRequestToken = 0;
        let latestThreadRequestToken = 0;
        let forumMermaidPromise = null;
        let sharedMermaidRenderSequence = 0;
        const FORUM_READ_PREFIX = 'forum:read:';
        const FORUM_BOARD_CACHE_TTL_MS = 60_000;
        const FORUM_THREAD_CACHE_TTL_MS = 20_000;
        const FORUM_POST_CACHE_TTL_MS = 20_000;
        const FORUM_PREFETCH_DELAY_MS = 120;
        const forumQueryCache = {
          boards: new Map(),
          threads: new Map(),
          posts: new Map(),
        };
        let forumScopePrefetchTimer = 0;
        let forumThreadPrefetchTimer = 0;
        let activeForumModalMedia = null;

        function ensureForumCacheEntry(cacheMap, cacheKey) {
          if (!cacheKey) return null;
          let entry = cacheMap.get(cacheKey);
          if (!entry) {
            entry = {
              data: null,
              fetchedAt: 0,
              promise: null,
            };
            cacheMap.set(cacheKey, entry);
          }
          return entry;
        }

        function getForumCachedPayload(cacheMap, cacheKey) {
          const entry = cacheKey ? cacheMap.get(cacheKey) : null;
          return entry?.data ?? null;
        }

        function isForumCacheFresh(cacheMap, cacheKey, ttlMs) {
          const entry = cacheKey ? cacheMap.get(cacheKey) : null;
          if (!entry?.data) return false;
          return Date.now() - Number(entry.fetchedAt || 0) < ttlMs;
        }

        function setForumCachedPayload(cacheMap, cacheKey, payload) {
          const entry = ensureForumCacheEntry(cacheMap, cacheKey);
          if (!entry) return payload;
          entry.data = payload;
          entry.fetchedAt = Date.now();
          return payload;
        }

        async function requestForumCachedPayload(cacheMap, cacheKey, fetcher) {
          const entry = ensureForumCacheEntry(cacheMap, cacheKey);
          if (!entry) return null;
          if (entry.promise) return entry.promise;

          const pending = (async () => {
            const payload = await fetcher();
            setForumCachedPayload(cacheMap, cacheKey, payload);
            return payload;
          })();

          entry.promise = pending;
          try {
            return await pending;
          } finally {
            if (entry.promise === pending) {
              entry.promise = null;
            }
          }
        }

        function getForumBoardsCacheKey(courseId = forumState.courseId) {
          return courseId ? `boards:${courseId}` : '';
        }

        function resolveForumScopeDescriptor(mode = forumState.mode, options = {}) {
          const normalizedMode = mode === 'lesson' ? 'lesson' : 'board';
          return {
            courseId: String(options.courseId || forumState.courseId || '').trim(),
            mode: normalizedMode,
            lessonSlug: String(
              normalizedMode === 'lesson'
                ? (options.lessonSlug ?? forumState.lessonSlug ?? '')
                : '',
            ).trim(),
            boardSlug: normalizeForumBoardSlug(
              normalizedMode === 'board'
                ? (options.boardSlug ?? forumState.boardSlug ?? 'general')
                : 'general',
            ),
          };
        }

        function getForumScopeCacheKey(scope = resolveForumScopeDescriptor()) {
          if (!scope?.courseId) return '';
          if (scope.mode === 'lesson') {
            return scope.lessonSlug
              ? `threads:${scope.courseId}:lesson:${scope.lessonSlug}`
              : '';
          }
          return `threads:${scope.courseId}:board:${normalizeForumBoardSlug(scope.boardSlug || 'general')}`;
        }

        function getForumPostsCacheKey(threadId) {
          const normalizedThreadId = String(threadId || '').trim();
          if (!forumState.courseId || !normalizedThreadId) return '';
          return `posts:${forumState.courseId}:${normalizedThreadId}`;
        }

        function isForumScopeCurrent(scope) {
          return getForumScopeCacheKey(resolveForumScopeDescriptor()) === getForumScopeCacheKey(scope);
        }

        function invalidateForumBoardsCache() {
          const cacheKey = getForumBoardsCacheKey();
          if (cacheKey) {
            forumQueryCache.boards.delete(cacheKey);
          }
        }

        function invalidateForumPostsCache(threadId) {
          const cacheKey = getForumPostsCacheKey(threadId);
          if (cacheKey) {
            forumQueryCache.posts.delete(cacheKey);
          }
        }

        function invalidateForumThreadCache(scope = resolveForumScopeDescriptor()) {
          const cacheKey = getForumScopeCacheKey(scope);
          if (!cacheKey) return;
          const cachedPayload = getForumCachedPayload(forumQueryCache.threads, cacheKey);
          const threadIds = Array.isArray(cachedPayload?.threads)
            ? cachedPayload.threads
              .map((thread) => String(thread?.id || '').trim())
              .filter(Boolean)
            : [];
          forumQueryCache.threads.delete(cacheKey);
          threadIds.forEach((threadId) => {
            invalidateForumPostsCache(threadId);
          });
        }

        function applyForumBoardsPayload(payload) {
          forumState.boards = Array.isArray(payload?.boards) ? payload.boards : [];
          forumState.canManageBoards = Boolean(payload?.canManageBoards);

          if (newBoardToggle instanceof HTMLElement) {
            newBoardToggle.hidden = !forumState.canManageBoards;
          }
          if (!forumState.canManageBoards) {
            setNewBoardPanelOpen(false);
            closeForumBoardContextMenu();
          }
        }

        function applyForumThreadsPayload(payload, { preserveSelection = true } = {}) {
          const previousThreadId = forumState.selectedThreadId;
          forumState.threads = Array.isArray(payload?.threads) ? payload.threads : [];
          forumState.canWrite = Boolean(payload?.canWrite);

          newThreadForm.hidden = !forumState.canWrite;
          if (newThreadContainer) newThreadContainer.hidden = !forumState.canWrite;

          if (
            preserveSelection &&
            previousThreadId &&
            forumState.threads.some((thread) => thread.id === previousThreadId)
          ) {
            forumState.selectedThreadId = previousThreadId;
          } else {
            forumState.selectedThreadId = forumState.threads[0]?.id || '';
          }

          renderThreadList();
          return forumState.selectedThreadId;
        }

        function applyForumPostsPayload(payload) {
          renderPosts(
            Array.isArray(payload?.posts) ? payload.posts : [],
            Boolean(payload?.canReply),
            Boolean(payload?.canVote),
          );
        }

        function setThreadListLoadingState() {
          threadListEl.innerHTML = '<p class="forum-empty">Cargando hilos...</p>';
        }

        async function fetchForumBoardsFromNetwork(courseId = forumState.courseId) {
          const url = new URL('/api/forum/boards', window.location.origin);
          url.searchParams.set('courseId', courseId);

          const response = await fetch(url.toString());
          const payload = await response.json().catch(() => ({}));

          if (!response.ok) {
            throw new Error(payload?.error || 'No se pudieron cargar los foros del curso.');
          }

          return {
            boards: Array.isArray(payload?.boards) ? payload.boards : [],
            canManageBoards: Boolean(payload?.canManageBoards),
          };
        }

        async function fetchForumThreadsFromNetwork(scope = resolveForumScopeDescriptor()) {
          const url = new URL('/api/forum/threads', window.location.origin);
          url.searchParams.set('courseId', scope.courseId);

          if (scope.mode === 'lesson' && scope.lessonSlug) {
            url.searchParams.set('lessonSlug', scope.lessonSlug);
          }
          if (scope.mode === 'board' && scope.boardSlug) {
            url.searchParams.set('boardSlug', scope.boardSlug);
          }

          const response = await fetch(url.toString());
          const payload = await response.json().catch(() => ({}));

          if (!response.ok) {
            throw new Error(payload?.error || 'No se pudieron cargar los hilos del foro.');
          }

          return {
            threads: Array.isArray(payload?.threads) ? payload.threads : [],
            canWrite: Boolean(payload?.canWrite),
          };
        }

        async function fetchForumPostsFromNetwork(threadId) {
          const response = await fetch(`/api/forum/threads/${encodeURIComponent(threadId)}/posts?renderContext=course`);
          const payload = await response.json().catch(() => ({}));

          if (!response.ok) {
            throw new Error(payload?.error || 'No se pudieron cargar los mensajes del hilo.');
          }

          return {
            posts: Array.isArray(payload?.posts) ? payload.posts : [],
            canReply: Boolean(payload?.canReply),
            canVote: Boolean(payload?.canVote),
          };
        }

        async function prefetchForumPosts(threadId) {
          const cacheKey = getForumPostsCacheKey(threadId);
          if (!cacheKey || isForumCacheFresh(forumQueryCache.posts, cacheKey, FORUM_POST_CACHE_TTL_MS)) {
            return getForumCachedPayload(forumQueryCache.posts, cacheKey);
          }

          try {
            return await requestForumCachedPayload(
              forumQueryCache.posts,
              cacheKey,
              () => fetchForumPostsFromNetwork(threadId),
            );
          } catch (error) {
            console.error('Forum prefetch posts error:', error);
            return null;
          }
        }

        async function prefetchForumScope(mode, options = {}) {
          const scope = resolveForumScopeDescriptor(mode, options);
          const cacheKey = getForumScopeCacheKey(scope);
          if (!cacheKey) return null;

          let payload = getForumCachedPayload(forumQueryCache.threads, cacheKey);
          if (!payload || !isForumCacheFresh(forumQueryCache.threads, cacheKey, FORUM_THREAD_CACHE_TTL_MS)) {
            try {
              payload = await requestForumCachedPayload(
                forumQueryCache.threads,
                cacheKey,
                () => fetchForumThreadsFromNetwork(scope),
              );
            } catch (error) {
              console.error('Forum prefetch threads error:', error);
              return null;
            }
          }

          const firstThreadId = String(payload?.threads?.[0]?.id || '').trim();
          syncCourseForumSubnavScopeMetrics(scope, payload?.threads || []);
          if (firstThreadId) {
            void prefetchForumPosts(firstThreadId);
          }

          return payload;
        }

        function clearForumScopePrefetchTimer() {
          if (!forumScopePrefetchTimer) return;
          window.clearTimeout(forumScopePrefetchTimer);
          forumScopePrefetchTimer = 0;
        }

        function scheduleForumScopePrefetch(mode, options = {}) {
          clearForumScopePrefetchTimer();
          forumScopePrefetchTimer = window.setTimeout(() => {
            forumScopePrefetchTimer = 0;
            void prefetchForumScope(mode, options);
          }, FORUM_PREFETCH_DELAY_MS);
        }

        function clearForumThreadPrefetchTimer() {
          if (!forumThreadPrefetchTimer) return;
          window.clearTimeout(forumThreadPrefetchTimer);
          forumThreadPrefetchTimer = 0;
        }

        function scheduleForumThreadPrefetch(threadId) {
          const normalizedThreadId = String(threadId || '').trim();
          if (!normalizedThreadId) return;
          clearForumThreadPrefetchTimer();
          forumThreadPrefetchTimer = window.setTimeout(() => {
            forumThreadPrefetchTimer = 0;
            void prefetchForumPosts(normalizedThreadId);
          }, FORUM_PREFETCH_DELAY_MS);
        }

        function getForumBoardRecord(boardSlug) {
          const normalizedBoardSlug = normalizeForumBoardSlug(boardSlug);
          return forumState.boards.find((board) => normalizeForumBoardSlug(board?.slug) === normalizedBoardSlug) || null;
        }

        function isManageableForumBoard(boardSlug) {
          const board = getForumBoardRecord(boardSlug);
          return Boolean(board && !board.isDefault && normalizeForumBoardSlug(board.slug) !== 'general');
        }

        function setNewBoardPanelOpen(nextOpen) {
          const isOpen = Boolean(nextOpen) && forumState.canManageBoards;
          if (newBoardPanel instanceof HTMLElement) {
            newBoardPanel.hidden = !isOpen;
          }
          if (newBoardToggle instanceof HTMLButtonElement) {
            newBoardToggle.setAttribute('aria-pressed', isOpen ? 'true' : 'false');
            newBoardToggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
          }
          if (isOpen && boardTitleInput instanceof HTMLInputElement) {
            window.requestAnimationFrame(() => {
              boardTitleInput.focus();
              boardTitleInput.select();
            });
          }
        }

        setNewBoardPanelOpen(false);

        function closeForumBoardContextMenu() {
          if (!(boardContextMenu instanceof HTMLElement)) return;
          boardContextMenu.hidden = true;
          boardContextMenu.style.left = '';
          boardContextMenu.style.top = '';
          delete boardContextMenu.dataset.boardSlug;
        }

        function openForumBoardContextMenu(boardSlug, clientX, clientY) {
          if (!(boardContextMenu instanceof HTMLElement) || !forumState.canManageBoards) return;
          if (!isManageableForumBoard(boardSlug)) return;

          const rootRect = forumRoot.getBoundingClientRect();
          const localX = Math.max(0, clientX - rootRect.left);
          const localY = Math.max(0, clientY - rootRect.top);

          boardContextMenu.dataset.boardSlug = normalizeForumBoardSlug(boardSlug);
          boardContextMenu.hidden = false;
          boardContextMenu.style.left = `${localX}px`;
          boardContextMenu.style.top = `${localY}px`;

          window.requestAnimationFrame(() => {
            if (!(boardContextMenu instanceof HTMLElement) || boardContextMenu.hidden) return;
            const menuRect = boardContextMenu.getBoundingClientRect();
            const clampedLeft = Math.min(localX, Math.max(0, forumRoot.clientWidth - menuRect.width - 8));
            const clampedTop = Math.min(localY, Math.max(0, forumRoot.scrollHeight - menuRect.height - 8));
            boardContextMenu.style.left = `${Math.max(0, clampedLeft)}px`;
            boardContextMenu.style.top = `${Math.max(0, clampedTop)}px`;
          });
        }

        async function renameForumBoard(boardSlug) {
          const board = getForumBoardRecord(boardSlug);
          if (!board || !isManageableForumBoard(boardSlug)) return;

          const nextTitle = window.prompt('Renombrar foro', String(board.title || ''));
          if (nextTitle === null) return;

          const title = nextTitle.trim();
          if (title.length < 3) {
            setForumStatus('El nombre del foro alternativo debe tener al menos 3 caracteres.', 'error');
            return;
          }

          try {
            const response = await fetch('/api/forum/boards', {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                courseId: forumState.courseId,
                boardSlug,
                title,
              }),
            });

            const payload = await response.json().catch(() => ({}));
            if (!response.ok) {
              throw new Error(payload?.error || 'No se pudo renombrar el foro.');
            }

            invalidateForumBoardsCache();
            await fetchForumBoards({ forceNetwork: true });
            await refreshCourseForumSubnav({
              preferredBoardSlug: forumState.boardSlug,
              boards: forumState.boards,
              activeMode: forumState.mode,
            });
            setForumStatus('Foro renombrado.', 'info');
          } catch (error) {
            console.error('Forum rename board error:', error);
            setForumStatus(error?.message || 'No se pudo renombrar el foro.', 'error');
          }
        }

        async function deleteForumBoard(boardSlug) {
          const board = getForumBoardRecord(boardSlug);
          if (!board || !isManageableForumBoard(boardSlug)) return;
          if (!window.confirm(`¿Borrar el foro "${board.title || boardSlug}"?`)) return;

          try {
            const response = await fetch('/api/forum/boards', {
              method: 'DELETE',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                courseId: forumState.courseId,
                boardSlug,
              }),
            });

            const payload = await response.json().catch(() => ({}));
            if (!response.ok) {
              throw new Error(payload?.error || 'No se pudo borrar el foro.');
            }

            invalidateForumBoardsCache();
            invalidateForumThreadCache(resolveForumScopeDescriptor('board', { boardSlug }));
            if (forumState.mode === 'board' && normalizeForumBoardSlug(forumState.boardSlug) === normalizeForumBoardSlug(boardSlug)) {
              if (forumState.isLessonPage && forumState.lessonSlug) {
                await fetchForumBoards({ forceNetwork: true });
                await applyForumScope('lesson');
              } else {
                forumState.boardSlug = 'general';
                await loadBoards({ preferredSlug: 'general', syncHistory: false });
                syncBoardQueryParam('replace');
                await loadThreads({ preserveSelection: false });
              }
            } else {
              await fetchForumBoards();
              await refreshCourseForumSubnav({
                preferredBoardSlug: forumState.boardSlug,
                boards: forumState.boards,
                activeMode: forumState.mode,
              });
            }

            setForumStatus('Foro borrado.', 'info');
          } catch (error) {
            console.error('Forum delete board error:', error);
            setForumStatus(error?.message || 'No se pudo borrar el foro.', 'error');
          }
        }

        function getForumShortName(value) {
          const cleaned = String(value || '').trim();
          if (!cleaned) return 'Usuario';
          return cleaned.split(/\s+/).filter(Boolean)[0] || cleaned;
        }

        const isDirectForumMediaUrl = (value) =>
          /\.(png|jpe?g|gif|webp|svg|mp4|webm|mov|m4v|mp3|wav|ogg|m4a)(?:$|[?#])/i.test(String(value || '').trim());

        const getForumMediaSource = (element) => {
          if (element instanceof HTMLImageElement) return element.currentSrc || element.src || '';
          if (element instanceof HTMLVideoElement || element instanceof HTMLAudioElement) {
            return element.currentSrc || element.getAttribute('src') || element.querySelector('source')?.src || '';
          }
          if (element instanceof HTMLAnchorElement) return element.href || '';
          return '';
        };

        const extractForumMediaTarget = (target) => {
          if (!(target instanceof Element)) return null;
          const mermaidEl = target.closest('.forum-post-body .mermaid');
          if (mermaidEl instanceof HTMLElement) {
            return {
              kind: 'diagram',
              node: mermaidEl.cloneNode(true),
            };
          }

          const mediaEl = target.closest('.forum-post-body img, .forum-post-body video, .forum-post-body audio, .forum-post-body a[href]');
          if (!mediaEl) return null;
          if (mediaEl instanceof HTMLAnchorElement && !isDirectForumMediaUrl(mediaEl.href)) return null;

          const src = getForumMediaSource(mediaEl);
          if (!src) return null;

          if (mediaEl instanceof HTMLImageElement || /\.(png|jpe?g|gif|webp|svg)(?:$|[?#])/i.test(src)) {
            return { kind: 'image', src, alt: mediaEl.getAttribute('alt') || '' };
          }
          if (mediaEl instanceof HTMLVideoElement || /\.(mp4|webm|mov|m4v)(?:$|[?#])/i.test(src)) {
            return { kind: 'video', src };
          }
          if (mediaEl instanceof HTMLAudioElement || /\.(mp3|wav|ogg|m4a)(?:$|[?#])/i.test(src)) {
            return { kind: 'audio', src };
          }
          return null;
        };

        const closeForumMediaModal = () => {
          if (!(mediaModalEl instanceof HTMLElement) || !(mediaModalContentEl instanceof HTMLElement)) return;
          if (activeForumModalMedia instanceof HTMLMediaElement) {
            activeForumModalMedia.pause();
            activeForumModalMedia.removeAttribute('src');
            activeForumModalMedia.load();
          }
          activeForumModalMedia = null;
          mediaModalContentEl.replaceChildren();
          mediaModalEl.hidden = true;
          mediaModalEl.setAttribute('aria-hidden', 'true');
          document.documentElement.style.overflow = '';
        };

        const enableForumMediaZoom = (viewport, target) => {
          if (!(viewport instanceof HTMLElement) || !(target instanceof HTMLElement)) return;

          let scale = 1;
          let offsetX = 0;
          let offsetY = 0;
          let pointerId = null;
          let dragOriginX = 0;
          let dragOriginY = 0;
          let startOffsetX = 0;
          let startOffsetY = 0;

          const clamp = (value, min, max) => Math.min(max, Math.max(min, value));
          const applyTransform = () => {
            if (scale <= 1) {
              offsetX = 0;
              offsetY = 0;
            }
            target.style.transform = `translate(${offsetX}px, ${offsetY}px) scale(${scale})`;
          };
          const setScale = (nextScale) => {
            scale = clamp(nextScale, 1, 8);
            applyTransform();
          };

          viewport.addEventListener('wheel', (event) => {
            event.preventDefault();
            setScale(scale + (event.deltaY < 0 ? 0.24 : -0.24));
          }, { passive: false });

          target.addEventListener('dblclick', (event) => {
            event.preventDefault();
            setScale(scale < 2 ? scale + 1 : 1);
          });

          viewport.addEventListener('pointerdown', (event) => {
            if (scale <= 1) return;
            pointerId = event.pointerId;
            dragOriginX = event.clientX;
            dragOriginY = event.clientY;
            startOffsetX = offsetX;
            startOffsetY = offsetY;
            viewport.classList.add('is-dragging');
            viewport.setPointerCapture(pointerId);
          });

          viewport.addEventListener('pointermove', (event) => {
            if (pointerId !== event.pointerId) return;
            offsetX = startOffsetX + (event.clientX - dragOriginX);
            offsetY = startOffsetY + (event.clientY - dragOriginY);
            applyTransform();
          });

          const stopDragging = (event) => {
            if (pointerId !== event.pointerId) return;
            try {
              viewport.releasePointerCapture(pointerId);
            } catch {}
            pointerId = null;
            viewport.classList.remove('is-dragging');
          };

          viewport.addEventListener('pointerup', stopDragging);
          viewport.addEventListener('pointercancel', stopDragging);

          applyTransform();
        };

        const openForumMediaModal = (payload) => {
          if (!(mediaModalEl instanceof HTMLElement) || !(mediaModalContentEl instanceof HTMLElement)) return;
          if (!payload || (!payload.src && payload.kind !== 'diagram')) return;

          let node = null;
          if (payload.kind === 'image') {
            const image = document.createElement('img');
            image.src = payload.src;
            image.alt = payload.alt || '';
            image.loading = 'eager';
            image.decoding = 'async';
            node = image;
          } else if (payload.kind === 'video') {
            const video = document.createElement('video');
            video.src = payload.src;
            video.controls = true;
            video.autoplay = true;
            video.playsInline = true;
            video.preload = 'metadata';
            node = video;
          } else if (payload.kind === 'audio') {
            const audio = document.createElement('audio');
            audio.src = payload.src;
            audio.controls = true;
            audio.autoplay = true;
            audio.preload = 'metadata';
            node = audio;
          } else if (payload.kind === 'diagram' && payload.node instanceof HTMLElement) {
            node = payload.node;
          }

          if (!node) return;

          if (payload.kind === 'image' && /\.svg(?:$|[?#])/i.test(payload.src)) {
            node.dataset.forumSvg = 'true';
          }

          if (payload.kind === 'image' || payload.kind === 'video' || payload.kind === 'diagram') {
            const viewport = document.createElement('div');
            viewport.className = 'forum-media-modal-viewport';
            viewport.appendChild(node);
            mediaModalContentEl.replaceChildren(viewport);
            enableForumMediaZoom(viewport, node);
          } else {
            mediaModalContentEl.replaceChildren(node);
          }
          activeForumModalMedia = node instanceof HTMLMediaElement ? node : null;
          mediaModalEl.hidden = false;
          mediaModalEl.setAttribute('aria-hidden', 'false');
          document.documentElement.style.overflow = 'hidden';
        };

        function syncBoardQueryParam(historyMode = 'replace', { anchorForum = false } = {}) {
          const nextUrl = new URL(window.location.href);
          const currentHash = String(window.location.hash || '').trim();
          nextUrl.hash =
            anchorForum || currentHash === '#lesson-forum'
              ? 'lesson-forum'
              : currentHash.replace(/^#/, '');
          if (forumState.mode !== 'board') {
            nextUrl.searchParams.delete('board');
          } else {
            const normalizedBoard = normalizeForumBoardSlug(forumState.boardSlug);
            nextUrl.searchParams.set('board', normalizedBoard);
          }

          const method = historyMode === 'push' ? 'pushState' : 'replaceState';
          window.history[method]({}, '', `${nextUrl.pathname}${nextUrl.search}${nextUrl.hash}`);
        }

        function setForumStatus(message, tone = 'info') {
          if (!message) {
            statusEl.hidden = true;
            statusEl.textContent = '';
            statusEl.classList.remove('error');
            return;
          }

          statusEl.hidden = false;
          statusEl.textContent = message;
          statusEl.classList.toggle('error', tone === 'error');
        }

        function pickNewestForumTimestamp(current, candidate) {
          if (!current) return candidate || '';
          if (!candidate) return current || '';
          const currentTime = new Date(current).getTime();
          const candidateTime = new Date(candidate).getTime();
          if (Number.isNaN(currentTime)) return candidate || '';
          if (Number.isNaN(candidateTime)) return current || '';
          return candidateTime > currentTime ? candidate : current;
        }

        function getForumScopeStorageKeyFromScope(scope = resolveForumScopeDescriptor()) {
          if (!scope?.courseId) return '';
          if (scope.mode === 'board') {
            return `board:${scope.courseId}:${normalizeForumBoardSlug(scope.boardSlug || 'general')}`;
          }
          if (!scope.lessonSlug) return '';
          return `lesson:${scope.courseId}:${scope.lessonSlug}`;
        }

        function getForumScopeStorageKey() {
          return getForumScopeStorageKeyFromScope(resolveForumScopeDescriptor());
        }

        function getForumScopeMessageTotal(threads = forumState.threads || []) {
          return (Array.isArray(threads) ? threads : []).reduce((sum, thread) => {
            const messageCount = Number(thread?.messageCount);
            if (Number.isFinite(messageCount) && messageCount >= 0) {
              return sum + messageCount;
            }
            const postCount = Number(thread?.postCount);
            if (Number.isFinite(postCount) && postCount >= 0) {
              return sum + postCount;
            }
            return sum;
          }, 0);
        }

        function getForumScopeLastActivityAt(threads = forumState.threads || []) {
          return (Array.isArray(threads) ? threads : []).reduce((latest, thread) => (
            pickNewestForumTimestamp(
              latest,
              String(thread?.lastActivityAt || thread?.updatedAt || thread?.createdAt || '').trim(),
            )
          ), '');
        }

        function syncCourseForumSubnavScopeMetrics(scope = resolveForumScopeDescriptor(), threads = forumState.threads || []) {
          const scopeKey = getForumScopeStorageKeyFromScope(scope);
          if (!scopeKey) return;
          setCourseForumScopeMetrics(scopeKey, {
            totalMessages: getForumScopeMessageTotal(threads),
            lastActivityAt: getForumScopeLastActivityAt(threads),
          });
          refreshCourseForumUnreadIndicators();
        }

        function markForumScopeAsRead() {
          const scopeKey = getForumScopeStorageKey();
          if (!scopeKey) return;

          try {
            localStorage.setItem(
              FORUM_READ_PREFIX + scopeKey,
              JSON.stringify({
                messageTotal: getForumScopeMessageTotal(),
                readAt: new Date().toISOString(),
              }),
            );
            refreshCourseForumUnreadIndicators();
          } catch (error) {
            console.error('Forum read-state storage error:', error);
          }
        }

        function getForumScopePayload() {
          if (forumState.mode === 'board') {
            return { boardSlug: forumState.boardSlug };
          }
          return { lessonSlug: forumState.lessonSlug };
        }

        function escapeHtml(value) {
          return String(value || '')
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#39;');
        }

        function getForumBodyHtml(post) {
          if (typeof post?.bodyHtml === 'string' && post.bodyHtml.trim().length > 0) {
            return post.bodyHtml;
          }

          const plain = escapeHtml(post?.body || '').replaceAll('\n', '<br />');
          return `<p>${plain}</p>`;
        }

        function setForumBodyContent(container, post) {
          function forumBodyHasRenderableMedia(root) {
            if (!(root instanceof HTMLElement)) return false;
            return Boolean(
              root.querySelector(
                'img, audio, video, iframe, svg, .mermaid, .katex, .lily-score, .obsidian-media-embed-card',
              ),
            );
          }

          function normalizeForumBodyNode(root) {
            if (!(root instanceof HTMLElement)) return;
            root.style.color = 'var(--forum-text-primary, var(--c-fg, #1c1f23))';
            root.style.opacity = '1';
            root.style.visibility = 'visible';

            root.querySelectorAll('[hidden]').forEach((node) => {
              if (node instanceof HTMLElement) {
                node.hidden = false;
                node.removeAttribute('hidden');
              }
            });

            root.querySelectorAll('*').forEach((node) => {
              if (!(node instanceof HTMLElement)) return;
              if (node.closest('svg, .mermaid, .katex, .lily-score')) return;
              if (node.style.display === 'none') node.style.display = '';
              if (node.style.visibility === 'hidden') node.style.visibility = 'visible';
              if (node.style.opacity === '0') node.style.opacity = '1';
              if (!node.style.color) node.style.color = 'inherit';
            });
          }

          container.replaceChildren();

          const nextHtml = getForumBodyHtml(post);
          try {
            const range = document.createRange();
            range.selectNode(container);
            const fragment = range.createContextualFragment(nextHtml);
            if (fragment.childNodes.length > 0) {
              container.appendChild(fragment);
            }
          } catch {
            container.innerHTML = nextHtml;
          }

          if (!String(container.textContent || '').trim() && !forumBodyHasRenderableMedia(container)) {
            const plainFallback = String(post?.body || '').trim();
            const paragraph = document.createElement('p');
            paragraph.innerHTML = plainFallback
              ? escapeHtml(plainFallback).replaceAll('\n', '<br />')
              : 'Sin contenido.';
            container.replaceChildren(paragraph);
          }

          normalizeForumBodyNode(container);

          container.querySelectorAll('a[href]').forEach((anchor) => {
            if (!(anchor instanceof HTMLAnchorElement)) return;
            if (!isDirectForumMediaUrl(anchor.href)) return;
            anchor.dataset.forumMediaLink = 'true';
          });
        }

        function replaceForumTextareaSelection(textarea, nextText, start, end, cursorStart, cursorEnd = cursorStart) {
          const value = textarea.value || '';
          textarea.value = `${value.slice(0, start)}${nextText}${value.slice(end)}`;
          textarea.setSelectionRange(cursorStart, cursorEnd);
          textarea.dispatchEvent(new Event('input', { bubbles: true }));
        }

        const FORUM_EDITOR_CURSOR_TOKEN = '<cursor here>';
        const FORUM_EDITOR_TEMPLATES = {
          lilypond: {
            title: 'Insertar bloque LilyPond',
            icon:
              '<svg viewBox="0 0 16 16" aria-hidden="true"><path d="M10.75 2v7.1"/><path d="M10.75 2 5.25 3.4v7.35"/><path d="M10.75 5.1 5.25 6.5"/><ellipse cx="4.1" cy="11.8" rx="1.85" ry="1.35"/><ellipse cx="9.6" cy="10.35" rx="1.85" ry="1.35"/></svg>',
            snippet:
