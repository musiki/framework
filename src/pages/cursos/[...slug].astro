        function insertForumTemplate(textarea, template) {
          if (!textarea || !template?.snippet) return;

          const start = textarea.selectionStart ?? 0;
          const end = textarea.selectionEnd ?? start;
          let snippet = template.snippet;
          let cursorOffset = snippet.length;
          let selectionLength = 0;

          if (template.cursorToken && snippet.includes(template.cursorToken)) {
            cursorOffset = snippet.indexOf(template.cursorToken);
            selectionLength = 0;
            snippet = snippet.replace(template.cursorToken, '');
          } else if (template.cursorSearch && snippet.includes(template.cursorSearch)) {
            cursorOffset = snippet.indexOf(template.cursorSearch);
            selectionLength = template.cursorSearch.length;
          }

          replaceForumTextareaSelection(
            textarea,
            snippet,
            start,
            end,
            start + cursorOffset,
            start + cursorOffset + selectionLength,
          );
          textarea.focus();
        }

        function createForumTemplateButton(textarea, templateKey) {
          const template = FORUM_EDITOR_TEMPLATES[templateKey];
          if (!template) return null;

          const button = document.createElement('button');
          button.type = 'button';
          button.className = 'forum-action-btn forum-action-f forum-editor-action-btn';
          button.title = template.title;
          button.setAttribute('aria-label', template.title);
          button.dataset.tooltip = template.title;
          button.innerHTML = template.icon;
          button.addEventListener('mousedown', (event) => {
            event.preventDefault();
          });
          button.addEventListener('click', () => insertForumTemplate(textarea, template));
          return button;
        }

        function ensureForumDropzone(textarea) {
          if (!textarea) return null;
          const existingParent = textarea.parentElement;
          if (existingParent && existingParent.classList.contains('forum-editor-dropzone')) {
            return existingParent;
          }

          const wrapper = document.createElement('div');
          wrapper.className = 'forum-editor-dropzone';

          const overlay = document.createElement('div');
          overlay.className = 'forum-editor-dropzone-overlay';
          overlay.setAttribute('aria-hidden', 'true');

          const label = document.createElement('span');
          label.className = 'forum-editor-dropzone-label';
          label.textContent = 'Drop file';
          overlay.appendChild(label);

          textarea.parentNode?.insertBefore(wrapper, textarea);
          wrapper.appendChild(textarea);
          wrapper.appendChild(overlay);
          return wrapper;
        }

        function createForumUploadButton(textarea) {
          if (!textarea) return null;

          const input = document.createElement('input');
          input.type = 'file';
          input.multiple = true;
          input.hidden = true;
          input.accept = '.png,.jpg,.jpeg,.gif,.webp,.svg,.avif,.mp3,.wav,.ogg,.m4a,.aac,.flac,.mp4,.m4v,.mov,.webm,.ogv,image/*,audio/*,video/*';

          const button = document.createElement('button');
          button.type = 'button';
          button.className = 'forum-action-btn forum-action-f forum-editor-action-btn';
          button.title = 'Insertar archivo';
          button.setAttribute('aria-label', 'Insertar archivo');
          button.dataset.tooltip = 'Insertar archivo';
          button.innerHTML = '<svg viewBox="0 0 16 16" aria-hidden="true"><path d="M6.15 8.95 10.9 4.2a2.1 2.1 0 0 1 2.95 2.95L8.1 12.9A3.3 3.3 0 1 1 3.45 8.25l5.35-5.35"/><path d="M5.7 11.05 11 5.75"/></svg>';
          button.addEventListener('mousedown', (event) => {
            event.preventDefault();
          });
          button.addEventListener('click', () => {
            input.click();
          });
          input.addEventListener('change', async () => {
            const files = Array.from(input.files || []);
            if (files.length > 0) {
              await handleForumMediaUpload(textarea, files, 'selector');
            }
            input.value = '';
          });

          button._forumFileInput = input;
          return button;
        }

        function mountForumEditorActions(textarea, explicitActions = null) {
          if (!textarea || textarea.dataset.forumEditorActionsEnhanced === 'true') return;

          const actions = explicitActions instanceof HTMLElement
            ? explicitActions
            : textarea.closest('form, .forum-edit-form')?.querySelector('.forum-form-actions');
          if (!(actions instanceof HTMLElement)) return;

          textarea.dataset.forumEditorActionsEnhanced = 'true';

          const spacer = document.createElement('span');
          spacer.className = 'forum-editor-action-spacer';
          spacer.setAttribute('aria-hidden', 'true');

          const lilypondButton = createForumTemplateButton(textarea, 'lilypond');
          const mermaidButton = createForumTemplateButton(textarea, 'mermaid');
          const uploadButton = createForumUploadButton(textarea);

          if (spacer) actions.prepend(spacer);
          if (uploadButton?._forumFileInput) actions.appendChild(uploadButton._forumFileInput);
          if (uploadButton) actions.prepend(uploadButton);
          if (mermaidButton) actions.prepend(mermaidButton);
          if (lilypondButton) actions.prepend(lilypondButton);
        }

        function getForumUploadKind(file) {
          if (!(file instanceof File)) return '';
          const mime = String(file.type || '').toLowerCase();
          if (mime.startsWith('image/')) return 'image';
          if (mime.startsWith('audio/')) return 'audio';
          if (mime.startsWith('video/')) return 'video';
          const fileName = String(file.name || '').toLowerCase();
          if (/\.(png|jpe?g|gif|webp|svg|avif)$/i.test(fileName)) return 'image';
          if (/\.(mp3|wav|ogg|m4a|aac|flac)$/i.test(fileName)) return 'audio';
          if (/\.(mp4|m4v|mov|webm|ogv)$/i.test(fileName)) return 'video';
          return '';
        }

        function extractForumUploadFiles(fileLikeCollection, itemLikeCollection = null) {
          const directFiles = Array.from(fileLikeCollection || []).filter((file) => {
            return getForumUploadKind(file) !== '';
          });
          if (directFiles.length > 0) return directFiles;

          return Array.from(itemLikeCollection || [])
            .map((item) => {
              if (!item || item.kind !== 'file' || typeof item.getAsFile !== 'function') return null;
              return item.getAsFile();
            })
            .filter((file) => {
              return getForumUploadKind(file) !== '';
            });
        }

        async function uploadForumMediaFile(file) {
          const uploadForm = new FormData();
          uploadForm.append('file', file, file.name || 'forum-upload');

          const response = await fetch('/api/forum/upload-image', {
            method: 'POST',
            body: uploadForm,
          });

          const payload = await response.json().catch(() => ({}));
          if (!response.ok) {
            throw new Error(payload?.error || 'No se pudo subir el archivo.');
          }

          const mediaUrl = typeof payload?.url === 'string' ? payload.url.trim() : '';
          const kind = typeof payload?.kind === 'string' ? payload.kind.trim() : getForumUploadKind(file);
          if (!mediaUrl) {
            throw new Error('El servidor no devolvió una URL de archivo.');
          }

          return { url: mediaUrl, kind };
        }

        function insertForumMediaEmbeds(textarea, mediaEntries) {
          if (!textarea || !Array.isArray(mediaEntries) || mediaEntries.length === 0) return;

          const start = textarea.selectionStart ?? 0;
          const end = textarea.selectionEnd ?? start;
          const currentValue = textarea.value || '';
          const previousChar = start > 0 ? currentValue.slice(start - 1, start) : '';
          const nextChar = end < currentValue.length ? currentValue.slice(end, end + 1) : '';

          let snippet = mediaEntries.map((entry) => `![](${entry.url})`).join('\n');
          if (previousChar && previousChar !== '\n') {
            snippet = `\n${snippet}`;
          }
          if (nextChar && nextChar !== '\n') {
            snippet = `${snippet}\n`;
          }

          replaceForumTextareaSelection(
            textarea,
            snippet,
            start,
            end,
            start + snippet.length,
          );
          textarea.focus();
        }

        function describeForumUploadBatch(files) {
          let imageCount = 0;
          let audioCount = 0;
          let videoCount = 0;
          for (const file of files) {
            const kind = getForumUploadKind(file);
            if (kind === 'image') imageCount += 1;
            if (kind === 'audio') audioCount += 1;
            if (kind === 'video') videoCount += 1;
          }

          const labels = [];
          if (imageCount > 0) labels.push(imageCount === 1 ? 'imagen' : `${imageCount} imágenes`);
          if (audioCount > 0) labels.push(audioCount === 1 ? 'audio' : `${audioCount} audios`);
          if (videoCount > 0) labels.push(videoCount === 1 ? 'video' : `${videoCount} videos`);
          return labels.join(' y ') || 'archivo';
        }

        async function handleForumMediaUpload(textarea, files, sourceLabel) {
          const uploadFiles = extractForumUploadFiles(files);
          if (!textarea || uploadFiles.length === 0) return false;

          const uploadLabel = describeForumUploadBatch(uploadFiles);
          textarea.closest('.forum-editor-dropzone')?.classList.add('is-uploading');
          textarea.classList.add('is-uploading');
          setForumStatus(`Subiendo ${uploadLabel} desde ${sourceLabel}...`, 'info');

          try {
            const uploadedEntries = [];
            for (const file of uploadFiles) {
              // Preserve order deterministically even if the remote service answers unevenly.
              const uploaded = await uploadForumMediaFile(file);
              uploadedEntries.push(uploaded);
            }

            insertForumMediaEmbeds(textarea, uploadedEntries);
            setForumStatus(
              uploadFiles.length === 1 ? 'Archivo insertado.' : `${uploadFiles.length} archivos insertados.`,
              'info',
            );
            return true;
          } catch (error) {
            console.error('Forum media upload client error:', error);
            setForumStatus(error?.message || 'No se pudo subir el archivo.', 'error');
            return true;
          } finally {
            textarea.closest('.forum-editor-dropzone')?.classList.remove('is-uploading');
            textarea.closest('.forum-editor-dropzone')?.classList.remove('is-upload-target');
            textarea.classList.remove('is-uploading');
            textarea.classList.remove('is-upload-target');
          }
        }

        function attachForumTypingHelpers(textarea) {
          if (!textarea || textarea.dataset.forumTypingEnhanced === 'true') return;
          textarea.dataset.forumTypingEnhanced = 'true';

          const openerPairs = {
            '(': ')',
            '[': ']',
            '{': '}',
            '"': '"',
            "'": "'",
            '`': '`',
          };
          const closers = new Set(Object.values(openerPairs));
          const normalizeMermaidArrows = (rawValue) => String(rawValue || '').replace(
            /```mermaid([\s\S]*?)```/g,
            (block) => block
              .replaceAll('→', '-->')
              .replaceAll('⟶', '-->')
              .replaceAll('⇢', '-->')
              .replaceAll('←', '<--')
              .replaceAll('⟵', '<--')
              .replaceAll('↔', '<-->')
              .replaceAll('⟷', '<-->'),
          );

          textarea.addEventListener('beforeinput', (event) => {
            if (event.inputType !== 'insertText') return;
            const inserted = String(event.data || '');
            if (!inserted || !/[→⟶⇢←⟵↔⟷]/.test(inserted)) return;

            const arrowMap = {
              '→': '-->',
              '⟶': '-->',
              '⇢': '-->',
              '←': '<--',
              '⟵': '<--',
              '↔': '<-->',
              '⟷': '<-->',
            };
            const replacement = arrowMap[inserted];
            if (!replacement) return;

            const start = textarea.selectionStart ?? 0;
            const end = textarea.selectionEnd ?? start;
            event.preventDefault();
            replaceForumTextareaSelection(textarea, replacement, start, end, start + replacement.length);
          });

          textarea.addEventListener('keydown', (event) => {
            const start = textarea.selectionStart ?? 0;
            const end = textarea.selectionEnd ?? 0;
            const value = textarea.value || '';

            if (event.key === 'Tab' && !event.metaKey && !event.ctrlKey && !event.altKey) {
              event.preventDefault();
              replaceForumTextareaSelection(textarea, '  ', start, end, start + 2);
              return;
            }

            if (
              event.key === 'Enter' &&
              !event.metaKey &&
              !event.ctrlKey &&
              !event.altKey &&
              !event.shiftKey &&
              start === end
            ) {
              const lineStart = value.lastIndexOf('\n', start - 1) + 1;
              const line = value.slice(lineStart, start);
              if (/^```[A-Za-z0-9_+-]*\s*$/.test(line)) {
                event.preventDefault();
                replaceForumTextareaSelection(textarea, '\n\n```', start, end, start + 1);
                return;
              }
            }

            if (event.metaKey || event.ctrlKey || event.altKey) return;

            if (closers.has(event.key) && start === end && value.slice(start, start + 1) === event.key) {
              event.preventDefault();
              textarea.setSelectionRange(start + 1, start + 1);
              return;
            }

            const closer = openerPairs[event.key];
            if (!closer) return;

            if ((event.key === '"' || event.key === "'") && start === end) {
              const prevChar = value.slice(Math.max(0, start - 1), start);
              const nextChar = value.slice(start, start + 1);
              if (/[A-Za-z0-9_]/.test(prevChar) || /[A-Za-z0-9_]/.test(nextChar)) {
                return;
              }
            }

            event.preventDefault();
            const selection = value.slice(start, end);
            const wrapped = `${event.key}${selection}${closer}`;
            if (selection) {
              replaceForumTextareaSelection(textarea, wrapped, start, end, start + 1, start + 1 + selection.length);
              return;
            }

            replaceForumTextareaSelection(textarea, wrapped, start, end, start + 1);
          });

          textarea.addEventListener('input', () => {
            const normalized = normalizeMermaidArrows(textarea.value || '');
            if (normalized === textarea.value) return;
            const cursor = textarea.selectionStart ?? normalized.length;
            textarea.value = normalized;
            textarea.setSelectionRange(cursor, cursor);
          });
        }

        function attachForumEditor(textarea, explicitActions = null) {
          if (!textarea || textarea.dataset.forumEditorEnhanced === 'true') return;
          textarea.dataset.forumEditorEnhanced = 'true';
          const dropzone = ensureForumDropzone(textarea);
          let dragDepth = 0;

          textarea.spellcheck = false;
          textarea.autocomplete = 'off';
          textarea.autocapitalize = 'off';
          textarea.setAttribute('autocorrect', 'off');

          attachForumTypingHelpers(textarea);
          textarea.classList.add('forum-editor-input');
          mountForumEditorActions(textarea, explicitActions);

          textarea.addEventListener('paste', async (event) => {
            const uploadFiles = extractForumUploadFiles(
              event.clipboardData?.files,
              event.clipboardData?.items,
            );
            if (uploadFiles.length === 0) return;

            event.preventDefault();
            await handleForumMediaUpload(textarea, uploadFiles, 'portapapeles');
          });

          textarea.addEventListener('dragover', (event) => {
            const uploadFiles = extractForumUploadFiles(
              event.dataTransfer?.files,
              event.dataTransfer?.items,
            );
            if (uploadFiles.length === 0) return;
            event.preventDefault();
            if (event.dataTransfer) {
              event.dataTransfer.dropEffect = 'copy';
            }
            if (dropzone) dropzone.classList.add('is-upload-target');
            textarea.classList.add('is-upload-target');
          });

          textarea.addEventListener('dragenter', (event) => {
            const uploadFiles = extractForumUploadFiles(
              event.dataTransfer?.files,
              event.dataTransfer?.items,
            );
            if (uploadFiles.length === 0) return;

            event.preventDefault();
            dragDepth += 1;
            if (dropzone) dropzone.classList.add('is-upload-target');
            textarea.classList.add('is-upload-target');
          });

          textarea.addEventListener('dragleave', () => {
            dragDepth = Math.max(0, dragDepth - 1);
            if (dragDepth === 0) {
              if (dropzone) dropzone.classList.remove('is-upload-target');
              textarea.classList.remove('is-upload-target');
            }
          });

          textarea.addEventListener('drop', async (event) => {
            const uploadFiles = extractForumUploadFiles(
              event.dataTransfer?.files,
              event.dataTransfer?.items,
            );
            if (uploadFiles.length === 0) return;

            event.preventDefault();
            dragDepth = 0;
            if (dropzone) dropzone.classList.remove('is-upload-target');
            textarea.classList.remove('is-upload-target');
            await handleForumMediaUpload(textarea, uploadFiles, 'arrastre');
          });
        }

        function isForumPostEdited(post) {
          if (!post?.createdAt || !post?.updatedAt) return false;
          const createdAt = new Date(post.createdAt);
          const updatedAt = new Date(post.updatedAt);
          if (Number.isNaN(createdAt.getTime()) || Number.isNaN(updatedAt.getTime())) return false;
          return Math.abs(updatedAt.getTime() - createdAt.getTime()) > 1000;
        }

        function getForumInitials(name) {
          const cleaned = String(name || '').trim();
          if (!cleaned) return 'U';
          const parts = cleaned.split(/\s+/).filter(Boolean);
          if (parts.length === 1) return parts[0].slice(0, 2).toUpperCase();
          return `${parts[0][0] || ''}${parts[1][0] || ''}`.toUpperCase();
        }

        function createForumAvatar(authorName, authorImage) {
          const createFallback = () => {
            const fallback = document.createElement('span');
            fallback.className = 'forum-post-avatar';
            fallback.textContent = getForumInitials(authorName);
            return fallback;
          };

          const imageUrl = typeof authorImage === 'string' ? authorImage.trim() : '';
          if (!imageUrl) return createFallback();

          const img = document.createElement('img');
          img.className = 'forum-post-avatar';
          img.src = imageUrl;
          img.alt = '';
          img.loading = 'lazy';
          img.decoding = 'async';
          img.referrerPolicy = 'no-referrer';
          img.addEventListener('error', () => {
            const replacement = createFallback();
            img.replaceWith(replacement);
          }, { once: true });

          return img;
        }

        function ensureForumMermaid() {
          if (window.mermaid?.run) {
            return Promise.resolve(window.mermaid);
          }

          if (forumMermaidPromise) return forumMermaidPromise;

          forumMermaidPromise = new Promise((resolve) => {
            const existing = document.querySelector('script[data-musiki-mermaid-loader="true"]');
            if (existing) {
              existing.addEventListener('load', () => resolve(window.mermaid || null), { once: true });
              existing.addEventListener('error', () => resolve(null), { once: true });
              return;
            }

            const script = document.createElement('script');
            script.src = 'https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js';
            script.defer = true;
            script.dataset.musikiMermaidLoader = 'true';
            script.onload = () => resolve(window.mermaid || null);
            script.onerror = () => resolve(null);
            document.head.appendChild(script);
          });

          return forumMermaidPromise;
        }

        const courseStaticMermaidRenderer = (container, attempt = 0) => {
          const nodes = Array.from(container.querySelectorAll('.mermaid'))
            .filter((node) => node instanceof HTMLElement)
            .filter((node) => !node.closest('#lesson-forum'))
            .filter(
              (node) =>
                node.dataset.mermaidRendered !== 'true' &&
                node.dataset.mermaidRendering !== 'true',
            );
          if (nodes.length === 0) return;

          ensureForumMermaid()
            .then((mermaid) => {
              if (!mermaid?.render) return;
              try {
                mermaid.initialize({
                  startOnLoad: false,
                  theme: 'default',
                  securityLevel: 'loose',
                  suppressErrorRendering: false,
                });
              } catch {}

              const tasks = nodes.map(async (node) => {
                const source = String(node.dataset.mermaidSource || node.textContent || '').trim();
                if (!source) return;
                node.dataset.mermaidSource = source;
                node.dataset.mermaidRendering = 'true';
                const renderId = `course-mermaid-${Date.now()}-${sharedMermaidRenderSequence += 1}`;
                const result = await mermaid.render(renderId, source);
                node.innerHTML = result?.svg || '';
                if (typeof result?.bindFunctions === 'function') {
                  result.bindFunctions(node);
                }
                delete node.dataset.mermaidRendering;
                node.dataset.mermaidRendered = 'true';
              });

              Promise.all(tasks).catch((error) => {
                nodes.forEach((node) => {
                  delete node.dataset.mermaidRendering;
                  delete node.dataset.mermaidRendered;
                  const source = String(node.dataset.mermaidSource || node.textContent || '').trim();
                  if (source) node.textContent = source;
                });
                if (attempt < 3) {
                  window.setTimeout(() => courseStaticMermaidRenderer(container, attempt + 1), 180 * (attempt + 1));
                } else {
                  console.error('Course mermaid render error:', error);
                }
              });
            })
            .catch((error) => {
              console.error('Course mermaid loader error:', error);
            });
        };
        (globalThis as any).__musikiCourseStaticMermaidRenderer = courseStaticMermaidRenderer;

        function renderForumMermaid(container) {
          const nodes = Array.from(container.querySelectorAll('.mermaid'));
          if (nodes.length === 0) return;

          ensureForumMermaid()
            .then((mermaid) => {
              if (!mermaid?.run) return;
              try {
                mermaid.initialize({ startOnLoad: false, theme: 'default' });
                mermaid.run({ nodes });
              } catch (error) {
                console.error('Forum mermaid render error:', error);
              }
            })
            .catch((error) => {
              console.error('Forum mermaid loader error:', error);
            });
        }

        function getSelectedThread() {
