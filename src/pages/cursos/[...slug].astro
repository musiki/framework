        }

        function moveThreadStageNodes(target) {
          if (!target) return;
          target.appendChild(postListEl);
          target.appendChild(replyForm);
        }

        function mountThreadStage() {
          moveThreadStageNodes(threadStageEl);
        }

        function mountThreadPanel(panel) {
          moveThreadStageNodes(panel);
        }

        function setThreadLoadingState() {
          postListEl.innerHTML = '<p class="forum-empty">Cargando mensajes...</p>';
        }

        function clearReplyTarget() {
          parentPostInput.value = '';
          replyTargetEl.textContent = '';
          replyTargetEl.hidden = true;
          cancelReplyBtn.hidden = true;
          replyBodyInput.placeholder = 'Responder al hilo...';
        }

        function setReplyTarget(postId, authorName) {
          parentPostInput.value = postId;
          replyTargetEl.hidden = false;
          replyTargetEl.textContent = `Responder a ${authorName || 'usuario'}`;
          cancelReplyBtn.hidden = false;
          replyBodyInput.placeholder = `Responder a ${authorName || 'usuario'}...`;
          replyBodyInput.focus();
        }

        function updateReplyFormVisibility(canReply) {
          if (!forumState.selectedThreadId || !canReply) {
            replyForm.hidden = true;
            clearReplyTarget();
            return;
          }

          replyForm.hidden = false;
        }

        function renderThreadList() {
          if (forumState.selectedThreadId && !forumState.threads.some((thread) => thread.id === forumState.selectedThreadId)) {
            forumState.selectedThreadId = '';
          }

          mountThreadStage();
          threadListEl.innerHTML = '';

          if (forumState.threads.length === 0) {
            const empty = document.createElement('p');
            empty.className = 'forum-empty';
            empty.textContent = forumState.mode === 'board'
              ? 'Todavía no hay hilos en este foro.'
              : 'Todavía no hay hilos en esta lección.';
            threadListEl.appendChild(empty);
            return;
          }

          forumState.threads.forEach((thread) => {
            const isActive = thread.id === forumState.selectedThreadId;

            const item = document.createElement('article');
            item.className = 'forum-thread-item';
            if (isActive) item.classList.add('active');

            const toggle = document.createElement('button');
            toggle.type = 'button';
            toggle.className = 'forum-thread-toggle';
            toggle.dataset.threadId = String(thread.id || '').trim();
            toggle.setAttribute('aria-expanded', isActive ? 'true' : 'false');

            const top = document.createElement('div');
            top.className = 'forum-thread-top';

            const title = document.createElement('span');
            title.className = 'forum-thread-title';
            title.textContent = thread.title;

            const messageCount = Number.isFinite(thread.messageCount)
              ? Math.max(0, Number(thread.messageCount))
              : (Number.isFinite(thread.postCount) ? Math.max(0, Number(thread.postCount)) : 0);
            const replyCount = Number.isFinite(thread.replyCount)
              ? Math.max(0, Number(thread.replyCount))
              : Math.max(messageCount - 1, 0);

            const caret = document.createElement('span');
            caret.className = 'forum-thread-caret';
            caret.textContent = isActive ? '▾' : '▸';

            const counts = document.createElement('span');
            counts.className = 'forum-thread-counts';

            const messageChip = document.createElement('span');
            messageChip.className = 'forum-thread-count forum-thread-count-messages';
            messageChip.textContent = String(messageCount);
            messageChip.dataset.tooltip = 'mensajes';
            messageChip.title = 'mensajes';
            counts.appendChild(messageChip);

            const replyChip = document.createElement('span');
            replyChip.className = 'forum-thread-count forum-thread-count-replies';
            replyChip.textContent = String(replyCount);
            replyChip.dataset.tooltip = 'respuestas';
            replyChip.title = 'respuestas';
            counts.appendChild(replyChip);

            const trailing = document.createElement('span');
            trailing.className = 'forum-thread-trailing';

            top.appendChild(title);
            top.appendChild(trailing);

            const divider = document.createElement('hr');
            divider.className = 'forum-thread-divider';

            const meta = document.createElement('div');
            meta.className = 'forum-thread-meta';
            const lastActivity = formatForumDate(thread.lastActivityAt || thread.updatedAt || thread.createdAt);
            const author = document.createElement('span');
            author.className = 'forum-thread-author';
            author.textContent = thread.createdByName || 'Usuario';
            const stats = document.createElement('span');
            stats.className = 'forum-thread-date';
            stats.textContent = lastActivity;
            meta.appendChild(author);
            meta.appendChild(stats);

            toggle.appendChild(top);
            toggle.appendChild(divider);
            toggle.appendChild(meta);
            toggle.addEventListener('click', async () => {
              const nextThreadId = forumState.selectedThreadId === thread.id ? '' : thread.id;
              forumState.selectedThreadId = nextThreadId;
              clearReplyTarget();
              clearForumThreadPrefetchTimer();

              if (nextThreadId && !getForumCachedPayload(forumQueryCache.posts, getForumPostsCacheKey(nextThreadId))) {
                setThreadLoadingState();
              }

              renderThreadList();
              if (nextThreadId) {
                await loadPosts(nextThreadId);
              } else {
                renderPosts([], false, false);
              }
            });

            const inlinePanel = document.createElement('div');
            inlinePanel.className = 'forum-thread-inline-panel';
            inlinePanel.hidden = !isActive;

            const canEditThread = Boolean(thread.canEdit);
            const canDeleteThread = Boolean(thread.canDelete);
            let threadEditButton = null;
            let threadDeleteButton = null;

            const setThreadActionState = (isDisabled) => {
              if (threadEditButton) threadEditButton.disabled = isDisabled;
              if (threadDeleteButton) threadDeleteButton.disabled = isDisabled;
            };

            const threadActions = document.createElement('div');
            threadActions.className = 'forum-thread-actions';
            threadActions.hidden = !canEditThread && !canDeleteThread;

            if (canEditThread) {
              threadEditButton = document.createElement('button');
              threadEditButton.type = 'button';
              threadEditButton.className = 'forum-thread-edit-btn forum-action-btn forum-action-e';
              threadEditButton.textContent = 'E';
              threadEditButton.dataset.tooltip = 'Editar hilo';
              threadEditButton.title = 'Editar hilo';
              threadEditButton.setAttribute('aria-label', 'Editar hilo');
              threadEditButton.addEventListener('click', async (event) => {
                event.preventDefault();
                event.stopPropagation();

                const nextTitle = window.prompt('Editar título del hilo', thread.title || '');
                if (nextTitle === null) return;

                const cleanedTitle = nextTitle.trim();
                if (cleanedTitle.length < 3) {
                  setForumStatus('El título del hilo debe tener al menos 3 caracteres.', 'error');
                  return;
                }

                setThreadActionState(true);
                try {
                  const response = await fetch(`/api/forum/threads/${encodeURIComponent(thread.id)}`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ title: cleanedTitle }),
                  });

                  const payload = await response.json().catch(() => ({}));
                  if (!response.ok) {
                    throw new Error(payload?.error || 'No se pudo editar el hilo.');
                  }

                  invalidateForumThreadCache();
                  invalidateForumPostsCache(thread.id);
                  setForumStatus('Hilo actualizado.', 'info');
                  await loadThreads({ preserveSelection: true });
                } catch (error) {
                  console.error('Forum thread edit error:', error);
                  setForumStatus(error?.message || 'No se pudo editar el hilo.', 'error');
                } finally {
                  setThreadActionState(false);
                }
              });
              threadActions.appendChild(threadEditButton);
            }

            if (canDeleteThread) {
              threadDeleteButton = document.createElement('button');
              threadDeleteButton.type = 'button';
              threadDeleteButton.className = 'forum-thread-delete-btn forum-action-btn forum-action-b';
              threadDeleteButton.textContent = 'B';
              threadDeleteButton.dataset.tooltip = 'Borrar hilo';
              threadDeleteButton.title = 'Borrar hilo';
              threadDeleteButton.setAttribute('aria-label', 'Borrar hilo');
              threadDeleteButton.addEventListener('click', async (event) => {
                event.preventDefault();
                event.stopPropagation();

                if (!confirm('¿Seguro que quieres borrar este hilo completo?')) return;

                setThreadActionState(true);
                try {
                  const response = await fetch(`/api/forum/threads/${encodeURIComponent(thread.id)}`, {
                    method: 'DELETE',
                  });

                  const payload = await response.json().catch(() => ({}));
                  if (!response.ok) {
                    throw new Error(payload?.error || 'No se pudo borrar el hilo.');
                  }

                  invalidateForumThreadCache();
                  invalidateForumPostsCache(thread.id);
                  clearReplyTarget();
                  setForumStatus('Hilo borrado.', 'info');
                  await loadThreads({ preserveSelection: true });
                } catch (error) {
                  console.error('Forum thread delete error:', error);
                  setForumStatus(error?.message || 'No se pudo borrar el hilo.', 'error');
                } finally {
                  setThreadActionState(false);
                }
              });
              threadActions.appendChild(threadDeleteButton);
            }

            trailing.appendChild(counts);
            if (!threadActions.hidden) {
              trailing.appendChild(threadActions);
            }
            trailing.appendChild(caret);

            if (isActive) {
              mountThreadPanel(inlinePanel);
            }

            item.appendChild(toggle);
            item.appendChild(inlinePanel);
            threadListEl.appendChild(item);
          });
        }

        function renderPosts(posts, canReply, canVote) {
          postListEl.innerHTML = '';
          updateReplyFormVisibility(canReply);

          if (!forumState.selectedThreadId) {
            const empty = document.createElement('p');
            empty.className = 'forum-empty';
            empty.textContent = 'Selecciona un hilo para ver los mensajes.';
            postListEl.appendChild(empty);
            return;
          }

          const visiblePosts = Array.isArray(posts)
            ? posts.filter((post) => String(post?.status || '').toLowerCase() !== 'deleted')
            : [];

          if (visiblePosts.length === 0) {
            const empty = document.createElement('p');
            empty.className = 'forum-empty';
            empty.textContent = 'Este hilo todavía no tiene mensajes.';
            postListEl.appendChild(empty);
            return;
          }

          const renderedThreadId = String(forumState.selectedThreadId || '').trim();
          const postsById = new Map(visiblePosts.map((post) => [post.id, post]));
          const childrenByParent = new Map();

          visiblePosts.forEach((post) => {
            const parentKey = post.parentPostId && postsById.has(post.parentPostId) ? post.parentPostId : 'root';
            if (!childrenByParent.has(parentKey)) childrenByParent.set(parentKey, []);
            childrenByParent.get(parentKey).push(post);
          });

          const fragment = document.createDocumentFragment();
          const rootPosts = childrenByParent.get('root') || [];
          const opPostId = rootPosts[0]?.id || visiblePosts[0]?.id || '';

          const appendChildren = (parentId, depth) => {
            const children = childrenByParent.get(parentId) || [];
            children.forEach((post) => {
              const card = document.createElement('article');
              card.className = 'forum-post';
              if (depth > 0) {
                card.classList.add('forum-post-reply');
                card.style.marginLeft = `${Math.min(depth, 2) * 0.72}rem`;
              }
              if (post.id === opPostId) {
                card.classList.add('forum-post-op');
              }
              const normalizedRole = String(post.authorRole || '').trim().toLowerCase();
              if (normalizedRole === 'teacher') {
                card.classList.add('forum-post-role-instructor');
              } else if (normalizedRole === 'student') {
                card.classList.add('forum-post-role-student');
              }

              const identity = document.createElement('aside');
              identity.className = 'forum-post-identity';

              const authorName = post.authorName || 'Usuario';
              const avatar = createForumAvatar(authorName, post.authorImage);
              identity.appendChild(avatar);

              const author = document.createElement('span');
              author.className = 'forum-post-name';
              author.textContent = authorName;
              identity.appendChild(author);

              const main = document.createElement('div');
              main.className = 'forum-post-main';

              const header = document.createElement('div');
              header.className = 'forum-post-header';

              const date = document.createElement('span');
              date.className = 'forum-post-date';
              const createdLabel = formatForumDate(post.createdAt);
              if (isForumPostEdited(post)) {
                date.textContent = `${createdLabel} • editado ${formatForumDate(post.updatedAt)}`;
              } else {
                date.textContent = createdLabel;
              }

              header.appendChild(date);
              main.appendChild(header);

              const body = document.createElement('div');
              body.className = 'forum-post-body';
              setForumBodyContent(body, post);
              main.appendChild(body);

              const canEditPost = Boolean(post.canEdit);
              const canDeletePost = Boolean(post.canDelete);
              const canVotePost = Boolean(canVote);
              if (canReply || canEditPost || canDeletePost || canVotePost) {
                const actions = document.createElement('div');
                actions.className = 'forum-post-actions';

                let replyButton = null;
                let reactionButtons = [];
                if (canReply) {
                  replyButton = document.createElement('button');
                  replyButton.type = 'button';
                  replyButton.className = 'forum-post-reply-btn forum-action-btn forum-action-r';
                  replyButton.textContent = 'R';
                  replyButton.dataset.tooltip = 'Responder';
                  replyButton.title = 'Responder';
                  replyButton.setAttribute('aria-label', 'Responder');
                  replyButton.addEventListener('click', () => {
                    setReplyTarget(post.id, post.authorName || 'usuario');
                  });
                  actions.appendChild(replyButton);
                }

                if (canVotePost) {
                  const reactionGroup = document.createElement('div');
                  reactionGroup.className = 'forum-post-reactions';

                  const reactionDefs = [
                    { value: 1, key: 'useful', icon: '👍', label: 'Útil', className: 'forum-post-reaction-useful' },
                    { value: 2, key: 'clarifies', icon: '💡', label: 'Aclara', className: 'forum-post-reaction-clarifies' },
                    { value: 3, key: 'reference', icon: '📎', label: 'Referencia valiosa', className: 'forum-post-reaction-reference' },
                  ];

                  const initialCounts = (post && typeof post.reactionCounts === 'object' && post.reactionCounts)
                    ? post.reactionCounts
                    : null;
                  const reactionCounts = {
                    useful: Math.max(0, Number(initialCounts?.useful) || 0),
                    clarifies: Math.max(0, Number(initialCounts?.clarifies) || 0),
                    reference: Math.max(0, Number(initialCounts?.reference) || 0),
                  };

                  let currentMyReaction = Number(post?.myReaction ?? post?.myVote ?? 0);
                  if (currentMyReaction !== 1 && currentMyReaction !== 2 && currentMyReaction !== 3) {
                    currentMyReaction = 0;
                  }

                  const reactionCountEls = {};
                  const buttonByReactionValue = new Map();

                  const applyReactionState = () => {
                    reactionDefs.forEach((def) => {
                      const button = buttonByReactionValue.get(def.value);
                      if (!button) return;

                      const isActive = currentMyReaction === def.value;
                      button.classList.toggle('is-active', isActive);
                      button.setAttribute('aria-pressed', isActive ? 'true' : 'false');

                      const countEl = reactionCountEls[def.key];
                      if (countEl) {
                        countEl.textContent = String(Math.max(0, Number(reactionCounts[def.key]) || 0));
                      }
                    });
                  };

                  const submitReaction = async (nextReaction) => {
                    if (!canVotePost) return;

                    reactionButtons.forEach((button) => {
                      button.disabled = true;
                    });

                    try {
                      const response = await fetch(`/api/forum/posts/${encodeURIComponent(post.id)}/vote`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ value: nextReaction }),
                      });
                      const payload = await response.json().catch(() => ({}));
                      if (!response.ok) {
                        throw new Error(payload?.error || 'No se pudo registrar la reacción.');
                      }

                      const payloadCounts = payload?.reactionCounts;
                      if (payloadCounts && typeof payloadCounts === 'object') {
                        reactionCounts.useful = Math.max(0, Number(payloadCounts.useful) || 0);
                        reactionCounts.clarifies = Math.max(0, Number(payloadCounts.clarifies) || 0);
                        reactionCounts.reference = Math.max(0, Number(payloadCounts.reference) || 0);
                      }

                      const nextMyReaction = Number(payload?.myReaction ?? payload?.myVote ?? 0);
                      if (nextMyReaction === 1 || nextMyReaction === 2 || nextMyReaction === 3) {
                        currentMyReaction = nextMyReaction;
                      } else {
                        currentMyReaction = 0;
                      }

                      invalidateForumPostsCache(renderedThreadId);
                      applyReactionState();
                    } catch (error) {
                      console.error('Forum reaction error:', error);
                      setForumStatus(error?.message || 'No se pudo registrar la reacción.', 'error');
                    } finally {
                      reactionButtons.forEach((button) => {
                        button.disabled = false;
                      });
                    }
                  };

                  reactionDefs.forEach((def) => {
                    const reactionItem = document.createElement('div');
                    reactionItem.className = 'forum-post-reaction-item';

                    const reactionButton = document.createElement('button');
                    reactionButton.type = 'button';
                    reactionButton.className = `forum-post-reaction-btn forum-action-btn ${def.className}`;
                    reactionButton.textContent = def.icon;
                    reactionButton.dataset.tooltip = def.label;
                    reactionButton.title = def.label;
                    reactionButton.setAttribute('aria-label', def.label);
                    reactionButton.setAttribute('aria-pressed', 'false');
                    reactionButton.addEventListener('click', () => {
                      submitReaction(currentMyReaction === def.value ? 0 : def.value);
                    });

                    const countEl = document.createElement('span');
                    countEl.className = 'forum-post-reaction-count';
                    reactionCountEls[def.key] = countEl;

                    buttonByReactionValue.set(def.value, reactionButton);
                    reactionButtons.push(reactionButton);

                    reactionItem.appendChild(reactionButton);
                    reactionItem.appendChild(countEl);
                    reactionGroup.appendChild(reactionItem);
                  });

                  applyReactionState();
                  actions.appendChild(reactionGroup);
                }

                let editButton = null;
                let deleteButton = null;
                let editContainer = null;
                let editTextarea = null;
                let saveEditButton = null;
                let cancelEditButton = null;

                function setEditMode(isEditing) {
                  if (!editContainer || !editTextarea || !editButton) return;
                  editContainer.hidden = !isEditing;
                  body.hidden = isEditing;
                  editButton.hidden = isEditing;
                  if (replyButton) replyButton.disabled = isEditing;
                  reactionButtons.forEach((button) => {
                    button.disabled = isEditing;
                  });
                  if (deleteButton) deleteButton.disabled = isEditing;

                  if (isEditing) {
                    editTextarea.value = post.body || '';
                    editTextarea.focus();
                    editTextarea.setSelectionRange(editTextarea.value.length, editTextarea.value.length);
                  }
                }

                if (canEditPost) {
                  editButton = document.createElement('button');
                  editButton.type = 'button';
                  editButton.className = 'forum-post-edit-btn forum-action-btn forum-action-e';
                  editButton.textContent = 'E';
                  editButton.dataset.tooltip = 'Editar';
                  editButton.title = 'Editar';
                  editButton.setAttribute('aria-label', 'Editar');
                  editButton.addEventListener('click', () => {
                    setEditMode(true);
                  });
                  actions.appendChild(editButton);

                  editContainer = document.createElement('div');
                  editContainer.className = 'forum-edit-form';
                  editContainer.hidden = true;

                  editTextarea = document.createElement('textarea');
                  editTextarea.className = 'forum-textarea forum-edit-textarea';
                  editTextarea.maxLength = 4000;
                  editTextarea.placeholder = 'Edita tu mensaje...';
                  editTextarea.addEventListener('keydown', (event) => {
                    if (event.key !== 'Enter') return;
                    if (!(event.metaKey || event.ctrlKey)) return;
                    event.preventDefault();
                    if (saveEditButton) saveEditButton.click();
                  });
                  editContainer.appendChild(editTextarea);

                  const editActions = document.createElement('div');
                  editActions.className = 'forum-form-actions';

                  saveEditButton = document.createElement('button');
                  saveEditButton.type = 'button';
                  saveEditButton.className = 'forum-secondary-btn';
                  saveEditButton.textContent = 'Guardar';
                  saveEditButton.addEventListener('click', async () => {
                    if (!editTextarea) return;

                    const nextBody = editTextarea.value.trim();
                    if (!nextBody) {
                      setForumStatus('El mensaje no puede quedar vacío.', 'error');
                      return;
                    }

                    if (saveEditButton) saveEditButton.disabled = true;
                    if (cancelEditButton) cancelEditButton.disabled = true;

                    try {
                      const response = await fetch(`/api/forum/posts/${encodeURIComponent(post.id)}?renderContext=course`, {
                        method: 'PATCH',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                          body: nextBody,
                        }),
                      });

                      const payload = await response.json().catch(() => ({}));
                      if (!response.ok) {
                        throw new Error(payload?.error || 'No se pudo editar el mensaje.');
                      }

                      invalidateForumPostsCache(renderedThreadId);
                      invalidateForumThreadCache();
                      setForumStatus('Mensaje actualizado.', 'info');
                      await loadPosts(renderedThreadId);
                    } catch (error) {
                      console.error('Forum post edit error:', error);
                      setForumStatus(error?.message || 'No se pudo editar el mensaje.', 'error');
                    } finally {
                      if (saveEditButton) saveEditButton.disabled = false;
                      if (cancelEditButton) cancelEditButton.disabled = false;
                    }
                  });
                  editActions.appendChild(saveEditButton);

                  cancelEditButton = document.createElement('button');
                  cancelEditButton.type = 'button';
                  cancelEditButton.className = 'forum-secondary-btn';
                  cancelEditButton.textContent = 'Cancelar';
                  cancelEditButton.addEventListener('click', () => {
                    setEditMode(false);
                  });
                  editActions.appendChild(cancelEditButton);

                  editContainer.appendChild(editActions);
                  attachForumEditor(editTextarea, editActions);
                }

                if (canDeletePost) {
                  deleteButton = document.createElement('button');
                  deleteButton.type = 'button';
                  deleteButton.className = 'forum-post-delete-btn forum-action-btn forum-action-b';
                  deleteButton.textContent = 'B';
                  deleteButton.dataset.tooltip = 'Borrar';
                  deleteButton.title = 'Borrar';
                  deleteButton.setAttribute('aria-label', 'Borrar');
                  deleteButton.addEventListener('click', async () => {
                    if (!confirm('¿Seguro que quieres borrar este mensaje?')) return;

                    if (deleteButton) deleteButton.disabled = true;
                    if (editButton) editButton.disabled = true;
                    if (replyButton) replyButton.disabled = true;

                    try {
                      const response = await fetch(`/api/forum/posts/${encodeURIComponent(post.id)}`, {
                        method: 'DELETE',
                      });

                      const payload = await response.json().catch(() => ({}));
                      if (!response.ok) {
                        throw new Error(payload?.error || 'No se pudo borrar el mensaje.');
                      }

                      invalidateForumPostsCache(renderedThreadId);
                      invalidateForumThreadCache();
                      setForumStatus('Mensaje borrado.', 'info');
                      await loadThreads({ preserveSelection: true });
                    } catch (error) {
                      console.error('Forum post delete error:', error);
                      setForumStatus(error?.message || 'No se pudo borrar el mensaje.', 'error');
                    } finally {
                      if (deleteButton) deleteButton.disabled = false;
                      if (editButton) editButton.disabled = false;
                      if (replyButton) replyButton.disabled = false;
                    }
                  });
                  actions.appendChild(deleteButton);
                }

                main.appendChild(actions);

                if (editContainer) {
                  main.appendChild(editContainer);
                }
              }

              card.appendChild(identity);
              card.appendChild(main);
              fragment.appendChild(card);
              appendChildren(post.id, depth + 1);
            });
          };

          appendChildren('root', 0);
          postListEl.appendChild(fragment);
          renderForumMermaid(postListEl);
        }

        async function loadPosts(threadId) {
          if (!threadId) {
            renderPosts([], false, false);
            return;
          }

          const requestToken = ++latestPostRequestToken;
          const cacheKey = getForumPostsCacheKey(threadId);
          const cachedPayload = getForumCachedPayload(forumQueryCache.posts, cacheKey);
          const applyPayloadIfCurrent = (payload) => {
            if (requestToken !== latestPostRequestToken) return;
            if (String(forumState.selectedThreadId || '').trim() !== String(threadId || '').trim()) return;
            applyForumPostsPayload(payload);
          };

          if (cachedPayload) {
            applyPayloadIfCurrent(cachedPayload);

            if (!isForumCacheFresh(forumQueryCache.posts, cacheKey, FORUM_POST_CACHE_TTL_MS)) {
              void requestForumCachedPayload(
                forumQueryCache.posts,
                cacheKey,
                () => fetchForumPostsFromNetwork(threadId),
              )
                .then((payload) => {
                  applyPayloadIfCurrent(payload);
                })
                .catch((error) => {
                  console.error('Forum load posts background error:', error);
                });
            }

            return cachedPayload;
          }

          setThreadLoadingState();

          try {
            const payload = await requestForumCachedPayload(
              forumQueryCache.posts,
              cacheKey,
              () => fetchForumPostsFromNetwork(threadId),
            );

            applyPayloadIfCurrent(payload);
            return payload;
          } catch (error) {
            console.error('Forum load posts error:', error);
            if (requestToken === latestPostRequestToken) {
              renderPosts([], false, false);
              setForumStatus(error?.message || 'No se pudieron cargar los mensajes del hilo.', 'error');
            }
            return null;
          }
        }

        async function fetchForumBoards({ forceNetwork = false, silent = false } = {}) {
          const cacheKey = getForumBoardsCacheKey();
          if (!cacheKey) return null;

          const cachedPayload = !forceNetwork
            ? getForumCachedPayload(forumQueryCache.boards, cacheKey)
            : null;

          if (cachedPayload && isForumCacheFresh(forumQueryCache.boards, cacheKey, FORUM_BOARD_CACHE_TTL_MS)) {
            applyForumBoardsPayload(cachedPayload);
            return cachedPayload;
          }

          try {
            const payload = await requestForumCachedPayload(
              forumQueryCache.boards,
              cacheKey,
              () => fetchForumBoardsFromNetwork(),
            );
            applyForumBoardsPayload(payload);
            return payload;
          } catch (error) {
            if (cachedPayload) {
              applyForumBoardsPayload(cachedPayload);
              if (!silent) {
                console.error('Forum board refresh error:', error);
              }
              return cachedPayload;
            }
            throw error;
          }
        }

        async function loadBoards({ preferredSlug = '', syncHistory = true } = {}) {
          if (forumState.mode !== 'board') return;

          await fetchForumBoards();

          const slugs = forumState.boards
            .map((board) => normalizeForumBoardSlug(board?.slug))
            .filter(Boolean);
          const targetSlug = normalizeForumBoardSlug(preferredSlug || forumState.boardSlug);
          if (targetSlug && slugs.includes(targetSlug)) {
            forumState.boardSlug = targetSlug;
          } else {
            forumState.boardSlug = slugs[0] || '';
          }

          if (syncHistory) {
            syncBoardQueryParam();
          }
          await refreshCourseForumSubnav({
            preferredBoardSlug: forumState.boardSlug,
            boards: forumState.boards,
            activeMode: 'board',
          });
        }

        async function loadThreads({ preserveSelection = true } = {}) {
          const scope = resolveForumScopeDescriptor();
          const cacheKey = getForumScopeCacheKey(scope);
          const requestToken = ++latestThreadRequestToken;
          const cachedPayload = getForumCachedPayload(forumQueryCache.threads, cacheKey);

          const applyPayloadIfCurrent = async (payload) => {
            if (requestToken !== latestThreadRequestToken) return;
            if (!isForumScopeCurrent(scope)) return;

            const selectedThreadId = applyForumThreadsPayload(payload, { preserveSelection });
            syncCourseForumSubnavScopeMetrics(scope, payload?.threads || []);

            if (selectedThreadId) {
              await loadPosts(selectedThreadId);
            } else {
              renderPosts([], false, false);
            }

            if (!forumState.canWrite) {
              setForumStatus('Puedes leer este foro, pero necesitas inscripción para publicar.', 'info');
            } else {
              setForumStatus('');
            }

            markForumScopeAsRead();
          };

          if (cachedPayload) {
            await applyPayloadIfCurrent(cachedPayload);

            if (!isForumCacheFresh(forumQueryCache.threads, cacheKey, FORUM_THREAD_CACHE_TTL_MS)) {
              void requestForumCachedPayload(
                forumQueryCache.threads,
                cacheKey,
                () => fetchForumThreadsFromNetwork(scope),
              )
                .then((payload) => {
                  void applyPayloadIfCurrent(payload);
                  const firstThreadId = String(payload?.threads?.[0]?.id || '').trim();
                  if (firstThreadId) {
                    void prefetchForumPosts(firstThreadId);
                  }
                })
                .catch((error) => {
                  console.error('Forum load threads background error:', error);
                });
            }

            return cachedPayload;
          }

          setThreadListLoadingState();
          renderPosts([], false, false);

          try {
            const payload = await requestForumCachedPayload(
              forumQueryCache.threads,
              cacheKey,
              () => fetchForumThreadsFromNetwork(scope),
            );

            await applyPayloadIfCurrent(payload);

            const firstThreadId = String(payload?.threads?.[0]?.id || '').trim();
            if (firstThreadId) {
              void prefetchForumPosts(firstThreadId);
            }

            return payload;
          } catch (error) {
            console.error('Forum load threads error:', error);
            if (requestToken === latestThreadRequestToken) {
              forumState.threads = [];
              forumState.selectedThreadId = '';
              forumState.canWrite = false;
              newThreadForm.hidden = true;
              if (newThreadContainer) newThreadContainer.hidden = true;
              renderThreadList();
              renderPosts([], false, false);
              setForumStatus(error?.message || 'No se pudieron cargar los hilos del foro.', 'error');
            }
            return null;
          }
        }

        async function applyForumScope(nextMode, { boardSlug = '', pushHistory = false } = {}) {
          const normalizedMode = nextMode === 'lesson' ? 'lesson' : 'board';
          if (normalizedMode === 'lesson' && (!forumState.isLessonPage || !forumState.lessonSlug)) {
            return;
          }

          setNewBoardPanelOpen(false);
          closeForumBoardContextMenu();
          forumState.mode = normalizedMode;
          if (normalizedMode === 'board') {
            forumState.boardSlug = normalizeForumBoardSlug(boardSlug || forumState.boardSlug || 'general');
            await loadBoards({ preferredSlug: forumState.boardSlug, syncHistory: false });
          } else {
            await refreshCourseForumSubnav({
              preferredBoardSlug: forumState.boardSlug,
              boards: forumState.boards,
              activeMode: 'lesson',
            });
          }

          forumState.selectedThreadId = '';
          syncBoardQueryParam(pushHistory ? 'push' : 'replace', {
            anchorForum: pushHistory,
          });
          await loadThreads({ preserveSelection: false });
        }

        if (newBoardToggle instanceof HTMLButtonElement) {
          newBoardToggle.addEventListener('click', () => {
            const shouldOpen = !(newBoardPanel instanceof HTMLElement) || newBoardPanel.hidden;
            setNewBoardPanelOpen(shouldOpen);
          });
        }

        if (newBoardForm && boardTitleInput) {
          newBoardForm.addEventListener('submit', async (event) => {
            event.preventDefault();
            if (!forumState.canManageBoards) return;

            const title = boardTitleInput.value.trim();
            if (title.length < 3) {
              setForumStatus('El nombre del foro alternativo debe tener al menos 3 caracteres.', 'error');
              return;
            }

            const submitButton = newBoardForm.querySelector('button[type="submit"]');
            if (submitButton) submitButton.disabled = true;

            try {
              const response = await fetch('/api/forum/boards', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  courseId: forumState.courseId,
                  title,
                  description: '',
                }),
              });

              const payload = await response.json().catch(() => ({}));
              if (!response.ok) {
                throw new Error(payload?.error || 'No se pudo crear el foro alternativo.');
              }

              boardTitleInput.value = '';
              setNewBoardPanelOpen(false);

              const newSlug = payload?.board?.slug || '';
              invalidateForumBoardsCache();
              await loadBoards({ preferredSlug: newSlug });
              await loadThreads({ preserveSelection: false });
              setForumStatus('Foro alternativo creado.', 'info');
            } catch (error) {
              console.error('Forum create board error:', error);
              setForumStatus(error?.message || 'No se pudo crear el foro alternativo.', 'error');
            } finally {
              if (submitButton) submitButton.disabled = false;
            }
          });
        }

        function bindSubmitShortcut(input, form) {
          if (!input || !form) return;
          input.addEventListener('keydown', (event) => {
            if (event.key !== 'Enter') return;
            if (!(event.metaKey || event.ctrlKey)) return;
            event.preventDefault();
            form.requestSubmit();
          });
        }

        attachForumEditor(threadBodyInput);
        attachForumEditor(replyBodyInput);

        bindSubmitShortcut(threadBodyInput, newThreadForm);
        bindSubmitShortcut(replyBodyInput, replyForm);
        refreshCourseForumUnreadIndicators();

        const forumSubnavEl = document.getElementById('course-forum-subnav');
        if (forumSubnavEl instanceof HTMLElement && forumSubnavEl.dataset.bound !== 'true') {
          forumSubnavEl.dataset.bound = 'true';
          forumSubnavEl.addEventListener('pointerover', (event) => {
            const anchor = event.target instanceof Element
              ? event.target.closest('a.forum-subforum-link')
              : null;
            if (!(anchor instanceof HTMLAnchorElement)) return;
            if (event.relatedTarget instanceof Node && anchor.contains(event.relatedTarget)) return;

            const targetScope = String(anchor.dataset.boardSlug || '').trim().toLowerCase();
            if (!targetScope) return;

            if (targetScope === 'lesson') {
              scheduleForumScopePrefetch('lesson');
              return;
            }

            scheduleForumScopePrefetch('board', { boardSlug: targetScope });
          });
          forumSubnavEl.addEventListener('pointerout', (event) => {
            const anchor = event.target instanceof Element
              ? event.target.closest('a.forum-subforum-link')
              : null;
            if (!(anchor instanceof HTMLAnchorElement)) return;
            if (event.relatedTarget instanceof Node && anchor.contains(event.relatedTarget)) return;
            clearForumScopePrefetchTimer();
          });
          forumSubnavEl.addEventListener('focusin', (event) => {
            const anchor = event.target instanceof Element
              ? event.target.closest('a.forum-subforum-link')
              : null;
            if (!(anchor instanceof HTMLAnchorElement)) return;

            const targetScope = String(anchor.dataset.boardSlug || '').trim().toLowerCase();
            if (!targetScope) return;

            if (targetScope === 'lesson') {
              scheduleForumScopePrefetch('lesson');
              return;
            }

            scheduleForumScopePrefetch('board', { boardSlug: targetScope });
          });
          forumSubnavEl.addEventListener('click', (event) => {
            const anchor = event.target instanceof Element
              ? event.target.closest('a.forum-subforum-link')
              : null;
            if (!(anchor instanceof HTMLAnchorElement)) return;
            clearForumScopePrefetchTimer();

            const targetScope = String(anchor.dataset.boardSlug || '').trim().toLowerCase();
            if (!targetScope) return;

            if ((event.altKey || event.shiftKey) && anchor.classList.contains('forum-switcher-link--board') && isManageableForumBoard(targetScope)) {
              event.preventDefault();
              openForumBoardContextMenu(targetScope, event.clientX, event.clientY);
              return;
            }

            if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;

            event.preventDefault();
            closeForumBoardContextMenu();
            if (targetScope === 'lesson') {
              void applyForumScope('lesson', { pushHistory: true });
              return;
            }

            void applyForumScope('board', {
              boardSlug: targetScope,
              pushHistory: true,
            });
          });

          forumSubnavEl.addEventListener('contextmenu', (event) => {
            const anchor = event.target instanceof Element
              ? event.target.closest('a.forum-subforum-link')
              : null;
            if (!(anchor instanceof HTMLAnchorElement)) return;
            clearForumScopePrefetchTimer();

            const targetScope = String(anchor.dataset.boardSlug || '').trim().toLowerCase();
            if (!targetScope || !anchor.classList.contains('forum-switcher-link--board') || !isManageableForumBoard(targetScope)) {
              return;
            }

            event.preventDefault();
            openForumBoardContextMenu(targetScope, event.clientX, event.clientY);
          });
        }

        if (threadListEl instanceof HTMLElement && threadListEl.dataset.prefetchBound !== 'true') {
          threadListEl.dataset.prefetchBound = 'true';
          threadListEl.addEventListener('pointerover', (event) => {
            const toggle = event.target instanceof Element
              ? event.target.closest('button.forum-thread-toggle')
              : null;
            if (!(toggle instanceof HTMLButtonElement)) return;
            if (event.relatedTarget instanceof Node && toggle.contains(event.relatedTarget)) return;
            scheduleForumThreadPrefetch(toggle.dataset.threadId || '');
          });
          threadListEl.addEventListener('pointerout', (event) => {
            const toggle = event.target instanceof Element
              ? event.target.closest('button.forum-thread-toggle')
              : null;
            if (!(toggle instanceof HTMLButtonElement)) return;
            if (event.relatedTarget instanceof Node && toggle.contains(event.relatedTarget)) return;
            clearForumThreadPrefetchTimer();
          });
          threadListEl.addEventListener('focusin', (event) => {
            const toggle = event.target instanceof Element
              ? event.target.closest('button.forum-thread-toggle')
              : null;
            if (!(toggle instanceof HTMLButtonElement)) return;
            scheduleForumThreadPrefetch(toggle.dataset.threadId || '');
          });
        }

        if (boardRenameAction instanceof HTMLButtonElement && boardRenameAction.dataset.bound !== 'true') {
          boardRenameAction.dataset.bound = 'true';
          boardRenameAction.addEventListener('click', async () => {
            const boardSlug = boardContextMenu instanceof HTMLElement
              ? normalizeForumBoardSlug(boardContextMenu.dataset.boardSlug || '')
              : '';
            closeForumBoardContextMenu();
            if (!boardSlug) return;
            await renameForumBoard(boardSlug);
          });
        }

        if (boardDeleteAction instanceof HTMLButtonElement && boardDeleteAction.dataset.bound !== 'true') {
          boardDeleteAction.dataset.bound = 'true';
          boardDeleteAction.addEventListener('click', async () => {
            const boardSlug = boardContextMenu instanceof HTMLElement
              ? normalizeForumBoardSlug(boardContextMenu.dataset.boardSlug || '')
              : '';
            closeForumBoardContextMenu();
            if (!boardSlug) return;
            await deleteForumBoard(boardSlug);
          });
        }

        if (document.body.dataset.lessonForumBoardMenuBound !== 'true') {
          document.body.dataset.lessonForumBoardMenuBound = 'true';
          document.addEventListener('click', (event) => {
            if (!(boardContextMenu instanceof HTMLElement) || boardContextMenu.hidden) return;
            if (event.target instanceof Node && boardContextMenu.contains(event.target)) return;
            closeForumBoardContextMenu();
          });
          document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape') {
              closeForumBoardContextMenu();
            }
          });
          window.addEventListener('resize', () => {
            closeForumBoardContextMenu();
          });
        }

        const forumSidebarScroller = forumRoot.closest('.sidebar');
        if (forumSidebarScroller instanceof HTMLElement && forumSidebarScroller.dataset.boardMenuScrollBound !== 'true') {
          forumSidebarScroller.dataset.boardMenuScrollBound = 'true';
          forumSidebarScroller.addEventListener('scroll', () => {
            closeForumBoardContextMenu();
          }, { passive: true });
        }

        if (postListEl instanceof HTMLElement && postListEl.dataset.mediaPreviewBound !== 'true') {
          postListEl.dataset.mediaPreviewBound = 'true';
          postListEl.addEventListener('dblclick', (event) => {
            const payload = extractForumMediaTarget(event.target);
            if (!payload) return;
            event.preventDefault();
            openForumMediaModal(payload);
          });
        }

        if (mediaModalCloseBtn instanceof HTMLButtonElement && mediaModalCloseBtn.dataset.bound !== 'true') {
          mediaModalCloseBtn.dataset.bound = 'true';
          mediaModalCloseBtn.addEventListener('click', closeForumMediaModal);
        }

        if (mediaModalEl instanceof HTMLElement && mediaModalEl.dataset.bound !== 'true') {
          mediaModalEl.dataset.bound = 'true';
          mediaModalEl.addEventListener('click', (event) => {
            if (event.target === mediaModalEl) {
              closeForumMediaModal();
            }
          });
        }

        if (document.body.dataset.lessonForumMediaEscapeBound !== 'true') {
          document.body.dataset.lessonForumMediaEscapeBound = 'true';
          document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape' && mediaModalEl instanceof HTMLElement && !mediaModalEl.hidden) {
              closeForumMediaModal();
            }
          });
        }

        if (window.__musikiForumPopstateBound !== true) {
          window.__musikiForumPopstateBound = true;
          window.addEventListener('popstate', () => {
            const boardParam = String(new URL(window.location.href).searchParams.get('board') || '').trim();
            if (forumState.isLessonPage && !boardParam) {
              void applyForumScope('lesson');
              return;
            }
            void applyForumScope('board', {
              boardSlug: normalizeForumBoardSlug(boardParam || 'general'),
            });
          });
        }

        newThreadForm.addEventListener('submit', async (event) => {
          event.preventDefault();
          if (!forumState.canWrite) return;

          const title = threadTitleInput.value.trim();
          const body = threadBodyInput.value.trim();

          if (title.length < 3) {
            setForumStatus('El título debe tener al menos 3 caracteres.', 'error');
            return;
          }

          if (!body) {
            setForumStatus('Escribe el primer mensaje del hilo.', 'error');
            return;
          }

          const submitButton = newThreadForm.querySelector('button[type="submit"]');
          if (submitButton) submitButton.disabled = true;

          try {
            const response = await fetch('/api/forum/threads', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                courseId: forumState.courseId,
                ...getForumScopePayload(),
                title,
                body,
              }),
            });

            const payload = await response.json().catch(() => ({}));
            if (!response.ok) {
              throw new Error(payload?.error || 'No se pudo crear el hilo.');
            }

            threadTitleInput.value = '';
            threadBodyInput.value = '';
            if (newThreadContainer instanceof HTMLDetailsElement) {
              newThreadContainer.open = false;
            }
            invalidateForumThreadCache();
            setForumStatus('Hilo publicado.', 'info');

            await loadThreads({ preserveSelection: false });
          } catch (error) {
            console.error('Forum create thread error:', error);
            setForumStatus(error?.message || 'No se pudo crear el hilo.', 'error');
          } finally {
            if (submitButton) submitButton.disabled = false;
          }
        });

        cancelReplyBtn.addEventListener('click', () => {
          clearReplyTarget();
        });

        replyForm.addEventListener('submit', async (event) => {
          event.preventDefault();

          if (!forumState.selectedThreadId) return;

          const replyBody = replyBodyInput.value.trim();
          if (!replyBody) {
            setForumStatus('Escribe una respuesta antes de publicar.', 'error');
            return;
          }

          const submitButton = replyForm.querySelector('button[type="submit"]');
          if (submitButton) submitButton.disabled = true;

          try {
            const response = await fetch(
              `/api/forum/threads/${encodeURIComponent(forumState.selectedThreadId)}/posts?renderContext=course`,
              {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  body: replyBody,
                  parentPostId: parentPostInput.value || null,
                }),
              },
            );

            const payload = await response.json().catch(() => ({}));
            if (!response.ok) {
              throw new Error(payload?.error || 'No se pudo publicar la respuesta.');
            }

            replyBodyInput.value = '';
            clearReplyTarget();
            invalidateForumThreadCache();
            invalidateForumPostsCache(forumState.selectedThreadId);
            setForumStatus('Respuesta publicada.', 'info');
            await loadThreads({ preserveSelection: true });
          } catch (error) {
            console.error('Forum create post error:', error);
            setForumStatus(error?.message || 'No se pudo publicar la respuesta.', 'error');
          } finally {
            if (submitButton) submitButton.disabled = false;
          }
        });

        try {
          await fetchForumBoards();
          await refreshCourseForumSubnav({
            preferredBoardSlug: forumState.boardSlug,
            boards: forumState.boards,
            activeMode: forumState.mode,
          });
        } catch (error) {
          setForumStatus(error?.message || 'No se pudo cargar la lista de foros del curso.', 'error');
          if (newThreadForm) newThreadForm.hidden = true;
          if (newThreadContainer) newThreadContainer.hidden = true;
          return;
        }

        if (forumState.mode === 'board') {
          const slugs = forumState.boards
            .map((board) => normalizeForumBoardSlug(board?.slug))
            .filter(Boolean);
          const preferredBoardSlug = normalizeForumBoardSlug(forumState.boardSlug || 'general');
          forumState.boardSlug = slugs.includes(preferredBoardSlug)
            ? preferredBoardSlug
            : (slugs[0] || 'general');
          syncBoardQueryParam();
          await refreshCourseForumSubnav({
            preferredBoardSlug: forumState.boardSlug,
            boards: forumState.boards,
            activeMode: 'board',
          });
        } else {
          syncBoardQueryParam();
        }

        if (forumState.isLessonPage && forumState.lessonSlug && forumState.mode !== 'lesson') {
          void prefetchForumScope('lesson', { lessonSlug: forumState.lessonSlug });
        }

        await loadThreads({ preserveSelection: false });
      }

      const LEGACY_OBSIDIAN_AUDIO_REGEX = /\.(mp3|wav|ogg|m4a|aac|flac)$/i;
      const legacyAudioResolveCache = new Map();

      function getLegacyAudioNameFromAnchor(anchor) {
        if (!anchor) return '';

        const text = (anchor.textContent || '').trim();
        if (LEGACY_OBSIDIAN_AUDIO_REGEX.test(text)) {
          return text;
        }

        const hrefAttr = anchor.getAttribute('href') || '';
        if (!hrefAttr) return '';

        try {
          const parsed = new URL(hrefAttr, window.location.origin);
          const rawPath = decodeURIComponent(parsed.pathname || '');
          const basename = rawPath.split('/').filter(Boolean).pop() || '';
          if (LEGACY_OBSIDIAN_AUDIO_REGEX.test(basename)) {
            return basename;
          }
        } catch {
          const fallbackBase = decodeURIComponent(hrefAttr).split('/').filter(Boolean).pop() || '';
          if (LEGACY_OBSIDIAN_AUDIO_REGEX.test(fallbackBase)) {
            return fallbackBase;
          }
        }

        return '';
      }

      async function resolveLegacyAudioName(name) {
        const key = String(name || '').trim();
        if (!key) return '';
        if (legacyAudioResolveCache.has(key)) return legacyAudioResolveCache.get(key);

        try {
          const response = await fetch(`/api/content-media/resolve?name=${encodeURIComponent(key)}`);
          const payload = await response.json().catch(() => ({}));
          const resolved = response.ok && typeof payload?.url === 'string' ? payload.url : '';
          legacyAudioResolveCache.set(key, resolved);
          return resolved;
        } catch (error) {
          console.error('Legacy audio resolve error:', error);
          legacyAudioResolveCache.set(key, '');
          return '';
        }
      }

      async function upgradeLegacyObsidianAudioLinks() {
        const contentArea = document.querySelector('.content-area');
        if (!contentArea) return;

        const anchors = Array.from(contentArea.querySelectorAll('a'));
        if (!anchors.length) return;

        for (const anchor of anchors) {
          if (anchor.closest('#lesson-forum')) continue;
          if (anchor.dataset.audioUpgraded === 'true') continue;

          const audioName = getLegacyAudioNameFromAnchor(anchor);
          if (!audioName) continue;

          const resolvedUrl = await resolveLegacyAudioName(audioName);
          if (!resolvedUrl) continue;

          const audio = document.createElement('audio');
          audio.className = 'obsidian-audio-embed obsidian-media-embed';
          audio.controls = true;
          audio.preload = 'metadata';
          audio.src = resolvedUrl;

          anchor.dataset.audioUpgraded = 'true';
          anchor.replaceWith(audio);
        }
      }

      function reportLessonForumBootError(error) {
        console.error('Lesson forum boot error:', error);

        const statusEl = document.getElementById('forum-status');
        if (statusEl instanceof HTMLElement) {
          statusEl.hidden = false;
          statusEl.textContent = 'No se pudo iniciar el foro de esta página.';
          statusEl.classList.add('error');
        }

        const threadListEl = document.getElementById('forum-thread-list');
        if (threadListEl instanceof HTMLElement) {
          threadListEl.innerHTML = '<p class="forum-empty">No se pudieron cargar los hilos.</p>';
        }

        const postListEl = document.getElementById('forum-post-list');
        if (postListEl instanceof HTMLElement) {
          postListEl.innerHTML = '<p class="forum-empty">No se pudieron cargar los mensajes.</p>';
        }
      }

      const mountCourseContent = async () => {
        const pageRoot = document.querySelector('[data-course-layout-root]');
        const hasPendingEvalHydration = Array.from(document.querySelectorAll('.eval-block-wrapper'))
          .some((wrapper) => wrapper instanceof HTMLElement && wrapper.childElementCount === 0);
        const bootKey = [
          window.location.pathname,
          window.location.search,
          pageRoot instanceof HTMLElement ? pageRoot.dataset.livePageSlug || '' : '',
        ].join('::');

        if (window.__musikiCourseContentBootKey === bootKey && !hasPendingEvalHydration) {
          return;
        }

        if (typeof window.__musikiCourseContentTeardown === 'function') {
          window.__musikiCourseContentTeardown();
          window.__musikiCourseContentTeardown = null;
        }

        window.__musikiCourseContentBootKey = bootKey;

        unsubscribeLivePolls?.();
        unsubscribeLivePolls = null;
        if (livePollTickId) {
          window.clearInterval(livePollTickId);
          livePollTickId = null;
        }
        progressByEvalId.clear();
        pollWidgetsByEvalId.clear();
        wordcloudWidgetsByEvalId.clear();
        renderPageProgress();

        document.querySelectorAll('.eval-block-wrapper').forEach((wrapper) => {
          if (wrapper instanceof HTMLElement) {
            wrapper.innerHTML = '';
          }
        });

        try {
          await refreshCourseForumSubnav();
          await initLessonForum();
        } catch (error) {
          reportLessonForumBootError(error);
        }

        try {
          await upgradeLegacyObsidianAudioLinks();
        } catch (error) {
          console.error('Legacy audio bootstrap error:', error);
        }

        try {
          const contentArea = document.querySelector('.content-area');
          if (contentArea instanceof HTMLElement) {
            const renderCourseMermaid = (globalThis as any).__musikiCourseStaticMermaidRenderer;
            if (typeof renderCourseMermaid === 'function') {
              renderCourseMermaid(contentArea);
            }
          }
        } catch (error) {
          console.error('Course mermaid bootstrap error:', error);
        }

        try {
          await loadUserSubmissions();
        } catch (error) {
          console.error('User submission bootstrap error:', error);
        }

        const evalWrappers = document.querySelectorAll('.eval-block-wrapper');
        hasEvalBlocks = evalWrappers.length > 0;

        evalWrappers.forEach((wrapper, index) => {
          try {
            const evalData = parseEvalData(wrapper);
            if (!evalData || !evalData.id || !evalData.type) return;

            if (evalData.type === 'mcq') {
              renderMCQ(wrapper, evalData, index);
              return;
            }

            if (evalData.type === 'mcc') {
              renderMCC(wrapper, evalData, index);
              return;
            }

            if (evalData.type === 'poll') {
              renderPoll(wrapper, evalData, index);
              return;
            }

            if (evalData.type === 'wordcloud') {
              renderWordcloud(wrapper, evalData, index);
              return;
            }

            if (evalData.type === 'patch_ai') {
              renderPatchAI(wrapper, evalData, index);
              return;
            }

            renderUnsupported(wrapper, evalData, index);
          } catch (error) {
            console.error('Eval block bootstrap error:', error);
          }
        });

        setupFoldableH2Sections();
        buildClassToc();
        mountLivePollTransport();

        const scrollTopBtn = document.getElementById('scroll-top-btn');
        const scrollForumBtn = document.getElementById('scroll-forum-btn');
        const primaryScroller = getPrimaryScroller();
        const { scrollKey } = getLessonStorageKeys();

        const restoreSavedScrollPosition = () => {
          if (window.location.hash) return;
          try {
            const raw = localStorage.getItem(scrollKey);
            const nextTop = Number(raw);
            if (!Number.isFinite(nextTop) || nextTop < 0) return;

            window.requestAnimationFrame(() => {
              if (primaryScroller) {
                primaryScroller.scrollTop = nextTop;
              } else {
                window.scrollTo({ top: nextTop, behavior: 'auto' });
              }
            });
          } catch {
            // ignore storage failures
          }
        };

        const persistScrollPosition = () => {
          try {
            const nextTop = primaryScroller
              ? Math.max(0, primaryScroller.scrollTop || 0)
              : Math.max(0, window.scrollY || window.pageYOffset || 0);
            localStorage.setItem(scrollKey, String(nextTop));
          } catch {
            // ignore storage failures
          }
        };

        const updateScrollShortcutVisibility = () => {
          const doc = document.documentElement;
          const scrollY = primaryScroller
            ? Math.max(0, primaryScroller.scrollTop || 0)
            : Math.max(0, window.scrollY || window.pageYOffset || 0);
          const maxScroll = primaryScroller
            ? Math.max(0, primaryScroller.scrollHeight - primaryScroller.clientHeight)
            : Math.max(0, doc.scrollHeight - window.innerHeight);

          const nearTop = scrollY <= 24;
          const nearBottom = scrollY >= maxScroll - 24;

          const forumRoot = document.getElementById('lesson-forum');
          let forumVisible = false;
          if (forumRoot) {
            const rect = forumRoot.getBoundingClientRect();
            if (primaryScroller) {
              const scrollerRect = primaryScroller.getBoundingClientRect();
              const visiblePx = Math.min(scrollerRect.bottom, rect.bottom) - Math.max(scrollerRect.top, rect.top);
              forumVisible = visiblePx > 56 || rect.top <= scrollerRect.top + 40;
            } else {
              const viewportHeight = window.innerHeight || doc.clientHeight || 0;
              const visiblePx = Math.min(viewportHeight, rect.bottom) - Math.max(0, rect.top);
              forumVisible = visiblePx > 56 || rect.top <= 40;
            }
          }

          if (scrollTopBtn) {
            scrollTopBtn.hidden = nearTop;
          }

          if (scrollForumBtn) {
            scrollForumBtn.hidden = nearBottom || forumVisible;
          }
        };

        const handleScrollTopClick = () => {
          scrollToTop('smooth');
        };

        const handleScrollForumClick = () => {
          scrollToForum('smooth');
        };

        if (scrollTopBtn) {
          scrollTopBtn.addEventListener('click', handleScrollTopClick);
        }

        if (scrollForumBtn) {
          scrollForumBtn.addEventListener('click', handleScrollForumClick);
        }

        const handleScrollShortcutVisibility = () => {
          updateScrollShortcutVisibility();
        };

        if (primaryScroller) {
          primaryScroller.addEventListener('scroll', handleScrollShortcutVisibility, { passive: true });
          primaryScroller.addEventListener('scroll', persistScrollPosition, { passive: true });
        } else {
          window.addEventListener('scroll', handleScrollShortcutVisibility, { passive: true });
          window.addEventListener('scroll', persistScrollPosition, { passive: true });
        }
        window.addEventListener('resize', handleScrollShortcutVisibility);

        const handleScrollHotkeys = (event) => {
          if (!(event.metaKey || event.ctrlKey)) return;

          const target = event.target;
          const isEditable =
            target instanceof HTMLElement &&
            (target.isContentEditable || /^(INPUT|TEXTAREA|SELECT)$/.test(target.tagName));
          if (isEditable) return;

          const foldNodes = getContentFoldNodes();
          if (foldNodes.length > 0 && event.key === 'ArrowUp') {
            event.preventDefault();
            setContentFoldState(false);
            return;
          }

          if (foldNodes.length > 0 && event.key === 'ArrowDown') {
            event.preventDefault();
            setContentFoldState(true);
            return;
          }

          if (event.altKey) return;

          if (event.key === 'ArrowUp') {
            event.preventDefault();
            scrollToTop('smooth');
            return;
          }

          if (event.key === 'ArrowDown') {
            event.preventDefault();
            scrollToForum('smooth');
          }
        };

        document.addEventListener('keydown', handleScrollHotkeys);

        if (window.location.hash === '#lesson-forum') {
          window.requestAnimationFrame(() => {
            scrollToForum('auto');
            window.requestAnimationFrame(updateScrollShortcutVisibility);
          });
        } else if (window.location.hash) {
          window.requestAnimationFrame(() => {
            if (navigateToContentHash(window.location.hash, { behavior: 'auto', updateHistory: false })) {
              window.requestAnimationFrame(updateScrollShortcutVisibility);
            }
          });
        }

        updateScrollShortcutVisibility();
        restoreSavedScrollPosition();

        window.__musikiCourseContentTeardown = () => {
          unsubscribeLivePolls?.();
          unsubscribeLivePolls = null;
          if (livePollTickId) {
            window.clearInterval(livePollTickId);
            livePollTickId = null;
          }
          if (scrollTopBtn) {
            scrollTopBtn.removeEventListener('click', handleScrollTopClick);
          }
          if (scrollForumBtn) {
            scrollForumBtn.removeEventListener('click', handleScrollForumClick);
          }
          if (primaryScroller) {
            primaryScroller.removeEventListener('scroll', handleScrollShortcutVisibility);
            primaryScroller.removeEventListener('scroll', persistScrollPosition);
          } else {
            window.removeEventListener('scroll', handleScrollShortcutVisibility);
            window.removeEventListener('scroll', persistScrollPosition);
          }
          window.removeEventListener('resize', handleScrollShortcutVisibility);
          document.removeEventListener('keydown', handleScrollHotkeys);
        };
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => {
          void mountCourseContent();
        }, { once: true });
      } else {
        void mountCourseContent();
      }

      document.addEventListener('astro:page-load', () => {
        void mountCourseContent();
      });

      window.addEventListener('beforeunload', () => {
        if (typeof window.__musikiCourseContentTeardown === 'function') {
          window.__musikiCourseContentTeardown();
        }
      });
      
    </script>

    <script>
      import { subscribeToClassActivity } from '../../lib/class-activity/client.mjs';
      import { normalizeActivityPageSlug, selectLessonActivityState } from '../../lib/class-activity/model.mjs';

      const setupLessonLiveBeacons = () => {
        const globalWindow = window;
        if (typeof globalWindow.__musikiLessonBeaconTeardown === 'function') {
          globalWindow.__musikiLessonBeaconTeardown();
          globalWindow.__musikiLessonBeaconTeardown = null;
        }

        const lessonLinks = Array.from(
          document.querySelectorAll('.lesson-link[data-course-id][data-lesson-page-slug]'),
        );
        if (lessonLinks.length === 0) return;

        const trackers = lessonLinks
          .map((link) => {
            const roomIndicator = link.querySelector('[data-lesson-room-indicator]');
            const interactionIndicator = link.querySelector('[data-lesson-live-indicator]');
            const countdown = link.querySelector('[data-lesson-live-countdown]');
            if (!(roomIndicator instanceof HTMLElement) && !(interactionIndicator instanceof HTMLElement)) return null;
            return {
              courseId: String(link.dataset.courseId || '').trim(),
              pageSlug: normalizeActivityPageSlug(link.dataset.lessonPageSlug || ''),
              roomIndicator: roomIndicator instanceof HTMLElement ? roomIndicator : null,
              interactionIndicator: interactionIndicator instanceof HTMLElement ? interactionIndicator : null,
              countdown: countdown instanceof HTMLElement ? countdown : null,
            };
          })
          .filter(Boolean);

        if (trackers.length === 0) return;

        const courseId = String(trackers[0]?.courseId || '').trim();
        if (!courseId) return;

        let latestSnapshot = null;

        const clearIndicator = (node, countdownNode = null) => {
          if (!(node instanceof HTMLElement)) return;
          node.hidden = true;
          node.classList.remove('is-live', 'is-closing');
          node.title = '';
          node.removeAttribute('role');
          node.removeAttribute('tabindex');
          node.removeAttribute('aria-label');
          delete node.dataset.href;
          if (countdownNode instanceof HTMLElement) {
            countdownNode.hidden = true;
            countdownNode.textContent = '';
          }
        };

        const bindIndicator = (node) => {
          if (!(node instanceof HTMLElement) || node.dataset.boundLessonActivity === 'true') return;
          node.dataset.boundLessonActivity = 'true';
          const open = (event) => {
            if (node.hidden) return;
            const href = String(node.dataset.href || '').trim();
            if (!href) return;
            event.preventDefault();
            event.stopPropagation();
            window.location.href = new URL(href, window.location.origin).toString();
          };
          const onKeydown = (event) => {
            const key = String(event.key || '').toLowerCase();
            const code = String(event.code || '').toLowerCase();
            if (key !== 'enter' && key !== ' ' && code !== 'space' && code !== 'spacebar') return;
            open(event);
          };
          node.addEventListener('click', open);
          node.addEventListener('keydown', onKeydown);
          node.__musikiOpenIndicator = open;
          node.__musikiOpenIndicatorKeydown = onKeydown;
        };

        trackers.forEach((tracker) => {
          bindIndicator(tracker.roomIndicator);
          bindIndicator(tracker.interactionIndicator);
        });

        const render = () => {
          trackers.forEach((tracker) => {
            const state = selectLessonActivityState(latestSnapshot, {
              courseId: tracker.courseId,
              pageSlug: tracker.pageSlug,
            });

            if (tracker.roomIndicator instanceof HTMLElement) {
              if (state.room.visible) {
                tracker.roomIndicator.hidden = false;
                tracker.roomIndicator.classList.add('is-live');
                tracker.roomIndicator.dataset.href = state.room.href || '';
                tracker.roomIndicator.title = state.room.title || 'Clase en vivo';
                tracker.roomIndicator.setAttribute('role', 'button');
                tracker.roomIndicator.setAttribute('tabindex', '0');
                tracker.roomIndicator.setAttribute('aria-label', state.room.title || 'Clase en vivo');
              } else {
                clearIndicator(tracker.roomIndicator);
              }
            }

            if (tracker.interactionIndicator instanceof HTMLElement) {
              if (state.interaction.visible) {
                tracker.interactionIndicator.hidden = false;
                tracker.interactionIndicator.classList.add('is-live');
                tracker.interactionIndicator.classList.toggle('is-closing', state.interaction.closing);
                tracker.interactionIndicator.dataset.href = state.interaction.href || '';
                tracker.interactionIndicator.title = state.interaction.title || 'Interacción en vivo';
                tracker.interactionIndicator.setAttribute('role', 'button');
                tracker.interactionIndicator.setAttribute('tabindex', '0');
                tracker.interactionIndicator.setAttribute('aria-label', state.interaction.title || 'Interacción en vivo');
                if (tracker.countdown instanceof HTMLElement) {
                  tracker.countdown.hidden = !state.interaction.timerLabel;
                  tracker.countdown.textContent = state.interaction.timerLabel || '';
                }
              } else {
                clearIndicator(tracker.interactionIndicator, tracker.countdown);
              }
            }
          });
        };

        const unsubscribe = subscribeToClassActivity({
          courseId,
          onEvent: (_eventName, snapshot) => {
            latestSnapshot = snapshot;
            render();
          },
        });

        const tickId = window.setInterval(() => {
          if (!latestSnapshot) return;
          render();
        }, 1000);

        render();

        globalWindow.__musikiLessonBeaconTeardown = () => {
          unsubscribe?.();
          window.clearInterval(tickId);
          trackers.forEach((tracker) => {
            [tracker.roomIndicator, tracker.interactionIndicator].forEach((node) => {
              if (!(node instanceof HTMLElement)) return;
              if (typeof node.__musikiOpenIndicator === 'function') {
                node.removeEventListener('click', node.__musikiOpenIndicator);
              }
              if (typeof node.__musikiOpenIndicatorKeydown === 'function') {
                node.removeEventListener('keydown', node.__musikiOpenIndicatorKeydown);
              }
            });
          });
        };
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', setupLessonLiveBeacons, { once: true });
      } else {
        setupLessonLiveBeacons();
      }
      document.addEventListener('astro:page-load', setupLessonLiveBeacons);
    </script>
    
