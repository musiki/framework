        stroke: currentColor;
        stroke-width: 1.15;
        stroke-linecap: round;
        stroke-linejoin: round;
        vector-effect: non-scaling-stroke;
      }

      .forum-editor-action-spacer {
        width: 0.4rem;
        min-width: 0.4rem;
        height: 1.42rem;
        display: inline-block;
        opacity: 0;
        pointer-events: none;
      }

      #forum-reply-form {
        margin-bottom: 0;
        gap: 0.35rem;
      }

      .forum-secondary-btn,
      .forum-form .nav-button {
        border-radius: 7px;
        padding: 0.46rem 0.74rem;
        font-size: 0.81rem;
      }

      .forum-secondary-btn {
        border: 1px solid var(--forum-border-strong);
        background: var(--forum-bg-panel);
        color: var(--forum-text-primary);
        cursor: pointer;
      }

      .forum-secondary-btn[hidden] {
        display: none;
      }

      .forum-thread-list,
      .forum-post-list {
        display: grid;
        gap: 0.58rem;
        max-height: 580px;
        overflow: auto;
        overflow-x: hidden;
      }

      .sidebar--right .forum-thread-list {
        max-height: min(30dvh, 20rem);
      }

      .sidebar--right .forum-thread-stage {
        display: grid;
        grid-template-rows: minmax(0, 1fr) auto;
        min-height: 18rem;
      }

      .sidebar--right .forum-post-list {
        max-height: min(38dvh, 28rem);
      }

      .forum-thread-item {
        width: 100%;
        text-align: left;
        border: 0;
        border-radius: 8px;
        background: var(--forum-bg-panel);
        color: var(--forum-text-primary);
        padding: 0.62rem 0.74rem;
        cursor: pointer;
        transition: background 0.15s ease, border-color 0.15s ease;
      }

      .forum-thread-item:hover {
        background: var(--forum-bg-subtle);
        border-color: var(--forum-border-strong);
      }

      .forum-thread-item.active {
        border-color: color-mix(in srgb, var(--forum-accent) 42%, var(--forum-border-strong));
        background: color-mix(in srgb, var(--forum-accent) 8%, var(--forum-bg-panel));
      }

      .forum-thread-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 0.6rem;
      }

      .forum-thread-title {
        display: block;
        font-weight: 600;
        font-size: 0.9rem;
        line-height: 1.35;
      }

      .forum-thread-activity {
        font-size: 0.73rem;
        color: var(--forum-text-secondary);
        white-space: nowrap;
      }

      .forum-thread-meta {
        margin-top: 0.35rem;
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 0.7rem;
        font-size: 0.76rem;
        color: var(--forum-text-secondary);
      }

      .forum-thread-author,
      .forum-thread-stats {
        white-space: nowrap;
      }

      .forum-post {
        border: 1px solid var(--forum-border-soft);
        background: var(--forum-bg-panel);
        border-radius: 9px;
        display: grid;
        grid-template-columns: 128px minmax(0, 1fr);
        gap: 0.95rem;
        padding: 0.78rem 0.78rem 0.78rem calc(0.78rem + 5px);
        --forum-post-body-size: 0.95rem;
        --forum-post-meta-size: 0.66rem;
      }

      .forum-post-op {
        border-left: 4px solid var(--forum-role-op);
        padding-left: 0.58rem;
      }

      .forum-post-reply {
        border-left: 2px solid var(--forum-border-soft);
      }

      .forum-post-identity {
        display: grid;
        align-content: flex-start;
        gap: 0.28rem;
      }

      .forum-post-avatar {
        width: 12px;
        height: 12px;
        aspect-ratio: 1 / 1;
        border-radius: 999px;
        border: 1px solid var(--forum-border-soft);
        background: var(--forum-bg-subtle);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.42rem;
        font-weight: 600;
        color: var(--forum-text-primary);
        vertical-align: middle;
        object-fit: cover;
        object-position: center;
        overflow: hidden;
        clip-path: circle(50% at 50% 50%);
        flex-shrink: 0;
        line-height: 1;
      }

      .forum-post-name {
        font-size: var(--forum-post-meta-size);
        line-height: 1.2;
        font-weight: 600;
      }

      .forum-post-badges {
        display: flex;
        flex-wrap: wrap;
        gap: 0.3rem;
      }

      .forum-role-badge {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: 0.1rem 0.42rem;
        font-size: 0.67rem;
        line-height: 1.4;
        border: 1px solid var(--forum-border-soft);
        color: var(--forum-text-secondary);
        background: var(--forum-bg-subtle);
      }

      .forum-role-badge.instructor {
        background: color-mix(in srgb, var(--forum-role-instructor) 20%, var(--forum-bg-panel));
        border-color: color-mix(in srgb, var(--forum-role-instructor) 40%, var(--forum-border-soft));
        color: color-mix(in srgb, var(--forum-role-instructor) 78%, #1f3550);
      }

      .forum-role-badge.op {
        background: color-mix(in srgb, var(--forum-role-op) 14%, var(--forum-bg-panel));
        border-color: color-mix(in srgb, var(--forum-role-op) 34%, var(--forum-border-soft));
        color: color-mix(in srgb, var(--forum-role-op) 68%, #1d4f35);
      }

      .forum-post-main {
        min-width: 0;
      }

      .forum-post-header {
        display: flex;
        justify-content: flex-end;
        margin-bottom: 0.38rem;
        font-size: var(--forum-post-meta-size);
      }

      .forum-post-date {
        color: var(--forum-text-secondary);
        font-size: var(--forum-post-meta-size);
      }

      .forum-post-body {
        display: block;
        font-size: var(--forum-post-body-size);
        line-height: 1.62;
        color: var(--forum-text-primary);
        max-width: 100%;
        min-width: 0;
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      .forum-post-body > :first-child {
        margin-top: 0;
      }

      .forum-post-body > :last-child {
        margin-bottom: 0;
      }

      .forum-post-body :where(p, ul, ol, pre, blockquote, table, .callout, .mermaid, .katex-display, .lily-score, .lilypond-block) {
        margin: 0 0 0.7rem 0;
        max-width: 100%;
      }

      .forum-post-body .lilypond-block {
        display: block;
        overflow-x: auto;
      }

        .forum-post-body .lilypond-block img {
          display: block;
          width: 200%;
          max-width: none;
          height: auto;
        }

        :global(.dark) .content-area :is(.lily-score, .lilypond-block) img,
        :global(.dark) .forum-post-body :is(.lily-score, .lilypond-block) img {
          filter: invert(1);
        }

        .forum-post-body pre {
          overflow: auto;
          background: var(--forum-bg-subtle);
        border: 1px solid var(--forum-border-soft);
        border-radius: 7px;
        padding: 0.62rem;
        max-width: 100%;
      }

      .forum-post-body code {
        font-size: 0.84em;
      }

      .forum-post-body blockquote {
        border-left: 3px solid var(--forum-border-strong);
        padding-left: 0.7rem;
        color: var(--forum-text-secondary);
      }

      .forum-post-body table {
        width: 100%;
        display: block;
        overflow-x: auto;
        max-width: 100%;
        border-collapse: collapse;
      }

      .forum-post-body th,
      .forum-post-body td {
        border: 1px solid var(--forum-border-soft);
        padding: 0.35rem 0.45rem;
        text-align: left;
      }

      .forum-post-body .mermaid {
        overflow-x: auto;
      }

      .forum-post-body :where(img, video, audio, a[data-forum-media-link='true'], .mermaid) {
        cursor: zoom-in;
      }

      .forum-media-modal {
        position: fixed;
        inset: 0;
        z-index: 120;
        display: grid;
        place-items: center;
        background: rgba(0, 0, 0, 0.9);
        padding: 1.25rem;
      }

      .forum-media-modal[hidden] {
        display: none;
      }

      .forum-media-modal-stage {
        position: relative;
        display: grid;
        place-items: center;
        width: min(96vw, 92rem);
        max-height: 92vh;
      }

      .forum-media-modal-close {
        position: absolute;
        top: 0.5rem;
        right: 0.5rem;
        z-index: 1;
        border: 0;
        background: transparent;
        color: rgba(255, 255, 255, 0.82);
        font: inherit;
        font-size: 1.8rem;
        line-height: 1;
        padding: 0.35rem 0.45rem;
        cursor: pointer;
      }

      .forum-media-modal-content {
        display: grid;
        place-items: center;
        width: 100%;
        max-height: 92vh;
      }

      .forum-media-modal-viewport {
        position: relative;
        display: grid;
        place-items: center;
        width: 100%;
        max-width: min(96vw, 92rem);
        max-height: 88vh;
        overflow: hidden;
        cursor: grab;
        touch-action: none;
      }

      .forum-media-modal-viewport.is-dragging {
        cursor: grabbing;
      }

      .forum-media-modal-content img,
      .forum-media-modal-content video {
        display: block;
        max-width: 100%;
        max-height: 88vh;
        width: auto;
        height: auto;
        user-select: none;
        -webkit-user-drag: none;
        transform-origin: center center;
        will-change: transform;
      }

      .forum-media-modal-content .mermaid {
        display: block;
        max-width: none;
        transform-origin: center center;
        will-change: transform;
      }

      .forum-media-modal-content .mermaid svg {
        display: block;
        max-width: none;
        height: auto;
      }

      .forum-media-modal-content img[data-forum-svg='true'] {
        background: #fff;
      }

      :global(.dark) .forum-media-modal-content img[data-forum-svg='true'] {
        background: #000;
        filter: invert(1) hue-rotate(180deg);
      }

      .forum-media-modal-content audio {
        width: min(92vw, 44rem);
        max-width: 100%;
      }

      .forum-post-actions {
        margin-top: 0.58rem;
        display: flex;
        align-items: center;
        gap: 0.45rem;
        flex-wrap: wrap;
      }

      .forum-post-reply-btn,
      .forum-post-edit-btn {
        border: 1px solid var(--forum-border-soft);
        background: var(--forum-bg-subtle);
        color: var(--forum-text-primary);
        border-radius: 6px;
        padding: 0.24rem 0.52rem;
        cursor: pointer;
        font-size: 0.74rem;
      }

      .forum-post-reply-btn:disabled,
      .forum-post-edit-btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
      }

      .forum-edit-form {
        margin-top: 0.55rem;
      }

      .forum-edit-textarea {
        min-height: 11.6rem;
      }

      .forum-reply-target {
        margin: 0;
        padding: 0.5rem 0.6rem;
        border: 1px dashed var(--forum-border-strong);
        border-radius: 7px;
        background: var(--forum-bg-panel);
        font-size: 0.8rem;
      }

      .forum-empty {
        margin: 0;
        padding: 0.7rem;
        border: 1px dashed var(--forum-border-soft);
        border-radius: 7px;
        color: var(--forum-text-secondary);
        font-size: 0.85rem;
        background: var(--forum-bg-panel);
      }

      .forum-status {
        margin: 0 0 0.8rem 0;
        font-size: 0.83rem;
        padding: 0.55rem 0.6rem;
        border-radius: 7px;
        border: 1px solid var(--forum-border-soft);
        background: var(--forum-bg-panel);
      }

      .forum-status[hidden] {
        display: none;
      }

      .forum-status.error {
        border-color: #f44336;
        color: #b3261e;
      }

      .forum-login-cta {
        border: 1px dashed var(--forum-border-soft);
        border-radius: 8px;
        background: var(--forum-bg-panel);
        padding: 1rem;
        font-size: 0.92rem;
      }
      
      @media (max-width: 1024px) {
        .course-container {
          grid-template-columns: minmax(0, 1fr);
          min-height: auto;
          padding: 0.92rem 0.65rem 0.65rem;
        }

        .course-container[data-left-open='false'],
        .course-container[data-right-open='false'],
        .course-container[data-left-open='false'][data-right-open='false'] {
          grid-template-columns: minmax(0, 1fr);
        }

        .course-sidebar-handle {
          display: inline-flex;
          top: auto;
          bottom: 0.8rem;
        }

        .course-sidebar-handle--left {
          left: 0.8rem;
        }

        .course-sidebar-handle--right {
          right: 0.8rem;
        }

        .sidebar {
          --course-sidebar-pad-top: 1rem;
          --course-sidebar-pad-x: 0.95rem;
          --course-sidebar-pad-bottom: 1.2rem;
          position: fixed;
          top: calc(var(--musiki-header-height, 4.5rem) + 0.32rem);
          bottom: 0;
          z-index: 44;
          width: min(84vw, 320px);
          height: calc(100dvh - var(--musiki-header-height, 4.5rem) - 0.32rem);
          max-height: none;
          border-radius: 0;
          padding: var(--course-sidebar-pad-top) var(--course-sidebar-pad-x) var(--course-sidebar-pad-bottom);
          overflow-y: auto;
          scrollbar-gutter: auto;
          box-shadow: 0 18px 42px rgba(0, 0, 0, 0.18);
        }

        .sidebar-maximize-btn {
          display: none;
        }

        .sidebar--left {
          left: 0;
          transform: translateX(-100%);
        }

        .sidebar--right {
          right: 0;
          transform: translateX(100%);
        }

        .course-container[data-left-open='false'] .sidebar--left {
          transform: translateX(-100%);
        }

        .course-container[data-right-open='false'] .sidebar--right {
          transform: translateX(100%);
        }

        .course-container[data-left-open='true'] .sidebar--left,
        .course-container[data-right-open='true'] .sidebar--right {
          opacity: 1;
          pointer-events: auto;
          border-color: var(--c-border);
        }

        .course-container[data-left-open='true'] .sidebar--left {
          transform: translateX(0);
        }

        .course-container[data-right-open='true'] .sidebar--right {
          transform: translateX(0);
        }

        .content-area {
          width: 100%;
          height: auto;
          min-height: calc(100dvh - 8.4rem);
          overflow: visible;
          scrollbar-gutter: auto;
        }

        .course-nav {
          flex-direction: column;
          gap: 0.75rem;
        }

        .nav-button {
          text-align: center;
        }

        .forum-grid {
          grid-template-columns: 1fr;
        }

        .forum-post {
          grid-template-columns: 1fr;
          gap: 0.7rem;
        }

        .forum-post-identity {
          grid-template-columns: auto 1fr;
          align-items: center;
          column-gap: 0.65rem;
          row-gap: 0.2rem;
        }
        .forum-post-avatar {
          grid-row: span 2;
        }

        .forum-post-badges {
          grid-column: 2;
        }
      }

      @media (max-width: 640px) {
        .course-sidebar-handle {
          width: 2.15rem;
          height: 2.15rem;
        }

        .sidebar {
          width: min(88vw, 308px);
        }

        .forum-thread-top,
        .forum-thread-meta {
          flex-direction: column;
          align-items: flex-start;
          gap: 0.2rem;
        }
      }

      @media (max-width: 500px) {
        .sidebar {
          --course-sidebar-pad-top: 0.9rem;
          --course-sidebar-pad-x: 0.9rem;
          --course-sidebar-pad-bottom: 1.1rem;
          top: calc(var(--musiki-header-height, 4.5rem) + 0.32rem);
          right: 0;
          bottom: 0;
          left: 0;
          width: 100vw;
          width: 100dvw;
          max-width: none;
          height: auto;
          min-height: calc(100dvh - var(--musiki-header-height, 4.5rem) - 0.32rem);
          padding: var(--course-sidebar-pad-top) var(--course-sidebar-pad-x) var(--course-sidebar-pad-bottom);
        }

        .sidebar-panel-actions {
          position: sticky;
          top: 0;
          z-index: 2;
          background: var(--c-bg);
          padding-top: 0.1rem;
        }
      }

      @media (max-width: 500px) {
        .course-container {
          width: 100%;
          max-width: 100vw;
          margin: 0;
          padding: 0.5rem;
          gap: 0.7rem;
        }

        .sidebar {
          --course-sidebar-pad-top: 0.9rem;
          --course-sidebar-pad-x: 0.85rem;
          --course-sidebar-pad-bottom: 1rem;
          padding: var(--course-sidebar-pad-top) var(--course-sidebar-pad-x) var(--course-sidebar-pad-bottom);
        }

        .content-area {
          width: 100%;
          min-width: 0;
          padding: 0.9rem;
        }

        .content-area > :not(.course-nav) {
          max-width: 100%;
        }

        .content-area :is(pre, table, .mermaid, .lily-score, .lilypond-block, .obsidian-media-embed, img, svg, iframe) {
          max-width: 100%;
        }

        .content-area :is(pre, table, .mermaid, .lily-score, .lilypond-block) {
          overflow-x: auto;
        }

        .course-nav {
          margin-top: 1.8rem;
          padding-top: 1.3rem;
          gap: 0.55rem;
        }

        .course-nav .nav-button {
          width: 100%;
          text-align: center;
        }

        .scroll-shortcuts {
          right: 0.45rem;
          bottom: 0.45rem;
        }
      }

      :global(html.course-sidebars-open),
      :global(body.course-sidebars-open) {
        overflow: hidden;
      }
    </style>
    <style is:global>
    .sidebar--left .lesson-item {
      padding-left: 0 !important;
      position: static !important;
    }

    .sidebar--left .lesson-item::before {
      content: none !important;
      display: none !important;
    }

    .sidebar--left .class-toc-summary {
      list-style: none !important;
      display: block !important;
      appearance: none !important;
      -webkit-appearance: none !important;
      padding-left: 0 !important;
    }

    .sidebar--left .class-toc-summary::-webkit-details-marker {
      display: none !important;
    }

    .sidebar--left .class-toc-summary::marker {
      content: none !important;
      font-size: 0 !important;
    }

    .content-area .content-fold-summary {
      list-style: none !important;
      display: block !important;
      appearance: none !important;
      -webkit-appearance: none !important;
      padding: 0.95rem 0 !important;
    }

    .content-area .content-fold-summary::-webkit-details-marker {
      display: none !important;
    }

    .content-area .content-fold-summary::marker {
      content: none !important;
      font-size: 0 !important;
    }

    .content-area .content-fold-summary::before,
    .content-area .content-fold[open] > .content-fold-summary::before {
      content: none !important;
      display: none !important;
    }

    .content-area .content-fold-summary h2 {
      margin: 0 !important;
      line-height: 1.24 !important;
      min-width: 0;
      display: block !important;
    }

    .content-area .content-fold-summary:hover,
    .content-area .content-fold-summary:hover *,
    .sidebar--left .class-toc-summary:hover,
    .sidebar--left .class-toc-summary:hover * {
      cursor: var(--course-fold-cursor-down) !important;
    }

    .content-area .content-fold[open] > .content-fold-summary:hover,
    .content-area .content-fold[open] > .content-fold-summary:hover *,
    .sidebar--left .class-toc-branch[open] > .class-toc-summary:hover,
    .sidebar--left .class-toc-branch[open] > .class-toc-summary:hover * {
      cursor: var(--course-fold-cursor-up) !important;
    }

    [data-musiki-no-list-marker='true'] {
      position: static !important;
      padding-left: 0 !important;
      list-style: none !important;
    }

    [data-musiki-no-list-marker='true']::before,
    [data-musiki-no-list-marker='true']::marker {
      content: none !important;
      display: none !important;
    }

    [data-musiki-no-summary-marker='true'] {
      display: block !important;
      list-style: none !important;
      appearance: none !important;
      -webkit-appearance: none !important;
      padding-left: 0 !important;
    }

    [data-musiki-no-summary-marker='true']::-webkit-details-marker {
      display: none !important;
    }

    [data-musiki-no-summary-marker='true']::before,
    [data-musiki-no-summary-marker='true']::marker {
      content: none !important;
      display: none !important;
    }
    </style>
  </head>
  <body>
    <Header
      courseId={canonicalCourseId || courseSlug}
      activeCourseId={canonicalCourseId || courseSlug}
      activeCourseCode={activeCourseCode}
      presentationHref={presentationHref}
      performativeRoomHref={performativeRoomHref}
      teacherCreateHref={teacherCreateHref}
      teacherEditHref={teacherEditHref}
    />
    <main
      class="course-container"
      data-course-layout-root
      data-user-key={String(session?.user?.email || '').trim()}
      data-left-open="true"
      data-right-open="false"
      data-right-maximized="false"
      data-has-right-sidebar={hasForumSidebar ? 'true' : 'false'}
      data-can-manage-live-interactions={canManageLiveInteractions ? 'true' : 'false'}
      data-live-course-id={canonicalCourseId || courseSlug}
      data-live-page-slug={livePageSlug}
    >
      <button
        type="button"
        class="course-sidebar-handle course-sidebar-handle--left"
        data-sidebar-handle="left"
        aria-label="Mostrar navegación del curso"
        title="Mostrar navegación del curso (⌘/Ctrl + \\)"
      >⋮</button>
      <button
        type="button"
        class="course-sidebar-handle course-sidebar-handle--right"
        data-sidebar-handle="right"
        aria-label="Mostrar foros"
        title="Mostrar foros (⌘/Ctrl + Shift + \\)"
      >⋮</button>
      <div class="course-sidebar-overlay" data-course-sidebar-overlay></div>

      <!-- Sidebar Navigation -->
      <aside class="sidebar sidebar--left" data-course-sidebar="left">
        <div class="course-title">
          <div class="course-title-row">
            <a href={courseHref} class="course-title-link">
              <span class="course-title-link-text">{courseIndex.data.title}</span>
            </a>
            <div class="course-title-actions">
              <button
                type="button"
                class="sidebar-toggle-btn"
                data-sidebar-toggle="left"
                aria-label="Ocultar navegación del curso"
                title="Ocultar navegación del curso (⌘/Ctrl + \\)"
              >←</button>
            </div>
          </div>
          {performativeRoomHref && isLessonPage && (
            <div class="course-title-secondary">
              <a href={performativeRoomHref} class="performative-room-link">
                Sala performativa
              </a>
            </div>
          )}
        </div>

