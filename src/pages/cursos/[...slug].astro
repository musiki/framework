      .lesson-live-indicator[hidden],
      .lesson-room-indicator[hidden] {
        display: none !important;
      }

      .lesson-live-led {
        width: 0.52rem;
        height: 0.52rem;
        border-radius: 999px;
        background: #ff3030;
        box-shadow: 0 0 0 0 rgba(255, 48, 48, 0.56);
        flex: 0 0 auto;
      }

      .lesson-live-led--room {
        background: #2196f3;
        box-shadow:
          0 0 0 0 rgba(33, 150, 243, 0.42),
          0 0 8px rgba(33, 150, 243, 0.5);
      }

      .lesson-live-indicator.is-live .lesson-live-led {
        animation: lesson-live-pulse 1.2s ease-in-out infinite;
      }

      .lesson-room-indicator.is-live .lesson-live-led--room {
        animation: lesson-live-pulse 1.35s ease-in-out infinite;
      }

      .lesson-live-indicator:focus-visible {
        outline: 2px solid color-mix(in srgb, var(--accent) 70%, white 30%);
        outline-offset: 2px;
        border-radius: 999px;
      }

      .lesson-live-indicator.is-closing .lesson-live-led {
        background: #ff5b5b;
        box-shadow: 0 0 0 2px rgba(255, 91, 91, 0.35);
      }

      .lesson-live-countdown {
        font-size: 0.84rem;
        line-height: 1;
        min-width: 2rem;
        text-align: center;
        font-variant-numeric: tabular-nums;
      }

      @keyframes lesson-live-pulse {
        0% {
          transform: scale(1);
          opacity: 1;
        }
        50% {
          transform: scale(1.1);
          opacity: 0.72;
        }
        100% {
          transform: scale(1);
          opacity: 1;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .lesson-live-indicator.is-live .lesson-live-led,
        .lesson-room-indicator.is-live .lesson-live-led--room {
          animation: none;
        }
      }

