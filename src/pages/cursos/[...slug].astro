      }

      .lesson-activity-indicators {
        display: inline-flex;
        align-items: center;
        gap: 0.32rem;
      }

      .lesson-live-indicator,
      .lesson-room-indicator {
        display: inline-flex;
        align-items: center;
        gap: 0.28rem;
        font-size: 0.68rem;
        line-height: 1;
        color: var(--c-fg-dim);
        white-space: nowrap;
        cursor: pointer;
