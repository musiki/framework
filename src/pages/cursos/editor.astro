---
export const prerender = false;

import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import {
  buildDefaultCreatePath,
  getEditableLocalRepoFile,
  isLocalContentAdminEnabled,
  resolveCourseSource,
  sanitizeRepoDirectoryPath,
  sanitizeRepoMarkdownPath,
} from '../../lib/content-admin';
import { canonicalizeCourseId } from '../../lib/course-alias';
import { getRepoFile, isGitHubAppConfigured } from '../../lib/github-app';
import { resolveLiveManageAccess } from '../../lib/live/access';

const session = (Astro.locals as any).session;
if (!session?.user?.email) {
  return Astro.redirect(`/login?redirect=${encodeURIComponent(`${Astro.url.pathname}${Astro.url.search}`)}`);
}

const rawCourseId = String(Astro.url.searchParams.get('course') || '').trim();
const canonicalCourseId = await canonicalizeCourseId(rawCourseId);
if (!canonicalCourseId) {
  return Astro.redirect('/cursos');
}

const access = await resolveLiveManageAccess(session, canonicalCourseId);
if (!access.canManage) {
  return Astro.redirect(`/cursos/${encodeURIComponent(canonicalCourseId)}`);
}

const source = resolveCourseSource(canonicalCourseId);
const localContentAdminEnabled = isLocalContentAdminEnabled();
const githubAppConfigured = localContentAdminEnabled || isGitHubAppConfigured();
const mode = String(Astro.url.searchParams.get('mode') || 'edit').trim().toLowerCase() === 'create'
  ? 'create'
  : 'edit';
const requestedPath = sanitizeRepoMarkdownPath(Astro.url.searchParams.get('path') || '');
const requestedDir = sanitizeRepoDirectoryPath(Astro.url.searchParams.get('dir') || '');
const returnTo = String(Astro.url.searchParams.get('returnTo') || `/cursos/${canonicalCourseId}`).trim();

let targetPath = requestedPath || buildDefaultCreatePath(canonicalCourseId, requestedDir);
let initialContent = `---
type: lesson
title: ""
chapter: ""
status:
order:
---

# Nueva nota

`;
let initialSha = '';
let editorError = '';

if (!source?.repo) {
  editorError = `No hay repo fuente configurado para ${canonicalCourseId}.`;
} else if (!githubAppConfigured) {
  editorError = 'La GitHub App no está configurada todavía en el server.';
} else if (mode === 'edit') {
  if (!requestedPath) {
    editorError = 'Falta el path de la nota a editar.';
  } else {
    try {
      const remoteFile = localContentAdminEnabled
        ? getEditableLocalRepoFile(source, requestedPath)
        : await getRepoFile({
            repoFullName: source.repo,
            path: requestedPath,
            ref: source.branch || 'main',
          });

      if (!remoteFile) {
        editorError = localContentAdminEnabled
          ? 'La nota no existe en local o no pudo resolverse.'
          : 'La nota no existe en GitHub o no pudo resolverse.';
      } else {
        targetPath = remoteFile.path || requestedPath;
        initialContent = remoteFile.content || '';
        initialSha = remoteFile.sha || '';
      }
    } catch (error: any) {
      editorError = error?.message || 'No se pudo cargar la nota desde GitHub.';
    }
  }
}
---

<!doctype html>
<html lang="es">
  <head>
    <BaseHead
      title={mode === 'create' ? 'Crear nota' : 'Editar nota'}
      description="Editor markdown mínimo para publicar notas docentes en el repo de materia."
    />
    <style>
      .editor-shell {
        width: min(1100px, calc(100vw - 2rem));
        margin: calc(var(--musiki-header-height, 4.5rem) + 1rem) auto 2rem;
        display: grid;
        gap: 1rem;
      }

      .editor-card {
        border: 1px solid var(--c-border);
        border-radius: 14px;
        background: var(--c-bg);
        padding: 1rem 1rem 1.1rem;
      }

      .editor-workspace {
        display: grid;
        grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
        gap: 1rem;
        align-items: start;
      }

      .editor-kicker {
        margin: 0 0 0.25rem 0;
        font-size: 0.72rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--c-fg-dim);
      }

      .editor-title {
        margin: 0;
        font-size: 1.35rem;
      }

      .editor-subtitle {
        margin: 0.45rem 0 0 0;
        color: var(--c-fg-dim);
        line-height: 1.5;
      }

      .editor-meta {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 0.8rem;
      }

      .editor-field {
        display: grid;
        gap: 0.35rem;
      }

      .editor-label {
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--c-fg-dim);
      }

      .editor-input,
      .editor-textarea {
        width: 100%;
        border: 1px solid var(--c-border);
        border-radius: 10px;
        background: var(--c-bg-mute);
        color: var(--c-fg);
        font: inherit;
        padding: 0.7rem 0.8rem;
      }

      .editor-textarea {
        min-height: 68dvh;
        resize: vertical;
        line-height: 1.55;
        font-family: 'SFMono-Regular', 'Menlo', monospace;
        font-size: 0.95rem;
      }

      .editor-actions {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.65rem;
      }

      .editor-action {
        width: 2rem;
        height: 2rem;
        border-radius: 7px;
        border: 1px solid var(--c-border);
        background: color-mix(in srgb, var(--c-bg) 88%, var(--c-bg-mute) 12%);
        color: var(--c-fg);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.8rem;
        font-weight: 700;
      }

      .editor-action--primary {
        width: auto;
        min-width: 2rem;
        padding: 0 0.8rem;
        cursor: pointer;
      }

      .editor-markdown-tool-btn {
        width: 2rem;
        height: 2rem;
        border-radius: 7px;
        border: 1px solid var(--c-border);
        background: color-mix(in srgb, var(--c-bg) 88%, var(--c-bg-mute) 12%);
        color: var(--c-fg);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.8rem;
        font-weight: 700;
        cursor: pointer;
      }

      .editor-markdown-tool-btn svg {
        width: 0.9rem;
        height: 0.9rem;
        display: block;
        fill: none;
        stroke: currentColor;
        stroke-width: 1.15;
        stroke-linecap: round;
        stroke-linejoin: round;
        vector-effect: non-scaling-stroke;
      }

      .editor-markdown-tool-spacer {
        width: 0.35rem;
        min-width: 0.35rem;
        height: 1.4rem;
        display: inline-block;
        opacity: 0;
        pointer-events: none;
      }

      .editor-status {
        min-height: 1.3rem;
        font-size: 0.9rem;
        color: var(--c-fg-dim);
      }

      .editor-status[data-tone='error'] {
        color: #b3261e;
      }

      .editor-status[data-tone='success'] {
        color: #14713e;
      }

      .editor-note {
        margin: 0;
        font-size: 0.9rem;
        line-height: 1.5;
        color: var(--c-fg-dim);
      }

      .editor-preview-card {
        min-height: 100%;
      }

      .editor-preview-meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        margin-bottom: 0.85rem;
      }

      .editor-preview-title {
        margin: 0;
        font-size: 1rem;
      }

      .editor-preview-status {
        min-height: 1.2rem;
        font-size: 0.82rem;
        color: var(--c-fg-dim);
      }

      .editor-preview-status[data-tone='error'] {
        color: #b3261e;
      }

      .editor-preview {
        min-height: 68dvh;
        border: 1px solid color-mix(in srgb, var(--c-border) 70%, transparent);
        border-radius: 12px;
        background: color-mix(in srgb, var(--c-bg) 92%, var(--c-bg-mute) 8%);
        padding: 1rem;
        overflow: auto;
      }

      .editor-preview.is-empty {
        display: grid;
        place-items: center;
        color: var(--c-fg-dim);
      }

      .editor-preview :where(h1, h2, h3, h4, h5, h6) {
        margin-top: 0;
      }

      .editor-preview :where(pre, table, blockquote, .callout, .mermaid, .katex-display, .lily-score, .lilypond-block) {
        margin: 1rem 0;
      }

      .editor-preview pre {
        overflow: auto;
        padding: 0.9rem 1rem;
        border-radius: 12px;
        background: color-mix(in srgb, var(--c-bg-mute) 86%, black 14%);
      }

      .editor-preview code {
        font-family: 'SFMono-Regular', 'Menlo', monospace;
        font-size: 0.92em;
      }

      .editor-preview pre code {
        display: block;
        white-space: pre;
      }

      .editor-preview :is(.lily-score, .lilypond-block) img {
        display: block;
        max-width: 100%;
        height: auto;
        margin: 0 auto;
      }

      .editor-markdown-dropzone {
        position: relative;
      }

      .editor-markdown-dropzone-overlay {
        position: absolute;
        inset: 0;
        display: grid;
        place-items: center;
        border: 2px dashed color-mix(in srgb, var(--c-accent, #2f6fff) 42%, transparent);
        background: color-mix(in srgb, var(--c-accent, #2f6fff) 8%, transparent);
        color: var(--c-fg);
        opacity: 0;
        pointer-events: none;
        transition: opacity 120ms ease;
        border-radius: 12px;
      }

      .editor-markdown-dropzone-label {
        padding: 0.3rem 0.55rem;
        border-radius: 999px;
        background: color-mix(in srgb, var(--c-bg) 88%, black 12%);
        border: 1px solid color-mix(in srgb, var(--c-border) 80%, transparent);
        font-size: 0.82rem;
      }

      .editor-markdown-dropzone.is-upload-target .editor-markdown-dropzone-overlay {
        opacity: 1;
      }

      .editor-markdown-dropzone.is-uploading .editor-textarea,
      .editor-textarea.is-uploading {
        cursor: progress;
        opacity: 0.88;
      }

      @media (max-width: 720px) {
        .editor-shell {
          width: min(100vw - 1rem, 1100px);
          margin-top: calc(var(--musiki-header-height, 4.5rem) + 0.6rem);
        }

        .editor-card {
          padding: 0.85rem;
        }

        .editor-textarea {
          min-height: 58dvh;
        }
      }

      @media (max-width: 980px) {
        .editor-workspace {
          grid-template-columns: minmax(0, 1fr);
        }

        .editor-preview {
          min-height: 38dvh;
        }
      }
    </style>
  </head>
  <body>
    <Header courseId={canonicalCourseId} activeCourseId={canonicalCourseId} />
    <main class="editor-shell">
      <section class="editor-card">
        <p class="editor-kicker">Editor docente</p>
        <h1 class="editor-title">{mode === 'create' ? 'Crear nota' : 'Editar nota'}</h1>
        <p class="editor-subtitle">
          Publica markdown directo en <strong>{source?.repo || 'repo no configurado'}</strong>.
          El source of truth sigue siendo GitHub; esto es sólo una vía más amable para escribir.
        </p>
      </section>

      <section class="editor-card">
        <div class="editor-meta">
          <label class="editor-field">
            <span class="editor-label">Curso</span>
            <input class="editor-input" type="text" value={canonicalCourseId} readonly />
          </label>
          <label class="editor-field">
            <span class="editor-label">Repo</span>
            <input class="editor-input" type="text" value={source?.repo || ''} readonly />
          </label>
          <label class="editor-field">
            <span class="editor-label">Branch</span>
            <input class="editor-input" type="text" value={source?.branch || 'main'} readonly />
          </label>
        </div>
      </section>

      <div class="editor-workspace">
        <section class="editor-card">
          <form id="content-editor-form">
            <input type="hidden" name="courseId" value={canonicalCourseId} />
            <input type="hidden" name="mode" value={mode} />
            <input type="hidden" name="sha" value={initialSha} />

            <label class="editor-field">
              <span class="editor-label">Path en repo</span>
              <input
                class="editor-input"
                type="text"
                name="targetPath"
                value={targetPath}
                spellcheck="false"
                autocomplete="off"
              />
            </label>

            <label class="editor-field" style="margin-top: 0.8rem;">
              <span class="editor-label">Resumen de cambios</span>
              <input
                class="editor-input"
                type="text"
                name="editSummary"
                placeholder="¿Qué cambiaste?"
                spellcheck="true"
                autocomplete="off"
              />
            </label>

            <label class="editor-field" style="margin-top: 0.8rem;">
              <span class="editor-label">Markdown</span>
              <textarea
                class="editor-textarea"
                name="content"
                spellcheck="false"
                autocapitalize="off"
                autocomplete="off"
                autocorrect="off"
              >{initialContent}</textarea>
            </label>

            <div class="editor-actions" style="margin-top: 0.9rem;">
              <button
                class="editor-action editor-action--primary"
                type="submit"
                title={mode === 'create' ? 'Crear nota en GitHub' : 'Guardar cambios en GitHub'}
                aria-label={mode === 'create' ? 'Crear nota en GitHub' : 'Guardar cambios en GitHub'}
                disabled={Boolean(editorError)}
              >
                {mode === 'create' ? 'C' : 'E'}
              </button>
              <a class="editor-action" href={returnTo} title="Volver" aria-label="Volver">X</a>
              <span class="editor-status" id="editor-status" data-tone={editorError ? 'error' : 'idle'}>
                {editorError}
              </span>
            </div>
          </form>
        </section>

        <section class="editor-card editor-preview-card">
          <div class="editor-preview-meta">
            <h2 class="editor-preview-title">Preview</h2>
            <span class="editor-preview-status" id="editor-preview-status">Esperando cambios…</span>
          </div>
          <div class="editor-preview is-empty" id="editor-preview">
            Escribe o pega markdown para ver la nota renderizada.
          </div>
        </section>
      </div>

      <section class="editor-card">
        <p class="editor-note">
          Este primer corte publica directo al repo de materia. Si el push entra bien, el workflow del repo debería
          despachar el sync hacia <code>framework</code> y Vercel. Tu Obsidian local verá el cambio cuando hagas pull.
        </p>
      </section>
    </main>

    <script>
      import { enhanceMarkdownTextarea } from '../../scripts/markdown-editor-tools.ts';

      const mountContentEditor = () => {
        const form = document.getElementById('content-editor-form');
        const statusNode = document.getElementById('editor-status');
        const previewNode = document.getElementById('editor-preview');
        const previewStatusNode = document.getElementById('editor-preview-status');
        if (!(form instanceof HTMLFormElement) || !(statusNode instanceof HTMLElement)) return;
        if (form.dataset.bound === 'true') return;
        form.dataset.bound = 'true';

        const textarea = form.elements.namedItem('content');
        const pathInput = form.elements.namedItem('targetPath');
        const courseIdInput = form.elements.namedItem('courseId');
        let previewTimer = 0;
        let previewRequestId = 0;

        const setPreviewHtml = (html) => {
          if (!(previewNode instanceof HTMLElement)) return;
          const normalizedHtml = String(html || '').trim();
          if (!normalizedHtml) {
            previewNode.innerHTML = 'Escribe o pega markdown para ver la nota renderizada.';
            previewNode.classList.add('is-empty');
            return;
          }
          previewNode.innerHTML = normalizedHtml;
          previewNode.classList.remove('is-empty');
        };

        const setPreviewStatus = (message, tone = 'idle') => {
          if (!(previewStatusNode instanceof HTMLElement)) return;
          previewStatusNode.dataset.tone = tone;
          previewStatusNode.textContent = message;
        };

        const requestPreview = async () => {
          if (!(textarea instanceof HTMLTextAreaElement) || !(courseIdInput instanceof HTMLInputElement)) return;
          const content = textarea.value || '';
          if (!content.trim()) {
            setPreviewHtml('');
            setPreviewStatus('Esperando cambios…');
            return;
          }

          const currentRequestId = ++previewRequestId;
          setPreviewStatus('Renderizando preview…');

          try {
            const response = await fetch('/api/content-admin/preview', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                courseId: courseIdInput.value,
                path: pathInput instanceof HTMLInputElement ? pathInput.value : '',
                content,
              }),
            });

            const raw = await response.text();
            let result = {};
            try {
              result = raw ? JSON.parse(raw) : {};
            } catch {
              result = { error: raw || 'No se pudo renderizar la preview.' };
            }

            if (currentRequestId !== previewRequestId) return;
            if (!response.ok) {
              throw new Error(result?.error || 'No se pudo renderizar la preview.');
            }

            setPreviewHtml(result?.html || '');
            setPreviewStatus('Preview al día.');
          } catch (error) {
            if (currentRequestId !== previewRequestId) return;
            setPreviewStatus(error instanceof Error ? error.message : 'Error en preview.', 'error');
          }
        };

        const schedulePreview = () => {
          window.clearTimeout(previewTimer);
          previewTimer = window.setTimeout(() => {
            void requestPreview();
          }, 320);
        };

        if (textarea instanceof HTMLTextAreaElement) {
          textarea.addEventListener('input', schedulePreview);
        }

        if (pathInput instanceof HTMLInputElement) {
          pathInput.addEventListener('input', schedulePreview);
        }

        const actionsContainer = form.querySelector('.editor-actions');
        if (textarea instanceof HTMLTextAreaElement) {
          enhanceMarkdownTextarea(textarea, {
            actionsContainer: actionsContainer instanceof HTMLElement ? actionsContainer : null,
            status: (message, tone = 'info') => {
              if (!(statusNode instanceof HTMLElement)) return;
              statusNode.dataset.tone = tone === 'error' ? 'error' : 'idle';
              statusNode.textContent = message;
            },
            buttonClassName: 'editor-markdown-tool-btn',
            actionSpacerClassName: 'editor-markdown-tool-spacer',
            dropzoneClassName: 'editor-markdown-dropzone',
            dropzoneOverlayClassName: 'editor-markdown-dropzone-overlay',
            dropzoneLabelClassName: 'editor-markdown-dropzone-label',
            inputClassName: '',
            dropLabel: 'Drop file',
          });
        }

        void requestPreview();

        form.addEventListener('submit', async (event) => {
          event.preventDefault();

          const submitter = form.querySelector('button[type="submit"]');
          if (submitter instanceof HTMLButtonElement) {
            submitter.disabled = true;
          }

          const payload = Object.fromEntries(new FormData(form).entries());
          statusNode.dataset.tone = 'idle';
          statusNode.textContent = 'Publicando en GitHub...';

          try {
            const response = await fetch('/api/content-admin/publish', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(payload),
            });
            const raw = await response.text();
            let result = {};
            try {
              result = raw ? JSON.parse(raw) : {};
            } catch {
              result = { error: raw || 'No se pudo publicar la nota.' };
            }
            if (!response.ok) {
              throw new Error(result?.error || 'No se pudo publicar la nota.');
            }

            if (typeof result?.path === 'string' && result.path) {
              const pathInput = form.elements.namedItem('targetPath');
              if (pathInput instanceof HTMLInputElement) {
                pathInput.value = result.path;
              }
            }

            const shaInput = form.elements.namedItem('sha');
            if (shaInput instanceof HTMLInputElement && typeof result?.fileSha === 'string') {
              shaInput.value = result.fileSha;
            }

            const modeInput = form.elements.namedItem('mode');
            if (modeInput instanceof HTMLInputElement && payload.mode === 'create') {
              modeInput.value = 'edit';
            }

            const summaryInput = form.elements.namedItem('editSummary');
            if (summaryInput instanceof HTMLInputElement) {
              summaryInput.value = '';
            }

            statusNode.dataset.tone = 'success';
            if (result?.prUrl) {
              statusNode.innerHTML = `Pull Request creado: <a href="${result.prUrl}" target="_blank" rel="noreferrer">Ver PR #${result.prNumber}</a>`;
            } else {
              statusNode.innerHTML = result?.commitUrl
                ? `Publicado. <a href="${result.commitUrl}" target="_blank" rel="noreferrer">Ver commit</a>`
                : 'Publicado.';
            }

            if (typeof result?.renderedHtml === 'string') {
              setPreviewHtml(result.renderedHtml);
              setPreviewStatus('Preview sincronizada con el guardado.');
            }
          } catch (error) {
            statusNode.dataset.tone = 'error';
            statusNode.textContent = error instanceof Error ? error.message : 'No se pudo publicar la nota.';
          } finally {
            if (submitter instanceof HTMLButtonElement) {
              submitter.disabled = false;
            }
          }
        });
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', mountContentEditor, { once: true });
      } else {
        mountContentEditor();
      }
      document.addEventListener('astro:page-load', mountContentEditor);
    </script>
  </body>
</html>
