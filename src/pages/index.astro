---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
---

<html lang="es">
  <head>
    <BaseHead
      title="musiki"
      description="Estamos preparando el nuevo musiki público."
    />
    <style>
      .home-main {
        width: 100% !important;
        max-width: none !important;
        padding: 0 !important;
      }

      .wrap {
        width: 100%;
        min-height: calc(100vh - var(--musiki-header-height, 4.5rem));
        margin: 0;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .panel {
        padding: 2rem 1.5rem;
        text-align: center;
      }

      h1 {
        margin: 0;
        font-size: clamp(2rem, 5vw, 3.4rem);
        line-height: 1;
        text-transform: lowercase;
      }

      p {
        margin: 1rem 0 0;
        font-size: 1.05rem;
        line-height: 1.6;
        color: var(--c-fg-dim);
      }

      .legal-links {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        margin-top: 1.5rem;
      }

      .legal-links a {
        color: var(--c-link);
        text-decoration: none;
      }

      .legal-links a:hover {
        text-decoration: underline;
      }
    </style>
  </head>
  <body>
    <Header />
    <main class="wrap home-main">
      <section class="panel">
        <h1>musiki</h1>
        <p>Estamos preparando el nuevo musiki público.</p>
        <div class="legal-links">
          <a href="/privacy">Política de privacidad</a>
          <a href="/terms">Términos del servicio</a>
        </div>
      </section>
    </main>
  </body>
</html>
