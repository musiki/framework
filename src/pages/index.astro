---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<html lang="es">
  <head>
    <BaseHead
      title="musiki"
      description="Estamos preparando el nuevo musiki público."
    />
    <style>
      .wrap {
        max-width: 760px;
        margin: 0 auto;
        padding: 4rem 1.5rem 5rem;
      }

      .panel {
        border: 1px solid var(--c-border);
        border-radius: 18px;
        background: var(--c-bg);
        padding: 2rem 1.5rem;
      }

      h1 {
        margin: 0;
        font-size: clamp(2rem, 5vw, 3.4rem);
        line-height: 1;
        text-transform: lowercase;
      }

      p {
        margin: 1rem 0 0;
        font-size: 1.05rem;
        line-height: 1.6;
        color: var(--c-fg-dim);
      }

      .legal-links {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        margin-top: 1.5rem;
      }

      .legal-links a {
        color: var(--c-link);
        text-decoration: none;
      }

      .legal-links a:hover {
        text-decoration: underline;
      }
    </style>
  </head>
  <body>
    <Header />
    <main class="wrap">
      <section class="panel">
        <h1>musiki</h1>
        <p>Estamos preparando el nuevo musiki público.</p>
        <div class="legal-links">
          <a href="/privacy">Política de privacidad</a>
          <a href="/terms">Términos del servicio</a>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
