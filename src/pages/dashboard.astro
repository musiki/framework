              if (!submissionId) return;
              const confirmed = window.confirm('¿Eliminar esta entrega? Esta acción no se puede deshacer.');
              if (!confirmed) return;

              button.disabled = true;
              try {
                const response = await fetch(`/api/submissions/${submissionId}`, {
                  method: 'DELETE',
