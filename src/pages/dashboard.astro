          <div id="deliveries-content" style="display: none;">
            <h2>Entregas</h2>
            <div class="deliveries-toolbar">
              <input
                type="search"
                class="log-input"
                data-deliveries-query
                placeholder="Buscar por curso, tipo, usuario, respuesta, payload..."
                aria-label="Buscar en entregas"
              />
            </div>
            <div class="deliveries-subtabs">
              <button type="button" class="deliveries-subtab active" data-delivery-view="recent">Recientes</button>
              <button type="button" class="deliveries-subtab" data-delivery-view="course">Curso</button>
              <button type="button" class="deliveries-subtab" data-delivery-view="log">Log</button>
            </div>

            <div id="deliveries-recent" data-delivery-panel="recent">
            <p class="fold-shortcuts">
              <strong>Atajos:</strong>
              <kbd>⌘</kbd> + <kbd>⇧</kbd> + <kbd>↑</kbd> fold all,
              <kbd>⌘</kbd> + <kbd>⇧</kbd> + <kbd>↓</kbd> unfold all,
              <kbd>⌘</kbd> + <kbd>↑</kbd> fold un nivel,
              <kbd>⌘</kbd> + <kbd>↓</kbd> unfold un nivel.
            </p>

            {(() => {
              if (recentTeacherSubmissions.length === 0) {
                return <p>No hay entregas recientes.</p>;
              }

              const groupedByType = recentTeacherSubmissions.reduce((acc: any, submission: any) => {
                const meta = resolveSubmissionMeta(submission);
                const noteTypeKey = meta.noteType || 'unknown';

                if (!acc[noteTypeKey]) {
                  acc[noteTypeKey] = {
                    key: noteTypeKey,
                    label: meta.noteTypeLabel,
                    order: meta.noteTypeOrder,
                    submissions: [],
                  };
                }

                acc[noteTypeKey].submissions.push({ submission, meta });
                return acc;
              }, {});

              const noteTypeGroups = Object.values(groupedByType || {}).sort((left: any, right: any) => {
                if (left.order !== right.order) return left.order - right.order;
                return String(left.label).localeCompare(String(right.label), 'es');
              });

              return noteTypeGroups.map((group: any) => {
                const pendingByType = group.submissions.filter((entry: any) => !isSubmissionReviewed(entry.submission)).length;

                return (
                  <section
                    class="fold-node fold-level-1"
                    data-fold-level="1"
                    data-fold-node
                    data-fold-scope="submissions"
                    data-submission-type-group
                    style="margin-bottom: 0.55rem;"
                  >
                    <button type="button" class="fold-header" data-fold-toggle>
                      <span class="fold-toggle-icon">▾</span>
                      <span>🧩 {group.label}</span>
                      <span class="fold-student-summary">{group.submissions.length} respuestas • {pendingByType} pendientes</span>
                    </button>
                    <div class="fold-children">
                      <table class="admin-table" data-submission-table style="margin-top: 0;">
                        <thead>
                          <tr>
                            <th>Usuario</th>
                            <th>Clase</th>
                            <th>ID</th>
                            <th>Entrega</th>
                            <th>Respuesta</th>
                            <th>Resultado</th>
                            <th>Punto (x/10)</th>
                            <th>Retroalimentación</th>
                            <th>Acciones</th>
                          </tr>
                        </thead>
                        <tbody>
                          {group.submissions.map((entry: any) => {
                            const sub = entry.submission;
                            const meta = entry.meta;
                            const submitter = allUsers && allUsers.find((u: any) => u.id === sub.userId);
                            const resultState = getSubmissionResultState(sub);
                            const answerText = getSubmissionAnswerText(sub, assignmentById);
                            const evalPreviewAttr = toEvalPreviewAttr(meta.evalPreview);
                            const rowSearch = [
                              submitter?.name,
                              submitter?.email,
                              meta.assignmentLabel,
                              meta.assignmentSlug,
                              meta.courseId,
                              meta.noteTypeLabel,
                              meta.evalType,
                              answerText,
                              sub.feedback,
                            ]
                              .map((value) => normalizeTextLower(value))
                              .filter(Boolean)
                              .join(' ');

                            return (
                              <tr data-submission-row data-submission-id={sub.id} data-search={rowSearch}>
                                <td>{submitter?.name || 'Usuario desconocido'}</td>
                                <td style="font-size: 0.85rem;" title={meta.assignmentSlug}>{meta.assignmentLabel}</td>
                                <td style="font-size: 0.78rem;">
                                  <button
                                    type="button"
                                    class="eval-id-anchor"
                                    data-eval-preview={evalPreviewAttr}
                                    aria-label={`Ver bloque eval ${sub.assignmentId}`}
                                  >
                                    <code>{sub.assignmentId}</code>
                                  </button>
                                </td>
                                <td style="font-size: 0.85rem;">{formatSubmissionDate(sub.submittedAt)}</td>
                                <td style="max-width: 320px; font-size: 0.84rem;">{answerText}</td>
                                <td style="text-align: center;">
                                  <span class:list={['result-icon', resultState]}>{getResultIcon(resultState)}</span>
                                </td>
                                <td style="text-align: center;">
                                  <input
                                    type="number"
                                    min="0"
                                    max="10"
                                    step="0.1"
                                    value={sub.score !== null && sub.score !== undefined ? sub.score : ''}
                                    placeholder="-"
                                    class="quick-score-input"
                                    data-submission-id={sub.id}
                                  />
                                </td>
                                <td>
                                  <input
                                    type="text"
                                    class="quick-feedback-input"
                                    data-submission-id={sub.id}
                                    value={sub.feedback || ''}
                                    placeholder="Enter para guardar"
                                  />
                                </td>
                                <td>
                                  <div class="table-actions">
                                    <span class="inline-grade-note">
                                      {normalizeText(sub?.feedback) ? 'Auto + feedback' : 'Auto'}
                                    </span>
                                    <button
                                      type="button"
                                      class="icon-btn icon-btn-danger js-delete-submission"
                                      data-submission-id={sub.id}
                                      aria-label="Eliminar entrega"
                                      title="Eliminar entrega"
                                    >
                                      <svg viewBox="0 0 24 24" aria-hidden="true">
                                        <path fill="currentColor" d="M9 3h6l1 2h5v2H3V5h5l1-2Zm1 6h2v9h-2V9Zm4 0h2v9h-2V9ZM7 9h2v9H7V9Zm-1 12a2 2 0 0 1-2-2V8h16v11a2 2 0 0 1-2 2H6Z" />
                                      </svg>
                                    </button>
                                  </div>
                                </td>
                              </tr>
                            );
                          })}
                        </tbody>
                      </table>
                    </div>
                  </section>
                );
              });
            })()}
          </div>

          <div id="deliveries-course" data-delivery-panel="course" style="display: none;">
            <p class="course-grades-shortcuts">
              <strong>Atajos:</strong>
              <kbd>⌘</kbd> + <kbd>⇧</kbd> + <kbd>↑</kbd> fold all,
              <kbd>⌘</kbd> + <kbd>⇧</kbd> + <kbd>↓</kbd> unfold all,
              <kbd>⌘</kbd> + <kbd>↑</kbd> fold un nivel,
              <kbd>⌘</kbd> + <kbd>↓</kbd> unfold un nivel.
            </p>
            <div class="course-bulk-toolbar" data-course-bulk-toolbar>
              <span class="bulk-hint">Edición masiva: <kbd>Alt</kbd> + click para seleccionar filas.</span>
              <span class="bulk-spacer"></span>
              <label for="bulk-turno-select">Turno:</label>
              <select id="bulk-turno-select" class="grade-board-meta-input grade-turno-select" data-bulk-turno>
                <option value="">-</option>
                <option value="M">M</option>
                <option value="T">T</option>
                <option value="N">N</option>
              </select>
              <button type="button" data-bulk-apply-turno>Aplicar</button>
              <button type="button" data-bulk-clear-selection>Limpiar selección</button>
              <span class="bulk-count" data-bulk-count>0 seleccionados</span>
            </div>

            {allEnrollments && allSubmissions && allUsers && allAssignments && (() => {
              const enrollmentSource = scopedTeacherEnrollments;

              const courseGroups = enrollmentSource.reduce((acc, enroll) => {
                const courseId = canonicalizeCourseId(enroll?.courseId) || String(enroll?.courseId || '').trim();
                if (!courseId) return acc;
                if (!acc[courseId]) acc[courseId] = [];
                acc[courseId].push(enroll);
                return acc;
              }, {});
              const usersById = new Map((allUsers || []).map((user) => [user.id, user]));

              return Object.entries(courseGroups)
                .sort(([left], [right]) => String(left).localeCompare(String(right), 'es'))
                .map(([courseId, enrolls]) => {
                  const courseSubmissionsAllYears = scopedTeacherSubmissions.filter((submission) => {
                    const meta = resolveSubmissionMeta(submission);
                    const submissionCourseId = canonicalizeCourseId(meta?.courseIdRaw || meta?.courseId || '');
                    return submissionCourseId === courseId;
                  });

                  const courseAssignmentsMap = new Map();

                  (allAssignments || [])
                    .filter((assignment) => canonicalizeCourseId(assignment?.courseId) === courseId)
                    .forEach((assignment) => {
                      if (!assignment?.id) return;
                      courseAssignmentsMap.set(assignment.id, assignment);
                    });

                  courseSubmissionsAllYears.forEach((submission) => {
                    const assignmentId = String(submission?.assignmentId || '').trim();
                    if (!assignmentId || courseAssignmentsMap.has(assignmentId)) return;
                    const meta = resolveSubmissionMeta(submission);
                    courseAssignmentsMap.set(assignmentId, {
                      id: assignmentId,
                      courseId,
                      slug: meta.assignmentSlug || `${courseId}/${assignmentId}`,
                    });
                  });

                  const courseAssignments = Array.from(courseAssignmentsMap.values())
                    .sort((left, right) => {
                      const leftKey = String(left.slug || left.id || '');
                      const rightKey = String(right.slug || right.id || '');
                      return leftKey.localeCompare(rightKey, 'es');
                    });
                  const assignmentsByPage = courseAssignments.reduce((acc, assignment) => {
                    const assignmentSlug = String(assignment.slug || assignment.id || '').replace(/^\/+|\/+$/g, '');
                    const slugParts = assignmentSlug.split('/').filter(Boolean);
                    const slugCourseId = canonicalizeCourseId(slugParts[0] || '');
                    const pageSlug = slugCourseId === courseId
                      ? slugParts.slice(1).join('/')
                      : assignmentSlug;
                    const page = pageSlug || 'other';
                    if (!acc[page]) acc[page] = [];
                    acc[page].push(assignment);
                    return acc;
                  }, {});
                  const lessonGroups = Object.entries(assignmentsByPage)
                    .sort(([left], [right]) => String(left).localeCompare(String(right), 'es'))
                    .map(([lessonSlug, lessonAssignments]) => ({
                      lessonSlug,
                      lessonLabel: decodeUriSafe(lessonSlug),
                      assignments: [...lessonAssignments].sort((left, right) => {
                        const leftLabel = decodeUriSafe(String(left.id || '')).toLowerCase();
                        const rightLabel = decodeUriSafe(String(right.id || '')).toLowerCase();
                        return leftLabel.localeCompare(rightLabel, 'es');
                      }),
                    }));
                  const flatAssignments = lessonGroups.flatMap((lesson) => lesson.assignments);
                  const assignmentIdSet = new Set(flatAssignments.map((assignment) => assignment.id));
                  const scopedCourseSubmissionsAllYears = courseSubmissionsAllYears.filter((submission) =>
                    assignmentIdSet.has(submission.assignmentId),
                  );
                  const yearSet = new Set([activeYear]);
                  scopedCourseSubmissionsAllYears.forEach((submission) => {
                    yearSet.add(getSubmissionYear(submission));
                  });
                  const years = Array.from(yearSet).sort((left, right) => {
                    const numericDiff = Number(right) - Number(left);
                    if (!Number.isNaN(numericDiff) && numericDiff !== 0) return numericDiff;
                    return String(right).localeCompare(String(left), 'es');
                  });

                  const currentStudents = enrolls
                    .filter((enrollment) => normalizeRole(enrollment?.roleInCourse) === 'student')
                    .map((enrollment) => usersById.get(enrollment.userId))
                    .filter(Boolean);

                  if (currentStudents.length === 0 && scopedCourseSubmissionsAllYears.length === 0) return null;

                  const enrollmentsByStudent = new Map(
                    enrolls
                      .filter((enrollment) => normalizeRole(enrollment?.roleInCourse) === 'student')
                      .map((enrollment) => [enrollment.userId, enrollment]),
                  );

                  return (
                    <section data-course-group style="margin-bottom: 0.9rem;">
                      {flatAssignments.length === 0 ? (
                        <p class="student-empty">No hay bloques de evaluación registrados en este curso.</p>
                      ) : (
                        years.map((year, yearIndex) => {
                            const yearSubmissions = scopedCourseSubmissionsAllYears.filter(
                              (submission) => getSubmissionYear(submission) === year,
                            );
                            const submissionMap = new Map();
                            yearSubmissions.forEach((submission) => {
                              submissionMap.set(`${submission.userId}::${submission.assignmentId}`, submission);
                            });

                            const yearStudentIds = new Set(currentStudents.map((student) => String(student?.id || '')));
                            yearSubmissions.forEach((submission) => {
                              const studentId = String(submission?.userId || '');
                              if (studentId) yearStudentIds.add(studentId);
                            });
                            const students = Array.from(yearStudentIds)
                              .map((studentId) => usersById.get(studentId))
                              .filter(Boolean)
                              .sort((left, right) =>
                                String(left?.name || left?.email || '').localeCompare(
                                  String(right?.name || right?.email || ''),
                                  'es',
                                ),
                              );

                            if (students.length === 0) return null;

                            const yearPending = yearSubmissions.filter((submission) => !isSubmissionReviewed(submission)).length;

                            return (
                              <section
                                class="fold-node fold-level-2"
                                data-fold-level="2"
                                data-fold-node
                                data-fold-scope="course-grades"
                                data-course-year-group
                                data-search={`${normalizeTextLower(courseId)} ${normalizeTextLower(year)}`}
                                style="margin-bottom: 0.6rem;"
                              >
                                <button type="button" class="fold-header" data-fold-toggle>
                                  <span class="fold-toggle-icon">▾</span>
                                  <span>🗓 {year}</span>
                                  <span class="fold-student-summary">{students.length} estudiantes • {yearPending} pendientes</span>
                                </button>
                                <div class="fold-children">
                                  <div class="grade-board-wrap">
                                    <table class="student-assignment-table grade-board-table">
                                      <thead>
                                        <tr>
                                          <th rowspan="2">Nombre</th>
                                          <th rowspan="2">Turno</th>
                                          <th rowspan="2">Email</th>
                                          <th colspan="4" class:list={['grade-board-final-header', 'group-general', 'group-start']}>General</th>
                                          {lessonGroups.map((lesson, lessonIndex) => (
                                            <th
                                              class:list={[
                                                'lesson-group-header',
                                                lessonIndex % 2 === 0 ? 'lesson-group-even' : 'lesson-group-odd',
                                                'group-start',
                                              ]}
                                              colspan={Math.max(lesson.assignments.length, 1)}
                                              title={lesson.lessonSlug}
                                            >
                                              {lesson.lessonLabel}
                                            </th>
                                          ))}
                                        </tr>
                                        <tr>
                                          <th class:list={['group-general', 'group-start']}>Promedio</th>
                                          <th class="group-general">Asistencia</th>
                                          <th class="group-general">Concepto</th>
                                          <th class="group-general">Grupo</th>
                                          {lessonGroups.map((lesson, lessonIndex) => lesson.assignments.map((assignment, assignmentIndex) => {
                                            const assignmentLabel = decodeUriSafe(String(assignment.id || '').split('/').pop() || assignment.id);
                                            return (
                                              <th
                                                class:list={[
                                                  'eval-header',
                                                  lessonIndex % 2 === 0 ? 'lesson-group-even' : 'lesson-group-odd',
                                                  assignmentIndex === 0 ? 'group-start' : '',
                                                ]}
                                                title={assignment.id}
                                              >
                                                {assignmentLabel}
                                              </th>
                                            );
                                          }))}
                                        </tr>
                                      </thead>
                                      <tbody>
                                        {students.map((student) => {
                                          const panelKey = `${courseId}__${year}__${student.id}`
                                            .replace(/[^a-zA-Z0-9_-]/g, '_')
                                            .slice(0, 140);
                                          const scores = flatAssignments
                                            .map((assignment) => {
                                              const submission = submissionMap.get(`${student.id}::${assignment.id}`);
                                              if (!submission) return null;
                                              if (submission.score === null || submission.score === undefined) return null;
                                              const value = Number(submission.score);
                                              return Number.isNaN(value) ? null : value;
                                            })
                                            .filter((value) => value !== null);
                                          const average = scores.length > 0
                                            ? (scores.reduce((sum, value) => sum + value, 0) / scores.length).toFixed(1)
                                            : '-';
                                          const studentEnrollment = enrollmentsByStudent.get(student.id);
                                          const metaKey = `${normalizeTextLower(courseId)}::${year}::${student.id}`;
                                          const savedMeta = courseStudentMetaByKey.get(metaKey);
                                          const attendanceCount = attendanceDayCountByStudentKey.get(metaKey)?.size || 0;
                                          const turnoRaw = normalizeText(savedMeta?.turno || studentEnrollment?.turno || student?.turno || '').toUpperCase();
                                          const turnoValue = ['M', 'T', 'N'].includes(turnoRaw) ? turnoRaw : 'M';
                                          const groupValue = normalizeText(
                                            savedMeta?.grupo
                                              || studentEnrollment?.group
                                              || studentEnrollment?.grupo
                                              || student?.group
                                              || student?.grupo
                                              || '',
                                          );
                                          const conceptValue = normalizeText(
                                            savedMeta?.concepto
                                              || studentEnrollment?.concept
                                              || studentEnrollment?.concepto
                                              || '',
                                          );
                                          const rowSearch = [
                                            courseId,
                                            year,
                                            student?.name,
                                            student?.email,
                                            turnoValue,
                                            String(attendanceCount),
                                            groupValue,
                                            conceptValue,
                                            ...lessonGroups.map((lesson) => lesson.lessonLabel),
                                            ...flatAssignments.map((assignment) => assignment.id),
                                          ]
                                            .map((value) => normalizeTextLower(value))
                                            .filter(Boolean)
                                            .join(' ');

                                          return (
                                            <tr
                                              data-course-row
                                              data-course-id={courseId}
                                              data-year={year}
                                              data-student-id={student.id}
                                              data-search={rowSearch}
                                            >
                                              <td>
                                                <div class="grade-board-student">
                                                  <span>{student?.name || student?.email || student?.id}</span>
                                                </div>
                                              </td>
                                              <td>
                                                <select
                                                  class="grade-board-meta-input grade-turno-select"
                                                  data-course-id={courseId}
                                                  data-year={year}
                                                  data-student-id={student.id}
                                                >
                                                  <option value="M" selected={turnoValue === 'M'}>M</option>
                                                  <option value="T" selected={turnoValue === 'T'}>T</option>
                                                  <option value="N" selected={turnoValue === 'N'}>N</option>
                                                </select>
                                              </td>
                                              <td class="grade-board-email">
                                                {student?.email || student?.id}
                                              </td>
                                              <td class:list={['grade-board-average', 'group-general', 'group-start']} data-average-for={panelKey}>
                                                {average}
                                              </td>
                                              <td class="group-general" title={`${attendanceCount} dias asistidos`}>
                                                {attendanceCount}
                                              </td>
                                              <td class="group-general">
                                                <input
                                                  type="number"
                                                  min="0"
                                                  max="10"
                                                  step="0.1"
                                                  class="grade-board-meta-input grade-concept-input"
                                                  data-course-id={courseId}
                                                  data-year={year}
                                                  data-student-id={student.id}
                                                  value={conceptValue}
                                                  placeholder="Concepto"
                                                />
                                              </td>
                                              <td class="group-general">
                                                <input
                                                  type="number"
                                                  min="0"
                                                  step="1"
                                                  class="grade-board-meta-input grade-group-input"
                                                  data-course-id={courseId}
                                                  data-year={year}
                                                  data-student-id={student.id}
                                                  value={groupValue}
                                                  placeholder="Grupo"
                                                />
                                              </td>
                                              {lessonGroups.map((lesson, lessonIndex) => lesson.assignments.map((assignment, assignmentIndex) => {
                                                const assignmentLabel = decodeUriSafe(String(assignment.id || '').split('/').pop() || assignment.id);
                                                const submission = submissionMap.get(`${student.id}::${assignment.id}`);
                                                const statusLabel = isSubmissionReviewed(submission)
                                                  ? 'calificada'
                                                  : submission
                                                    ? 'pendiente'
                                                    : 'sin entrega';

                                                return (
                                                  <td
                                                    class:list={[
                                                      lessonIndex % 2 === 0 ? 'lesson-group-even' : 'lesson-group-odd',
                                                      assignmentIndex === 0 ? 'group-start' : '',
                                                    ]}
                                                    title={`${assignmentLabel} • ${statusLabel}`}
                                                  >
                                                    {submission ? (
                                                      <div>
                                                        <input
                                                          type="number"
                                                          min="0"
                                                          max="10"
                                                          step="0.1"
                                                          value={submission.score !== null && submission.score !== undefined ? submission.score : ''}
                                                          placeholder="-"
                                                          data-submission-id={submission.id}
                                                          data-assignment-id={assignment.id}
                                                          data-student-panel={panelKey}
                                                          class="grade-input"
                                                          style="width: 56px; padding: 0.18rem; text-align: center; border: 1px solid var(--c-border); border-radius: 4px; background: var(--c-bg); font-size: 0.74rem;"
                                                        />
                                                        <div class="grade-board-state">{statusLabel}</div>
                                                      </div>
                                                    ) : (
                                                      <span style="color: var(--c-fg-dim);">-</span>
                                                    )}
                                                  </td>
                                                );
                                              }))}
                                            </tr>
                                          );
                                        })}
                                      </tbody>
                                    </table>
                                  </div>
                                </div>
                              </section>
                            );
                          })
                      )}
                    </section>
                  );
                });
            })()}
          </div>

