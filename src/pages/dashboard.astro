        border: 1px solid var(--c-border);
        border-radius: 8px;
        background: var(--c-bg);
        box-shadow: 0 12px 30px rgba(0, 0, 0, 0.2);
        padding: 0.55rem 0.65rem;
        pointer-events: none;
      }
      .eval-preview-tooltip[hidden] {
        display: none !important;
      }
      .eval-preview-tooltip h4 {
        margin: 0 0 0.4rem 0;
        font-size: 0.85rem;
      }
      .eval-preview-tooltip p {
        margin: 0 0 0.35rem 0;
        font-size: 0.79rem;
        line-height: 1.42;
      }
      .eval-preview-tooltip ul {
        margin: 0 0 0.35rem 1rem;
        padding: 0;
        font-size: 0.79rem;
        line-height: 1.4;
      }
      .eval-preview-tooltip li {
        margin: 0 0 0.2rem 0;
      }
      .eval-preview-tooltip code {
        font-size: 0.75rem;
      }
      @media (max-width: 960px) {
        .wrap {
          padding: 0;
        }
        .dashboard-shell {
          grid-template-columns: 1fr;
        }
        .dashboard-sidebar {
          position: static;
          height: auto;
        }
        .log-toolbar {
          grid-template-columns: 1fr;
        }
        .tabs {
          display: flex;
          flex-wrap: wrap;
          border-bottom: 1px solid var(--c-border);
          margin-bottom: 0.2rem;
        }
        .dashboard-scope-controls {
          display: flex;
          flex-wrap: nowrap;
          align-items: flex-end;
          gap: 0.55rem;
          width: 100%;
          padding-top: 0.7rem;
          overflow-x: auto;
          overflow-y: hidden;
          scrollbar-width: thin;
        }
        .dashboard-scope-field {
