          <script>
            const foldStates = {};

            function getFoldState(scope) {
              if (!foldStates[scope]) {
                foldStates[scope] = { depth: 0, maxLevel: 1 };
              }
              return foldStates[scope];
            }

            function getFoldNodes(scope) {
              return Array.from(document.querySelectorAll(`[data-fold-node][data-fold-scope="${scope}"]`));
            }

            function getActiveTabName() {
              const activeTab = document.querySelector('.tab.active');
              return activeTab ? activeTab.getAttribute('data-tab') : null;
            }

            function getActiveDeliveryView() {
              const activeSubtab = document.querySelector('.deliveries-subtab.active');
              return activeSubtab ? String(activeSubtab.getAttribute('data-delivery-view') || 'recent') : 'recent';
            }

            function getActiveFoldScope() {
              const activeTabName = getActiveTabName();
              if (activeTabName === 'attendance') return 'attendance';
              if (activeTabName !== 'deliveries') return null;
              const view = getActiveDeliveryView();
              if (view === 'recent') return 'submissions';
              if (view === 'course') return 'course-grades';
              return null;
            }

            function showMainTab(tabName) {
              document.querySelectorAll('.tab').forEach((tab) => tab.classList.remove('active'));
              document.querySelectorAll('[id$="-content"]').forEach((content) => {
                content.style.display = 'none';
              });

              const tabNode = document.querySelector(`.tab[data-tab="${tabName}"]`);
              if (tabNode) tabNode.classList.add('active');
              const contentNode = document.getElementById(`${tabName}-content`);
              if (contentNode) contentNode.style.display = 'block';

              if (tabName === 'deliveries') {
                initializeDeliveriesTab();
                return;
              }

              if (tabName === 'attendance') {
                initializeAttendanceTab();
              }
            }

            function bindMainTabs() {
              document.querySelectorAll('.tab').forEach((tab) => {
                if (tab.dataset.bound === 'true') return;
                tab.dataset.bound = 'true';
                tab.addEventListener('click', () => {
                  const tabName = String(tab.getAttribute('data-tab') || '');
                  if (!tabName) return;
                  showMainTab(tabName);
                });
              });
            }

            function updateDashboardScopeQuery(nextCourseId, nextYear) {
              const url = new URL(window.location.href);
              if (nextCourseId) {
                url.searchParams.set('course', nextCourseId);
              } else {
                url.searchParams.delete('course');
              }
              if (nextYear) {
                url.searchParams.set('year', nextYear);
              } else {
                url.searchParams.delete('year');
              }

              const activeTabName = getActiveTabName();
              if (activeTabName) {
                url.searchParams.set('tab', activeTabName);
                if (activeTabName === 'deliveries') {
                  url.searchParams.set('deliveryView', getActiveDeliveryView());
                } else {
                  url.searchParams.delete('deliveryView');
                }
              }
              window.location.href = `${url.pathname}${url.search}${url.hash}`;
            }

            function initializeDashboardScopeSelectors() {
              const courseSelect = document.querySelector('[data-dashboard-scope="course"]');
              const yearSelect = document.querySelector('[data-dashboard-scope="year"]');
              if (!(courseSelect instanceof HTMLSelectElement) || !(yearSelect instanceof HTMLSelectElement)) {
                return;
              }
              if (courseSelect.dataset.boundScope !== 'true') {
                courseSelect.dataset.boundScope = 'true';
                courseSelect.addEventListener('change', () => {
                  updateDashboardScopeQuery(courseSelect.value, yearSelect.value);
                });
              }
              if (yearSelect.dataset.boundScope !== 'true') {
                yearSelect.dataset.boundScope = 'true';
                yearSelect.addEventListener('change', () => {
                  updateDashboardScopeQuery(courseSelect.value, yearSelect.value);
                });
              }
            }

            function restoreDashboardTabFromQuery() {
              const params = new URLSearchParams(window.location.search);
              const tab = String(params.get('tab') || '').trim();
              const deliveryView = String(params.get('deliveryView') || '').trim();
              if (tab && ['users', 'enrollments', 'deliveries', 'attendance'].includes(tab)) {
                showMainTab(tab);
              }
              if (tab === 'deliveries' && deliveryView) {
                switchDeliveryView(deliveryView);
              }
            }

            function switchDeliveryView(view) {
              const requestedView = ['recent', 'course', 'log'].includes(view) ? view : 'recent';
              document.querySelectorAll('.deliveries-subtab').forEach((subtab) => {
                subtab.classList.toggle('active', subtab.getAttribute('data-delivery-view') === requestedView);
              });
              document.querySelectorAll('[data-delivery-panel]').forEach((panel) => {
                panel.style.display = panel.getAttribute('data-delivery-panel') === requestedView ? 'block' : 'none';
              });

              if (requestedView === 'recent') {
                initializeSubmissionQuickEditors();
                initializeSubmissionDeleteButtons();
                initializeCorrectionFolding('submissions');
              }
              if (requestedView === 'course') {
                initializeGradeAutosave();
                initializeCorrectionFolding('course-grades');
              }
              if (requestedView === 'log') {
                if (typeof initializeDashboardLogPanels === 'function') {
                  initializeDashboardLogPanels();
                }
              }

              const queryInput = document.querySelector('[data-deliveries-query]');
              const queryValue = queryInput instanceof HTMLInputElement ? queryInput.value : '';
              applyDeliveriesSearch(queryValue);
            }

            function bindDeliverySubtabs() {
              document.querySelectorAll('.deliveries-subtab').forEach((subtab) => {
                if (subtab.dataset.bound === 'true') return;
                subtab.dataset.bound = 'true';
                subtab.addEventListener('click', () => {
                  const view = String(subtab.getAttribute('data-delivery-view') || 'recent');
                  switchDeliveryView(view);
                });
              });
            }

            function includesQuery(value, query) {
              if (!query) return true;
              return String(value || '').toLowerCase().includes(query);
            }

            function applyRecentSearch(query) {
              const rows = Array.from(document.querySelectorAll('#deliveries-recent [data-submission-row]'));
              rows.forEach((row) => {
                const search = row.getAttribute('data-search') || '';
                row.hidden = !includesQuery(search, query);
              });

              document.querySelectorAll('#deliveries-recent [data-submission-type-group]').forEach((group) => {
                const visibleRows = group.querySelectorAll('[data-submission-row]:not([hidden])').length;
                group.hidden = visibleRows === 0;
                if (query && visibleRows > 0) group.classList.remove('is-collapsed');
              });
            }

            function applyCourseSearch(query) {
              const rows = Array.from(document.querySelectorAll('#deliveries-course [data-course-row]'));
              rows.forEach((row) => {
                const search = row.getAttribute('data-search') || '';
                row.hidden = !includesQuery(search, query);
              });

              document.querySelectorAll('#deliveries-course [data-course-year-group]').forEach((group) => {
                const visibleRows = group.querySelectorAll('[data-course-row]:not([hidden])').length;
                group.hidden = visibleRows === 0;
                if (query && visibleRows > 0) group.classList.remove('is-collapsed');
              });

              document.querySelectorAll('#deliveries-course [data-course-group]').forEach((group) => {
                const visibleYearGroups = group.querySelectorAll('[data-course-year-group]:not([hidden])').length;
                group.hidden = visibleYearGroups === 0;
                if (query && visibleYearGroups > 0) group.classList.remove('is-collapsed');
              });
            }

            function applyLogSearch(query) {
              document.querySelectorAll('#deliveries-log [data-log-panel]').forEach((panel) => {
                panel.dispatchEvent(new CustomEvent('dashboard-log-query', {
                  detail: { query },
                  bubbles: false,
                }));
              });

              const logQueryInput = document.querySelector('#deliveries-log [data-log-query]');
              if (!(logQueryInput instanceof HTMLInputElement)) return;
              if (logQueryInput.value === query) return;
              logQueryInput.value = query;
              logQueryInput.dispatchEvent(new Event('input', { bubbles: true }));
            }

            function applyDeliveriesSearch(rawValue) {
              const query = String(rawValue || '').trim().toLowerCase();
              const activeView = getActiveDeliveryView();
              if (activeView === 'recent') {
                applyRecentSearch(query);
                return;
              }
