        totalJoinCount: 0,
        totalLeaveCount: 0,
        totalAbortedCount: 0,
        totalDurationMs: 0,
        lastSeenAt: '',
        lastStatus: '',
      });
    });
  }

  scopedLiveAttendance.forEach((attendance: any) => {
    const userId = String(attendance?.userId || '').trim();
    const identity = String(attendance?.identity || '').trim();
    const key = userId ? `user:${userId}` : identity ? `identity:${identity}` : '';
    if (!key) return;

    const user = resolveAttendanceUser(userId);
    const role = normalizeRole(attendance?.role || user?.role || 'student') || 'student';
    const session = scopedLiveSessionById.get(String(attendance?.sessionId || '')) || null;
    const existing = summaryByKey.get(key) || {
      key,
      userId,
      identity,
      role,
      name: String(user?.name || attendance?.name || identity || 'Participante'),
      email: String(user?.email || attendance?.email || ''),
      sessionIds: new Set<string>(),
      dayKeys: new Set<string>(),
      totalJoinCount: 0,
      totalLeaveCount: 0,
      totalAbortedCount: 0,
      totalDurationMs: 0,
      lastSeenAt: '',
      lastStatus: '',
    };

    existing.role = existing.role || role;
    existing.name = String(existing.name || user?.name || attendance?.name || identity || 'Participante');
    existing.email = String(existing.email || user?.email || attendance?.email || '');
    existing.totalJoinCount += Math.max(0, Number(attendance?.joinCount || 0));
    existing.totalLeaveCount += Math.max(0, Number(attendance?.leaveCount || 0));
    existing.totalAbortedCount += Math.max(0, Number(attendance?.abortedCount || 0));
    existing.totalDurationMs += computeAttendanceDurationMs(attendance, session);

    const sessionId = String(attendance?.sessionId || '').trim();
    if (sessionId && Number(attendance?.joinCount || 0) > 0) {
      existing.sessionIds.add(sessionId);
    }

    const dayKey = getAttendanceDayKey(session, attendance);
    if (dayKey && Number(attendance?.joinCount || 0) > 0) {
      existing.dayKeys.add(dayKey);
    }

    const nextLastSeenAt = String(attendance?.lastEventAt || attendance?.lastLeftAt || attendance?.lastJoinedAt || '');
    if (getDateTimestamp(nextLastSeenAt) >= getDateTimestamp(existing.lastSeenAt)) {
      existing.lastSeenAt = nextLastSeenAt;
      existing.lastStatus = String(attendance?.lastStatus || existing.lastStatus || '');
    }

    summaryByKey.set(key, existing);
  });

  return Array.from(summaryByKey.values())
    .map((row: any) => {
      const sessionsAttended = row.sessionIds.size;
      return {
        ...row,
        sessionsAttended,
        totalDaysAttended: row.dayKeys.size,
        totalDurationLabel: formatDurationFromMs(row.totalDurationMs),
        averageDurationLabel: formatDurationFromMs(
          sessionsAttended > 0 ? row.totalDurationMs / sessionsAttended : 0,
        ),
        lastSeenLabel: formatSubmissionDate(row.lastSeenAt),
      };
    })
    .sort((left: any, right: any) =>
      String(left.name || '').localeCompare(String(right.name || ''), 'es'),
    );
})();

const attendanceDayGroups = (() => {
  const groups = new Map<string, any>();

  attendanceSessionRows.forEach((session: any) => {
    const dayKey = String(session?.dayKey || '').trim();
    const group = groups.get(dayKey) || {
      dayKey,
      dayLabel: session?.dayLabel || 'Sin fecha',
      latestStartedAt: '',
      sessionIds: new Set<string>(),
      studentKeys: new Set<string>(),
      teacherKeys: new Set<string>(),
      totalDurationMs: 0,
      sessions: [],
    };

    if (!group.sessionIds.has(session.id)) {
      group.sessionIds.add(session.id);
      group.sessions.push(session);
      group.totalDurationMs += Math.max(0, Number(session?.durationMs || 0));
    }

    (session.participants || []).forEach((participant: any) => {
      const identityKey =
        String(participant?.userId || '').trim()
          ? `user:${String(participant.userId).trim()}`
          : String(participant?.identity || '').trim()
            ? `identity:${String(participant.identity).trim()}`
            : '';
      if (!identityKey) return;
      if (normalizeRole(participant?.role) === 'teacher') {
        group.teacherKeys.add(identityKey);
      } else {
        group.studentKeys.add(identityKey);
      }
    });

    if (getDateTimestamp(session?.startedAt) >= getDateTimestamp(group.latestStartedAt)) {
      group.latestStartedAt = String(session?.startedAt || '');
    }

    groups.set(dayKey, group);
  });

  return Array.from(groups.values())
    .map((group: any) => ({
      ...group,
      sessionCount: group.sessionIds.size,
      studentCount: group.studentKeys.size,
      teacherCount: group.teacherKeys.size,
      totalDurationLabel: formatDurationFromMs(group.totalDurationMs),
      sessions: [...group.sessions].sort(
        (left: any, right: any) => getDateTimestamp(right.startedAt) - getDateTimestamp(left.startedAt),
      ),
    }))
    .sort(
      (left: any, right: any) => getDateTimestamp(right.latestStartedAt) - getDateTimestamp(left.latestStartedAt),
    );
})();

const attendanceLogRows = scopedLiveAttendance
  .map((attendance: any) => {
    const session = scopedLiveSessionById.get(String(attendance?.sessionId || '')) || null;
    const user = resolveAttendanceUser(attendance?.userId);
    const courseId = getLiveRecordCourseId(session || attendance) || activeCourseId || 'sin-curso';
    const durationMs = computeAttendanceDurationMs(attendance, session);
    const dayKey = getAttendanceDayKey(session, attendance);
    const role = normalizeRole(attendance?.role || user?.role || 'student') || 'student';
    return {
      id: String(attendance?.id || `${attendance?.sessionId || 'session'}::${attendance?.userId || attendance?.identity || 'user'}`),
      sessionId: String(attendance?.sessionId || ''),
      dayKey,
      dayLabel: formatAttendanceDayLabel(dayKey),
      courseId,
      pageSlug: String(session?.pageSlug || attendance?.pageSlug || ''),
      lessonLabel: decodeUriSafe(
        String(session?.pageSlug || attendance?.pageSlug || session?.roomName || 'Clase').split('/').pop() || 'Clase',
      ),
      role,
      displayName: String(user?.name || attendance?.name || attendance?.identity || 'Participante'),
      email: String(user?.email || attendance?.email || ''),
      identity: String(attendance?.identity || ''),
      joinCount: Math.max(0, Number(attendance?.joinCount || 0)),
      leaveCount: Math.max(0, Number(attendance?.leaveCount || 0)),
      abortedCount: Math.max(0, Number(attendance?.abortedCount || 0)),
      durationMs,
      durationLabel: formatDurationFromMs(durationMs),
      firstJoinedLabel: formatSubmissionDate(attendance?.firstJoinedAt),
      lastLeftLabel: formatSubmissionDate(attendance?.lastLeftAt),
      lastSeenLabel: formatSubmissionDate(attendance?.lastEventAt),
      lastStatus: String(attendance?.lastStatus || ''),
      sortTs: getDateTimestamp(attendance?.lastEventAt || attendance?.lastLeftAt || attendance?.firstJoinedAt),
    };
  })
  .sort((left: any, right: any) => right.sortTs - left.sortTs);

const attendanceDayCountByStudentKey = (() => {
  const daysByKey = new Map<string, Set<string>>();
  if (!isTeacher) return daysByKey;

  scopedLiveAttendance
    .filter((attendance: any) => normalizeRole(attendance?.role) === 'student')
    .forEach((attendance: any) => {
      const userId = String(attendance?.userId || '').trim();
      if (!userId || Number(attendance?.joinCount || 0) <= 0) return;
      const session = scopedLiveSessionById.get(String(attendance?.sessionId || '')) || null;
      const courseId = canonicalizeCourseId(getLiveRecordCourseId(session || attendance));
      const year = getLiveSessionYear(session || attendance);
      const dayKey = getAttendanceDayKey(session, attendance);
      if (!courseId || !year || !dayKey) return;

      const mapKey = `${normalizeTextLower(courseId)}::${year}::${userId}`;
      if (!daysByKey.has(mapKey)) daysByKey.set(mapKey, new Set<string>());
      daysByKey.get(mapKey)?.add(dayKey);
    });

  courseAttendanceManualByKey.forEach((manualDays, mapKey) => {
    const nextSet = daysByKey.get(mapKey) || new Set<string>();
    Object.entries(manualDays || {}).forEach(([dayKey, count]) => {
      if (!/^\d{4}-\d{2}-\d{2}$/.test(String(dayKey || ''))) return;
      if (Number(count || 0) <= 0) return;
      nextSet.add(String(dayKey));
    });
    if (nextSet.size > 0) {
      daysByKey.set(mapKey, nextSet);
    }
  });

  return daysByKey;
})();

const defaultAttendanceRange = (() => {
  const dayKeys = Array.from(
    new Set(
      attendanceSessionRows
        .map((session: any) => normalizeText(session?.dayKey || ''))
        .filter((dayKey) => /^\d{4}-\d{2}-\d{2}$/.test(dayKey)),
    ),
  ).sort();

  if (dayKeys.length > 0) {
    return {
      startDate: dayKeys[0],
      endDate: dayKeys[dayKeys.length - 1],
    };
  }

  const fallbackStart = `${activeYear || new Date().getFullYear()}-01-01`;
  const parsedFallbackStart = parseDateOnly(fallbackStart);
  const fallbackEnd = parsedFallbackStart ? formatDateOnly(addUtcDays(parsedFallbackStart, 27)) : fallbackStart;
  return {
    startDate: fallbackStart,
    endDate: fallbackEnd,
  };
})();

const activeAttendanceConfigKey = `${normalizeTextLower(activeCourseId)}::${activeYear}`;
const savedAttendanceConfig = courseAttendanceConfigByKey.get(activeAttendanceConfigKey);
const activeAttendanceConfig = {
  courseId: activeCourseId,
  year: activeYear,
  startDate: normalizeText(savedAttendanceConfig?.startDate || defaultAttendanceRange.startDate),
  endDate: normalizeText(savedAttendanceConfig?.endDate || defaultAttendanceRange.endDate),
};

const attendanceWeekGrid = buildAttendanceWeekGroups(
  activeAttendanceConfig.startDate,
  activeAttendanceConfig.endDate,
);

const attendanceLiveCountByStudentDayKey = (() => {
  const counts = new Map<string, number>();
  if (!isTeacher) return counts;

  scopedTeacherLiveAttendance
    .filter((attendance: any) => normalizeRole(attendance?.role) === 'student')
    .forEach((attendance: any) => {
      const userId = normalizeText(attendance?.userId || '');
      const session = scopedTeacherLiveSessionById.get(String(attendance?.sessionId || '')) || null;
      const courseId = canonicalizeCourseId(getLiveRecordCourseId(session || attendance));
      const year = getLiveSessionYear(session || attendance);
      const dayKey = getAttendanceDayKey(session, attendance);
      if (!userId || !courseId || !year || !dayKey) return;
      if (Number(attendance?.joinCount || 0) <= 0) return;

      const mapKey = `${normalizeTextLower(courseId)}::${year}::${userId}::${dayKey}`;
      counts.set(mapKey, (counts.get(mapKey) || 0) + 1);
    });

  return counts;
})();

const attendanceGridRows = (() => {
  if (!isTeacher) return [] as any[];
  const studentEnrollmentsById = new Map<string, any>();
  scopedTeacherEnrollments
    .filter((enrollment: any) => normalizeRole(enrollment?.roleInCourse) === 'student')
    .forEach((enrollment: any) => {
      const userId = normalizeText(enrollment?.userId || '');
      if (!userId || studentEnrollmentsById.has(userId)) return;
      studentEnrollmentsById.set(userId, enrollment);
    });

  return Array.from(studentEnrollmentsById.values())
    .map((enrollment: any) => {
      const userId = normalizeText(enrollment?.userId || '');
      const user = allUsersById.get(userId);
      const manualDays = courseAttendanceManualByKey.get(
        `${normalizeTextLower(activeCourseId)}::${activeYear}::${userId}`,
      ) || {};

      let totalLiveCount = 0;
      let totalManualCount = 0;
      const weeks = attendanceWeekGrid.weeks.map((week: any) => ({
        ...week,
        days: week.days.map((day: any) => {
          if (!day.inRange) {
            return {
              ...day,
              liveCount: 0,
              manualCount: 0,
              totalCount: 0,
            };
          }

          const liveCount = attendanceLiveCountByStudentDayKey.get(
            `${normalizeTextLower(activeCourseId)}::${activeYear}::${userId}::${day.dateKey}`,
          ) || 0;
          const manualCount = Math.max(0, Number(manualDays?.[day.dateKey] || 0));
          const totalCount = liveCount + manualCount;
          totalLiveCount += liveCount;
          totalManualCount += manualCount;

          return {
            ...day,
            liveCount,
            manualCount,
            totalCount,
          };
        }),
      }));

      return {
        userId,
        name: String(user?.name || user?.email || userId),
        email: String(user?.email || ''),
        daysAttended: weeks.reduce(
          (sum: number, week: any) =>
            sum + week.days.filter((day: any) => day.inRange && day.totalCount > 0).length,
          0,
        ),
        totalLiveCount,
        totalManualCount,
        totalCount: totalLiveCount + totalManualCount,
        weeks,
      };
    })
    .sort((left: any, right: any) => String(left.name || '').localeCompare(String(right.name || ''), 'es'));
})();

const attendanceLogSearchRows = attendanceLogRows.map((row: any) => ({
  ...row,
  search: [
    row.dayLabel,
    row.courseId,
    row.lessonLabel,
    row.displayName,
    row.email,
    row.identity,
    row.role,
    row.lastStatus,
  ]
    .map((value) => normalizeTextLower(value))
    .filter(Boolean)
    .join(' '),
}));

const buildSubmissionLogRows = (submissions: any[], options: { includeUser: boolean }) => {
  const includeUser = Boolean(options?.includeUser);
  return submissions
    .map((submission: any) => {
      const meta = resolveSubmissionMeta(submission);
      const scoreValue =
        submission?.score !== null && submission?.score !== undefined ? Number(submission.score) : null;
      const attempts = Number(submission?.attempts || 0);
      const submittedAt = normalizeText(submission?.submittedAt);
      const gradedAt = normalizeText(submission?.gradedAt);
      const feedback = normalizeText(submission?.feedback);
      const answerText = getSubmissionAnswerText(submission, assignmentById);
      const resultState = getSubmissionResultState(submission);
      const userRecord = includeUser
        ? (allUsers || []).find((user: any) => user.id === submission?.userId)
        : dbUser;
      const userName = normalizeText(userRecord?.name || userRecord?.email || submission?.userId || 'unknown');
      const userEmail = normalizeText(userRecord?.email || '');
      const payloadText = asJsonText(submission?.payload || null);
      const submittedAtTs = submittedAt ? new Date(submittedAt).getTime() : 0;
      const reviewed = isSubmissionReviewed(submission);
      const reviewDate = gradedAt || (reviewed ? submittedAt : '');
      const gradedAtTs = reviewDate ? new Date(reviewDate).getTime() : 0;

      const search = [
        submission?.id,
        submission?.assignmentId,
        meta.assignmentSlug,
        meta.assignmentLabel,
        meta.courseId,
        meta.evalType,
        meta.mode,
        meta.noteType,
        meta.noteTypeLabel,
        answerText,
        feedback,
        userName,
        userEmail,
        payloadText,
        meta?.evalPreview?.prompt,
        ...(Array.isArray(meta?.evalPreview?.options) ? meta.evalPreview.options : []),
      ]
        .map((value) => normalizeTextLower(value))
        .filter(Boolean)
        .join(' ');

      return {
        submissionId: String(submission?.id || ''),
        userId: String(submission?.userId || ''),
        userName,
        userEmail,
        assignmentId: String(submission?.assignmentId || ''),
        assignmentSlug: meta.assignmentSlug,
        assignmentLabel: meta.assignmentLabel,
        courseId: meta.courseId,
        evalType: meta.evalType,
        mode: meta.mode,
        noteType: meta.noteType,
        noteTypeLabel: meta.noteTypeLabel,
        noteTypeOrder: meta.noteTypeOrder,
        attempts,
        score: scoreValue,
        feedback,
        evalPreview: meta.evalPreview,
        evalPreviewAttr: toEvalPreviewAttr(meta.evalPreview),
        submittedAt,
        submittedAtTs,
        gradedAt: reviewDate,
        gradedAtTs,
        resultState,
        answerText,
        payloadText,
        reviewState: reviewed ? 'reviewed' : 'pending',
        submissionState: submittedAt ? 'submitted' : 'missing',
        catalogSource: normalizeText(meta.catalogEntry?.sourcePath || ''),
        search,
      };
    })
    .sort((a, b) => b.submittedAtTs - a.submittedAtTs);
};

const teacherLogRows = isTeacher ? buildSubmissionLogRows(scopedTeacherSubmissions, { includeUser: true }) : [];
const studentLogRows = !isTeacher ? buildSubmissionLogRows(scopedStudentSubmissions || [], { includeUser: false }) : [];
const activeLogRows = isTeacher ? teacherLogRows : studentLogRows;
const logEvalTypes = Array.from(new Set(activeLogRows.map((row) => row.evalType).filter(Boolean))).sort();
const logModes = Array.from(new Set(activeLogRows.map((row) => row.mode).filter(Boolean))).sort();
const logNoteTypes = Array.from(new Set(activeLogRows.map((row) => row.noteType).filter(Boolean))).sort(
  (left, right) => (EVAL_NOTE_TYPE_ORDER[left as EvalNoteType] || 99) - (EVAL_NOTE_TYPE_ORDER[right as EvalNoteType] || 99),
);
const getNoteTypeDisplay = (value: string) => EVAL_NOTE_TYPE_LABEL[(value as EvalNoteType) || 'unknown'] || value;
const dashboardLogData = {
  teacher: teacherLogRows,
  student: studentLogRows,
  filters: {
    evalTypes: logEvalTypes,
    modes: logModes,
    noteTypes: logNoteTypes.map((noteType) => ({
      value: noteType,
      label: getNoteTypeDisplay(noteType),
    })),
  },
};
const dashboardLogDataJson = JSON.stringify(dashboardLogData).replaceAll('<', '\\u003c');
