const attendanceDayCountByStudentKey = (() => {
  const daysByKey = new Map<string, Set<string>>();
  if (!isTeacher) return daysByKey;

  scopedLiveAttendance
    .filter((attendance: any) => normalizeRole(attendance?.role) === 'student')
    .forEach((attendance: any) => {
      const userId = String(attendance?.userId || '').trim();
      if (!userId || Number(attendance?.joinCount || 0) <= 0) return;
      const session = scopedLiveSessionById.get(String(attendance?.sessionId || '')) || null;
      const courseId = canonicalizeCourseId(getLiveRecordCourseId(session || attendance));
      const year = getLiveSessionYear(session || attendance);
      const dayKey = getAttendanceDayKey(session, attendance);
      if (!courseId || !year || !dayKey) return;

      const mapKey = `${normalizeTextLower(courseId)}::${year}::${userId}`;
      if (!daysByKey.has(mapKey)) daysByKey.set(mapKey, new Set<string>());
      daysByKey.get(mapKey)?.add(dayKey);
    });

  courseAttendanceManualByKey.forEach((manualDays, mapKey) => {
    const nextSet = daysByKey.get(mapKey) || new Set<string>();
    Object.entries(manualDays || {}).forEach(([dayKey, count]) => {
      if (!/^\d{4}-\d{2}-\d{2}$/.test(String(dayKey || ''))) return;
      if (Number(count || 0) <= 0) return;
      nextSet.add(String(dayKey));
    });
    if (nextSet.size > 0) {
      daysByKey.set(mapKey, nextSet);
    }
  });

  return daysByKey;
})();

const defaultAttendanceRange = (() => {
  const dayKeys = Array.from(
    new Set(
      attendanceSessionRows
        .map((session: any) => normalizeText(session?.dayKey || ''))
        .filter((dayKey) => /^\d{4}-\d{2}-\d{2}$/.test(dayKey)),
    ),
  ).sort();

  if (dayKeys.length > 0) {
    return {
      startDate: dayKeys[0],
      endDate: dayKeys[dayKeys.length - 1],
    };
  }

  const fallbackStart = `${activeYear || new Date().getFullYear()}-01-01`;
  const parsedFallbackStart = parseDateOnly(fallbackStart);
  const fallbackEnd = parsedFallbackStart ? formatDateOnly(addUtcDays(parsedFallbackStart, 7 * 14)) : fallbackStart;
  return {
    startDate: fallbackStart,
    endDate: fallbackEnd,
  };
})();

const activeAttendanceConfigKey = `${normalizeTextLower(activeCourseId)}::${activeYear}`;
const savedAttendanceConfig = courseAttendanceConfigByKey.get(activeAttendanceConfigKey);
const activeAttendanceConfig = {
  courseId: activeCourseId,
  year: activeYear,
  startDate: normalizeText(savedAttendanceConfig?.startDate || defaultAttendanceRange.startDate),
  endDate: normalizeText(savedAttendanceConfig?.endDate || defaultAttendanceRange.endDate),
};

const todayAttendanceDateKey = formatDateOnly(new Date()) || '';
const attendanceScheduleGrid = buildAttendanceScheduleColumns(
  activeAttendanceConfig.startDate,
  activeAttendanceConfig.endDate,
);

const attendanceLiveValueByStudentDayKey = (() => {
  const values = new Map<string, number>();
  if (!isTeacher) return values;

  scopedTeacherLiveAttendance
    .filter((attendance: any) => normalizeRole(attendance?.role) === 'student')
    .forEach((attendance: any) => {
      const userId = normalizeText(attendance?.userId || '');
      const session = scopedTeacherLiveSessionById.get(String(attendance?.sessionId || '')) || null;
      const courseId = canonicalizeCourseId(getLiveRecordCourseId(session || attendance));
      const year = getLiveSessionYear(session || attendance);
      const dayKey = getAttendanceDayKey(session, attendance);
      if (!userId || !courseId || !year || !dayKey) return;
      if (Number(attendance?.joinCount || 0) <= 0) return;

      const mapKey = `${normalizeTextLower(courseId)}::${year}::${userId}::${dayKey}`;
      values.set(mapKey, 1);
    });

  return values;
})();

const attendanceGridRows = (() => {
  if (!isTeacher) return [] as any[];
  const studentEnrollmentsById = new Map<string, any>();
  scopedTeacherEnrollments
    .filter((enrollment: any) => normalizeRole(enrollment?.roleInCourse) === 'student')
    .forEach((enrollment: any) => {
      const userId = normalizeText(enrollment?.userId || '');
      if (!userId || studentEnrollmentsById.has(userId)) return;
      studentEnrollmentsById.set(userId, enrollment);
    });

  return Array.from(studentEnrollmentsById.values())
    .map((enrollment: any) => {
      const userId = normalizeText(enrollment?.userId || '');
      const user = allUsersById.get(userId);
      const displayName = String(user?.name || user?.email || userId);
      const { firstName, lastName } = splitAttendanceName(displayName);
      const metaKey = `${normalizeTextLower(activeCourseId)}::${activeYear}::${userId}`;
      const savedMeta = courseStudentMetaByKey.get(metaKey);
      const manualDays = courseAttendanceManualByKey.get(metaKey) || {};
      const turnoRaw = normalizeText(savedMeta?.turno || enrollment?.turno || user?.turno || '').toUpperCase();
      const turnoValue = ['M', 'T', 'N'].includes(turnoRaw) ? turnoRaw : '—';
      const groupValue = normalizeText(
        savedMeta?.grupo
          || enrollment?.group
          || enrollment?.grupo
          || user?.group
          || user?.grupo
          || '',
      ) || '—';

      let absenceUnits = 0;
      const columns = attendanceScheduleGrid.columns.map((column: any) => {
        const liveValue = attendanceLiveValueByStudentDayKey.get(
          `${normalizeTextLower(activeCourseId)}::${activeYear}::${userId}::${column.dateKey}`,
        ) || 0;
        const hasManualOverride = Object.prototype.hasOwnProperty.call(manualDays, column.dateKey);
        const manualValue = hasManualOverride ? normalizeAttendanceValue(manualDays?.[column.dateKey]) : 0;
        const effectiveValue = hasManualOverride ? manualValue : liveValue;
        const absenceValue = column.dateKey <= todayAttendanceDateKey
          ? Math.max(0, 1 - effectiveValue)
          : 0;
        const isFuture = column.dateKey > todayAttendanceDateKey;
        const liveLabel = formatAttendanceValue(liveValue, { isFuture }) || '—';
        const manualLabel = hasManualOverride
          ? formatAttendanceValue(manualValue, { isFuture }) || '—'
          : 'auto';
        const effectiveLabel = formatAttendanceValue(effectiveValue, { isFuture }) || '—';

        absenceUnits += absenceValue;

        return {
          ...column,
          liveValue,
          manualValue,
          hasManualOverride,
          effectiveValue,
          absenceValue,
          displayValue: hasManualOverride
            ? formatAttendanceValue(manualValue, { isFuture })
            : formatAttendanceValue(liveValue, { isFuture }),
          title: `Room: ${liveLabel} • Override: ${manualLabel} • Final: ${effectiveLabel} • ${ATTENDANCE_VALUE_HELP}`,
        };
      });

      return {
        userId,
        name: displayName,
        firstName,
        lastName,
        email: String(user?.email || ''),
        turno: turnoValue,
        grupo: groupValue,
        absenceUnits,
        absenceDisplay: formatAbsenceValue(absenceUnits),
        rowState: absenceUnits >= 4 ? 'critical' : absenceUnits >= 3 ? 'warning' : '',
        columns,
      };
    })
    .sort((left: any, right: any) => {
      const lastNameDiff = String(left.lastName || '').localeCompare(String(right.lastName || ''), 'es');
      if (lastNameDiff !== 0) return lastNameDiff;
      return String(left.firstName || left.name || '').localeCompare(String(right.firstName || right.name || ''), 'es');
    });
})();

