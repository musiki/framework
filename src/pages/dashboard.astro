---
// src/pages/dashboard.astro
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import { createClient } from '@supabase/supabase-js';
import { createSupabaseServerClient } from '../lib/forum-server';
import {
  getResultIcon,
  getSubmissionAnswerText,
  getSubmissionResultState,
  isSubmissionReviewed,
} from '../lib/submission-table';
import { getEvalOptionMap } from '../lib/eval-option-map';
import {
  buildEvalCatalog,
  EVAL_NOTE_TYPE_LABEL,
  EVAL_NOTE_TYPE_ORDER,
  inferEvalNoteTypeFromSlug,
  resolveEvalCatalogEntry,
  type EvalNoteType,
} from '../lib/eval-catalog';
import { getCourseFrontmatterId } from '../lib/course-metadata';
import { normalizeActivityPageSlug } from '../lib/class-activity/model.mjs';
import { buildAttendanceProjection } from '../lib/dashboard/attendance-projection';
import { listDashboardAnnotations } from '../lib/dashboard/annotation-store';
import { buildAdminProjection } from '../lib/dashboard/admin-projection';
import { buildCommentsProjection } from '../lib/dashboard/comments-projection';
import { buildGradebookProjection } from '../lib/dashboard/gradebook-projection';
import { buildOverviewProjection } from '../lib/dashboard/overview-projection';
import { toDashboardProjectionJson } from '../lib/dashboard/shared';
import { getRoleBadgeLabel } from '../lib/dashboard-role';
import 'tabulator-tables/dist/css/tabulator.min.css';
import '../styles/theme.css';

// --- AUTHENTICATION ---
const session = Astro.locals.session as any;
const currentUser = session?.user;

if (!currentUser?.email) {
  return Astro.redirect('/login?redirect=/dashboard');
}

const dashboardUrl = new URL(Astro.request.url);
const requestedCourseParam = String(dashboardUrl.searchParams.get('course') || '').trim();
const requestedYearParam = String(dashboardUrl.searchParams.get('year') || '').trim();
const requestedTabParam = String(dashboardUrl.searchParams.get('tab') || '').trim().toLowerCase();

// Initialize Supabase
const supabase = createClient(import.meta.env.SUPABASE_URL, import.meta.env.SUPABASE_KEY);

const sessionEmail = String(currentUser.email || '').trim();
const normalizedSessionEmail = sessionEmail.toLowerCase();

const normalizeRole = (value) => String(value || '').trim().toLowerCase();

async function resolveDashboardUserByEmail(email, normalizedEmail) {
  const { data, error } = await supabase
    .from('User')
    .select('*')
    .ilike('email', normalizedEmail)
    .order('updatedAt', { ascending: false })
    .order('createdAt', { ascending: false });

  if (error) throw error;

  const rows = Array.isArray(data) ? data : [];
  if (rows.length === 0) return { user: null, rows: [] };
  if (rows.length === 1) return { user: rows[0], rows };

  // Prefer exact-case email match first, then normalized match, then most recently updated row.
  const exactCaseRows = rows.filter((row) => String(row?.email || '').trim() === email);
  if (exactCaseRows.length > 0) return { user: exactCaseRows[0], rows };

  const normalizedRows = rows.filter(
    (row) => String(row?.email || '').trim().toLowerCase() === normalizedEmail
  );
  if (normalizedRows.length > 0) return { user: normalizedRows[0], rows };

  return { user: rows[0], rows };
}

let dbUser = null;
let matchedUsers = [];
try {
  const resolved = await resolveDashboardUserByEmail(sessionEmail, normalizedSessionEmail);
  dbUser = resolved.user;
  matchedUsers = resolved.rows;
} catch (userResolveError) {
  console.error('Error resolving dashboard user:', userResolveError);
}

// If user doesn't exist in DB, create them (first login)
if (!dbUser) {
  const { data: newUsers, error } = await supabase.from('User').insert([{
    id: crypto.randomUUID(),
    email: normalizedSessionEmail,
    name: currentUser.name || normalizedSessionEmail,
    emailVerified: true,
    image: currentUser.image || null,
    role: 'student', // Default role
    createdAt: new Date(),
    updatedAt: new Date(),
  }]).select();
  
  if (error) console.error('Error creating user:', error);
  // Fetch the newly created user
  dbUser = newUsers?.[0];
  
  if (!dbUser) {
    return Astro.redirect('/login?redirect=/dashboard');
  }

  matchedUsers = [dbUser];
}

const dashboardUserIds = Array.from(
  new Set(
    (matchedUsers.length > 0 ? matchedUsers : [dbUser])
      .map((row) => row?.id)
      .filter(Boolean)
  )
);

let hasTeacherEnrollment = false;
if (dashboardUserIds.length > 0) {
  const { data: teacherEnrollments, error: teacherEnrollmentError } = await supabase
    .from('Enrollment')
    .select('userId, roleInCourse')
    .in('userId', dashboardUserIds)
    .limit(50);

  if (teacherEnrollmentError) {
    console.error('Error resolving teacher enrollment for dashboard user:', teacherEnrollmentError);
  } else {
    hasTeacherEnrollment =
      Array.isArray(teacherEnrollments) &&
      teacherEnrollments.some((row) => normalizeRole(row?.roleInCourse) === 'teacher');
  }
}

const hasTeacherRole = (matchedUsers.length > 0 ? matchedUsers : [dbUser]).some(
  (row) => normalizeRole(row?.role) === 'teacher'
);
const isTeacher = hasTeacherRole || hasTeacherEnrollment;
const initialTeacherDashboardTab = isTeacher && ['overview', 'gradebook', 'attendance', 'comments', 'admin'].includes(requestedTabParam)
  ? requestedTabParam
  : 'overview';

if (isTeacher && normalizeRole(dbUser?.role) !== 'teacher') {
  const teacherRow = matchedUsers.find((row) => normalizeRole(row?.role) === 'teacher');
  if (teacherRow) {
    dbUser = teacherRow;
  } else if (dashboardUserIds.length > 0) {
    const preferredTeacherEnrollmentId = dashboardUserIds[0];
    const enrollmentMatchedUser = matchedUsers.find((row) => row?.id === preferredTeacherEnrollmentId);
    if (enrollmentMatchedUser) {
      dbUser = enrollmentMatchedUser;
    }
  }
}

// --- TEACHER DASHBOARD ---
let allUsers, allEnrollments, allSubmissions, allAssignments;
let allLiveClassSessions: any[] = [];
let allLiveClassAttendance: any[] = [];

if (isTeacher) {
  // Query all data for teacher view
  const { data: u } = await supabase.from('User').select('*'); allUsers = u || [];
  const { data: e } = await supabase.from('Enrollment').select('*'); allEnrollments = e || [];
  const { data: s } = await supabase.from('Submission').select('*').order('submittedAt', { ascending: false }); allSubmissions = s || [];
  const { data: a } = await supabase.from('Assignment').select('*'); allAssignments = a || [];

  try {
    const attendanceSupabase = createSupabaseServerClient({ requireServiceRole: true });
    const { data: liveSessions, error: liveSessionsError } = await attendanceSupabase
      .from('LiveClassSession')
      .select('*')
      .order('startedAt', { ascending: false });
    if (liveSessionsError) {
      console.error('Error loading LiveClassSession rows:', liveSessionsError);
    } else {
      allLiveClassSessions = liveSessions || [];
    }

    const { data: liveAttendance, error: liveAttendanceError } = await attendanceSupabase
      .from('LiveClassAttendance')
      .select('*')
      .order('lastEventAt', { ascending: false });
    if (liveAttendanceError) {
      console.error('Error loading LiveClassAttendance rows:', liveAttendanceError);
    } else {
      allLiveClassAttendance = liveAttendance || [];
    }
  } catch (error) {
    console.error('Error initializing attendance dashboard queries:', error);
  }
}

// --- STUDENT DASHBOARD ---
let studentAssignments: any[] = [];
let studentSubmissions: any[] = [];

let enrollmentQuery = supabase.from('Enrollment').select('courseId');
if (dashboardUserIds.length > 1) {
  enrollmentQuery = enrollmentQuery.in('userId', dashboardUserIds);
} else {
  enrollmentQuery = enrollmentQuery.eq('userId', dbUser.id);
}
const { data: userEnrollmentsData } = await enrollmentQuery;

const userEnrollments = userEnrollmentsData || [];
const enrolledCourseIds = userEnrollments.map((e: any) => e.courseId);

if (!isTeacher) {
  if (enrolledCourseIds.length > 0) {
    const { data: a } = await supabase
      .from('Assignment')
      .select('id, courseId, slug')
      .in('courseId', enrolledCourseIds);
    studentAssignments = a || [];
  }

  let studentSubmissionQuery = supabase
    .from('Submission')
    .select('*')
    .order('submittedAt', { ascending: false });
  if (dashboardUserIds.length > 1) {
    studentSubmissionQuery = studentSubmissionQuery.in('userId', dashboardUserIds);
  } else {
    studentSubmissionQuery = studentSubmissionQuery.eq('userId', dbUser.id);
  }

  const { data: s } = await studentSubmissionQuery;
  studentSubmissions = s || [];

  try {
    const attendanceSupabase = createSupabaseServerClient({ requireServiceRole: true });
    let liveAttendanceQuery = attendanceSupabase
      .from('LiveClassAttendance')
      .select('*')
      .order('lastEventAt', { ascending: false });

    if (dashboardUserIds.length > 1) {
      liveAttendanceQuery = liveAttendanceQuery.in('userId', dashboardUserIds);
    } else {
      liveAttendanceQuery = liveAttendanceQuery.eq('userId', dbUser.id);
    }

    const { data: liveAttendance, error: liveAttendanceError } = await liveAttendanceQuery;
    if (liveAttendanceError) {
      console.error('Error loading student LiveClassAttendance rows:', liveAttendanceError);
    } else {
      allLiveClassAttendance = liveAttendance || [];
    }

    const sessionIds = Array.from(
      new Set(
        (allLiveClassAttendance || [])
          .map((attendance: any) => String(attendance?.sessionId || '').trim())
          .filter(Boolean),
      ),
    );

    if (sessionIds.length > 0) {
      const { data: liveSessions, error: liveSessionsError } = await attendanceSupabase
        .from('LiveClassSession')
        .select('*')
        .in('id', sessionIds)
        .order('startedAt', { ascending: false });

      if (liveSessionsError) {
        console.error('Error loading student LiveClassSession rows:', liveSessionsError);
      } else {
        allLiveClassSessions = liveSessions || [];
      }
    }
  } catch (error) {
    console.error('Error initializing student attendance dashboard queries:', error);
  }
}

const studentAssignmentById = new Map<string, any>(
  (studentAssignments || []).map((assignment: any) => [assignment.id, assignment]),
);

// --- LOAD COURSES FROM FILES ---
// Use import.meta.glob for robust file finding in production/Vercel
const courseFiles = import.meta.glob('/src/content/cursos/**/_index.{md,mdx}', { eager: true });

const courseEntries = Object.entries(courseFiles).map(([filepath, module]: any) => {
  const fm = module.frontmatter;
  
  // Only process files explicitly marked as courses
  if (fm.type !== 'course') return null;

  // Extract courseId from path (e.g., /src/content/cursos/my-course/_index.md -> my-course)
  const parts = filepath.split('/');
  // Assuming structure is .../cursos/[courseId]/_index.md
  const courseId = parts[parts.length - 2];

  return {
    slug: courseId, // The slug for the course page
    courseId: courseId,
    title: fm.title || courseId,
    code: getCourseFrontmatterId(fm, courseId),
    // Support multiple image keys
    img: fm.coverImage || fm.img || fm.coverUrl || fm.image || '', 
    tags: Array.isArray(fm.tags) 
      ? fm.tags 
      : (fm.tags ? String(fm.tags).split(',').map(s => s.trim()) : [])
  };
}).filter(Boolean);

const evalOptionMap = await getEvalOptionMap();
const assignmentById = new Map<string, any>(
  (allAssignments || []).map((assignment: any) => {
    const fallbackOptions = evalOptionMap.get(assignment.id);
    return [assignment.id, fallbackOptions ? { ...assignment, options: fallbackOptions } : assignment];
  }),
);
for (const [evalId, options] of evalOptionMap.entries()) {
  if (!assignmentById.has(evalId)) {
    assignmentById.set(evalId, { id: evalId, options });
  }
}

const formatSubmissionDate = (value: string | null | undefined) => {
  if (!value) return '—';
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return '—';
  return date.toLocaleString('es-ES', {
    day: '2-digit',
    month: '2-digit',
    year: '2-digit',
    hour: '2-digit',
    minute: '2-digit',
  });
};

const decodeUriSafe = (value: string | null | undefined) => {
  if (!value) return '';
  try {
    return decodeURIComponent(value);
  } catch {
    return value;
  }
};

const normalizeText = (value: unknown) => String(value || '').trim();
const normalizeTextLower = (value: unknown) => normalizeText(value).toLowerCase();

const asPayloadObject = (value: unknown): Record<string, any> => {
  if (!value || typeof value !== 'object' || Array.isArray(value)) return {};
  return value as Record<string, any>;
};

const COURSE_STUDENT_META_KIND = 'course_student_profile';
const COURSE_ATTENDANCE_CONFIG_META_KIND = 'course_attendance_config';
const COURSE_ATTENDANCE_MANUAL_META_KIND = 'course_attendance_manual';

const normalizeCourseId = (value: unknown) => {
  const raw = normalizeText(value);
  if (!raw) return '';
  try {
    return decodeURIComponent(raw);
  } catch {
    return raw;
  }
};

const toCourseAliasSlug = (value: unknown) =>
  String(value || '')
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '');

const courseCanonicalByAlias = new Map<string, string>();
for (const course of courseEntries) {
  const canonical = normalizeCourseId(course?.courseId);
  if (!canonical) continue;
  courseCanonicalByAlias.set(normalizeTextLower(canonical), canonical);
  const canonicalSlugAlias = toCourseAliasSlug(canonical);
  if (canonicalSlugAlias) {
    courseCanonicalByAlias.set(canonicalSlugAlias, canonical);
  }
  const codeAlias = normalizeText(course?.code || '');
  if (codeAlias) {
    courseCanonicalByAlias.set(normalizeTextLower(codeAlias), canonical);
  }
  const titleAlias = toCourseAliasSlug(course?.title || '');
  if (titleAlias) {
    courseCanonicalByAlias.set(titleAlias, canonical);
  }
}

const canonicalizeCourseId = (value: unknown) => {
  const normalized = normalizeCourseId(value);
  if (!normalized) return '';
  return courseCanonicalByAlias.get(normalizeTextLower(normalized)) || normalized;
};

const catalogCourseIds = new Set(
  courseEntries
    .map((course: any) => canonicalizeCourseId(course?.courseId))
    .filter(Boolean),
);

const isCatalogCourseId = (value: unknown) => {
  const courseId = canonicalizeCourseId(value);
  return Boolean(courseId) && catalogCourseIds.has(courseId);
};

const deriveCourseIdFromPageSlug = (value: unknown) => {
  const normalized = normalizeActivityPageSlug(normalizeText(value));
  if (!normalized) return '';
  const firstSegment = normalized.split('/').find(Boolean) || '';
  return canonicalizeCourseId(firstSegment);
};

const getLiveRecordCourseId = (record: any) =>
  canonicalizeCourseId(record?.courseId) || deriveCourseIdFromPageSlug(record?.pageSlug);

const isTeacherOwnedLiveSession = (session: any) => {
  const sessionCourseId = getLiveRecordCourseId(session);
  if (sessionCourseId && teacherManagedCourseIds.has(normalizeTextLower(sessionCourseId))) {
    return true;
  }

  const teacherUserId = String(session?.teacherUserId || '').trim();
  return Boolean(teacherUserId) && dashboardUserIds.includes(teacherUserId);
};

const getSubmissionYear = (submission: any) => {
  const directYear = normalizeText(
    asPayloadObject(submission?.payload)?.year
      || asPayloadObject(submission?.payload)?.academicYear
      || '',
  );
  if (/^\d{4}$/.test(directYear)) return directYear;

  const dateCandidates = [submission?.submittedAt, submission?.gradedAt, submission?.createdAt];
  for (const candidate of dateCandidates) {
    const parsed = new Date(String(candidate || ''));
    if (!Number.isNaN(parsed.getTime())) return String(parsed.getFullYear());
  }

  return String(new Date().getFullYear());
};

const getEnrollmentYear = (enrollment: any) => {
  const directYear = normalizeText(
    enrollment?.year
      || enrollment?.academicYear
      || enrollment?.cohortYear
      || enrollment?.periodYear
      || '',
  );
  if (/^\d{4}$/.test(directYear)) return directYear;

  const dateCandidates = [enrollment?.createdAt, enrollment?.updatedAt, enrollment?.enrolledAt];
  for (const candidate of dateCandidates) {
    const parsed = new Date(String(candidate || ''));
    if (!Number.isNaN(parsed.getTime())) return String(parsed.getFullYear());
  }

  return String(new Date().getFullYear());
};

const getLiveSessionYear = (session: any) => {
  const dateCandidates = [session?.startedAt, session?.finishedAt, session?.lastEventAt, session?.createdAt];
  for (const candidate of dateCandidates) {
    const parsed = new Date(String(candidate || ''));
    if (!Number.isNaN(parsed.getTime())) return String(parsed.getFullYear());
  }

  return String(new Date().getFullYear());
};

const getDateTimestamp = (value: unknown) => {
  const parsed = new Date(String(value || ''));
  if (Number.isNaN(parsed.getTime())) return 0;
  return parsed.getTime();
};

const formatDurationFromMs = (value: unknown) => {
  const ms = Number(value || 0);
  if (!Number.isFinite(ms) || ms <= 0) return '—';

  const totalSeconds = Math.max(0, Math.round(ms / 1000));
  const hours = Math.floor(totalSeconds / 3600);
  const minutes = Math.floor((totalSeconds % 3600) / 60);
  const seconds = totalSeconds % 60;

  if (hours > 0) {
    return `${hours}:${String(minutes).padStart(2, '0')}:${String(seconds).padStart(2, '0')}`;
  }

  return `${minutes}:${String(seconds).padStart(2, '0')}`;
};

const getAttendanceDayKey = (session: any, attendance: any) => {
  const value =
    session?.startedAt
    || attendance?.firstJoinedAt
    || attendance?.lastEventAt
    || attendance?.lastLeftAt
    || attendance?.createdAt
    || '';
  const parsed = new Date(String(value || ''));
  if (Number.isNaN(parsed.getTime())) return '';
  const year = parsed.getFullYear();
  const month = String(parsed.getMonth() + 1).padStart(2, '0');
  const day = String(parsed.getDate()).padStart(2, '0');
  return `${year}-${month}-${day}`;
};

const formatAttendanceDayLabel = (value: string) => {
  if (!/^\d{4}-\d{2}-\d{2}$/.test(String(value || ''))) return 'Sin fecha';
  const [year, month, day] = String(value).split('-').map(Number);
  const parsed = new Date(year, (month || 1) - 1, day || 1);
  if (Number.isNaN(parsed.getTime())) return 'Sin fecha';
  return parsed.toLocaleDateString('es-ES', {
    weekday: 'short',
    day: '2-digit',
    month: '2-digit',
    year: 'numeric',
  });
};

const computeAttendanceDurationMs = (attendance: any, session: any) => {
  const startedAt = getDateTimestamp(attendance?.firstJoinedAt);
  const endedAt =
    getDateTimestamp(attendance?.lastLeftAt)
    || getDateTimestamp(attendance?.lastEventAt)
    || getDateTimestamp(session?.finishedAt)
    || getDateTimestamp(session?.lastEventAt);

  if (!startedAt || !endedAt || endedAt <= startedAt) return 0;
  return endedAt - startedAt;
};

const parseDateOnly = (value: unknown) => {
  const raw = normalizeText(value);
  if (!/^\d{4}-\d{2}-\d{2}$/.test(raw)) return null;
  const parsed = new Date(`${raw}T12:00:00Z`);
  if (Number.isNaN(parsed.getTime())) return null;
  return parsed;
};

const formatDateOnly = (value: Date | null | undefined) => {
  if (!(value instanceof Date) || Number.isNaN(value.getTime())) return '';
  const year = value.getUTCFullYear();
  const month = String(value.getUTCMonth() + 1).padStart(2, '0');
  const day = String(value.getUTCDate()).padStart(2, '0');
  return `${year}-${month}-${day}`;
};

const addUtcDays = (value: Date, amount: number) => {
  const next = new Date(value.getTime());
  next.setUTCDate(next.getUTCDate() + amount);
  return next;
};

const formatAttendanceGridDayLabel = (value: string) => {
  const parsed = parseDateOnly(value);
  if (!parsed) return value;
  return parsed.toLocaleDateString('es-ES', {
    weekday: 'short',
    day: '2-digit',
    month: '2-digit',
    timeZone: 'UTC',
  });
};

const ATTENDANCE_VALUE_HELP = 'Input: / o 1 -> ✔ • -, ~ o 0.5 -> ~ • x o 0 -> ✖';

const normalizeAttendanceValue = (value: unknown) => {
  const raw = normalizeText(String(value ?? '').replace(',', '.')).toLowerCase();
  if (!raw) return 0;
  if (raw === '/' || raw === '1' || raw === '✔') return 1;
  if (raw === '-' || raw === '~' || raw === '0.5' || raw === '.5') return 0.5;
  if (raw === 'x' || raw === '0' || raw === '✖') return 0;
  const parsed = Number(raw);
  if (!Number.isFinite(parsed)) return 0;
  const clamped = Math.max(0, Math.min(1, parsed));
  return Math.round(clamped * 2) / 2;
};

const formatAttendanceValue = (value: unknown, options: { isFuture?: boolean } = {}) => {
  const normalized = normalizeAttendanceValue(value);
  if (options.isFuture && normalized <= 0) return '';
  if (normalized >= 1) return '✔';
  if (normalized > 0) return '~';
  return '✖';
};

const formatAbsenceValue = (value: unknown) => {
  const parsed = Number(value);
  if (!Number.isFinite(parsed) || parsed <= 0) return '0';
  const normalized = Math.round(parsed * 2) / 2;
  return Number.isInteger(normalized) ? String(normalized) : normalized.toFixed(1).replace(/\.0$/, '');
};

const splitAttendanceName = (value: unknown) => {
  const normalized = normalizeText(value);
  if (!normalized) {
    return { firstName: '—', lastName: '' };
  }

  const parts = normalized.split(/\s+/).filter(Boolean);
  if (parts.length <= 1) {
    return {
      firstName: parts[0] || normalized,
      lastName: '',
    };
  }

  return {
    firstName: parts[0] || normalized,
    lastName: parts.slice(1).join(' '),
  };
};

const buildAttendanceScheduleColumns = (startDateValue: string, endDateValue: string) => {
  const parsedStart = parseDateOnly(startDateValue);
  const parsedEnd = parseDateOnly(endDateValue);
  if (!parsedStart || !parsedEnd) {
    return {
      startDate: '',
      endDate: '',
      columns: [] as any[],
    };
  }

  const normalizedStart = parsedStart.getTime() <= parsedEnd.getTime() ? parsedStart : parsedEnd;
  const normalizedEnd = parsedStart.getTime() <= parsedEnd.getTime() ? parsedEnd : parsedStart;
  const columns: any[] = [];
  let cursor = normalizedStart;

  while (cursor.getTime() <= normalizedEnd.getTime()) {
    const dateKey = formatDateOnly(cursor);
    columns.push({
      dateKey,
      label: formatAttendanceGridDayLabel(dateKey),
      isoWeekday: cursor.getUTCDay() || 7,
    });
    cursor = addUtcDays(cursor, 7);
  }

  return {
    startDate: formatDateOnly(normalizedStart),
    endDate: formatDateOnly(normalizedEnd),
    columns,
  };
};

const buildCourseLessonGroups = (assignmentsByPage: Record<string, any[]>) =>
  Object.entries(assignmentsByPage || {})
    .sort(([left], [right]) => String(left).localeCompare(String(right), 'es'))
    .map(([lessonSlug, lessonAssignments]) => {
      const sortedAssignments = [...(Array.isArray(lessonAssignments) ? lessonAssignments : [])].sort((left: any, right: any) => {
        const leftLabel = decodeUriSafe(String(left?.id || '')).toLowerCase();
        const rightLabel = decodeUriSafe(String(right?.id || '')).toLowerCase();
        return leftLabel.localeCompare(rightLabel, 'es');
      });

      return {
        lessonSlug: String(lessonSlug || ''),
        lessonLabel: decodeUriSafe(String(lessonSlug || '')),
        assignments: sortedAssignments,
      };
    });

const groupCourseAssignmentsByPage = (courseAssignments: any[], courseId: string) => {
  const groups: Record<string, any[]> = {};

  (Array.isArray(courseAssignments) ? courseAssignments : []).forEach((assignment: any) => {
    const assignmentSlug = String(assignment?.slug || assignment?.id || '').replace(/^\/+|\/+$/g, '');
    const slugParts = assignmentSlug.split('/').filter(Boolean);
    const slugCourseId = canonicalizeCourseId(slugParts[0] || '');
    const pageSlug = slugCourseId === courseId
      ? slugParts.slice(1).join('/')
      : assignmentSlug;
    const pageKey = pageSlug || 'other';
    if (!groups[pageKey]) groups[pageKey] = [];
    groups[pageKey].push(assignment);
  });

  return groups;
};

const getSubmissionMetaKind = (submission: any) => {
  const payload = asPayloadObject(submission?.payload);
  return normalizeTextLower(payload?.__metaKind || payload?.metaKind || '');
};

const isCourseStudentMetaSubmission = (submission: any) => {
  return getSubmissionMetaKind(submission) === COURSE_STUDENT_META_KIND;
};

const isCourseAttendanceConfigSubmission = (submission: any) =>
  getSubmissionMetaKind(submission) === COURSE_ATTENDANCE_CONFIG_META_KIND;

const isCourseAttendanceManualSubmission = (submission: any) =>
  getSubmissionMetaKind(submission) === COURSE_ATTENDANCE_MANUAL_META_KIND;

const isKnownCourseMetaSubmission = (submission: any) =>
  isCourseStudentMetaSubmission(submission)
  || isCourseAttendanceConfigSubmission(submission)
  || isCourseAttendanceManualSubmission(submission);

const isSystemMetaAssignmentRef = (value: unknown) => {
  const normalized = String(value || '').trim().replace(/^\/+|\/+$/g, '');
  if (!normalized) return false;
  return normalized.includes('/__meta__/') || normalized.startsWith('__meta__:');
};

const isVisibleCourseDeliveryAssignment = (assignment: any) => {
  if (!assignment || typeof assignment !== 'object') return false;
  return !isSystemMetaAssignmentRef(assignment?.slug || assignment?.id || '');
};

const asJsonText = (value: unknown) => {
  try {
    return JSON.stringify(value ?? null);
  } catch {
    return '';
  }
};

const toPreviewOptions = (value: unknown): string[] => {
  if (!Array.isArray(value)) return [];
  return value
    .map((option) => {
      if (typeof option === 'string') return normalizeText(option);
      if (option && typeof option === 'object') {
        const optionObject = option as Record<string, unknown>;
        return normalizeText(
          optionObject.text
            || optionObject.label
            || optionObject.value
            || optionObject.id
            || '',
        );
      }
      return '';
    })
    .filter(Boolean);
};

const buildEvalPreview = ({
  evalId,
  evalType,
  mode,
  prompt,
  options,
}: {
  evalId: string;
  evalType: string;
  mode: string;
  prompt: string;
  options: string[];
}) => ({
  id: normalizeText(evalId || '-'),
  type: normalizeText(evalType || 'unknown') || 'unknown',
  mode: normalizeText(mode || 'unknown') || 'unknown',
  prompt: normalizeText(prompt || ''),
  options: Array.isArray(options) ? options.map((item) => normalizeText(item)).filter(Boolean) : [],
});

const toEvalPreviewAttr = (value: unknown) => {
  try {
    return encodeURIComponent(JSON.stringify(value ?? {}));
  } catch {
    return '';
  }
};

const teacherManagedCourseIds = new Set<string>();
const teacherManagedCourseIdsRaw = new Set<string>();
if (isTeacher && Array.isArray(allEnrollments)) {
  allEnrollments
    .filter(
      (enrollment: any) =>
        dashboardUserIds.includes(enrollment.userId) &&
        normalizeRole(enrollment?.roleInCourse) === 'teacher',
    )
    .forEach((enrollment: any) => {
      const rawCourseId = canonicalizeCourseId(enrollment?.courseId);
      if (!rawCourseId || !catalogCourseIds.has(rawCourseId)) return;
      const normalizedCourseId = normalizeTextLower(rawCourseId);
      if (normalizedCourseId) teacherManagedCourseIds.add(normalizedCourseId);
      if (rawCourseId) teacherManagedCourseIdsRaw.add(rawCourseId);
    });
}

const teacherMetaSubmissions = isTeacher
  ? (allSubmissions || []).filter((submission: any) => isKnownCourseMetaSubmission(submission))
  : [];
const teacherDataSubmissions = isTeacher
  ? (allSubmissions || []).filter((submission: any) => !isKnownCourseMetaSubmission(submission))
  : [];

if (!isTeacher) {
  studentSubmissions = (studentSubmissions || []).filter((submission: any) => !isKnownCourseMetaSubmission(submission));
}

const courseStudentMetaByKey = new Map<string, { turno: string; concepto: string; grupo: string }>();
const courseAttendanceConfigByKey = new Map<string, { startDate: string; endDate: string; updatedAt: string }>();
const courseAttendanceManualByKey = new Map<string, Record<string, number>>();
if (isTeacher) {
  teacherMetaSubmissions.forEach((submission: any) => {
    const metaKind = getSubmissionMetaKind(submission);
    const payload = asPayloadObject(submission?.payload);
    const courseId = canonicalizeCourseId(payload?.courseId || payload?.course || payload?.courseSlug);
    const year = normalizeText(payload?.year || getSubmissionYear(submission));
    if (!courseId || !year) return;

    if (metaKind === COURSE_STUDENT_META_KIND) {
      const studentId = normalizeText(payload?.studentId || submission?.userId);
      if (!studentId) return;

      courseStudentMetaByKey.set(
        `${normalizeTextLower(courseId)}::${year}::${studentId}`,
        {
          turno: normalizeText(payload?.turno || '').toUpperCase(),
          concepto: normalizeText(payload?.concepto || payload?.concept || ''),
          grupo: normalizeText(payload?.grupo || payload?.group || ''),
        },
      );
      return;
    }

    if (metaKind === COURSE_ATTENDANCE_CONFIG_META_KIND) {
      const mapKey = `${normalizeTextLower(courseId)}::${year}`;
      const nextConfig = {
        startDate: normalizeText(payload?.startDate || ''),
        endDate: normalizeText(payload?.endDate || ''),
        updatedAt: normalizeText(payload?.updatedAt || submission?.submittedAt || ''),
      };
      const existingConfig = courseAttendanceConfigByKey.get(mapKey);
      if (!existingConfig || getDateTimestamp(nextConfig.updatedAt) >= getDateTimestamp(existingConfig.updatedAt)) {
        courseAttendanceConfigByKey.set(mapKey, nextConfig);
      }
      return;
    }

    if (metaKind === COURSE_ATTENDANCE_MANUAL_META_KIND) {
      const studentId = normalizeText(payload?.studentId || submission?.userId);
      if (!studentId) return;
      const manualDaysPayload = asPayloadObject(payload?.manualDays || payload?.dates || {});
      const normalizedManualDays = Object.fromEntries(
        Object.entries(manualDaysPayload)
          .map(([dateKey, countValue]) => {
            const date = normalizeText(dateKey);
            if (!/^\d{4}-\d{2}-\d{2}$/.test(date)) {
              return [null, null];
            }
            return [date, normalizeAttendanceValue(countValue)];
          })
          .filter(([dateKey, countValue]) => Boolean(dateKey) && countValue !== null),
      );
      courseAttendanceManualByKey.set(
        `${normalizeTextLower(courseId)}::${year}::${studentId}`,
        normalizedManualDays,
      );
    }
  });
}

const evalCatalog = await buildEvalCatalog();
const liveEvalEntries = Array.from(evalCatalog.entries())
  .map(([evalId, entries]) => {
    const entry = resolveEvalCatalogEntry(entries, '') || entries[0] || null;
    if (!entry) return null;
    const canonicalCourseId = canonicalizeCourseId(entry.courseId || entry.entryId.split('/')[0] || '');
    return {
      ...entry,
      evalId,
      canonicalCourseId,
    };
  })
  .filter(Boolean);
const liveEvalEntryById = new Map(
  liveEvalEntries.map((entry: any) => [String(entry.evalId || ''), entry]),
);
const liveEvalEntriesByCourseId = liveEvalEntries.reduce((acc, entry: any) => {
  const courseId = canonicalizeCourseId(entry?.canonicalCourseId || entry?.courseId || '');
  if (!courseId) return acc;
  if (!acc[courseId]) acc[courseId] = [];
  acc[courseId].push(entry);
  return acc;
}, {} as Record<string, any[]>);

const resolveSubmissionMeta = (submission: any) => {
  const assignment = assignmentById.get(submission.assignmentId);
  const assignmentSlug = String(assignment?.slug || submission.assignmentId || '');
  const assignmentCourseId = canonicalizeCourseId(assignment?.courseId);
  const inferredNoteType = inferEvalNoteTypeFromSlug(assignmentSlug, assignmentCourseId) as EvalNoteType;
  const catalogEntries = evalCatalog.get(String(submission.assignmentId || '')) || [];
  const catalogEntry = resolveEvalCatalogEntry(catalogEntries, assignmentSlug);
  const payload = asPayloadObject(submission?.payload);
  const payloadCourseId = canonicalizeCourseId(payload.courseId || payload.course || payload.courseSlug);
  const catalogCourseId = canonicalizeCourseId(catalogEntry?.courseId);
  const slugCourseId = canonicalizeCourseId(assignmentSlug.split('/')[0]);
  const resolvedCourseIdRaw =
    assignmentCourseId || catalogCourseId || payloadCourseId || slugCourseId || 'sin-curso';

  const noteType = (catalogEntry?.noteType || inferredNoteType || 'unknown') as EvalNoteType;
  const noteTypeLabel = EVAL_NOTE_TYPE_LABEL[noteType] || EVAL_NOTE_TYPE_LABEL.unknown;
  const noteTypeOrder = EVAL_NOTE_TYPE_ORDER[noteType] || EVAL_NOTE_TYPE_ORDER.unknown;
  const evalType = normalizeText(catalogEntry?.evalType || payload.type || 'unknown') || 'unknown';
  const mode = normalizeText(catalogEntry?.mode || payload.mode || 'unknown') || 'unknown';
  const previewPrompt = normalizeText(catalogEntry?.prompt || payload.prompt || payload.question || payload.title || '');
  const previewOptions = toPreviewOptions(
    catalogEntry?.options || payload.options || payload.choices || payload.answers || [],
  );
  const evalPreview = buildEvalPreview({
    evalId: String(submission?.assignmentId || ''),
    evalType,
    mode,
    prompt: previewPrompt,
    options: previewOptions,
  });

  return {
    assignment,
    assignmentSlug,
    assignmentLabel: decodeUriSafe(assignmentSlug.split('/').pop() || assignmentSlug || String(submission.assignmentId || '')),
    courseId: decodeUriSafe(canonicalizeCourseId(resolvedCourseIdRaw) || resolvedCourseIdRaw),
    courseIdRaw: resolvedCourseIdRaw,
    courseIdKey: normalizeTextLower(canonicalizeCourseId(resolvedCourseIdRaw) || resolvedCourseIdRaw),
    noteType,
    noteTypeLabel,
    noteTypeOrder,
    evalType,
    mode,
    catalogEntry,
    payload,
    evalPreview,
  };
};

const teacherScopedSubmissions = isTeacher
  ? (teacherDataSubmissions || []).filter((submission: any) => {
      if (teacherManagedCourseIds.size === 0) return false;
      const meta = resolveSubmissionMeta(submission);
      const courseIdKey = normalizeTextLower(meta?.courseIdRaw || meta?.courseId || '');
      if (!courseIdKey || courseIdKey === 'sin-curso') return true;
      return teacherManagedCourseIds.has(courseIdKey);
    })
  : [];

const availableCourseIds = (() => {
  if (isTeacher) {
    if (teacherManagedCourseIdsRaw.size > 0) {
      return Array.from(
        new Set(
          Array.from(teacherManagedCourseIdsRaw)
            .map((courseId) => canonicalizeCourseId(courseId))
            .filter((courseId) => isCatalogCourseId(courseId))
            .filter(Boolean),
        ),
      );
    }
    return [];
  }

  return Array.from(
    new Set(
      (userEnrollments || [])
        .map((enrollment: any) => canonicalizeCourseId(enrollment?.courseId))
        .filter((courseId) => isCatalogCourseId(courseId))
        .filter(Boolean),
    ),
  );
})();

const availableCourseMeta = availableCourseIds
  .map((courseId) => {
    const entry = courseEntries.find((course: any) => canonicalizeCourseId(course?.courseId) === courseId);
    return {
      courseId,
      title: String(entry?.title || decodeUriSafe(courseId)),
      code: String(entry?.code || '').trim(),
    };
  })
  .sort((left, right) => String(left.title || '').localeCompare(String(right.title || ''), 'es'));

const selectedCourseId = canonicalizeCourseId(requestedCourseParam);
const activeCourseId = availableCourseMeta.some((course) => course.courseId === selectedCourseId)
  ? selectedCourseId
  : String(availableCourseMeta[0]?.courseId || '');
const activeCourseMeta = availableCourseMeta.find((course) => course.courseId === activeCourseId) || null;
const activeCourseCode = String(activeCourseMeta?.code || '').trim();

const activeCourseSubmissions = (() => {
  if (!activeCourseId) {
    return isTeacher ? teacherScopedSubmissions : studentSubmissions;
  }

  const source = isTeacher ? teacherScopedSubmissions : studentSubmissions;
  return (source || []).filter((submission: any) => {
    const meta = resolveSubmissionMeta(submission);
    const submissionCourseId = canonicalizeCourseId(meta?.courseIdRaw || meta?.courseId || '');
    return submissionCourseId === activeCourseId;
  });
})();

const availableYears = (() => {
  const yearSet = new Set<string>();

  const enrollmentSource = isTeacher
    ? (allEnrollments || [])
    : (userEnrollments || []);
  enrollmentSource.forEach((enrollment: any) => {
    const enrollmentCourseId = canonicalizeCourseId(enrollment?.courseId);
    if (activeCourseId && enrollmentCourseId !== activeCourseId) return;
    yearSet.add(getEnrollmentYear(enrollment));
  });

  (activeCourseSubmissions || []).forEach((submission: any) => {
    yearSet.add(getSubmissionYear(submission));
  });

  if (isTeacher) {
    (allLiveClassSessions || []).forEach((session: any) => {
      const sessionCourseId = canonicalizeCourseId(getLiveRecordCourseId(session));
      if (!sessionCourseId || !teacherManagedCourseIds.has(normalizeTextLower(sessionCourseId))) return;
      if (activeCourseId && sessionCourseId !== activeCourseId) return;
      yearSet.add(getLiveSessionYear(session));
    });
  }

  const years = Array.from(yearSet)
    .filter((year) => /^\d{4}$/.test(String(year || '')))
    .sort((left, right) => Number(right) - Number(left));
  if (years.length === 0) {
    years.push(String(new Date().getFullYear()));
  }
  return years;
})();

const activeYear = availableYears.includes(requestedYearParam)
  ? requestedYearParam
  : String(availableYears[0] || String(new Date().getFullYear()));

const matchesActiveYear = (submission: any) => {
  if (!activeYear) return true;
  return getSubmissionYear(submission) === activeYear;
};

const scopedTeacherSubmissions = isTeacher
  ? (activeCourseSubmissions || []).filter((submission: any) => matchesActiveYear(submission))
  : [];
const scopedStudentSubmissions = !isTeacher
  ? (activeCourseSubmissions || []).filter((submission: any) => matchesActiveYear(submission))
  : [];
const scopedTeacherEnrollments = isTeacher
  ? (allEnrollments || []).filter((enrollment: any) => {
      if (teacherManagedCourseIds.size === 0) return false;
      const enrollmentCourseId = canonicalizeCourseId(enrollment?.courseId);
      if (!teacherManagedCourseIds.has(normalizeTextLower(enrollmentCourseId))) {
        return false;
      }
      if (activeCourseId && enrollmentCourseId !== activeCourseId) return false;
      if (activeYear && getEnrollmentYear(enrollment) !== activeYear) return false;
      return true;
    })
  : [];

const recentTeacherSubmissions = isTeacher
  ? [...scopedTeacherSubmissions].sort((a: any, b: any) => {
      return new Date(b.submittedAt).getTime() - new Date(a.submittedAt).getTime();
    })
  : [];

const allUsersById = new Map<string, any>(
  (allUsers || []).map((user: any) => [String(user?.id || ''), user]),
);

const isTeacherCourseMember = (userIdInput: any, courseIdInput: any, enrollmentsInput: any[] = allEnrollments || []) => {
  const userId = String(userIdInput || '').trim();
  if (!userId) return false;

  const userRole = normalizeRole(allUsersById.get(userId)?.role);
  if (userRole === 'teacher') return true;

  const courseId = canonicalizeCourseId(courseIdInput);
  if (!courseId) return false;

  return (enrollmentsInput || []).some((enrollment: any) =>
    String(enrollment?.userId || '').trim() === userId &&
    canonicalizeCourseId(enrollment?.courseId) === courseId &&
    normalizeRole(enrollment?.roleInCourse) === 'teacher',
  );
};

const teacherLiveSessions = isTeacher
  ? (allLiveClassSessions || []).filter((session: any) => {
      if (teacherManagedCourseIds.size === 0) return false;
      const sessionCourseId = canonicalizeCourseId(getLiveRecordCourseId(session));
      if (!sessionCourseId) return false;
      return teacherManagedCourseIds.has(normalizeTextLower(sessionCourseId));
    })
  : [];

const scopedTeacherLiveSessions = isTeacher
  ? teacherLiveSessions.filter((session: any) => {
      const sessionCourseId = getLiveRecordCourseId(session);
      if (activeCourseId && sessionCourseId !== activeCourseId) return false;
      if (activeYear && getLiveSessionYear(session) !== activeYear) return false;
      return true;
    })
  : [];

const scopedTeacherLiveSessionById = new Map<string, any>(
  scopedTeacherLiveSessions.map((session: any) => [String(session?.id || ''), session]),
);

const scopedTeacherLiveAttendance = isTeacher
  ? (allLiveClassAttendance || []).filter((attendance: any) => {
      const sessionId = String(attendance?.sessionId || '');
      if (sessionId && scopedTeacherLiveSessionById.has(sessionId)) return true;

      const attendanceCourseId = getLiveRecordCourseId(attendance);
      const attendanceUserId = String(attendance?.userId || '').trim();
      const belongsToTeacherCourse = Boolean(
        attendanceCourseId && teacherManagedCourseIds.has(normalizeTextLower(attendanceCourseId)),
      );
      const belongsToTeacherUser = Boolean(attendanceUserId && dashboardUserIds.includes(attendanceUserId));
      if (!belongsToTeacherCourse && !belongsToTeacherUser) {
        return false;
      }
      if (activeCourseId && attendanceCourseId !== activeCourseId) return false;
      if (activeYear) {
        const attendanceYear = getLiveSessionYear(attendance);
        if (attendanceYear !== activeYear) return false;
      }
      return true;
    })
  : [];

const attendanceCourseSummaryRows = isTeacher
  ? (() => {
      const summaryByKey = new Map<string, any>();
      const totalSessions = scopedTeacherLiveSessions.length;

      scopedTeacherEnrollments
        .filter((enrollment: any) => normalizeRole(enrollment?.roleInCourse) === 'student')
        .forEach((enrollment: any) => {
          const studentUser = allUsersById.get(String(enrollment?.userId || ''));
          const key = `user:${String(enrollment?.userId || '')}`;
          if (!String(enrollment?.userId || '').trim() || summaryByKey.has(key)) return;

          summaryByKey.set(key, {
            key,
            userId: String(enrollment?.userId || ''),
            identity: '',
            name: String(studentUser?.name || studentUser?.email || enrollment?.userId || 'Estudiante'),
            email: String(studentUser?.email || ''),
            sessionsAttended: 0,
            totalJoinCount: 0,
            totalLeaveCount: 0,
            totalAbortedCount: 0,
            totalDurationMs: 0,
            lastStatus: '',
            lastSeenAt: '',
            sessionIds: new Set<string>(),
          });
        });

      scopedTeacherLiveAttendance
        .filter((attendance: any) => normalizeRole(attendance?.role) === 'student')
        .forEach((attendance: any) => {
          const userId = String(attendance?.userId || '');
          const identity = String(attendance?.identity || '');
          const key = userId ? `user:${userId}` : identity ? `identity:${identity}` : '';
          if (!key) return;

          const user = userId ? allUsersById.get(userId) : null;
          const session = scopedTeacherLiveSessionById.get(String(attendance?.sessionId || ''));
          const existing = summaryByKey.get(key) || {
            key,
            userId,
            identity,
            name: String(user?.name || attendance?.name || identity || 'Participante'),
            email: String(user?.email || ''),
            sessionsAttended: 0,
            totalJoinCount: 0,
            totalLeaveCount: 0,
            totalAbortedCount: 0,
            totalDurationMs: 0,
            lastStatus: '',
            lastSeenAt: '',
            sessionIds: new Set<string>(),
          };

          existing.name = String(existing.name || user?.name || attendance?.name || identity || 'Participante');
          existing.email = String(existing.email || user?.email || '');
          existing.totalJoinCount += Math.max(0, Number(attendance?.joinCount || 0));
          existing.totalLeaveCount += Math.max(0, Number(attendance?.leaveCount || 0));
          existing.totalAbortedCount += Math.max(0, Number(attendance?.abortedCount || 0));
          existing.totalDurationMs += computeAttendanceDurationMs(attendance, session);

          const sessionId = String(attendance?.sessionId || '');
          if (sessionId && Number(attendance?.joinCount || 0) > 0 && !existing.sessionIds.has(sessionId)) {
            existing.sessionIds.add(sessionId);
            existing.sessionsAttended += 1;
          }

          const nextLastSeenAt = String(attendance?.lastEventAt || attendance?.lastLeftAt || attendance?.lastJoinedAt || '');
          if (getDateTimestamp(nextLastSeenAt) >= getDateTimestamp(existing.lastSeenAt)) {
            existing.lastSeenAt = nextLastSeenAt;
            existing.lastStatus = String(attendance?.lastStatus || existing.lastStatus || '');
          }

          summaryByKey.set(key, existing);
        });

      return Array.from(summaryByKey.values())
        .map((row: any) => ({
          ...row,
          totalSessions,
          totalDurationLabel: formatDurationFromMs(row.totalDurationMs),
          lastSeenLabel: formatSubmissionDate(row.lastSeenAt),
        }))
        .sort((left: any, right: any) =>
          String(left.name || '').localeCompare(String(right.name || ''), 'es'),
        );
    })()
  : [];

const attendanceRowsBySessionId = (() => {
  const grouped = new Map<string, any[]>();
  scopedTeacherLiveAttendance.forEach((attendance: any) => {
    const sessionId = String(attendance?.sessionId || '');
    if (!sessionId) return;
    if (!grouped.has(sessionId)) grouped.set(sessionId, []);
    grouped.get(sessionId)?.push(attendance);
  });
  return grouped;
})();

const attendanceLessonGroups = isTeacher
  ? (() => {
      const groups = new Map<string, any>();

      scopedTeacherLiveSessions.forEach((session: any) => {
        const sessionId = String(session?.id || '');
        if (!sessionId) return;

        const pageSlug = String(session?.pageSlug || '').trim() || 'sin-clase';
        const lessonLabel = decodeUriSafe(pageSlug.split('/').pop() || pageSlug || session?.roomName || 'Clase');
        const sessionAttendance = [...(attendanceRowsBySessionId.get(sessionId) || [])].sort((left: any, right: any) => {
          const leftRole = normalizeRole(left?.role) === 'teacher' ? 0 : 1;
          const rightRole = normalizeRole(right?.role) === 'teacher' ? 0 : 1;
          if (leftRole !== rightRole) return leftRole - rightRole;

          const leftUser = allUsersById.get(String(left?.userId || ''));
          const rightUser = allUsersById.get(String(right?.userId || ''));
          const leftName = String(leftUser?.name || left?.name || left?.identity || '');
          const rightName = String(rightUser?.name || right?.name || right?.identity || '');
          return leftName.localeCompare(rightName, 'es');
        });

        const participants = sessionAttendance.map((attendance: any) => {
          const user = allUsersById.get(String(attendance?.userId || ''));
          return {
            ...attendance,
            displayName: String(user?.name || attendance?.name || attendance?.identity || 'Participante'),
            email: String(user?.email || ''),
            durationLabel: formatDurationFromMs(computeAttendanceDurationMs(attendance, session)),
            firstJoinedLabel: formatSubmissionDate(attendance?.firstJoinedAt),
            lastLeftLabel: formatSubmissionDate(attendance?.lastLeftAt),
            lastEventLabel: formatSubmissionDate(attendance?.lastEventAt),
          };
        });

        const group = groups.get(pageSlug) || {
          pageSlug,
          lessonLabel,
          latestStartedAt: '',
          sessions: [],
        };

        group.sessions.push({
          id: sessionId,
          roomName: String(session?.roomName || ''),
          startedAt: String(session?.startedAt || ''),
          startedAtLabel: formatSubmissionDate(session?.startedAt),
          finishedAtLabel: formatSubmissionDate(session?.finishedAt),
          durationLabel: formatDurationFromMs(
            Math.max(
              0,
              getDateTimestamp(session?.finishedAt || session?.lastEventAt) - getDateTimestamp(session?.startedAt),
            ),
          ),
          studentCount: participants.filter((attendance: any) => normalizeRole(attendance?.role) === 'student').length,
          participantCount: participants.length,
          participants,
        });

        if (getDateTimestamp(session?.startedAt) >= getDateTimestamp(group.latestStartedAt)) {
          group.latestStartedAt = String(session?.startedAt || '');
        }

        groups.set(pageSlug, group);
      });

      return Array.from(groups.values())
        .map((group: any) => ({
          ...group,
          sessions: [...group.sessions].sort(
            (left: any, right: any) => getDateTimestamp(right.startedAt) - getDateTimestamp(left.startedAt),
          ),
        }))
        .sort(
          (left: any, right: any) =>
            getDateTimestamp(right.latestStartedAt) - getDateTimestamp(left.latestStartedAt),
        );
    })()
  : [];

const dashboardUsersById = new Map<string, any>(
  Array.from(
    new Map(
      [...(matchedUsers || []), dbUser]
        .filter(Boolean)
        .map((user: any) => [String(user?.id || ''), user]),
    ).entries(),
  ),
);

const resolveAttendanceUser = (userId: unknown) => {
  const key = String(userId || '').trim();
  if (!key) return null;
  return allUsersById.get(key) || dashboardUsersById.get(key) || null;
};

const scopedStudentLiveSessions = !isTeacher
  ? (allLiveClassSessions || []).filter((session: any) => {
      const sessionCourseId = getLiveRecordCourseId(session);
      if (activeCourseId && sessionCourseId !== activeCourseId) return false;
      if (activeYear && getLiveSessionYear(session) !== activeYear) return false;
      return true;
    })
  : [];

const scopedStudentLiveSessionById = new Map<string, any>(
  scopedStudentLiveSessions.map((session: any) => [String(session?.id || ''), session]),
);

const scopedStudentLiveAttendance = !isTeacher
  ? (allLiveClassAttendance || []).filter((attendance: any) => {
      const attendanceUserId = String(attendance?.userId || '').trim();
      const attendanceEmail = normalizeTextLower(attendance?.email || '');
      const attendanceIdentity = normalizeTextLower(attendance?.identity || '');
      const matchesDashboardUser =
        (attendanceUserId && dashboardUserIds.includes(attendanceUserId))
        || (attendanceEmail && attendanceEmail === normalizedSessionEmail)
        || (attendanceIdentity && attendanceIdentity === normalizedSessionEmail);

      if (!matchesDashboardUser) return false;

      const sessionId = String(attendance?.sessionId || '');
      if (sessionId && scopedStudentLiveSessionById.has(sessionId)) return true;

      const attendanceCourseId = getLiveRecordCourseId(attendance);
      if (activeCourseId && attendanceCourseId !== activeCourseId) return false;
      if (activeYear && getLiveSessionYear(attendance) !== activeYear) return false;
      return true;
    })
  : [];

const scopedLiveSessions = isTeacher ? scopedTeacherLiveSessions : scopedStudentLiveSessions;
const scopedLiveSessionById = isTeacher ? scopedTeacherLiveSessionById : scopedStudentLiveSessionById;
const scopedLiveAttendance = isTeacher ? scopedTeacherLiveAttendance : scopedStudentLiveAttendance;

const scopedAttendanceRowsBySessionId = (() => {
  const grouped = new Map<string, any[]>();
  scopedLiveAttendance.forEach((attendance: any) => {
    const sessionId = String(attendance?.sessionId || '');
    if (!sessionId) return;
    if (!grouped.has(sessionId)) grouped.set(sessionId, []);
    grouped.get(sessionId)?.push(attendance);
  });
  return grouped;
})();

const attendanceSessionRows = (() => {
  const sessionIds = new Set<string>();
  scopedLiveSessions.forEach((session: any) => {
    const sessionId = String(session?.id || '').trim();
    if (sessionId) sessionIds.add(sessionId);
  });
  scopedLiveAttendance.forEach((attendance: any) => {
    const sessionId = String(attendance?.sessionId || '').trim();
    if (sessionId) sessionIds.add(sessionId);
  });

  return Array.from(sessionIds)
    .map((sessionId) => {
      const session = scopedLiveSessionById.get(sessionId) || null;
      const sessionAttendance = [...(scopedAttendanceRowsBySessionId.get(sessionId) || [])].sort((left: any, right: any) => {
        const leftRole = normalizeRole(left?.role) === 'teacher' ? 0 : 1;
        const rightRole = normalizeRole(right?.role) === 'teacher' ? 0 : 1;
        if (leftRole !== rightRole) return leftRole - rightRole;

        const leftUser = resolveAttendanceUser(left?.userId);
        const rightUser = resolveAttendanceUser(right?.userId);
        const leftName = String(leftUser?.name || left?.name || left?.identity || '');
        const rightName = String(rightUser?.name || right?.name || right?.identity || '');
        return leftName.localeCompare(rightName, 'es');
      });
      const fallbackAttendance = sessionAttendance[0] || {};
      const pageSlug = normalizeText(session?.pageSlug || fallbackAttendance?.pageSlug || '') || 'sin-clase';
      const lessonLabel = decodeUriSafe(pageSlug.split('/').pop() || pageSlug || session?.roomName || 'Clase');
      const startedAt = String(
        session?.startedAt
          || fallbackAttendance?.firstJoinedAt
          || fallbackAttendance?.lastEventAt
          || '',
      );
      const finishedAt = String(session?.finishedAt || session?.lastEventAt || fallbackAttendance?.lastEventAt || '');
      const courseId = getLiveRecordCourseId(session || fallbackAttendance) || activeCourseId || 'sin-curso';
      const participants = sessionAttendance.map((attendance: any) => {
        const user = resolveAttendanceUser(attendance?.userId);
        const role = normalizeRole(attendance?.role || user?.role || 'student') || 'student';
        const durationMs = computeAttendanceDurationMs(attendance, session);
        return {
          ...attendance,
          role,
          displayName: String(user?.name || attendance?.name || attendance?.identity || 'Participante'),
          email: String(user?.email || attendance?.email || ''),
          durationMs,
          durationLabel: formatDurationFromMs(durationMs),
          firstJoinedLabel: formatSubmissionDate(attendance?.firstJoinedAt),
          lastLeftLabel: formatSubmissionDate(attendance?.lastLeftAt),
          lastEventLabel: formatSubmissionDate(attendance?.lastEventAt),
        };
      });

      const dayKey = getAttendanceDayKey(session, fallbackAttendance);
      const sessionDurationMs = Math.max(
        0,
        getDateTimestamp(finishedAt) - getDateTimestamp(startedAt),
      );
      const participantStudentKeys = new Set<string>();
      const participantTeacherKeys = new Set<string>();
      participants.forEach((participant: any) => {
        const identityKey =
          String(participant?.userId || '').trim()
            ? `user:${String(participant.userId).trim()}`
            : String(participant?.identity || '').trim()
              ? `identity:${String(participant.identity).trim()}`
              : '';
        if (!identityKey) return;
        if (normalizeRole(participant?.role) === 'teacher') {
          participantTeacherKeys.add(identityKey);
        } else {
          participantStudentKeys.add(identityKey);
        }
      });

      return {
        id: sessionId,
        courseId,
        pageSlug,
        lessonLabel,
        startedAt,
        startedAtLabel: formatSubmissionDate(startedAt),
        finishedAtLabel: formatSubmissionDate(finishedAt),
        durationMs: sessionDurationMs,
        durationLabel: formatDurationFromMs(sessionDurationMs),
        dayKey,
        dayLabel: formatAttendanceDayLabel(dayKey),
        participants,
        participantCount: participants.length,
        studentCount: participantStudentKeys.size,
        teacherCount: participantTeacherKeys.size,
      };
    })
    .sort((left: any, right: any) => getDateTimestamp(right.startedAt) - getDateTimestamp(left.startedAt));
})();

const attendanceUserSummaryRows = (() => {
  const summaryByKey = new Map<string, any>();

  if (isTeacher) {
    scopedTeacherEnrollments.forEach((enrollment: any) => {
      const userId = String(enrollment?.userId || '').trim();
      if (!userId) return;
      const user = resolveAttendanceUser(userId);
      const role = normalizeRole(enrollment?.roleInCourse || user?.role || 'student') || 'student';
      const key = `user:${userId}`;
      if (summaryByKey.has(key)) return;

      summaryByKey.set(key, {
        key,
        userId,
        identity: '',
        role,
        name: String(user?.name || user?.email || userId),
        email: String(user?.email || ''),
        sessionIds: new Set<string>(),
        dayKeys: new Set<string>(),
        totalJoinCount: 0,
        totalLeaveCount: 0,
        totalAbortedCount: 0,
        totalDurationMs: 0,
        lastSeenAt: '',
        lastStatus: '',
      });
    });
  }

  scopedLiveAttendance.forEach((attendance: any) => {
    const userId = String(attendance?.userId || '').trim();
    const identity = String(attendance?.identity || '').trim();
    const key = userId ? `user:${userId}` : identity ? `identity:${identity}` : '';
    if (!key) return;

    const user = resolveAttendanceUser(userId);
    const role = normalizeRole(attendance?.role || user?.role || 'student') || 'student';
    const session = scopedLiveSessionById.get(String(attendance?.sessionId || '')) || null;
    const existing = summaryByKey.get(key) || {
      key,
      userId,
      identity,
      role,
      name: String(user?.name || attendance?.name || identity || 'Participante'),
      email: String(user?.email || attendance?.email || ''),
      sessionIds: new Set<string>(),
      dayKeys: new Set<string>(),
      totalJoinCount: 0,
      totalLeaveCount: 0,
      totalAbortedCount: 0,
      totalDurationMs: 0,
      lastSeenAt: '',
      lastStatus: '',
    };

    existing.role = existing.role || role;
    existing.name = String(existing.name || user?.name || attendance?.name || identity || 'Participante');
    existing.email = String(existing.email || user?.email || attendance?.email || '');
    existing.totalJoinCount += Math.max(0, Number(attendance?.joinCount || 0));
    existing.totalLeaveCount += Math.max(0, Number(attendance?.leaveCount || 0));
    existing.totalAbortedCount += Math.max(0, Number(attendance?.abortedCount || 0));
    existing.totalDurationMs += computeAttendanceDurationMs(attendance, session);

    const sessionId = String(attendance?.sessionId || '').trim();
    if (sessionId && Number(attendance?.joinCount || 0) > 0) {
      existing.sessionIds.add(sessionId);
    }

    const dayKey = getAttendanceDayKey(session, attendance);
    if (dayKey && Number(attendance?.joinCount || 0) > 0) {
      existing.dayKeys.add(dayKey);
    }

    const nextLastSeenAt = String(attendance?.lastEventAt || attendance?.lastLeftAt || attendance?.lastJoinedAt || '');
    if (getDateTimestamp(nextLastSeenAt) >= getDateTimestamp(existing.lastSeenAt)) {
      existing.lastSeenAt = nextLastSeenAt;
      existing.lastStatus = String(attendance?.lastStatus || existing.lastStatus || '');
    }

    summaryByKey.set(key, existing);
  });

  return Array.from(summaryByKey.values())
    .map((row: any) => {
      const sessionsAttended = row.sessionIds.size;
      return {
        ...row,
        sessionsAttended,
        totalDaysAttended: row.dayKeys.size,
        totalDurationLabel: formatDurationFromMs(row.totalDurationMs),
        averageDurationLabel: formatDurationFromMs(
          sessionsAttended > 0 ? row.totalDurationMs / sessionsAttended : 0,
        ),
        lastSeenLabel: formatSubmissionDate(row.lastSeenAt),
      };
    })
    .sort((left: any, right: any) =>
      String(left.name || '').localeCompare(String(right.name || ''), 'es'),
    );
})();

const attendanceDayGroups = (() => {
  const groups = new Map<string, any>();

  attendanceSessionRows.forEach((session: any) => {
    const dayKey = String(session?.dayKey || '').trim();
    const group = groups.get(dayKey) || {
      dayKey,
      dayLabel: session?.dayLabel || 'Sin fecha',
      latestStartedAt: '',
      sessionIds: new Set<string>(),
      studentKeys: new Set<string>(),
      teacherKeys: new Set<string>(),
      totalDurationMs: 0,
      sessions: [],
    };

    if (!group.sessionIds.has(session.id)) {
      group.sessionIds.add(session.id);
      group.sessions.push(session);
      group.totalDurationMs += Math.max(0, Number(session?.durationMs || 0));
    }

    (session.participants || []).forEach((participant: any) => {
      const identityKey =
        String(participant?.userId || '').trim()
          ? `user:${String(participant.userId).trim()}`
          : String(participant?.identity || '').trim()
            ? `identity:${String(participant.identity).trim()}`
            : '';
      if (!identityKey) return;
      if (normalizeRole(participant?.role) === 'teacher') {
        group.teacherKeys.add(identityKey);
      } else {
        group.studentKeys.add(identityKey);
      }
    });

    if (getDateTimestamp(session?.startedAt) >= getDateTimestamp(group.latestStartedAt)) {
      group.latestStartedAt = String(session?.startedAt || '');
    }

    groups.set(dayKey, group);
  });

  return Array.from(groups.values())
    .map((group: any) => ({
      ...group,
      sessionCount: group.sessionIds.size,
      studentCount: group.studentKeys.size,
      teacherCount: group.teacherKeys.size,
      totalDurationLabel: formatDurationFromMs(group.totalDurationMs),
      sessions: [...group.sessions].sort(
        (left: any, right: any) => getDateTimestamp(right.startedAt) - getDateTimestamp(left.startedAt),
      ),
    }))
    .sort(
      (left: any, right: any) => getDateTimestamp(right.latestStartedAt) - getDateTimestamp(left.latestStartedAt),
    );
})();

const attendanceLogRows = scopedLiveAttendance
