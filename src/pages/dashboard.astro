    <script type="application/json" id="dashboard-teacher-attendance" set:html={teacherAttendanceProjectionJson}></script>
    <script type="application/json" id="dashboard-teacher-comments" set:html={teacherCommentsProjectionJson}></script>
    <script type="application/json" id="dashboard-teacher-admin" set:html={teacherAdminProjectionJson}></script>
    <script type="application/json" id="dashboard-teacher-annotations" set:html={teacherDashboardAnnotationsJson}></script>

    <script>
      import { mountDashboardTabulators } from '../scripts/dashboard-tabulator.ts';

      const escapeHtml = (value) =>
        String(value ?? '')
          .replaceAll('&', '&amp;')
          .replaceAll('<', '&lt;')
          .replaceAll('>', '&gt;')
          .replaceAll('"', '&quot;')
          .replaceAll("'", '&#039;');

      const renderInlineMarkdown = (value) => {
        const escaped = escapeHtml(value ?? '');
        return escaped
          .replace(/`([^`]+)`/g, '<code>$1</code>')
          .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
      };

      const renderSimpleMarkdown = (markdown) => {
        const lines = String(markdown || '').split('\n');
        let html = '';
        let inList = false;

        lines.forEach((line) => {
          const raw = String(line || '');
          const trimmed = raw.trim();

          if (!trimmed) {
            if (inList) {
              html += '</ul>';
              inList = false;
            }
            return;
          }

          if (trimmed.startsWith('- ')) {
            if (!inList) {
              html += '<ul>';
              inList = true;
            }
            html += `<li>${renderInlineMarkdown(trimmed.slice(2))}</li>`;
            return;
          }

          if (inList) {
            html += '</ul>';
            inList = false;
          }

          if (trimmed.startsWith('### ')) {
            html += `<h4>${renderInlineMarkdown(trimmed.slice(4))}</h4>`;
            return;
          }

          html += `<p>${renderInlineMarkdown(trimmed)}</p>`;
        });

        if (inList) html += '</ul>';
        return html;
      };

      const buildEvalPreviewMarkdown = (preview) => {
        const options = Array.isArray(preview?.options)
          ? preview.options.map((option) => String(option || '').trim()).filter(Boolean)
          : [];

        const lines = [
          '### Bloque eval',
          `- **id**: \`${preview?.id || '-'}\``,
          `- **type**: \`${preview?.type || 'unknown'}\``,
          `- **mode**: \`${preview?.mode || 'unknown'}\``,
          `- **prompt**: ${preview?.prompt ? String(preview.prompt) : '—'}`,
          '- **options**:',
        ];

        if (options.length === 0) {
          lines.push('- _(sin opciones)_');
        } else {
          options.forEach((option, index) => {
            lines.push(`- ${index + 1}. ${option}`);
          });
        }

        return lines.join('\n');
      };

      const parseEvalPreviewAttr = (encodedPreview) => {
        if (!encodedPreview) return null;
        try {
          const parsed = JSON.parse(decodeURIComponent(String(encodedPreview)));
          if (!parsed || typeof parsed !== 'object') return null;
          return {
            id: String(parsed.id || '-'),
            type: String(parsed.type || 'unknown'),
            mode: String(parsed.mode || 'unknown'),
            prompt: String(parsed.prompt || ''),
            options: Array.isArray(parsed.options)
              ? parsed.options.map((item) => String(item || '')).filter(Boolean)
              : [],
          };
        } catch {
          return null;
        }
      };

      const ensureEvalPreviewTooltip = () => {
        let tooltip = document.getElementById('eval-preview-tooltip');
        if (tooltip instanceof HTMLElement) return tooltip;

        tooltip = document.createElement('div');
        tooltip.id = 'eval-preview-tooltip';
        tooltip.className = 'eval-preview-tooltip';
        tooltip.hidden = true;
        tooltip.setAttribute('role', 'tooltip');
        document.body.appendChild(tooltip);
        return tooltip;
      };

      const positionEvalPreviewTooltip = (tooltip, x, y) => {
        const gap = 14;
        const maxX = window.innerWidth - tooltip.offsetWidth - gap;
        const maxY = window.innerHeight - tooltip.offsetHeight - gap;
        const nextLeft = Math.min(Math.max(gap, x + gap), Math.max(gap, maxX));
        const nextTop = Math.min(Math.max(gap, y + gap), Math.max(gap, maxY));
        tooltip.style.left = `${nextLeft}px`;
        tooltip.style.top = `${nextTop}px`;
      };

      let activeEvalPreviewAnchor = null;

      const showEvalPreviewTooltip = (anchor, coords) => {
        if (!(anchor instanceof HTMLElement)) return;
        const preview = parseEvalPreviewAttr(anchor.getAttribute('data-eval-preview'));
        if (!preview) return;

        const tooltip = ensureEvalPreviewTooltip();
        const markdown = buildEvalPreviewMarkdown(preview);
        tooltip.innerHTML = renderSimpleMarkdown(markdown);
        tooltip.hidden = false;

        const fallbackX = window.innerWidth / 2;
        const fallbackY = 28;
        positionEvalPreviewTooltip(
          tooltip,
          Number.isFinite(coords?.x) ? coords.x : fallbackX,
          Number.isFinite(coords?.y) ? coords.y : fallbackY,
        );
        activeEvalPreviewAnchor = anchor;
      };

      const hideEvalPreviewTooltip = (anchor = null) => {
        if (anchor && activeEvalPreviewAnchor && anchor !== activeEvalPreviewAnchor) return;
        const tooltip = ensureEvalPreviewTooltip();
        tooltip.hidden = true;
        activeEvalPreviewAnchor = null;
      };

      const attachEvalPreviewHandlers = (root = document) => {
        if (!(root instanceof Element || root instanceof Document || root instanceof DocumentFragment)) return;
        root.querySelectorAll('[data-eval-preview]').forEach((node) => {
          if (!(node instanceof HTMLElement)) return;
          if (node.dataset.evalPreviewBound === 'true') return;
          node.dataset.evalPreviewBound = 'true';

          node.addEventListener('mouseenter', (event) => {
            showEvalPreviewTooltip(node, {
              x: Number(event?.clientX || 0),
              y: Number(event?.clientY || 0),
            });
          });

          node.addEventListener('mousemove', (event) => {
            if (activeEvalPreviewAnchor !== node) return;
            const tooltip = ensureEvalPreviewTooltip();
            positionEvalPreviewTooltip(tooltip, Number(event?.clientX || 0), Number(event?.clientY || 0));
          });

          node.addEventListener('mouseleave', () => {
            hideEvalPreviewTooltip(node);
          });

          node.addEventListener('focus', () => {
            const rect = node.getBoundingClientRect();
            showEvalPreviewTooltip(node, {
              x: rect.left + rect.width / 2,
              y: rect.bottom + 8,
            });
          });

          node.addEventListener('blur', () => {
            hideEvalPreviewTooltip(node);
          });
        });
      };

      const getLogData = () => {
        const node = document.getElementById('dashboard-log-data');
        if (!(node instanceof HTMLScriptElement)) return { teacher: [], student: [], filters: {} };
        try {
          const parsed = JSON.parse(node.textContent || '{}');
          return {
            teacher: Array.isArray(parsed.teacher) ? parsed.teacher : [],
            student: Array.isArray(parsed.student) ? parsed.student : [],
            filters: parsed.filters && typeof parsed.filters === 'object' ? parsed.filters : {},
          };
        } catch {
          return { teacher: [], student: [], filters: {} };
        }
      };

      const compareValues = (left, right) => {
        const a = left ?? '';
        const b = right ?? '';
        if (typeof a === 'number' && typeof b === 'number') return a - b;
        return String(a).localeCompare(String(b), 'es', { sensitivity: 'base' });
      };

      const mountLogPanel = (panel, rows, filtersMeta) => {
        if (!(panel instanceof HTMLElement) || panel.dataset.logMounted === 'true') return;
        panel.dataset.logMounted = 'true';

        const queryInput = panel.querySelector('[data-log-query]');
        const filterType = panel.querySelector('[data-log-filter="evalType"]');
        const filterMode = panel.querySelector('[data-log-filter="mode"]');
        const filterNoteType = panel.querySelector('[data-log-filter="noteType"]');
        const body = panel.querySelector('[data-log-body]');
        const emptyNode = panel.querySelector('[data-log-empty]');
        const summaryNode = panel.querySelector('[data-log-summary]');
        const showUser = panel.dataset.showUser === 'true';

        if (
          !(queryInput instanceof HTMLInputElement) ||
          !(filterType instanceof HTMLSelectElement) ||
          !(filterMode instanceof HTMLSelectElement) ||
          !(filterNoteType instanceof HTMLSelectElement) ||
          !(body instanceof HTMLElement)
        ) {
          return;
        }

        const noteTypeLabelByValue = new Map(
          Array.isArray(filtersMeta?.noteTypes)
            ? filtersMeta.noteTypes.map((entry) => [String(entry.value || ''), String(entry.label || entry.value || '')])
            : [],
        );

        const setOptions = (select, values, labelResolver = (value) => value) => {
          const base = Array.from(select.options).slice(0, 1);
          select.innerHTML = '';
          base.forEach((option) => select.appendChild(option));
          values.forEach((value) => {
            const option = document.createElement('option');
            option.value = value;
            option.textContent = labelResolver(value);
            select.appendChild(option);
          });
        };

        const evalTypes = Array.from(new Set(rows.map((row) => String(row.evalType || '')).filter(Boolean))).sort();
        const modes = Array.from(new Set(rows.map((row) => String(row.mode || '')).filter(Boolean))).sort();
        const noteTypes = Array.from(new Set(rows.map((row) => String(row.noteType || '')).filter(Boolean))).sort(
          (left, right) => {
            const leftRow = rows.find((row) => row.noteType === left);
            const rightRow = rows.find((row) => row.noteType === right);
            return Number(leftRow?.noteTypeOrder || 99) - Number(rightRow?.noteTypeOrder || 99);
          },
        );

        setOptions(filterType, evalTypes);
        setOptions(filterMode, modes);
        setOptions(filterNoteType, noteTypes, (value) => noteTypeLabelByValue.get(value) || value);

        const state = {
          query: '',
          evalType: '',
          mode: '',
          noteType: '',
          sortKey: 'submittedAtTs',
          sortDirection: 'desc',
        };

        const getRowMarkup = (row) => {
          const score = row.score === null || row.score === undefined || Number.isNaN(Number(row.score))
            ? '-'
            : Number(row.score).toFixed(1);
          const noteTypeLabel = row.noteTypeLabel || noteTypeLabelByValue.get(String(row.noteType || '')) || row.noteType || '-';
          const previewAttr = escapeHtml(String(row.evalPreviewAttr || ''));
          const assignmentIdSafe = escapeHtml(row.assignmentId || '-');
          const evalIdMarkup = `
            <button type="button" class="eval-id-anchor" data-eval-preview="${previewAttr}" aria-label="Preview eval ${assignmentIdSafe}">
              <code>${assignmentIdSafe}</code>
            </button>
          `;

          const cells = [
            `<td>${escapeHtml(row.submittedAt || '-')}</td>`,
            `<td>${escapeHtml(row.gradedAt || '-')}</td>`,
            `<td>${escapeHtml(row.courseId || '-')}</td>`,
            `<td><span class="log-tag">${escapeHtml(noteTypeLabel)}</span></td>`,
            `<td><span class="log-tag">${escapeHtml(row.evalType || '-')}</span></td>`,
            `<td><span class="log-tag">${escapeHtml(row.mode || '-')}</span></td>`,
          ];

          if (showUser) {
            cells.push(
              `<td>${escapeHtml(row.userName || '-')}<br><small>${escapeHtml(row.userEmail || '')}</small></td>`,
            );
          }

          cells.push(
            `<td title="${escapeHtml(row.assignmentSlug || '')}">${escapeHtml(row.assignmentLabel || row.assignmentId || '-')}</td>`,
            `<td>${evalIdMarkup}</td>`,
            `<td>${escapeHtml(row.attempts ?? 0)}</td>`,
            `<td>${escapeHtml(score)}</td>`,
            `<td>${escapeHtml(row.resultState || '-')}</td>`,
            `<td>${escapeHtml(row.submissionState || '-')}</td>`,
            `<td>${escapeHtml(row.reviewState || '-')}</td>`,
            `<td class="log-answer">${escapeHtml(row.answerText || '-')}</td>`,
            `<td><span class="log-payload" title="${escapeHtml(row.payloadText || '')}">${escapeHtml(row.payloadText || '-')}</span></td>`,
            `<td>${escapeHtml(row.feedback || '-')}</td>`,
            `<td><code>${escapeHtml(row.submissionId || '-')}</code></td>`,
            `<td title="${escapeHtml(row.catalogSource || '')}">${escapeHtml(row.catalogSource || '-')}</td>`,
          );

          return `<tr>${cells.join('')}</tr>`;
        };

        const render = () => {
          const query = state.query.trim().toLowerCase();
          const filtered = rows.filter((row) => {
            if (state.evalType && String(row.evalType || '') !== state.evalType) return false;
            if (state.mode && String(row.mode || '') !== state.mode) return false;
            if (state.noteType && String(row.noteType || '') !== state.noteType) return false;
            if (!query) return true;
            return String(row.search || '').includes(query);
          });

          filtered.sort((left, right) => {
            const compare = compareValues(left[state.sortKey], right[state.sortKey]);
            return state.sortDirection === 'asc' ? compare : -compare;
          });

          hideEvalPreviewTooltip();
          body.innerHTML = filtered.map(getRowMarkup).join('');
          attachEvalPreviewHandlers(body);
          if (emptyNode instanceof HTMLElement) emptyNode.hidden = filtered.length !== 0;
          if (summaryNode instanceof HTMLElement) {
            summaryNode.textContent = `${filtered.length} / ${rows.length} registros`;
          }
        };

        queryInput.addEventListener('input', () => {
          state.query = queryInput.value || '';
          render();
        });

        panel.addEventListener('dashboard-log-query', (event) => {
          const nextQuery = String(event?.detail?.query || '');
          if (queryInput.value !== nextQuery) {
            queryInput.value = nextQuery;
          }
          state.query = nextQuery;
          render();
        });

        filterType.addEventListener('change', () => {
          state.evalType = filterType.value || '';
          render();
        });

        filterMode.addEventListener('change', () => {
          state.mode = filterMode.value || '';
          render();
        });

        filterNoteType.addEventListener('change', () => {
          state.noteType = filterNoteType.value || '';
          render();
        });

        panel.querySelectorAll('[data-log-sort]').forEach((button) => {
          button.addEventListener('click', () => {
            const nextKey = String(button.getAttribute('data-log-sort') || '');
            if (!nextKey) return;
            if (state.sortKey === nextKey) {
              state.sortDirection = state.sortDirection === 'asc' ? 'desc' : 'asc';
            } else {
              state.sortKey = nextKey;
              state.sortDirection = 'desc';
            }
            render();
          });
        });

        render();
      };

      const initializeDashboardLogPanels = () => {
        const data = getLogData();
        document.querySelectorAll('[data-log-panel]').forEach((panel) => {
          const scope = String(panel.getAttribute('data-log-scope') || '').trim();
          const rows = scope === 'teacher' ? data.teacher : data.student;
          mountLogPanel(panel, rows, data.filters || {});
        });
      };

      const initializeEnrollButtons = () => {
        document.querySelectorAll('.enroll-btn').forEach((btn) => {
          if (btn.dataset.bound === 'true') return;
          btn.dataset.bound = 'true';

          btn.addEventListener('click', async (event) => {
            const target = event.currentTarget;
            if (!(target instanceof HTMLButtonElement)) return;
            const courseId = target.dataset.courseId;
            if (!courseId) return;

            target.textContent = 'Inscribiendo...';
            target.disabled = true;

            try {
              const res = await fetch('/api/enroll', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ courseId }),
              });

              if (res.ok) {
                window.location.reload();
                return;
              }

              alert('Error al inscribirse. Intente nuevamente.');
              target.textContent = 'Inscribirme';
              target.disabled = false;
            } catch (err) {
              console.error(err);
              alert('Error de conexión');
              target.textContent = 'Inscribirme';
              target.disabled = false;
            }
          });
        });
      };

      const handleUnenrollStudent = async (button) => {
        const enrollmentId = String(button.getAttribute('data-enrollment-id') || '').trim();
        const userName = String(button.getAttribute('data-user-name') || 'este estudiante').trim();
        const enrollmentRole = String(button.getAttribute('data-enrollment-role') || 'student').trim().toLowerCase();
        const isTeacherEnrollment = enrollmentRole === 'teacher';
        if (!enrollmentId) return;

        const confirmed = window.confirm(
          isTeacherEnrollment
            ? `¿Quitar tu inscripción docente "${userName}" de este curso?`
            : `¿Desinscribir a "${userName}" de este curso?`,
        );
        if (!confirmed) return;

        button.disabled = true;
        try {
          const response = await fetch('/api/enroll', {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ enrollmentId }),
          });

          if (!response.ok) {
            const payload = await response.json().catch(() => ({}));
            throw new Error(
              payload?.error
              || (isTeacherEnrollment
                ? 'No se pudo quitar la inscripción docente'
                : 'No se pudo desinscribir al estudiante'),
            );
          }

          window.location.reload();
        } catch (error) {
          console.error('Error removing enrollment:', error);
          alert(
            error?.message
            || (isTeacherEnrollment
              ? 'No se pudo quitar la inscripción docente'
              : 'No se pudo desinscribir al estudiante'),
          );
          button.disabled = false;
        }
      };

      const initializeUnenrollButtons = () => {
        document.querySelectorAll('.js-unenroll-student').forEach((button) => {
          if (button.dataset.bound === 'true') return;
          button.dataset.bound = 'true';
          button.addEventListener('click', () => {
            void handleUnenrollStudent(button);
          });
        });
      };

      let teardownDashboardTabulators = null;

      const bootDashboardSidebar = () => {
        const shell = document.querySelector('.dashboard-shell');
        const toggle = document.querySelector('.dashboard-sidebar-toggle');
        const handle = document.querySelector('.dashboard-sidebar-handle');
        if (!shell || !toggle || !handle) return;

        const STORAGE_KEY = 'musiki:dashboard:sidebar-open';
        const initialState = localStorage.getItem(STORAGE_KEY) !== 'false';
        shell.setAttribute('data-left-open', initialState ? 'true' : 'false');

        const setSidebarOpen = (isOpen) => {
          shell.setAttribute('data-left-open', isOpen ? 'true' : 'false');
          localStorage.setItem(STORAGE_KEY, isOpen ? 'true' : 'false');
          // Trigger window resize for Tabulator to adjust
          window.dispatchEvent(new Event('resize'));
        };

        toggle.addEventListener('click', () => setSidebarOpen(false));
        handle.addEventListener('click', () => setSidebarOpen(true));

        // Keyboard shortcut: Cmd/Ctrl + \
        window.addEventListener('keydown', (e) => {
          if ((e.metaKey || e.ctrlKey) && e.key === '\\') {
            e.preventDefault();
            const isOpen = shell.getAttribute('data-left-open') === 'true';
            setSidebarOpen(!isOpen);
          }
        });
      };

      const bootDashboardEnhancements = () => {
        const dashboardRoot = document.querySelector('[data-dashboard-root]');
        bootDashboardSidebar();
        if (dashboardRoot instanceof HTMLElement) {
          if (typeof teardownDashboardTabulators === 'function') {
            teardownDashboardTabulators();
            teardownDashboardTabulators = null;
          }
          teardownDashboardTabulators = mountDashboardTabulators(dashboardRoot);
        }
        initializeDashboardLogPanels();
        initializeEnrollButtons();
        initializeUnenrollButtons();
        attachEvalPreviewHandlers(document);
      };

      window.__musikiDashboardRemount = bootDashboardEnhancements;

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', bootDashboardEnhancements, { once: true });
      } else {
        bootDashboardEnhancements();
      }

      document.addEventListener('astro:page-load', bootDashboardEnhancements);
    </script>
  </body>
</html>
