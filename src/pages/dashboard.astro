        min-width: max-content;
      }
      .attendance-grid-table th,
      .attendance-grid-table td {
        text-align: center;
      }
      .attendance-grid-table th:nth-child(2),
      .attendance-grid-table td:nth-child(2),
      .attendance-grid-table th:nth-child(3),
      .attendance-grid-table td:nth-child(3) {
        position: sticky;
        background: var(--c-bg);
        z-index: 3;
      }
      .attendance-grid-table th:nth-child(2),
      .attendance-grid-table td:nth-child(2) {
        left: 172px;
        min-width: 220px;
        text-align: left;
      }
      .attendance-grid-table th:nth-child(3),
      .attendance-grid-table td:nth-child(3) {
        left: 392px;
        min-width: 82px;
        text-align: left;
      }
      .attendance-grid-table thead th:nth-child(2),
      .attendance-grid-table thead th:nth-child(3) {
        background: var(--c-bg-mute);
        z-index: 4;
      }
      .attendance-grid-table tbody td:nth-child(2),
      .attendance-grid-table tbody td:nth-child(3) {
        box-shadow: 8px 0 14px rgba(0, 0, 0, 0.16);
      }
      .attendance-grid-table th.attendance-week-head {
        min-width: 280px;
      }
      .attendance-day-head {
        min-width: 56px;
        font-size: 0.72rem;
        line-height: 1.15;
      }
      .attendance-day-head.is-out-of-range {
        color: var(--c-fg-dim);
      }
      .attendance-day-cell {
        padding: 0.32rem 0.24rem;
      }
      .attendance-day-cell.is-present {
        background: color-mix(in srgb, var(--c-link) 10%, transparent);
      }
      .attendance-day-stack {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.22rem;
      }
      .attendance-day-total {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 1.45rem;
        min-height: 1.05rem;
        font-size: 0.77rem;
        font-weight: 600;
        line-height: 1;
        cursor: help;
      }
      .attendance-manual-input {
        width: 2.8rem;
        padding: 0.16rem 0.2rem;
        text-align: center;
        font-size: 0.72rem;
      }
      .attendance-day-empty {
        color: var(--c-fg-dim);
        font-size: 0.74rem;
      }
      .attendance-log-panel {
        margin-top: 0.9rem;
      }
      .attendance-log-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.55rem;
        flex-wrap: wrap;
        margin-bottom: 0.65rem;
      }
      .attendance-log-search {
        min-width: min(360px, 100%);
      }
      .attendance-log-subline {
        font-size: 0.8rem;
        color: var(--c-fg-dim);
      }
      .role-badge { padding: 0.25rem 0.5rem; border-radius: 4px; font-size: 0.75rem; font-weight: 500; }
      .role-teacher { background: #e3f2fd; color: #1976d2; }
      .role-student { background: #f3e5f5; color: #7b1fa2; }
      .enrollment-list { font-size: 0.85rem; }
      .enrollment-item { display: inline-block; padding: 0.2rem 0.5rem; background: var(--c-bg-mute); border-radius: 4px; margin: 0.2rem; }
      .submission-count { font-weight: 600; color: var(--c-link); }
      .inline-grade-note {
        font-size: 0.75rem;
        color: var(--c-fg-dim);
        border: 1px solid var(--c-border);
        border-radius: 999px;
        padding: 0.12rem 0.45rem;
        background: var(--c-bg-mute);
      }
      .table-actions {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
      }
      .icon-btn {
        width: 30px;
        height: 30px;
        border: 1px solid var(--c-border);
        border-radius: 6px;
        background: var(--c-bg);
        color: var(--c-fg);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        text-decoration: none;
        transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
      }
      .icon-btn svg {
        width: 15px;
        height: 15px;
      }
      .icon-btn:hover {
        background: var(--c-bg-mute);
        border-color: var(--c-link);
        color: var(--c-link);
      }
      .icon-btn-danger:hover {
        border-color: #dc2626;
        color: #dc2626;
      }
      .status-pending { color: #f57c00; }
      .status-graded { color: #388e3c; }
      .tabs {
        display: grid;
        gap: 0.2rem;
        border-bottom: 0;
        margin-bottom: 0;
      }
      .tab {
        padding: 0.6rem 0.7rem;
        cursor: pointer;
        border-left: 2px solid transparent;
        margin-bottom: 0;
        font-weight: 500;
        transition: all 0.2s;
      }
      .tab:hover { background: var(--c-bg-mute); }
      .tab.active { border-left-color: var(--c-link); color: var(--c-link); background: var(--c-bg-mute); }
      .dashboard-scope-controls {
        display: grid;
        gap: 0.8rem;
        padding-top: 1rem;
        margin: 0;
      }
      .dashboard-scope-field {
        display: grid;
        flex-direction: column;
        gap: 0.22rem;
        font-size: 0.78rem;
        color: var(--c-fg-dim);
      }
      .dashboard-scope-field select {
        min-width: 150px;
        border: 1px solid var(--c-border);
        border-radius: 7px;
        background: var(--c-bg);
        color: var(--c-fg);
        padding: 0.34rem 0.48rem;
      }
      .deliveries-toolbar {
        margin-bottom: 0.7rem;
      }
      .deliveries-subtabs {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-bottom: 0.95rem;
      }
      .deliveries-subtab {
        border: 1px solid var(--c-border);
        background: var(--c-bg);
        color: var(--c-fg);
        border-radius: 999px;
        padding: 0.35rem 0.75rem;
        font-size: 0.82rem;
        cursor: pointer;
        transition: all 0.15s ease;
      }
      .deliveries-subtab:hover {
        border-color: var(--c-link);
      }
      .deliveries-subtab.active {
        border-color: var(--c-link);
        color: var(--c-link);
        background: var(--c-bg-mute);
      }
      .result-icon { font-size: 1rem; font-weight: 700; line-height: 1; display: inline-flex; align-items: center; justify-content: center; min-width: 1rem; }
      .result-icon.correct { color: #1f8f45; }
      .result-icon.incorrect { color: #c62828; }
      .result-icon.pending { color: #8b9098; }
      .quick-score-input {
        width: 64px;
        padding: 0.3rem 0.45rem;
        text-align: center;
        border: 1px solid var(--c-border);
        border-radius: 6px;
        background: var(--c-bg);
        color: var(--c-fg);
        font-size: 0.86rem;
      }
      .quick-feedback-input {
        width: min(100%, 320px);
        padding: 0.35rem 0.5rem;
        border: 1px solid var(--c-border);
        border-radius: 6px;
        background: var(--c-bg);
        color: var(--c-fg);
        font-size: 0.84rem;
      }
      .quick-saving { border-color: #f59e0b !important; }
      .quick-success { border-color: #16a34a !important; }
      .quick-error { border-color: #dc2626 !important; }
      .teacher-courses-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 0.85rem;
      }
      .teacher-course-card {
        border: 1px solid var(--c-border);
        border-radius: 8px;
        padding: 0.8rem;
        background: var(--c-bg);
      }
      .teacher-course-card h3 {
        margin: 0 0 0.45rem 0;
        font-size: 1rem;
      }
      .teacher-course-meta {
        margin: 0;
        display: grid;
        gap: 0.25rem;
        font-size: 0.84rem;
        color: var(--c-fg-dim);
      }
      .fold-shortcuts,
      .course-grades-shortcuts {
        margin: 0 0 0.8rem 0;
        padding: 0.6rem 0.7rem;
        border: 1px solid var(--c-border);
        border-radius: 8px;
        background: var(--c-bg-mute);
        font-size: 0.82rem;
      }
      .fold-shortcuts kbd,
      .course-grades-shortcuts kbd {
        border: 1px solid var(--c-border);
        border-bottom-width: 2px;
        border-radius: 4px;
        padding: 0.05rem 0.35rem;
        font-size: 0.75rem;
        background: var(--c-bg);
      }
      .fold-node {
        border: 1px solid var(--c-border);
        border-radius: 8px;
        background: var(--c-bg);
      }
      .fold-node + .fold-node {
        margin-top: 0.7rem;
      }
      .fold-header {
        width: 100%;
        display: flex;
        align-items: center;
        gap: 0.55rem;
        padding: 0.55rem 0.65rem;
        border: none;
        background: var(--c-bg-mute);
        color: var(--c-fg);
        text-align: left;
        cursor: pointer;
        border-radius: 7px 7px 0 0;
        font-size: 0.88rem;
      }
      .fold-node[data-fold-level="1"] > .fold-header {
        font-weight: 700;
      }
      .fold-node[data-fold-level="2"] > .fold-header {
        font-weight: 600;
      }
      .fold-children {
        padding: 0.65rem;
      }
      .fold-node.is-collapsed > .fold-children {
        display: none;
      }
      .fold-toggle-icon {
        width: 1rem;
        text-align: center;
        font-size: 0.82rem;
        color: var(--c-fg-dim);
      }
      .fold-node.is-collapsed .fold-toggle-icon {
        transform: rotate(-90deg);
      }
      .fold-student-summary {
        margin-left: auto;
        font-size: 0.8rem;
        color: var(--c-fg-dim);
      }
      .student-assignment-table {
        width: 100%;
        border-collapse: collapse;
      }
      .course-bulk-toolbar {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.45rem;
        margin: 0.35rem 0 0.8rem;
        padding: 0.45rem 0.55rem;
        border: 1px solid var(--c-border);
        border-radius: 8px;
        background: color-mix(in srgb, var(--c-bg-mute) 70%, transparent);
        font-size: 0.78rem;
      }
      .course-bulk-toolbar .bulk-hint {
        color: var(--c-fg-dim);
      }
      .course-bulk-toolbar .bulk-count {
        color: var(--c-fg-dim);
        font-variant-numeric: tabular-nums;
      }
      .course-bulk-toolbar .bulk-spacer {
        flex: 1 1 auto;
      }
      .course-bulk-toolbar button {
        border: 1px solid var(--c-border);
        border-radius: 6px;
        background: var(--c-bg);
        color: var(--c-fg);
        font: inherit;
        padding: 0.2rem 0.45rem;
        cursor: pointer;
      }
      .grade-board-wrap {
        border: 1px solid var(--c-border);
        border-radius: 8px;
        overflow: auto;
      }
      .grade-board-table {
        min-width: 640px;
        font-size: 0.78rem;
      }
      .grade-board-table th,
      .grade-board-table td {
        white-space: nowrap;
        text-align: center;
        padding: 0.28rem 0.32rem;
      }
      .grade-board-table .group-start {
        border-left: 2px solid color-mix(in srgb, var(--c-border) 70%, #ffffff 30%);
      }
      .grade-board-table .group-general {
        background: color-mix(in srgb, var(--c-link) 20%, transparent);
      }
      .grade-board-table .lesson-group-even {
        background: rgba(34, 197, 94, 0.12);
      }
      .grade-board-table .lesson-group-odd {
        background: rgba(251, 191, 36, 0.12);
      }
      .grade-board-table th.lesson-group-header {
        font-size: 0.74rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        background: var(--c-bg-mute);
      }
      .grade-board-table th.grade-board-final-header {
        font-size: 0.74rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        background: var(--c-bg-mute);
      }
      .grade-board-table th.eval-header {
        font-size: 0.74rem;
      }
      .grade-board-table th:first-child,
      .grade-board-table td:first-child {
        text-align: left;
        position: sticky;
        left: 0;
        background: color-mix(in srgb, var(--c-bg, #111) 95%, #000 5%);
        z-index: 3;
        min-width: 172px;
      }
      .grade-board-table thead th:first-child {
        z-index: 4;
        background: var(--c-bg-mute);
      }
      .grade-board-table tbody td:first-child {
        box-shadow: 8px 0 14px rgba(0, 0, 0, 0.2);
      }
      .grade-board-student {
        display: grid;
        gap: 0.1rem;
      }
      .grade-board-student small {
        color: var(--c-fg-dim);
        font-size: 0.72rem;
      }
      .grade-board-state {
        margin-top: 0.2rem;
        font-size: 0.7rem;
        color: var(--c-fg-dim);
      }
      .grade-board-average {
        font-weight: 600;
      }
      .grade-board-meta-input {
        width: 82px;
        max-width: 100%;
        padding: 0.18rem 0.28rem;
        border: 1px solid var(--c-border);
        border-radius: 4px;
        background: var(--c-bg);
        color: var(--c-fg);
        font: inherit;
        font-size: 0.74rem;
      }
      .grade-turno-select {
        width: 54px;
      }
      .grade-board-email {
        font-size: 0.72rem;
        color: var(--c-fg-dim);
        max-width: 150px;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .student-assignment-table th,
      .student-assignment-table td {
        border-bottom: 1px solid var(--c-border);
        padding: 0.3rem;
        text-align: center;
      }
      .student-assignment-table th {
        font-size: 0.72rem;
        font-weight: 600;
        color: var(--c-fg-dim);
      }
      .student-assignment-table td:first-child,
      .student-assignment-table th:first-child {
        text-align: left;
      }
      .fold-level-2 {
        margin-left: 0.4rem;
      }
      .fold-level-3 {
        margin-left: 0.4rem;
      }
      .fold-level-4 {
        margin-left: 0.4rem;
      }
      .grade-board-table tbody tr.is-row-selected td {
        outline: 1px solid color-mix(in srgb, var(--c-link) 65%, #ffffff 35%);
        outline-offset: -1px;
        box-shadow: inset 0 0 0 999px color-mix(in srgb, var(--c-link) 18%, transparent);
      }
      .grade-board-table tbody tr.is-row-selected td:first-child {
        box-shadow:
          inset 0 0 0 999px color-mix(in srgb, var(--c-link) 20%, transparent),
          8px 0 14px rgba(0, 0, 0, 0.2);
      }
      @media (max-width: 980px) {
        .attendance-grid-table th:nth-child(2),
        .attendance-grid-table td:nth-child(2),
        .attendance-grid-table th:nth-child(3),
        .attendance-grid-table td:nth-child(3) {
          position: static;
          box-shadow: none;
        }
      }
      .log-panel {
        border: 1px solid var(--c-border);
        border-radius: 10px;
        background: var(--c-bg);
        padding: 0.9rem;
      }
      .log-toolbar {
        display: grid;
        gap: 0.6rem;
        grid-template-columns: 1.6fr 1fr 1fr 1fr;
        margin-bottom: 0.8rem;
      }
      .log-input,
      .log-select {
        width: 100%;
        padding: 0.45rem 0.55rem;
        border: 1px solid var(--c-border);
        border-radius: 6px;
        background: var(--c-bg);
        color: var(--c-fg);
        font: inherit;
        font-size: 0.84rem;
      }
      .log-count {
        margin: 0 0 0.65rem 0;
        font-size: 0.82rem;
        color: var(--c-fg-dim);
      }
      .log-table-wrap {
        overflow: auto;
        max-height: min(70dvh, 900px);
        border: 1px solid var(--c-border);
        border-radius: 8px;
      }
      .log-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 1180px;
        font-size: 0.74rem;
      }
      .log-table th,
      .log-table td {
        border-bottom: 1px solid var(--c-border);
        padding: 0.26rem 0.34rem;
        text-align: left;
        vertical-align: top;
      }
      .log-table th {
        position: sticky;
        top: 0;
        background: var(--c-bg-mute);
        z-index: 2;
      }
      .log-sort-btn {
        border: none;
        background: transparent;
        color: inherit;
        font: inherit;
        cursor: pointer;
        padding: 0;
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
      }
      .log-sort-btn:hover {
        color: var(--c-link);
      }
      .log-tag {
        display: inline-flex;
        align-items: center;
        border: 1px solid var(--c-border);
        border-radius: 999px;
        padding: 0.1rem 0.45rem;
        font-size: 0.74rem;
        white-space: nowrap;
      }
      .log-answer {
        max-width: 240px;
        white-space: normal;
      }
      .log-payload {
        display: inline-block;
        max-width: 280px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
      .log-empty {
        font-size: 0.85rem;
        color: var(--c-fg-dim);
      }
      .eval-id-anchor {
        border: none;
        background: transparent;
        color: inherit;
        font: inherit;
        cursor: help;
        padding: 0;
      }
      .eval-id-anchor code {
        text-decoration: underline dotted;
        text-underline-offset: 2px;
      }
      .eval-preview-tooltip {
        position: fixed;
        top: 0;
        left: 0;
        z-index: 2400;
        max-width: min(440px, 92vw);
        border: 1px solid var(--c-border);
        border-radius: 8px;
        background: var(--c-bg);
        box-shadow: 0 12px 30px rgba(0, 0, 0, 0.2);
        padding: 0.55rem 0.65rem;
        pointer-events: none;
      }
      .eval-preview-tooltip[hidden] {
        display: none !important;
      }
      .eval-preview-tooltip h4 {
        margin: 0 0 0.4rem 0;
        font-size: 0.85rem;
      }
      .eval-preview-tooltip p {
        margin: 0 0 0.35rem 0;
        font-size: 0.79rem;
        line-height: 1.42;
      }
      .eval-preview-tooltip ul {
        margin: 0 0 0.35rem 1rem;
        padding: 0;
        font-size: 0.79rem;
        line-height: 1.4;
      }
      .eval-preview-tooltip li {
        margin: 0 0 0.2rem 0;
      }
      .eval-preview-tooltip code {
        font-size: 0.75rem;
      }
      @media (max-width: 960px) {
        .dashboard-shell {
          grid-template-columns: 1fr;
        }
        .dashboard-sidebar {
          position: static;
          height: auto;
        }
        .log-toolbar {
          grid-template-columns: 1fr;
        }
        .tabs {
          display: flex;
          flex-wrap: wrap;
          border-bottom: 1px solid var(--c-border);
          margin-bottom: 0.2rem;
        }
        .dashboard-scope-controls {
          width: 100%;
          justify-content: flex-end;
          padding-top: 0.7rem;
        }
        .tab {
          border-left: 0;
          border-bottom: 2px solid transparent;
        }
        .tab.active {
          border-left-color: transparent;
          border-bottom-color: var(--c-link);
        }
      }
    </style>
  </head>
  <body>
    <Header
      courseId={activeCourseId}
      activeCourseId={activeCourseId}
      activeCourseCode={activeCourseCode}
    />
    <main class="wrap">
      <div class="dashboard-shell">
        <aside class="dashboard-sidebar" aria-label="Navegación del panel">
          {isTeacher ? (
            <>
              <h1 class="dashboard-sidebar-title">Panel de Administración</h1>
              <p class="dashboard-sidebar-copy">Usuarios, inscripciones, entregas y asistencia del curso activo.</p>
              <div class="tabs">
                <div class="tab active" data-tab="users">Usuarios</div>
                <div class="tab" data-tab="enrollments">Inscripciones</div>
                <div class="tab" data-tab="deliveries">Entregas</div>
                <div class="tab" data-tab="attendance">Asistencia</div>
                <div class="dashboard-scope-controls">
                  <label class="dashboard-scope-field">
                    <span>Curso</span>
                    <select data-dashboard-scope="course">
                      {availableCourseMeta.length === 0 ? (
                        <option value="">Sin cursos</option>
                      ) : (
                        availableCourseMeta.map((course) => (
                          <option value={course.courseId} selected={course.courseId === activeCourseId}>
                            {course.title}
                          </option>
                        ))
                      )}
                    </select>
                  </label>
                  <label class="dashboard-scope-field">
                    <span>Año</span>
                    <select data-dashboard-scope="year">
                      {availableYears.map((year) => (
                        <option value={year} selected={year === activeYear}>{year}</option>
                      ))}
                    </select>
                  </label>
                </div>
              </div>
            </>
          ) : (
            <>
              <h1 class="dashboard-sidebar-title">Panel de Estudiante</h1>
              <p class="dashboard-sidebar-copy">Perfil, entregas y log personal del curso seleccionado.</p>
              <nav class="dashboard-sidebar-nav" aria-label="Secciones del panel">
                <a href="#student-profile" class="tab active">Perfil</a>
                <a href="#student-deliveries" class="tab">Entregas</a>
                <a href="#student-attendance" class="tab">Asistencia</a>
                <a href="#student-log" class="tab">Log</a>
              </nav>
              <div class="dashboard-scope-controls">
                <label class="dashboard-scope-field">
                  <span>Curso</span>
                  <select data-dashboard-scope="course">
                    {availableCourseMeta.length === 0 ? (
                      <option value="">Sin cursos</option>
                    ) : (
                      availableCourseMeta.map((course) => (
                        <option value={course.courseId} selected={course.courseId === activeCourseId}>
                          {course.title}
                        </option>
                      ))
                    )}
                  </select>
                </label>
                <label class="dashboard-scope-field">
                  <span>Año</span>
                  <select data-dashboard-scope="year">
                    {availableYears.map((year) => (
                      <option value={year} selected={year === activeYear}>{year}</option>
                    ))}
                  </select>
                </label>
              </div>
