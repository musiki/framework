                if (button.dataset.bound === 'true') return;
                button.dataset.bound = 'true';
                button.addEventListener('click', () => handleDeleteSubmission(button));
              });
            }

            async function handleDeleteUser(button) {
              const userId = String(button.getAttribute('data-user-id') || '').trim();
              const userName = String(button.getAttribute('data-user-name') || userId).trim();
              if (!userId) return;

              const confirmed = window.confirm(`¿Eliminar usuario "${userName}"? Se eliminarán sus inscripciones y entregas.`);
              if (!confirmed) return;

              button.disabled = true;
              try {
                const response = await fetch(`/api/admin/users/${userId}`, {
                  method: 'DELETE',
                });
                if (!response.ok) {
                  const payload = await response.json().catch(() => ({}));
                  throw new Error(payload?.error || 'No se pudo eliminar el usuario');
                }
                window.location.reload();
              } catch (error) {
                console.error('Error deleting user:', error);
                alert(error?.message || 'No se pudo eliminar el usuario');
                button.disabled = false;
              }
            }

            function initializeUserDeleteButtons() {
              document.querySelectorAll('.js-delete-user').forEach((button) => {
                if (button.dataset.bound === 'true') return;
                button.dataset.bound = 'true';
                button.addEventListener('click', () => handleDeleteUser(button));
              });
            }

            async function handleUnenrollStudent(button) {
              const enrollmentId = String(button.getAttribute('data-enrollment-id') || '').trim();
              const userName = String(button.getAttribute('data-user-name') || 'este estudiante').trim();
              const enrollmentRole = String(button.getAttribute('data-enrollment-role') || 'student').trim().toLowerCase();
              const isTeacherEnrollment = enrollmentRole === 'teacher';
              if (!enrollmentId) return;

              const confirmed = window.confirm(
                isTeacherEnrollment
                  ? `¿Quitar tu inscripción docente "${userName}" de este curso?`
                  : `¿Desinscribir a "${userName}" de este curso?`,
              );
              if (!confirmed) return;

              button.disabled = true;
              try {
                const response = await fetch('/api/enroll', {
                  method: 'DELETE',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ enrollmentId }),
                });
                if (!response.ok) {
                  const payload = await response.json().catch(() => ({}));
                  throw new Error(
                    payload?.error
                    || (isTeacherEnrollment
                      ? 'No se pudo quitar la inscripción docente'
                      : 'No se pudo desinscribir al estudiante'),
                  );
                }
                window.location.reload();
              } catch (error) {
                console.error('Error removing enrollment:', error);
                alert(
                  error?.message
                  || (isTeacherEnrollment
                    ? 'No se pudo quitar la inscripción docente'
                    : 'No se pudo desinscribir al estudiante'),
                );
                button.disabled = false;
              }
            }

            function initializeUnenrollButtons() {
              document.querySelectorAll('.js-unenroll-student').forEach((button) => {
                if (button.dataset.bound === 'true') return;
                button.dataset.bound = 'true';
                button.addEventListener('click', () => handleUnenrollStudent(button));
              });
            }

            document.addEventListener('DOMContentLoaded', () => {
              bindMainTabs();
              initializeDashboardScopeSelectors();
              initializeUserDeleteButtons();
              initializeUnenrollButtons();
              restoreDashboardTabFromQuery();
              const activeTab = getActiveTabName();
              if (activeTab === 'deliveries') {
                initializeDeliveriesTab();
              }
              document.addEventListener('keydown', handleFoldShortcuts);
            });
          </script>
        </>
      ) : (
        <>
          <section class="student-section" id="student-profile">
            <h2 class="group-title">Mi Perfil</h2>
            <article class="student-profile-card">
              {dbUser.image ? (
                <img class="student-profile-avatar" src={dbUser.image} alt={dbUser.name || dbUser.email || 'Perfil'} />
              ) : (
                <span class="student-profile-fallback">
                  {String(dbUser.name || dbUser.email || 'U').trim().charAt(0).toUpperCase()}
                </span>
              )}
              <div>
                <p class="student-profile-name">{dbUser.name || 'Estudiante'}</p>
                <p class="student-profile-meta">
                  <span>{dbUser.email}</span>
                  <span>Rol: estudiante</span>
                </p>
                <p class="student-profile-note">
                  Este panel muestra tus datos, entregas, asistencia y log personal del curso activo.
                </p>
              </div>
            </article>
          </section>

          <section class="student-section" id="student-deliveries">
            <h2 class="group-title">Entregas</h2>
            {scopedStudentSubmissions.length === 0 ? (
              <p class="student-empty">No registras entregas todavía.</p>
            ) : (
              <table class="admin-table">
                <thead>
                  <tr>
                    <th>Clase</th>
                    <th>ID</th>
