const teacherCourseGradeGroups = (() => {
  if (!(isTeacher && allEnrollments && allSubmissions && allUsers && allAssignments)) return [] as any[];

  const enrollmentSource = scopedTeacherEnrollments.filter((enrollment: any) =>
    !isTeacherCourseMember(enrollment?.userId, enrollment?.courseId, scopedTeacherEnrollments),
  );

  const courseGroups = enrollmentSource.reduce((acc: Record<string, any[]>, enroll: any) => {
    const courseId = canonicalizeCourseId(enroll?.courseId) || String(enroll?.courseId || '').trim();
    if (!courseId) return acc;
    if (!acc[courseId]) acc[courseId] = [];
    acc[courseId].push(enroll);
    return acc;
  }, {});

  const usersById = new Map((allUsers || []).map((user: any) => [user.id, user]));

  return Object.entries(courseGroups)
    .sort(([left], [right]) => String(left).localeCompare(String(right), 'es'))
    .map(([courseId, enrolls]) => {
      const courseSubmissionsAllYears = scopedTeacherSubmissions.filter((submission: any) => {
        const meta = resolveSubmissionMeta(submission);
        const submissionCourseId = canonicalizeCourseId(meta?.courseIdRaw || meta?.courseId || '');
        return submissionCourseId === courseId;
      });

      const courseAssignmentsMap = new Map<string, any>();

      (liveEvalEntriesByCourseId[courseId] || []).forEach((entry: any) => {
        const assignmentId = String(entry?.evalId || '').trim();
        if (!assignmentId) return;
        courseAssignmentsMap.set(assignmentId, {
          id: assignmentId,
          courseId,
          slug: String(entry?.entryId || ''),
        });
      });

      courseSubmissionsAllYears.forEach((submission: any) => {
        const assignmentId = String(submission?.assignmentId || '').trim();
        const meta = resolveSubmissionMeta(submission);
        if (
          !assignmentId
          || courseAssignmentsMap.has(assignmentId)
          || !liveEvalEntryById.has(assignmentId)
          || isSystemMetaAssignmentRef(meta.assignmentSlug || assignmentId)
        ) return;
        courseAssignmentsMap.set(assignmentId, {
          id: assignmentId,
          courseId,
          slug: meta.assignmentSlug || `${courseId}/${assignmentId}`,
        });
      });

      const courseAssignments = Array.from(courseAssignmentsMap.values()).sort((left: any, right: any) => {
        const leftKey = String(left?.slug || left?.id || '');
        const rightKey = String(right?.slug || right?.id || '');
        return leftKey.localeCompare(rightKey, 'es');
      });

      const assignmentsByPage = groupCourseAssignmentsByPage(courseAssignments, courseId);
      const lessonGroups = buildCourseLessonGroups(assignmentsByPage).map((lesson: any) => ({
        lessonSlug: String(lesson?.lessonSlug || ''),
        lessonLabel: String(lesson?.lessonLabel || ''),
        assignments: (lesson?.assignments || []).map((assignment: any) => {
          const assignmentId = String(assignment?.id || '');
          const dbAssignment = assignmentById.get(assignmentId);
          const group = String(dbAssignment?.settings?.group || dbAssignment?.settings?.tarea || '').trim();
          return {
            id: assignmentId,
            label: decodeUriSafe(assignmentId.split('/').pop() || assignmentId),
            group,
          };
        }),
      }));

      const flatAssignments = lessonGroups.flatMap((lesson: any) => lesson.assignments || []);
      const assignmentIdSet = new Set(flatAssignments.map((assignment: any) => String(assignment?.id || '')).filter(Boolean));
      const visibleSubmissions = courseSubmissionsAllYears.filter((submission: any) =>
        assignmentIdSet.has(String(submission?.assignmentId || ''))
        && !isTeacherCourseMember(submission?.userId, courseId, enrolls),
      );

      const yearSet = new Set([activeYear]);
      visibleSubmissions.forEach((submission: any) => {
        yearSet.add(getSubmissionYear(submission));
      });
      const years = Array.from(yearSet).sort((left, right) => {
        const numericDiff = Number(right) - Number(left);
        if (!Number.isNaN(numericDiff) && numericDiff !== 0) return numericDiff;
        return String(right).localeCompare(String(left), 'es');
      });

      const currentStudents = (enrolls || [])
        .filter((enrollment: any) => normalizeRole(enrollment?.roleInCourse) === 'student')
        .map((enrollment: any) => usersById.get(enrollment.userId))
        .filter(Boolean);

      if (currentStudents.length === 0 && visibleSubmissions.length === 0) return null;

      const enrollmentsByStudent = new Map(
        (enrolls || [])
          .filter((enrollment: any) => normalizeRole(enrollment?.roleInCourse) === 'student')
          .map((enrollment: any) => [enrollment.userId, enrollment]),
      );

      const yearGroups = years
        .map((year) => {
          const yearSubmissions = visibleSubmissions.filter((submission: any) => getSubmissionYear(submission) === year);
          const submissionMap = new Map<string, any>();
          yearSubmissions.forEach((submission: any) => {
            submissionMap.set(`${submission.userId}::${submission.assignmentId}`, submission);
          });

          const yearStudentIds = new Set(currentStudents.map((student: any) => String(student?.id || '')));
          yearSubmissions.forEach((submission: any) => {
            const studentId = String(submission?.userId || '');
            if (studentId) yearStudentIds.add(studentId);
          });

          const students = Array.from(yearStudentIds)
            .map((studentId) => usersById.get(studentId))
            .filter(Boolean)
            .sort((left: any, right: any) =>
              String(left?.name || left?.email || '').localeCompare(
                String(right?.name || right?.email || ''),
                'es',
              ),
            );

          if (students.length === 0) return null;

          const yearPending = yearSubmissions.filter((submission: any) => !isSubmissionReviewed(submission)).length;
          const rows = students.map((student: any) => {
            const panelKey = `${courseId}__${year}__${student.id}`
              .replace(/[^a-zA-Z0-9_-]/g, '_')
              .slice(0, 140);
            const scores = flatAssignments
              .map((assignment: any) => {
                const submission = submissionMap.get(`${student.id}::${assignment.id}`);
                if (!submission) return null;
                if (submission.score === null || submission.score === undefined) return null;
                const value = Number(submission.score);
                return Number.isNaN(value) ? null : value;
              })
              .filter((value: number | null) => value !== null) as number[];
            const average = scores.length > 0
              ? (scores.reduce((sum, value) => sum + value, 0) / scores.length).toFixed(1)
              : '-';
            const studentEnrollment = enrollmentsByStudent.get(student.id);
            const metaKey = `${normalizeTextLower(courseId)}::${year}::${student.id}`;
            const savedMeta = courseStudentMetaByKey.get(metaKey);
            const attendanceCount = attendanceDayCountByStudentKey.get(metaKey)?.size || 0;
            const turnoRaw = normalizeText(savedMeta?.turno || studentEnrollment?.turno || student?.turno || '').toUpperCase();
            const turnoValue = ['M', 'T', 'N'].includes(turnoRaw) ? turnoRaw : 'M';
            const groupValue = normalizeText(
              savedMeta?.grupo
                || studentEnrollment?.group
                || studentEnrollment?.grupo
                || student?.group
                || student?.grupo
                || '',
            );
            const conceptValue = normalizeText(
              savedMeta?.concepto
                || studentEnrollment?.concept
                || studentEnrollment?.concepto
                || '',
            );
            const rowSearch = [
              courseId,
              year,
              student?.name,
              student?.email,
              turnoValue,
              String(attendanceCount),
              groupValue,
              conceptValue,
              ...lessonGroups.map((lesson: any) => lesson.lessonLabel),
              ...flatAssignments.map((assignment: any) => assignment.id),
            ]
              .map((value) => normalizeTextLower(value))
              .filter(Boolean)
              .join(' ');

            const cells = Object.fromEntries(
              flatAssignments.map((assignment: any) => {
                const submission = submissionMap.get(`${student.id}::${assignment.id}`);
                if (!submission) return [assignment.id, null];
                const statusLabel = isSubmissionReviewed(submission)
                  ? 'calificada'
                  : 'pendiente';
                return [assignment.id, {
                  submissionId: submission.id,
                  assignmentId: assignment.id,
                  score: submission.score !== null && submission.score !== undefined ? submission.score : '',
                  statusLabel,
                }];
              }),
            );

            return {
              studentId: student.id,
              name: student?.name || student?.email || student?.id,
              email: student?.email || student?.id,
              panelKey,
              average,
              turnoValue,
              groupValue,
              conceptValue,
              attendanceCount,
              rowSearch,
              cells,
            };
          });

          return {
            year,
            yearPending,
            rows,
            search: `${normalizeTextLower(courseId)} ${normalizeTextLower(year)}`,
          };
        })
        .filter(Boolean);

      return {
        courseId,
        hasAssignments: flatAssignments.length > 0,
        lessonGroups,
        yearGroups,
      };
    })
    .filter(Boolean);
})();

const teacherRecentSubmissionGroups = (() => {
  if (!isTeacher) return [] as any[];

  const groupedByType = recentTeacherSubmissions.reduce((acc: Record<string, any>, submission: any) => {
    const meta = resolveSubmissionMeta(submission);
    const noteTypeKey = meta.noteType || 'unknown';

    if (!acc[noteTypeKey]) {
      acc[noteTypeKey] = {
        key: noteTypeKey,
        label: meta.noteTypeLabel,
        order: meta.noteTypeOrder,
        submissions: [],
      };
    }

    const submitter = (allUsers || []).find((user: any) => user.id === submission?.userId);
    const answerText = getSubmissionAnswerText(submission, assignmentById);
    const rowSearch = [
      submitter?.name,
      submitter?.email,
      meta.assignmentLabel,
      meta.assignmentSlug,
      meta.courseId,
      meta.noteTypeLabel,
      meta.evalType,
      answerText,
      submission?.feedback,
    ]
      .map((value) => normalizeTextLower(value))
      .filter(Boolean)
      .join(' ');

    acc[noteTypeKey].submissions.push({
      submission,
      meta,
      submitterName: submitter?.name || 'Usuario desconocido',
      answerText,
      evalPreviewAttr: toEvalPreviewAttr(meta.evalPreview),
      resultState: getSubmissionResultState(submission),
      rowSearch,
    });
    return acc;
  }, {});

  return Object.values(groupedByType || {})
    .sort((left: any, right: any) => {
      if (left.order !== right.order) return left.order - right.order;
      return String(left.label).localeCompare(String(right.label), 'es');
    })
    .map((group: any) => ({
      ...group,
      pendingByType: (group.submissions || []).filter((entry: any) => !isSubmissionReviewed(entry.submission)).length,
    }));
})();

const buildSubmissionLogRows = (submissions: any[], options: { includeUser: boolean }) => {
  const includeUser = Boolean(options?.includeUser);
  return submissions
    .map((submission: any) => {
      const meta = resolveSubmissionMeta(submission);
      const scoreValue =
        submission?.score !== null && submission?.score !== undefined ? Number(submission.score) : null;
      const attempts = Number(submission?.attempts || 0);
      const submittedAt = normalizeText(submission?.submittedAt);
      const gradedAt = normalizeText(submission?.gradedAt);
      const feedback = normalizeText(submission?.feedback);
      const answerText = getSubmissionAnswerText(submission, assignmentById);
      const resultState = getSubmissionResultState(submission);
      const userRecord = includeUser
        ? (allUsers || []).find((user: any) => user.id === submission?.userId)
        : dbUser;
      const userName = normalizeText(userRecord?.name || userRecord?.email || submission?.userId || 'unknown');
      const userEmail = normalizeText(userRecord?.email || '');
      const payloadText = asJsonText(submission?.payload || null);
      const submittedAtTs = submittedAt ? new Date(submittedAt).getTime() : 0;
      const reviewed = isSubmissionReviewed(submission);
      const reviewDate = gradedAt || (reviewed ? submittedAt : '');
      const gradedAtTs = reviewDate ? new Date(reviewDate).getTime() : 0;

      const search = [
        submission?.id,
        submission?.assignmentId,
        meta.assignmentSlug,
        meta.assignmentLabel,
        meta.courseId,
        meta.evalType,
        meta.mode,
        meta.noteType,
        meta.noteTypeLabel,
        answerText,
        feedback,
        userName,
        userEmail,
        payloadText,
        meta?.evalPreview?.prompt,
        ...(Array.isArray(meta?.evalPreview?.options) ? meta.evalPreview.options : []),
      ]
        .map((value) => normalizeTextLower(value))
        .filter(Boolean)
        .join(' ');

      return {
        submissionId: String(submission?.id || ''),
        userId: String(submission?.userId || ''),
        userName,
        userEmail,
        assignmentId: String(submission?.assignmentId || ''),
        assignmentSlug: meta.assignmentSlug,
        assignmentLabel: meta.assignmentLabel,
        courseId: meta.courseId,
        evalType: meta.evalType,
        mode: meta.mode,
        noteType: meta.noteType,
        noteTypeLabel: meta.noteTypeLabel,
        noteTypeOrder: meta.noteTypeOrder,
        attempts,
        score: scoreValue,
        feedback,
        evalPreview: meta.evalPreview,
        evalPreviewAttr: toEvalPreviewAttr(meta.evalPreview),
        submittedAt,
        submittedAtTs,
        gradedAt: reviewDate,
        gradedAtTs,
        resultState,
        answerText,
        payloadText,
        reviewState: reviewed ? 'reviewed' : 'pending',
        submissionState: submittedAt ? 'submitted' : 'missing',
        catalogSource: normalizeText(meta.catalogEntry?.sourcePath || ''),
        search,
      };
    })
    .sort((a, b) => b.submittedAtTs - a.submittedAtTs);
};

const teacherLogRows = isTeacher ? buildSubmissionLogRows(scopedTeacherSubmissions, { includeUser: true }) : [];
const studentLogRows = !isTeacher ? buildSubmissionLogRows(scopedStudentSubmissions || [], { includeUser: false }) : [];
const activeLogRows = isTeacher ? teacherLogRows : studentLogRows;
const logEvalTypes = Array.from(new Set(activeLogRows.map((row) => row.evalType).filter(Boolean))).sort();
const logModes = Array.from(new Set(activeLogRows.map((row) => row.mode).filter(Boolean))).sort();
const logNoteTypes = Array.from(new Set(activeLogRows.map((row) => row.noteType).filter(Boolean))).sort(
  (left, right) => (EVAL_NOTE_TYPE_ORDER[left as EvalNoteType] || 99) - (EVAL_NOTE_TYPE_ORDER[right as EvalNoteType] || 99),
);
const getNoteTypeDisplay = (value: string) => EVAL_NOTE_TYPE_LABEL[(value as EvalNoteType) || 'unknown'] || value;
const dashboardLogData = {
  teacher: teacherLogRows,
  student: studentLogRows,
  filters: {
    evalTypes: logEvalTypes,
    modes: logModes,
    noteTypes: logNoteTypes.map((noteType) => ({
      value: noteType,
      label: getNoteTypeDisplay(noteType),
    })),
  },
};
const dashboardLogDataJson = JSON.stringify(dashboardLogData).replaceAll('<', '\\u003c');

let teacherDashboardAnnotations = [] as any[];
if (isTeacher && activeCourseId) {
  try {
    const annotationSupabase = createSupabaseServerClient({ requireServiceRole: true });
    const loadedAnnotations = await listDashboardAnnotations(annotationSupabase, {
      courseId: activeCourseId,
      year: activeYear,
    });
    teacherDashboardAnnotations = loadedAnnotations
      .filter((annotation) =>
        annotation.visibility === 'teachers'
        || String(annotation.authorUserId || '') === String(dbUser?.id || ''),
      )
      .map((annotation) => ({
        ...annotation,
        metadata: {
          ...(annotation.metadata || {}),
          updatedAtLabel: formatSubmissionDate(annotation.updatedAt || annotation.createdAt),
        },
      }));
  } catch (error: any) {
    const relationMissing =
      ['42P01', 'PGRST205'].includes(String(error?.code || ''))
      || String(error?.message || '').toLowerCase().includes('gradebookannotation');
    if (!relationMissing) {
      console.error('Error loading teacher dashboard annotations:', error);
    }
  }
}

const teacherOverviewProjection = isTeacher
  ? buildOverviewProjection({
      activeCourseId,
      activeYear,
      attendanceRows: attendanceGridRows,
      attendanceSummaryRows: attendanceUserSummaryRows,
      submissions: scopedTeacherSubmissions,
      todayDateKey: todayAttendanceDateKey,
      teacherCourseGradeGroups,
    })
  : { columns: [], rows: [], emptyMessage: '' };

const teacherGradebookProjection = isTeacher
  ? buildGradebookProjection({
      activeCourseId,
      activeYear,
      teacherCourseGradeGroups,
    })
  : { columns: [], rows: [], emptyMessage: '' };

const teacherAttendanceProjection = isTeacher
  ? buildAttendanceProjection({
      attendanceGridRows,
      attendanceLogRows: attendanceLogRows,
      attendanceScheduleGrid,
      todayDateKey: todayAttendanceDateKey,
    })
  : {
      summary: { columns: [], rows: [], emptyMessage: '' },
      log: { columns: [], rows: [], emptyMessage: '' },
    };

const teacherCommentsProjection = isTeacher
  ? buildCommentsProjection({
      annotations: teacherDashboardAnnotations,
    })
  : { columns: [], rows: [], emptyMessage: '' };

const teacherAdminProjection = isTeacher
  ? buildAdminProjection({
      activeCourseId,
      allUsers: allUsers || [],
      allEnrollments: allEnrollments || [],
      allSubmissions: allSubmissions || [],
      allLiveClassAttendance: allLiveClassAttendance || [],
    })
  : { columns: [], rows: [], emptyMessage: '' };

const teacherTabulatorMetaJson = toDashboardProjectionJson({
  userId: String(dbUser?.id || ''),
  courseId: activeCourseId,
  year: activeYear,
  initialTeacherTab: initialTeacherDashboardTab,
  supabaseUrl: import.meta.env.PUBLIC_SUPABASE_URL || import.meta.env.SUPABASE_URL,
  supabaseKey: import.meta.env.PUBLIC_SUPABASE_ANON_KEY || import.meta.env.SUPABASE_ANON_KEY || '',
});
const teacherOverviewProjectionJson = toDashboardProjectionJson(teacherOverviewProjection);
const teacherGradebookProjectionJson = toDashboardProjectionJson(teacherGradebookProjection);
const teacherAttendanceProjectionJson = toDashboardProjectionJson(teacherAttendanceProjection);
const teacherCommentsProjectionJson = toDashboardProjectionJson(teacherCommentsProjection);
const teacherAdminProjectionJson = toDashboardProjectionJson(teacherAdminProjection);
const teacherDashboardAnnotationsJson = toDashboardProjectionJson(teacherDashboardAnnotations);
