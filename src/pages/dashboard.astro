                      <th><button type="button" class="log-sort-btn" data-log-sort="submittedAtTs">Envío</button></th>
                      <th><button type="button" class="log-sort-btn" data-log-sort="gradedAtTs">Revisión</button></th>
                      <th><button type="button" class="log-sort-btn" data-log-sort="courseId">Curso</button></th>
                      <th><button type="button" class="log-sort-btn" data-log-sort="noteTypeOrder">Tipo Nota</button></th>
                      <th><button type="button" class="log-sort-btn" data-log-sort="evalType">Eval Type</button></th>
                      <th><button type="button" class="log-sort-btn" data-log-sort="mode">Mode</button></th>
                      <th><button type="button" class="log-sort-btn" data-log-sort="assignmentLabel">Clase</button></th>
                      <th><button type="button" class="log-sort-btn" data-log-sort="assignmentId">ID</button></th>
                      <th><button type="button" class="log-sort-btn" data-log-sort="attempts">Attempt</button></th>
                      <th><button type="button" class="log-sort-btn" data-log-sort="score">Score</button></th>
                      <th><button type="button" class="log-sort-btn" data-log-sort="resultState">Result</button></th>
                      <th><button type="button" class="log-sort-btn" data-log-sort="submissionState">Submission</button></th>
                      <th><button type="button" class="log-sort-btn" data-log-sort="reviewState">Review</button></th>
                      <th>Respuesta</th>
                      <th>Payload</th>
                      <th>Feedback</th>
                      <th>ID Submission</th>
                      <th>Source</th>
                    </tr>
                  </thead>
