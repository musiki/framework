const attendanceCourseSummaryRows = isTeacher
  ? (() => {
      const summaryByKey = new Map<string, any>();
      const totalSessions = scopedTeacherLiveSessions.length;

      scopedTeacherEnrollments
        .filter((enrollment: any) => normalizeRole(enrollment?.roleInCourse) === 'student')
        .forEach((enrollment: any) => {
          const studentUser = allUsersById.get(String(enrollment?.userId || ''));
          const key = `user:${String(enrollment?.userId || '')}`;
          if (!String(enrollment?.userId || '').trim() || summaryByKey.has(key)) return;

          summaryByKey.set(key, {
            key,
            userId: String(enrollment?.userId || ''),
            identity: '',
            name: String(studentUser?.name || studentUser?.email || enrollment?.userId || 'Estudiante'),
            email: String(studentUser?.email || ''),
            sessionsAttended: 0,
            totalJoinCount: 0,
            totalLeaveCount: 0,
            totalAbortedCount: 0,
            totalDurationMs: 0,
            lastStatus: '',
            lastSeenAt: '',
            sessionIds: new Set<string>(),
          });
        });

      scopedTeacherLiveAttendance
        .filter((attendance: any) => normalizeRole(attendance?.role) === 'student')
        .forEach((attendance: any) => {
          const userId = String(attendance?.userId || '');
          const identity = String(attendance?.identity || '');
          const key = userId ? `user:${userId}` : identity ? `identity:${identity}` : '';
          if (!key) return;

          const user = userId ? allUsersById.get(userId) : null;
          const session = scopedTeacherLiveSessionById.get(String(attendance?.sessionId || ''));
          const existing = summaryByKey.get(key) || {
            key,
            userId,
            identity,
            name: String(user?.name || attendance?.name || identity || 'Participante'),
            email: String(user?.email || ''),
            sessionsAttended: 0,
            totalJoinCount: 0,
            totalLeaveCount: 0,
            totalAbortedCount: 0,
            totalDurationMs: 0,
            lastStatus: '',
            lastSeenAt: '',
            sessionIds: new Set<string>(),
          };

          existing.name = String(existing.name || user?.name || attendance?.name || identity || 'Participante');
          existing.email = String(existing.email || user?.email || '');
          existing.totalJoinCount += Math.max(0, Number(attendance?.joinCount || 0));
          existing.totalLeaveCount += Math.max(0, Number(attendance?.leaveCount || 0));
          existing.totalAbortedCount += Math.max(0, Number(attendance?.abortedCount || 0));
          existing.totalDurationMs += computeAttendanceDurationMs(attendance, session);

          const sessionId = String(attendance?.sessionId || '');
          if (sessionId && Number(attendance?.joinCount || 0) > 0 && !existing.sessionIds.has(sessionId)) {
            existing.sessionIds.add(sessionId);
            existing.sessionsAttended += 1;
          }

          const nextLastSeenAt = String(attendance?.lastEventAt || attendance?.lastLeftAt || attendance?.lastJoinedAt || '');
          if (getDateTimestamp(nextLastSeenAt) >= getDateTimestamp(existing.lastSeenAt)) {
            existing.lastSeenAt = nextLastSeenAt;
            existing.lastStatus = String(attendance?.lastStatus || existing.lastStatus || '');
          }

          summaryByKey.set(key, existing);
        });

      return Array.from(summaryByKey.values())
        .map((row: any) => ({
          ...row,
          totalSessions,
          totalDurationLabel: formatDurationFromMs(row.totalDurationMs),
          lastSeenLabel: formatSubmissionDate(row.lastSeenAt),
        }))
        .sort((left: any, right: any) =>
          String(left.name || '').localeCompare(String(right.name || ''), 'es'),
        );
    })()
  : [];

const attendanceRowsBySessionId = (() => {
