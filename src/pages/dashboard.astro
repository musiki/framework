            function applyFoldDepth(scope) {
              const foldNodes = getFoldNodes(scope);
              if (foldNodes.length === 0) return;

              const state = getFoldState(scope);
              const collapseFromLevel = state.maxLevel - state.depth + 1;

              foldNodes.forEach((node) => {
                const level = Number(node.dataset.foldLevel || 0);
                const shouldCollapse = state.depth > 0 && level >= collapseFromLevel;
                node.classList.toggle('is-collapsed', shouldCollapse);
              });
            }

            function setFoldDepth(scope, nextDepth) {
              const state = getFoldState(scope);
              const bounded = Math.max(0, Math.min(state.maxLevel, nextDepth));
              state.depth = bounded;
              applyFoldDepth(scope);
            }

            function initializeCorrectionFolding(scope) {
              const foldNodes = getFoldNodes(scope);
              if (foldNodes.length === 0) return false;

              const state = getFoldState(scope);
              state.maxLevel = foldNodes.reduce((max, node) => {
                const level = Number(node.dataset.foldLevel || 0);
                return Math.max(max, level);
              }, 1);

              foldNodes.forEach((node) => {
                if (node.dataset.foldBound === 'true') return;
                node.dataset.foldBound = 'true';

                const toggle = node.querySelector('[data-fold-toggle]');
                if (!toggle) return;

                toggle.addEventListener('click', () => {
                  node.classList.toggle('is-collapsed');
                });
              });

              applyFoldDepth(scope);
              return true;
            }

            function handleFoldShortcuts(event) {
              const isMacShortcut = event.metaKey;
              if (!isMacShortcut) return;

              const target = event.target;
              if (target instanceof HTMLElement) {
                const tag = target.tagName.toLowerCase();
                if (target.isContentEditable || tag === 'input' || tag === 'textarea' || tag === 'select') {
                  return;
                }
              }

              const scope = getActiveFoldScope();
              if (!scope) return;
              if (!initializeCorrectionFolding(scope)) return;

              const state = getFoldState(scope);

              if (event.shiftKey && event.key === 'ArrowUp') {
                event.preventDefault();
                setFoldDepth(scope, state.maxLevel);
                return;
              }

              if (event.shiftKey && event.key === 'ArrowDown') {
                event.preventDefault();
                setFoldDepth(scope, 0);
                return;
              }

              if (!event.shiftKey && event.key === 'ArrowUp') {
                event.preventDefault();
                setFoldDepth(scope, state.depth + 1);
                return;
              }

              if (!event.shiftKey && event.key === 'ArrowDown') {
                event.preventDefault();
                setFoldDepth(scope, state.depth - 1);
              }
            }

            function markQuickState(input, state) {
              input.classList.remove('quick-saving', 'quick-success', 'quick-error');
              if (state) input.classList.add(state);
              if (state === 'quick-success' || state === 'quick-error') {
                setTimeout(() => {
                  input.classList.remove('quick-success', 'quick-error');
                }, 1200);
              }
            }

