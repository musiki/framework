                          const enrollmentRole = normalizeRole(enrollment?.roleInCourse);
                          const enrollmentLabel = String(user?.name || user?.email || enrollment.userId || 'estudiante').trim();
                          const canRemoveEnrollment =
                            enrollmentRole === 'student'
