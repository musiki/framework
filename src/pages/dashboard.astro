          flex-direction: column;
          flex: 0 0 auto;
          min-width: 144px;
        }
        .tab {
          border-left: 0;
          border-bottom: 2px solid transparent;
        }
        .tab.active {
          border-left-color: transparent;
          border-bottom-color: var(--c-link);
        }
      }
    </style>
  </head>
  <body>
    <Header
      courseId={activeCourseId}
