            function debounce(func, wait) {
              let timeout;
              return function executedFunction(...args) {
                const later = () => {
                  clearTimeout(timeout);
                  func(...args);
                };
                clearTimeout(timeout);
                timeout = setTimeout(later, wait);
              };
            }

            async function saveGrade(input) {
              const submissionId = input.dataset.submissionId;
              const score = parseFloat(input.value);

              if (!submissionId || Number.isNaN(score)) return;

              input.style.borderColor = '#ffa500';

              try {
                const response = await fetch(`/api/grade/quick-update`, {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({
                    submissionId: submissionId,
                    score: score,
                  }),
                });

                if (response.ok) {
                  input.style.borderColor = '#4caf50';
                  setTimeout(() => {
                    input.style.borderColor = '';
                  }, 1000);
                  updateRowAverage(input);
                } else {
                  input.style.borderColor = '#f44336';
                  setTimeout(() => {
                    input.style.borderColor = '';
                  }, 2000);
                }
              } catch (error) {
                console.error('Error saving grade:', error);
                input.style.borderColor = '#f44336';
                setTimeout(() => {
                  input.style.borderColor = '';
                }, 2000);
              }
            }

            function updateRowAverage(input) {
              const panelKey = input.dataset.studentPanel;
              if (!panelKey) return;

              const panelInputs = document.querySelectorAll(`.grade-input[data-student-panel="${panelKey}"]`);
              const scores = [];

              panelInputs.forEach((panelInput) => {
                const value = parseFloat(panelInput.value);
                if (!Number.isNaN(value)) scores.push(value);
              });

              const averageElement = document.querySelector(`[data-average-for="${panelKey}"]`);
              if (!averageElement) return;

              if (scores.length === 0) {
                averageElement.textContent = '-';
                return;
              }

              const average = (scores.reduce((sum, value) => sum + value, 0) / scores.length).toFixed(1);
              averageElement.textContent = average;
            }

            const debouncedSaveGrade = debounce(saveGrade, 800);

            async function saveCourseStudentMeta(row, input) {
              if (!(row instanceof HTMLElement) || !(input instanceof HTMLElement)) return;

              const courseId = String(row.getAttribute('data-course-id') || '').trim();
              const studentId = String(row.getAttribute('data-student-id') || '').trim();
              const year = String(row.getAttribute('data-year') || '').trim();
              if (!courseId || !studentId || !year) return;

              const turnoInput = row.querySelector('.grade-turno-select');
              const conceptInput = row.querySelector('.grade-concept-input');
              const groupInput = row.querySelector('.grade-group-input');
              if (!(turnoInput instanceof HTMLSelectElement)) return;
              if (!(conceptInput instanceof HTMLInputElement)) return;
              if (!(groupInput instanceof HTMLInputElement)) return;

              const payload = {
                courseId,
                studentId,
                year,
                turno: String(turnoInput.value || ''),
                concepto: String(conceptInput.value || ''),
                grupo: String(groupInput.value || ''),
              };

              markQuickState(input, 'quick-saving');

              try {
                const response = await fetch('/api/grade/course-student-meta', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify(payload),
                });

                if (!response.ok) {
                  markQuickState(input, 'quick-error');
                  return;
                }

                const result = await response.json().catch(() => ({}));
                const meta = result?.meta || {};
                if (typeof meta.turno === 'string' && ['M', 'T', 'N'].includes(meta.turno)) {
                  turnoInput.value = meta.turno;
                }
                if (typeof meta.concepto === 'string') {
                  conceptInput.value = meta.concepto;
                }
                if (typeof meta.grupo === 'string') {
                  groupInput.value = meta.grupo;
                }
                markQuickState(input, 'quick-success');
              } catch (error) {
                console.error('Error saving course student meta:', error);
                markQuickState(input, 'quick-error');
              }
            }

            const debouncedSaveCourseStudentMeta = debounce((row, input) => {
              saveCourseStudentMeta(row, input);
            }, 700);

            const selectedCourseRowKeys = new Set();

            function getCourseRowKey(row) {
              if (!(row instanceof HTMLElement)) return '';
              const courseId = String(row.getAttribute('data-course-id') || '').trim();
              const year = String(row.getAttribute('data-year') || '').trim();
              const studentId = String(row.getAttribute('data-student-id') || '').trim();
              if (!courseId || !year || !studentId) return '';
              return `${courseId}::${year}::${studentId}`;
            }

            function getCourseRowByKey(key) {
              if (!key) return null;
              const [courseId = '', year = '', studentId = ''] = String(key).split('::');
              if (!courseId || !year || !studentId) return null;
              return document.querySelector(
                `[data-course-row][data-course-id="${CSS.escape(courseId)}"][data-year="${CSS.escape(year)}"][data-student-id="${CSS.escape(studentId)}"]`,
              );
            }

            function getSelectedCourseRows() {
              return Array.from(selectedCourseRowKeys)
                .map((key) => getCourseRowByKey(key))
                .filter((row) => row instanceof HTMLElement && row.isConnected);
            }

            function updateCourseBulkSelectionUI() {
              const countNode = document.querySelector('[data-bulk-count]');
              if (countNode instanceof HTMLElement) {
                countNode.textContent = `${selectedCourseRowKeys.size} seleccionados`;
              }
            }

            function setCourseRowSelected(row, selected) {
              const key = getCourseRowKey(row);
              if (!key) return;

              if (selected) {
                selectedCourseRowKeys.add(key);
                row.classList.add('is-row-selected');
              } else {
                selectedCourseRowKeys.delete(key);
                row.classList.remove('is-row-selected');
              }
              updateCourseBulkSelectionUI();
            }

            function clearCourseRowSelection() {
              getSelectedCourseRows().forEach((row) => row.classList.remove('is-row-selected'));
              selectedCourseRowKeys.clear();
              updateCourseBulkSelectionUI();
            }

            function propagateMetaValueToSelectedRows(sourceRow, field, value) {
              if (!(sourceRow instanceof HTMLElement)) return;
              const sourceKey = getCourseRowKey(sourceRow);
              if (!sourceKey || selectedCourseRowKeys.size < 2 || !selectedCourseRowKeys.has(sourceKey)) return;

              const selectorByField = {
                turno: '.grade-turno-select',
                concepto: '.grade-concept-input',
                grupo: '.grade-group-input',
              };
              const selector = selectorByField[field];
              if (!selector) return;

              getSelectedCourseRows().forEach((row) => {
                const rowKey = getCourseRowKey(row);
                if (!rowKey || rowKey === sourceKey) return;

                const input = row.querySelector(selector);
                if (
                  !(
                    input instanceof HTMLInputElement ||
                    input instanceof HTMLSelectElement
                  )
                ) {
                  return;
                }
                if (String(input.value || '') === String(value || '')) return;

                input.value = String(value || '');
                saveCourseStudentMeta(row, input);
              });
            }

            function applyTurnoToSelectedRows(turnoValue) {
              const normalizedTurno = String(turnoValue || '').trim().toUpperCase();
              if (!['M', 'T', 'N'].includes(normalizedTurno)) return;

              getSelectedCourseRows().forEach((row) => {
                const input = row.querySelector('.grade-turno-select');
                if (!(input instanceof HTMLSelectElement)) return;
                if (input.value === normalizedTurno) return;
                input.value = normalizedTurno;
                saveCourseStudentMeta(row, input);
              });
            }

