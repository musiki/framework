  });
  return grouped;
})();

const attendanceLessonGroups = isTeacher
  ? (() => {
      const groups = new Map<string, any>();

      scopedTeacherLiveSessions.forEach((session: any) => {
        const sessionId = String(session?.id || '');
        if (!sessionId) return;

        const pageSlug = String(session?.pageSlug || '').trim() || 'sin-clase';
        const lessonLabel = decodeUriSafe(pageSlug.split('/').pop() || pageSlug || session?.roomName || 'Clase');
        const sessionAttendance = [...(attendanceRowsBySessionId.get(sessionId) || [])].sort((left: any, right: any) => {
          const leftRole = normalizeRole(left?.role) === 'teacher' ? 0 : 1;
          const rightRole = normalizeRole(right?.role) === 'teacher' ? 0 : 1;
          if (leftRole !== rightRole) return leftRole - rightRole;

          const leftUser = allUsersById.get(String(left?.userId || ''));
          const rightUser = allUsersById.get(String(right?.userId || ''));
          const leftName = String(leftUser?.name || left?.name || left?.identity || '');
          const rightName = String(rightUser?.name || right?.name || right?.identity || '');
          return leftName.localeCompare(rightName, 'es');
        });

        const participants = sessionAttendance.map((attendance: any) => {
          const user = allUsersById.get(String(attendance?.userId || ''));
          return {
            ...attendance,
            displayName: String(user?.name || attendance?.name || attendance?.identity || 'Participante'),
            email: String(user?.email || ''),
            durationLabel: formatDurationFromMs(computeAttendanceDurationMs(attendance, session)),
            firstJoinedLabel: formatSubmissionDate(attendance?.firstJoinedAt),
            lastLeftLabel: formatSubmissionDate(attendance?.lastLeftAt),
            lastEventLabel: formatSubmissionDate(attendance?.lastEventAt),
          };
        });

        const group = groups.get(pageSlug) || {
          pageSlug,
          lessonLabel,
          latestStartedAt: '',
          sessions: [],
        };

        group.sessions.push({
          id: sessionId,
          roomName: String(session?.roomName || ''),
          startedAt: String(session?.startedAt || ''),
          startedAtLabel: formatSubmissionDate(session?.startedAt),
          finishedAtLabel: formatSubmissionDate(session?.finishedAt),
          durationLabel: formatDurationFromMs(
            Math.max(
              0,
              getDateTimestamp(session?.finishedAt || session?.lastEventAt) - getDateTimestamp(session?.startedAt),
            ),
          ),
          studentCount: participants.filter((attendance: any) => normalizeRole(attendance?.role) === 'student').length,
          participantCount: participants.length,
          participants,
        });

        if (getDateTimestamp(session?.startedAt) >= getDateTimestamp(group.latestStartedAt)) {
          group.latestStartedAt = String(session?.startedAt || '');
        }

        groups.set(pageSlug, group);
      });

      return Array.from(groups.values())
        .map((group: any) => ({
          ...group,
          sessions: [...group.sessions].sort(
            (left: any, right: any) => getDateTimestamp(right.startedAt) - getDateTimestamp(left.startedAt),
          ),
        }))
        .sort(
          (left: any, right: any) =>
            getDateTimestamp(right.latestStartedAt) - getDateTimestamp(left.latestStartedAt),
        );
    })()
  : [];

