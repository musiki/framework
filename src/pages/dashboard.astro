                </thead>
                <tbody>
                  {scopedStudentSubmissions.map((sub: any) => {
                    const assignment = studentAssignmentById.get(sub.assignmentId);
                    const assignmentSlug = String(assignment?.slug || sub.assignmentId || '');
                    const assignmentLabel = decodeUriSafe(assignmentSlug.split('/').pop() || assignmentSlug);
                    const courseLabel = decodeUriSafe(assignment?.courseId || assignmentSlug.split('/')[0] || '—');
                    const meta = resolveSubmissionMeta(sub);
                    const evalPreviewAttr = toEvalPreviewAttr(meta.evalPreview);
                    return (
                      <tr>
