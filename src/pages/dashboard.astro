---
// src/pages/dashboard.astro
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { createClient } from '@supabase/supabase-js';
import { createSupabaseServerClient } from '../lib/forum-server';
import {
  getResultIcon,
  getSubmissionAnswerText,
  getSubmissionResultState,
  isSubmissionReviewed,
} from '../lib/submission-table';
import { getEvalOptionMap } from '../lib/eval-option-map';
import {
  buildEvalCatalog,
  EVAL_NOTE_TYPE_LABEL,
  EVAL_NOTE_TYPE_ORDER,
  inferEvalNoteTypeFromSlug,
  resolveEvalCatalogEntry,
  type EvalNoteType,
} from '../lib/eval-catalog';
import { getCourseFrontmatterId } from '../lib/course-metadata';
import { normalizeActivityPageSlug } from '../lib/class-activity/model.mjs';
import '../styles/theme.css';

// --- AUTHENTICATION ---
const session = Astro.locals.session as any;
const currentUser = session?.user;

if (!currentUser?.email) {
  return Astro.redirect('/login?redirect=/dashboard');
}

const dashboardUrl = new URL(Astro.request.url);
const requestedCourseParam = String(dashboardUrl.searchParams.get('course') || '').trim();
const requestedYearParam = String(dashboardUrl.searchParams.get('year') || '').trim();

// Initialize Supabase
const supabase = createClient(import.meta.env.SUPABASE_URL, import.meta.env.SUPABASE_KEY);

const sessionEmail = String(currentUser.email || '').trim();
const normalizedSessionEmail = sessionEmail.toLowerCase();

const normalizeRole = (value) => String(value || '').trim().toLowerCase();

async function resolveDashboardUserByEmail(email, normalizedEmail) {
  const { data, error } = await supabase
    .from('User')
    .select('*')
    .ilike('email', normalizedEmail)
    .order('updatedAt', { ascending: false })
    .order('createdAt', { ascending: false });

  if (error) throw error;

  const rows = Array.isArray(data) ? data : [];
  if (rows.length === 0) return { user: null, rows: [] };
  if (rows.length === 1) return { user: rows[0], rows };

  // Prefer exact-case email match first, then normalized match, then most recently updated row.
  const exactCaseRows = rows.filter((row) => String(row?.email || '').trim() === email);
  if (exactCaseRows.length > 0) return { user: exactCaseRows[0], rows };

  const normalizedRows = rows.filter(
    (row) => String(row?.email || '').trim().toLowerCase() === normalizedEmail
  );
  if (normalizedRows.length > 0) return { user: normalizedRows[0], rows };

  return { user: rows[0], rows };
}

let dbUser = null;
let matchedUsers = [];
try {
  const resolved = await resolveDashboardUserByEmail(sessionEmail, normalizedSessionEmail);
  dbUser = resolved.user;
  matchedUsers = resolved.rows;
} catch (userResolveError) {
  console.error('Error resolving dashboard user:', userResolveError);
}

// If user doesn't exist in DB, create them (first login)
if (!dbUser) {
  const { data: newUsers, error } = await supabase.from('User').insert([{
    id: crypto.randomUUID(),
    email: normalizedSessionEmail,
    name: currentUser.name || normalizedSessionEmail,
    emailVerified: true,
    image: currentUser.image || null,
    role: 'student', // Default role
    createdAt: new Date(),
    updatedAt: new Date(),
  }]).select();
  
  if (error) console.error('Error creating user:', error);
  // Fetch the newly created user
  dbUser = newUsers?.[0];
  
  if (!dbUser) {
    return Astro.redirect('/login?redirect=/dashboard');
  }

  matchedUsers = [dbUser];
}

const dashboardUserIds = Array.from(
  new Set(
    (matchedUsers.length > 0 ? matchedUsers : [dbUser])
      .map((row) => row?.id)
      .filter(Boolean)
  )
);

let hasTeacherEnrollment = false;
if (dashboardUserIds.length > 0) {
  const { data: teacherEnrollments, error: teacherEnrollmentError } = await supabase
    .from('Enrollment')
    .select('userId, roleInCourse')
    .in('userId', dashboardUserIds)
    .limit(50);

  if (teacherEnrollmentError) {
    console.error('Error resolving teacher enrollment for dashboard user:', teacherEnrollmentError);
  } else {
    hasTeacherEnrollment =
      Array.isArray(teacherEnrollments) &&
      teacherEnrollments.some((row) => normalizeRole(row?.roleInCourse) === 'teacher');
  }
}

const hasTeacherRole = (matchedUsers.length > 0 ? matchedUsers : [dbUser]).some(
  (row) => normalizeRole(row?.role) === 'teacher'
);
const isTeacher = hasTeacherRole || hasTeacherEnrollment;

if (isTeacher && normalizeRole(dbUser?.role) !== 'teacher') {
  const teacherRow = matchedUsers.find((row) => normalizeRole(row?.role) === 'teacher');
  if (teacherRow) {
    dbUser = teacherRow;
  } else if (dashboardUserIds.length > 0) {
    const preferredTeacherEnrollmentId = dashboardUserIds[0];
    const enrollmentMatchedUser = matchedUsers.find((row) => row?.id === preferredTeacherEnrollmentId);
    if (enrollmentMatchedUser) {
      dbUser = enrollmentMatchedUser;
    }
  }
}

// --- TEACHER DASHBOARD ---
let allUsers, allEnrollments, allSubmissions, allAssignments;
let allLiveClassSessions: any[] = [];
let allLiveClassAttendance: any[] = [];

if (isTeacher) {
  // Query all data for teacher view
  const { data: u } = await supabase.from('User').select('*'); allUsers = u || [];
  const { data: e } = await supabase.from('Enrollment').select('*'); allEnrollments = e || [];
  const { data: s } = await supabase.from('Submission').select('*').order('submittedAt', { ascending: false }); allSubmissions = s || [];
  const { data: a } = await supabase.from('Assignment').select('*'); allAssignments = a || [];

  try {
    const attendanceSupabase = createSupabaseServerClient({ requireServiceRole: true });
    const { data: liveSessions, error: liveSessionsError } = await attendanceSupabase
      .from('LiveClassSession')
      .select('*')
      .order('startedAt', { ascending: false });
    if (liveSessionsError) {
      console.error('Error loading LiveClassSession rows:', liveSessionsError);
    } else {
      allLiveClassSessions = liveSessions || [];
    }

    const { data: liveAttendance, error: liveAttendanceError } = await attendanceSupabase
      .from('LiveClassAttendance')
      .select('*')
      .order('lastEventAt', { ascending: false });
    if (liveAttendanceError) {
      console.error('Error loading LiveClassAttendance rows:', liveAttendanceError);
    } else {
      allLiveClassAttendance = liveAttendance || [];
    }
  } catch (error) {
    console.error('Error initializing attendance dashboard queries:', error);
  }
}

// --- STUDENT DASHBOARD ---
let studentAssignments: any[] = [];
let studentSubmissions: any[] = [];

let enrollmentQuery = supabase.from('Enrollment').select('courseId');
if (dashboardUserIds.length > 1) {
  enrollmentQuery = enrollmentQuery.in('userId', dashboardUserIds);
} else {
  enrollmentQuery = enrollmentQuery.eq('userId', dbUser.id);
}
const { data: userEnrollmentsData } = await enrollmentQuery;

const userEnrollments = userEnrollmentsData || [];
const enrolledCourseIds = userEnrollments.map((e: any) => e.courseId);

if (!isTeacher) {
  if (enrolledCourseIds.length > 0) {
    const { data: a } = await supabase
      .from('Assignment')
      .select('id, courseId, slug')
      .in('courseId', enrolledCourseIds);
    studentAssignments = a || [];
  }

  let studentSubmissionQuery = supabase
    .from('Submission')
    .select('*')
    .order('submittedAt', { ascending: false });
  if (dashboardUserIds.length > 1) {
    studentSubmissionQuery = studentSubmissionQuery.in('userId', dashboardUserIds);
  } else {
    studentSubmissionQuery = studentSubmissionQuery.eq('userId', dbUser.id);
  }

  const { data: s } = await studentSubmissionQuery;
  studentSubmissions = s || [];

  try {
    const attendanceSupabase = createSupabaseServerClient({ requireServiceRole: true });
    let liveAttendanceQuery = attendanceSupabase
      .from('LiveClassAttendance')
      .select('*')
      .order('lastEventAt', { ascending: false });

    if (dashboardUserIds.length > 1) {
      liveAttendanceQuery = liveAttendanceQuery.in('userId', dashboardUserIds);
    } else {
      liveAttendanceQuery = liveAttendanceQuery.eq('userId', dbUser.id);
    }

    const { data: liveAttendance, error: liveAttendanceError } = await liveAttendanceQuery;
    if (liveAttendanceError) {
      console.error('Error loading student LiveClassAttendance rows:', liveAttendanceError);
    } else {
      allLiveClassAttendance = liveAttendance || [];
    }

    const sessionIds = Array.from(
      new Set(
        (allLiveClassAttendance || [])
          .map((attendance: any) => String(attendance?.sessionId || '').trim())
          .filter(Boolean),
      ),
    );

    if (sessionIds.length > 0) {
      const { data: liveSessions, error: liveSessionsError } = await attendanceSupabase
        .from('LiveClassSession')
        .select('*')
        .in('id', sessionIds)
        .order('startedAt', { ascending: false });

      if (liveSessionsError) {
        console.error('Error loading student LiveClassSession rows:', liveSessionsError);
      } else {
        allLiveClassSessions = liveSessions || [];
      }
    }
  } catch (error) {
    console.error('Error initializing student attendance dashboard queries:', error);
  }
}

const studentAssignmentById = new Map<string, any>(
  (studentAssignments || []).map((assignment: any) => [assignment.id, assignment]),
);

// --- LOAD COURSES FROM FILES ---
// Use import.meta.glob for robust file finding in production/Vercel
const courseFiles = import.meta.glob('/src/content/cursos/**/_index.{md,mdx}', { eager: true });

const courseEntries = Object.entries(courseFiles).map(([filepath, module]: any) => {
  const fm = module.frontmatter;
  
  // Only process files explicitly marked as courses
  if (fm.type !== 'course') return null;

  // Extract courseId from path (e.g., /src/content/cursos/my-course/_index.md -> my-course)
  const parts = filepath.split('/');
  // Assuming structure is .../cursos/[courseId]/_index.md
  const courseId = parts[parts.length - 2];

  return {
    slug: courseId, // The slug for the course page
    courseId: courseId,
    title: fm.title || courseId,
    code: getCourseFrontmatterId(fm, courseId),
    // Support multiple image keys
    img: fm.coverImage || fm.img || fm.coverUrl || fm.image || '', 
    tags: Array.isArray(fm.tags) 
      ? fm.tags 
      : (fm.tags ? String(fm.tags).split(',').map(s => s.trim()) : [])
  };
}).filter(Boolean);

const evalOptionMap = await getEvalOptionMap();
const assignmentById = new Map<string, any>(
  (allAssignments || []).map((assignment: any) => {
    const fallbackOptions = evalOptionMap.get(assignment.id);
    return [assignment.id, fallbackOptions ? { ...assignment, options: fallbackOptions } : assignment];
  }),
);
for (const [evalId, options] of evalOptionMap.entries()) {
  if (!assignmentById.has(evalId)) {
    assignmentById.set(evalId, { id: evalId, options });
  }
}

const formatSubmissionDate = (value: string | null | undefined) => {
  if (!value) return '—';
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return '—';
  return date.toLocaleString('es-ES', {
    day: '2-digit',
    month: '2-digit',
    year: '2-digit',
    hour: '2-digit',
    minute: '2-digit',
  });
};

const decodeUriSafe = (value: string | null | undefined) => {
  if (!value) return '';
  try {
    return decodeURIComponent(value);
  } catch {
    return value;
  }
};

const normalizeText = (value: unknown) => String(value || '').trim();
const normalizeTextLower = (value: unknown) => normalizeText(value).toLowerCase();

const asPayloadObject = (value: unknown): Record<string, any> => {
  if (!value || typeof value !== 'object' || Array.isArray(value)) return {};
  return value as Record<string, any>;
};

const COURSE_STUDENT_META_KIND = 'course_student_profile';
const COURSE_ATTENDANCE_CONFIG_META_KIND = 'course_attendance_config';
const COURSE_ATTENDANCE_MANUAL_META_KIND = 'course_attendance_manual';

const normalizeCourseId = (value: unknown) => {
  const raw = normalizeText(value);
  if (!raw) return '';
  try {
    return decodeURIComponent(raw);
  } catch {
    return raw;
  }
};

const toCourseAliasSlug = (value: unknown) =>
  String(value || '')
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '');

const courseCanonicalByAlias = new Map<string, string>();
for (const course of courseEntries) {
  const canonical = normalizeCourseId(course?.courseId);
  if (!canonical) continue;
  courseCanonicalByAlias.set(normalizeTextLower(canonical), canonical);
  const canonicalSlugAlias = toCourseAliasSlug(canonical);
  if (canonicalSlugAlias) {
    courseCanonicalByAlias.set(canonicalSlugAlias, canonical);
  }
  const codeAlias = normalizeText(course?.code || '');
  if (codeAlias) {
    courseCanonicalByAlias.set(normalizeTextLower(codeAlias), canonical);
  }
  const titleAlias = toCourseAliasSlug(course?.title || '');
  if (titleAlias) {
    courseCanonicalByAlias.set(titleAlias, canonical);
  }
}

const canonicalizeCourseId = (value: unknown) => {
  const normalized = normalizeCourseId(value);
  if (!normalized) return '';
  return courseCanonicalByAlias.get(normalizeTextLower(normalized)) || normalized;
};

const deriveCourseIdFromPageSlug = (value: unknown) => {
  const normalized = normalizeActivityPageSlug(normalizeText(value));
  if (!normalized) return '';
  const firstSegment = normalized.split('/').find(Boolean) || '';
  return canonicalizeCourseId(firstSegment);
};

const getLiveRecordCourseId = (record: any) =>
  canonicalizeCourseId(record?.courseId) || deriveCourseIdFromPageSlug(record?.pageSlug);

const isTeacherOwnedLiveSession = (session: any) => {
  const sessionCourseId = getLiveRecordCourseId(session);
  if (sessionCourseId && teacherManagedCourseIds.has(normalizeTextLower(sessionCourseId))) {
    return true;
  }

  const teacherUserId = String(session?.teacherUserId || '').trim();
  return Boolean(teacherUserId) && dashboardUserIds.includes(teacherUserId);
};

const getSubmissionYear = (submission: any) => {
  const directYear = normalizeText(
    asPayloadObject(submission?.payload)?.year
      || asPayloadObject(submission?.payload)?.academicYear
      || '',
  );
  if (/^\d{4}$/.test(directYear)) return directYear;

  const dateCandidates = [submission?.submittedAt, submission?.gradedAt, submission?.createdAt];
  for (const candidate of dateCandidates) {
    const parsed = new Date(String(candidate || ''));
    if (!Number.isNaN(parsed.getTime())) return String(parsed.getFullYear());
  }

  return String(new Date().getFullYear());
};

const getEnrollmentYear = (enrollment: any) => {
  const directYear = normalizeText(
    enrollment?.year
      || enrollment?.academicYear
      || enrollment?.cohortYear
      || enrollment?.periodYear
      || '',
  );
  if (/^\d{4}$/.test(directYear)) return directYear;

  const dateCandidates = [enrollment?.createdAt, enrollment?.updatedAt, enrollment?.enrolledAt];
  for (const candidate of dateCandidates) {
    const parsed = new Date(String(candidate || ''));
    if (!Number.isNaN(parsed.getTime())) return String(parsed.getFullYear());
  }

  return String(new Date().getFullYear());
};

const getLiveSessionYear = (session: any) => {
  const dateCandidates = [session?.startedAt, session?.finishedAt, session?.lastEventAt, session?.createdAt];
  for (const candidate of dateCandidates) {
    const parsed = new Date(String(candidate || ''));
    if (!Number.isNaN(parsed.getTime())) return String(parsed.getFullYear());
  }

  return String(new Date().getFullYear());
};

const getDateTimestamp = (value: unknown) => {
  const parsed = new Date(String(value || ''));
  if (Number.isNaN(parsed.getTime())) return 0;
  return parsed.getTime();
};

const formatDurationFromMs = (value: unknown) => {
  const ms = Number(value || 0);
  if (!Number.isFinite(ms) || ms <= 0) return '—';

  const totalSeconds = Math.max(0, Math.round(ms / 1000));
  const hours = Math.floor(totalSeconds / 3600);
  const minutes = Math.floor((totalSeconds % 3600) / 60);
  const seconds = totalSeconds % 60;

  if (hours > 0) {
    return `${hours}:${String(minutes).padStart(2, '0')}:${String(seconds).padStart(2, '0')}`;
  }

  return `${minutes}:${String(seconds).padStart(2, '0')}`;
};

const getAttendanceDayKey = (session: any, attendance: any) => {
  const value =
    session?.startedAt
    || attendance?.firstJoinedAt
    || attendance?.lastEventAt
    || attendance?.lastLeftAt
    || attendance?.createdAt
    || '';
  const parsed = new Date(String(value || ''));
  if (Number.isNaN(parsed.getTime())) return '';
  const year = parsed.getFullYear();
  const month = String(parsed.getMonth() + 1).padStart(2, '0');
  const day = String(parsed.getDate()).padStart(2, '0');
  return `${year}-${month}-${day}`;
};

const formatAttendanceDayLabel = (value: string) => {
  if (!/^\d{4}-\d{2}-\d{2}$/.test(String(value || ''))) return 'Sin fecha';
  const [year, month, day] = String(value).split('-').map(Number);
  const parsed = new Date(year, (month || 1) - 1, day || 1);
  if (Number.isNaN(parsed.getTime())) return 'Sin fecha';
  return parsed.toLocaleDateString('es-ES', {
    weekday: 'short',
    day: '2-digit',
    month: '2-digit',
    year: 'numeric',
  });
};

const computeAttendanceDurationMs = (attendance: any, session: any) => {
  const startedAt = getDateTimestamp(attendance?.firstJoinedAt);
  const endedAt =
    getDateTimestamp(attendance?.lastLeftAt)
    || getDateTimestamp(attendance?.lastEventAt)
    || getDateTimestamp(session?.finishedAt)
    || getDateTimestamp(session?.lastEventAt);

  if (!startedAt || !endedAt || endedAt <= startedAt) return 0;
  return endedAt - startedAt;
};

const parseDateOnly = (value: unknown) => {
  const raw = normalizeText(value);
  if (!/^\d{4}-\d{2}-\d{2}$/.test(raw)) return null;
  const parsed = new Date(`${raw}T12:00:00Z`);
  if (Number.isNaN(parsed.getTime())) return null;
  return parsed;
};

const formatDateOnly = (value: Date | null | undefined) => {
  if (!(value instanceof Date) || Number.isNaN(value.getTime())) return '';
  const year = value.getUTCFullYear();
  const month = String(value.getUTCMonth() + 1).padStart(2, '0');
  const day = String(value.getUTCDate()).padStart(2, '0');
  return `${year}-${month}-${day}`;
};

const addUtcDays = (value: Date, amount: number) => {
  const next = new Date(value.getTime());
  next.setUTCDate(next.getUTCDate() + amount);
  return next;
};

const getStartOfIsoWeek = (value: Date) => {
  const day = value.getUTCDay() || 7;
  return addUtcDays(value, 1 - day);
};

const formatAttendanceGridDayLabel = (value: string) => {
  const parsed = parseDateOnly(value);
  if (!parsed) return value;
  return parsed.toLocaleDateString('es-ES', {
    weekday: 'short',
    day: '2-digit',
    month: '2-digit',
    timeZone: 'UTC',
  });
};

const buildAttendanceWeekGroups = (startDateValue: string, endDateValue: string) => {
  const parsedStart = parseDateOnly(startDateValue);
  const parsedEnd = parseDateOnly(endDateValue);
  if (!parsedStart || !parsedEnd) {
    return {
      startDate: '',
      endDate: '',
      weeks: [] as any[],
    };
  }

  const normalizedStart = parsedStart.getTime() <= parsedEnd.getTime() ? parsedStart : parsedEnd;
  const normalizedEnd = parsedStart.getTime() <= parsedEnd.getTime() ? parsedEnd : parsedStart;
  const weeks: any[] = [];
  let cursor = getStartOfIsoWeek(normalizedStart);
  let weekIndex = 0;

  while (cursor.getTime() <= normalizedEnd.getTime()) {
    const days = Array.from({ length: 5 }, (_, index) => {
      const date = addUtcDays(cursor, index);
      const dateKey = formatDateOnly(date);
      const inRange = date.getTime() >= normalizedStart.getTime() && date.getTime() <= normalizedEnd.getTime();
      return {
        dateKey,
        inRange,
        label: formatAttendanceGridDayLabel(dateKey),
      };
    });

    const visibleDays = days.filter((day) => day.inRange);
    if (visibleDays.length > 0) {
      weeks.push({
        key: formatDateOnly(cursor),
        label: `Sem ${weekIndex + 1}`,
        title: `${visibleDays[0]?.label || ''} -> ${visibleDays[visibleDays.length - 1]?.label || ''}`,
        days,
      });
      weekIndex += 1;
    }

    cursor = addUtcDays(cursor, 7);
  }

  return {
    startDate: formatDateOnly(normalizedStart),
    endDate: formatDateOnly(normalizedEnd),
    weeks,
  };
};

const getSubmissionMetaKind = (submission: any) => {
  const payload = asPayloadObject(submission?.payload);
  return normalizeTextLower(payload?.__metaKind || payload?.metaKind || '');
};

const isCourseStudentMetaSubmission = (submission: any) => {
  return getSubmissionMetaKind(submission) === COURSE_STUDENT_META_KIND;
};

const isCourseAttendanceConfigSubmission = (submission: any) =>
  getSubmissionMetaKind(submission) === COURSE_ATTENDANCE_CONFIG_META_KIND;

const isCourseAttendanceManualSubmission = (submission: any) =>
  getSubmissionMetaKind(submission) === COURSE_ATTENDANCE_MANUAL_META_KIND;

const isKnownCourseMetaSubmission = (submission: any) =>
  isCourseStudentMetaSubmission(submission)
  || isCourseAttendanceConfigSubmission(submission)
  || isCourseAttendanceManualSubmission(submission);

const asJsonText = (value: unknown) => {
  try {
    return JSON.stringify(value ?? null);
  } catch {
    return '';
  }
};

const toPreviewOptions = (value: unknown): string[] => {
  if (!Array.isArray(value)) return [];
  return value
    .map((option) => {
      if (typeof option === 'string') return normalizeText(option);
      if (option && typeof option === 'object') {
        const optionObject = option as Record<string, unknown>;
        return normalizeText(
          optionObject.text
            || optionObject.label
            || optionObject.value
            || optionObject.id
            || '',
        );
      }
      return '';
    })
    .filter(Boolean);
};

const buildEvalPreview = ({
  evalId,
  evalType,
  mode,
  prompt,
  options,
}: {
  evalId: string;
  evalType: string;
  mode: string;
  prompt: string;
  options: string[];
}) => ({
  id: normalizeText(evalId || '-'),
  type: normalizeText(evalType || 'unknown') || 'unknown',
  mode: normalizeText(mode || 'unknown') || 'unknown',
  prompt: normalizeText(prompt || ''),
  options: Array.isArray(options) ? options.map((item) => normalizeText(item)).filter(Boolean) : [],
});

const toEvalPreviewAttr = (value: unknown) => {
  try {
    return encodeURIComponent(JSON.stringify(value ?? {}));
  } catch {
    return '';
  }
};

const teacherManagedCourseIds = new Set<string>();
const teacherManagedCourseIdsRaw = new Set<string>();
if (isTeacher && Array.isArray(allEnrollments)) {
  allEnrollments
    .filter(
      (enrollment: any) =>
        dashboardUserIds.includes(enrollment.userId) &&
        normalizeRole(enrollment?.roleInCourse) === 'teacher',
    )
    .forEach((enrollment: any) => {
      const rawCourseId = canonicalizeCourseId(enrollment?.courseId);
      const normalizedCourseId = normalizeTextLower(rawCourseId);
      if (normalizedCourseId) teacherManagedCourseIds.add(normalizedCourseId);
      if (rawCourseId) teacherManagedCourseIdsRaw.add(rawCourseId);
    });
}

const teacherMetaSubmissions = isTeacher
  ? (allSubmissions || []).filter((submission: any) => isKnownCourseMetaSubmission(submission))
  : [];
const teacherDataSubmissions = isTeacher
  ? (allSubmissions || []).filter((submission: any) => !isKnownCourseMetaSubmission(submission))
  : [];

if (!isTeacher) {
  studentSubmissions = (studentSubmissions || []).filter((submission: any) => !isKnownCourseMetaSubmission(submission));
}

const courseStudentMetaByKey = new Map<string, { turno: string; concepto: string; grupo: string }>();
const courseAttendanceConfigByKey = new Map<string, { startDate: string; endDate: string; updatedAt: string }>();
const courseAttendanceManualByKey = new Map<string, Record<string, number>>();
if (isTeacher) {
  teacherMetaSubmissions.forEach((submission: any) => {
    const metaKind = getSubmissionMetaKind(submission);
    const payload = asPayloadObject(submission?.payload);
    const courseId = canonicalizeCourseId(payload?.courseId || payload?.course || payload?.courseSlug);
    const year = normalizeText(payload?.year || getSubmissionYear(submission));
    if (!courseId || !year) return;

    if (metaKind === COURSE_STUDENT_META_KIND) {
      const studentId = normalizeText(payload?.studentId || submission?.userId);
      if (!studentId) return;

      courseStudentMetaByKey.set(
        `${normalizeTextLower(courseId)}::${year}::${studentId}`,
        {
          turno: normalizeText(payload?.turno || '').toUpperCase(),
          concepto: normalizeText(payload?.concepto || payload?.concept || ''),
          grupo: normalizeText(payload?.grupo || payload?.group || ''),
        },
      );
      return;
    }

    if (metaKind === COURSE_ATTENDANCE_CONFIG_META_KIND) {
      const mapKey = `${normalizeTextLower(courseId)}::${year}`;
      const nextConfig = {
        startDate: normalizeText(payload?.startDate || ''),
        endDate: normalizeText(payload?.endDate || ''),
        updatedAt: normalizeText(payload?.updatedAt || submission?.submittedAt || ''),
      };
      const existingConfig = courseAttendanceConfigByKey.get(mapKey);
      if (!existingConfig || getDateTimestamp(nextConfig.updatedAt) >= getDateTimestamp(existingConfig.updatedAt)) {
        courseAttendanceConfigByKey.set(mapKey, nextConfig);
      }
      return;
    }

    if (metaKind === COURSE_ATTENDANCE_MANUAL_META_KIND) {
      const studentId = normalizeText(payload?.studentId || submission?.userId);
      if (!studentId) return;
      const manualDaysPayload = asPayloadObject(payload?.manualDays || payload?.dates || {});
      const normalizedManualDays = Object.fromEntries(
        Object.entries(manualDaysPayload)
          .map(([dateKey, countValue]) => {
            const date = normalizeText(dateKey);
            const parsedCount = Number(countValue);
            if (!/^\d{4}-\d{2}-\d{2}$/.test(date) || !Number.isFinite(parsedCount) || parsedCount <= 0) {
              return [null, null];
            }
            return [date, Math.max(0, Math.trunc(parsedCount))];
          })
          .filter(([dateKey, countValue]) => Boolean(dateKey) && countValue !== null),
      );
      courseAttendanceManualByKey.set(
        `${normalizeTextLower(courseId)}::${year}::${studentId}`,
        normalizedManualDays,
      );
    }
  });
}

const evalCatalog = await buildEvalCatalog();

const resolveSubmissionMeta = (submission: any) => {
  const assignment = assignmentById.get(submission.assignmentId);
  const assignmentSlug = String(assignment?.slug || submission.assignmentId || '');
  const assignmentCourseId = canonicalizeCourseId(assignment?.courseId);
  const inferredNoteType = inferEvalNoteTypeFromSlug(assignmentSlug, assignmentCourseId) as EvalNoteType;
  const catalogEntries = evalCatalog.get(String(submission.assignmentId || '')) || [];
  const catalogEntry = resolveEvalCatalogEntry(catalogEntries, assignmentSlug);
  const payload = asPayloadObject(submission?.payload);
  const payloadCourseId = canonicalizeCourseId(payload.courseId || payload.course || payload.courseSlug);
  const catalogCourseId = canonicalizeCourseId(catalogEntry?.courseId);
  const slugCourseId = canonicalizeCourseId(assignmentSlug.split('/')[0]);
  const resolvedCourseIdRaw =
    assignmentCourseId || catalogCourseId || payloadCourseId || slugCourseId || 'sin-curso';

  const noteType = (catalogEntry?.noteType || inferredNoteType || 'unknown') as EvalNoteType;
  const noteTypeLabel = EVAL_NOTE_TYPE_LABEL[noteType] || EVAL_NOTE_TYPE_LABEL.unknown;
  const noteTypeOrder = EVAL_NOTE_TYPE_ORDER[noteType] || EVAL_NOTE_TYPE_ORDER.unknown;
  const evalType = normalizeText(catalogEntry?.evalType || payload.type || 'unknown') || 'unknown';
  const mode = normalizeText(catalogEntry?.mode || payload.mode || 'unknown') || 'unknown';
  const previewPrompt = normalizeText(catalogEntry?.prompt || payload.prompt || payload.question || payload.title || '');
  const previewOptions = toPreviewOptions(
    catalogEntry?.options || payload.options || payload.choices || payload.answers || [],
  );
  const evalPreview = buildEvalPreview({
    evalId: String(submission?.assignmentId || ''),
    evalType,
    mode,
    prompt: previewPrompt,
    options: previewOptions,
  });

  return {
    assignment,
    assignmentSlug,
    assignmentLabel: decodeUriSafe(assignmentSlug.split('/').pop() || assignmentSlug || String(submission.assignmentId || '')),
    courseId: decodeUriSafe(canonicalizeCourseId(resolvedCourseIdRaw) || resolvedCourseIdRaw),
    courseIdRaw: resolvedCourseIdRaw,
    courseIdKey: normalizeTextLower(canonicalizeCourseId(resolvedCourseIdRaw) || resolvedCourseIdRaw),
    noteType,
    noteTypeLabel,
    noteTypeOrder,
    evalType,
    mode,
    catalogEntry,
    payload,
    evalPreview,
  };
};

const teacherScopedSubmissions = isTeacher
