const availableYears = (() => {
  const yearSet = new Set<string>();

  const enrollmentSource = isTeacher
    ? (allEnrollments || [])
    : (userEnrollments || []);
  enrollmentSource.forEach((enrollment: any) => {
    const enrollmentCourseId = canonicalizeCourseId(enrollment?.courseId);
    if (activeCourseId && enrollmentCourseId !== activeCourseId) return;
    yearSet.add(getEnrollmentYear(enrollment));
  });

  (activeCourseSubmissions || []).forEach((submission: any) => {
    yearSet.add(getSubmissionYear(submission));
  });

  if (isTeacher) {
    (allLiveClassSessions || []).forEach((session: any) => {
      const sessionCourseId = canonicalizeCourseId(getLiveRecordCourseId(session));
      if (!sessionCourseId || !teacherManagedCourseIds.has(normalizeTextLower(sessionCourseId))) return;
      if (activeCourseId && sessionCourseId !== activeCourseId) return;
      yearSet.add(getLiveSessionYear(session));
    });
  }

  const years = Array.from(yearSet)
    .filter((year) => /^\d{4}$/.test(String(year || '')))
    .sort((left, right) => Number(right) - Number(left));
  if (years.length === 0) {
    years.push(String(new Date().getFullYear()));
  }
  return years;
})();

