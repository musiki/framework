---
// Eliminamos prerender = true para evitar warnings de headers durante el build
// y permitir que el Header muestre la sesión del usuario si está logueado.
// Al usar output: 'server' en astro.config.mjs, esta página se renderizará en el servidor.

import { getEntry, render, getCollection } from 'astro:content';
import WikiLayout from '../layouts/WikiLayout.astro';
import {
  getPublicContentStaticPaths,
  type PublicContentRouteProps,
} from '../lib/public-content-routes';

// En modo SSR (sin prerender), getStaticPaths no es necesario para la generación de archivos,
// pero Astro aún puede usarlo si la ruta es ambigua. 
// Sin embargo, para SSR puro con parámetros dinámicos, simplemente usamos Astro.params.

const { slug } = Astro.params;

// Intentamos encontrar la entrada de contenido público que corresponda a este slug.
// Para esto, usamos la misma lógica que getStaticPaths pero para la ruta actual.
const allPaths = await getPublicContentStaticPaths();
const routeMatch = allPaths.find(p => p.params.slug === slug);

if (!routeMatch) {
  return Astro.redirect('/404');
}

const route = routeMatch.props as PublicContentRouteProps;

if (route.kind === 'redirect') {
  return Astro.redirect(route.redirectTo);
}

const entry = await getEntry('content', route.entryId);
if (!entry) {
  return Astro.redirect('/404');
}

// Render the content
const { Content } = await render(entry);

// Resolve title: Frontmatter > Filename
const title = entry.data.title || entry.id.split('/').pop()?.replace(/\.[^/.]+$/, '') || 'Untitled';
const description = entry.data.summary || entry.data.description || entry.data.subtitle || '';
const tags = Array.isArray(entry.data.tags)
  ? entry.data.tags
  : entry.data.tags
    ? String(entry.data.tags).split(',').map((tag) => tag.trim()).filter(Boolean)
    : undefined;
const defaultSlideTheme = 'zztt';
const slideThemeFromData =
  (entry.data as Record<string, unknown>).slideTheme ||
  (entry.data as Record<string, unknown>).revealTheme ||
  (entry.data as Record<string, unknown>).theme;
const slideTheme = typeof slideThemeFromData === 'string' && slideThemeFromData.trim()
  ? slideThemeFromData.trim()
  : defaultSlideTheme;
const rawPresentationTheme =
  (entry.data as Record<string, unknown>).theme ||
  (entry.data as Record<string, unknown>).slideTheme ||
  (entry.data as Record<string, unknown>).revealTheme;
const hasPresentationTheme = typeof rawPresentationTheme === 'string' && rawPresentationTheme.trim().length > 0;
const presentationHref = hasPresentationTheme ? route.presentationHref : '';
---

<>
  {
    presentationHref ? (
      <script is:inline define:vars={{ presentationHref }}>
        const currentUrl = new URL(window.location.href);
        if (currentUrl.searchParams.get('view') === 'slides') {
          window.location.replace(presentationHref);
        }
      </script>
    ) : null
  }
  <WikiLayout
    title={title}
    description={description}
    id={entry.id}
    tags={tags}
    presentationHref={presentationHref}
  >
    <Content />
  </WikiLayout>
</>
