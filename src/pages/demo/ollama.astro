---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const session = (Astro.locals as any).session;
const currentUser = session?.user;
const correctionConfigured = Boolean(import.meta.env.CORRECTION_API_URL && import.meta.env.CORRECTION_API_TOKEN);
---

<!doctype html>
<html lang="es">
  <head>
    <BaseHead title="Demo Ollama" description="Prueba rápida del endpoint de corrección" />
    <style>
      .demo-wrap {
        max-width: 980px;
        margin: 0 auto;
        padding: 1.5rem;
      }

      .panel {
        border: 1px solid var(--c-border);
        border-radius: 10px;
        padding: 1rem;
        margin-bottom: 1rem;
        background: var(--c-bg);
      }

      .status {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.92rem;
        padding: 0.35rem 0.65rem;
        border-radius: 999px;
        margin-right: 0.5rem;
      }

      .status.ok {
        background: #e8f6ec;
        color: #176f35;
      }

      .status.bad {
        background: #fdecec;
        color: #8a1f1f;
      }

      .grid {
        display: grid;
        gap: 1rem;
        grid-template-columns: 1fr;
      }

      @media (min-width: 980px) {
        .grid {
          grid-template-columns: 1.2fr 1fr;
        }
      }

      .field {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        margin-bottom: 0.85rem;
      }

      .field label {
        font-weight: 600;
      }

      .field input,
      .field select,
      .field textarea {
        width: 100%;
        border: 1px solid var(--c-border);
        border-radius: 8px;
        background: var(--c-bg);
        color: var(--c-fg);
        padding: 0.7rem;
        font-family: inherit;
      }

      .field textarea {
        min-height: 180px;
        resize: vertical;
      }

      .actions {
        display: flex;
        gap: 0.6rem;
        flex-wrap: wrap;
      }

      button {
        border: none;
        border-radius: 8px;
        padding: 0.65rem 1rem;
        font-weight: 600;
        cursor: pointer;
      }

      button.primary {
        background: var(--accent);
        color: #fff;
      }

      button.secondary {
        background: var(--c-bg-mute);
        color: var(--c-fg);
        border: 1px solid var(--c-border);
      }

      button:disabled {
        opacity: 0.55;
        cursor: not-allowed;
      }

      .hint {
        font-size: 0.9rem;
        color: var(--c-fg-dim);
      }

      .result-grid {
        display: grid;
        gap: 0.75rem;
      }

      .result-card {
        border: 1px solid var(--c-border);
        border-radius: 8px;
        padding: 0.75rem;
        background: var(--c-bg-mute);
      }

      .result-title {
        margin: 0 0 0.4rem 0;
        font-size: 0.9rem;
        color: var(--c-fg-dim);
        text-transform: uppercase;
        letter-spacing: 0.03em;
      }

      .result-body {
        margin: 0;
        line-height: 1.45;
      }

      pre {
        white-space: pre-wrap;
        word-break: break-word;
        border: 1px solid var(--c-border);
        border-radius: 8px;
        padding: 0.75rem;
        background: #0f1720;
        color: #d7e2ef;
        overflow: auto;
        max-height: 420px;
      }

      .warning {
        border-left: 4px solid #f59e0b;
        padding-left: 0.8rem;
      }

      .demo-section {
        margin-top: 1rem;
      }

      .demo-grid {
        display: grid;
        gap: 1rem;
        grid-template-columns: 1fr;
      }

      @media (min-width: 980px) {
        .demo-grid {
          grid-template-columns: 1.2fr 1fr;
        }
      }

      .demo-col {
        border: 1px solid var(--c-border);
        border-radius: 10px;
        padding: 1rem;
        background: var(--c-bg-mute);
      }

      .tech-meta {
        font-size: 0.78rem;
        line-height: 1.35;
        margin-top: 0.65rem;
      }
    </style>
  </head>
  <body>
    <Header />
    <main class="demo-wrap">
      <h1>Demo rápido: API de corrección (Ollama)</h1>
      <p class="hint">Prueba el endpoint puente <code>/api/ai/correct</code> con un texto real de estudiante.</p>

      <section class="panel">
        <span class:list={["status", currentUser?.email ? "ok" : "bad"]}>
          {currentUser?.email ? '✓ Sesión activa' : '✗ Sin sesión'}
        </span>
        <span class:list={["status", correctionConfigured ? "ok" : "bad"]}>
          {correctionConfigured ? '✓ Backend IA configurado' : '✗ Falta CORRECTION_API_URL/TOKEN'}
        </span>
        {!currentUser?.email && (
          <p class="hint warning">Este demo usa un endpoint autenticado. Inicia sesión para ejecutar correcciones.</p>
        )}
      </section>

      <section class="panel demo-section">
        <h2 style="margin-top: 0;">Destino LMS (Entregas reales)</h2>
        <p class="hint">Puedes guardar el resultado de cada demo como entrega real (Submission) para verla en “Entregas Recientes”.</p>
        <div class="grid">
          <article>
            <div class="field">
              <label for="target-student-name">Nombre estudiante destino</label>
              <input id="target-student-name" value="James Olsecom" />
            </div>
            <div class="field">
              <label for="target-student-email">Email estudiante destino</label>
              <input id="target-student-email" value="james.olsecom@dummy.local" />
            </div>
          </article>
          <article>
            <div class="field">
              <label for="target-course-id">Course ID (Assignment)</label>
              <input id="target-course-id" value="demo-ollama" />
            </div>
            <div class="field">
              <label for="target-page-slug">Page slug (Assignment)</label>
              <input id="target-page-slug" value="demo/ollama" />
            </div>
          </article>
        </div>
      </section>

      <section class="panel demo-section">
        <h2 style="margin-top: 0;">Demo 1: Corrección de texto general</h2>
        <div class="demo-grid">
          <article class="demo-col">
            <div class="field">
              <label for="d1-texto">Texto del estudiante</label>
              <textarea id="d1-texto" placeholder="Escribe aquí el texto a corregir..."></textarea>
            </div>

            <div class="field">
              <label for="d1-rubrica">Rúbrica (opcional)</label>
              <textarea id="d1-rubrica" placeholder="Ej: Claridad de tesis; uso de evidencia; precisión conceptual" style="min-height: 90px;"></textarea>
            </div>

            <div class="field">
              <label for="d1-provider">Proveedor</label>
              <select id="d1-provider">
                <option value="ollama">Ollama (local)</option>
                <option value="deepseek">DeepSeek (API)</option>
              </select>
            </div>

            <div class="field">
              <label for="d1-provider">Proveedor</label>
              <select id="d1-provider">
                <option value="ollama">Ollama (local)</option>
                <option value="deepseek">DeepSeek (API)</option>
              </select>
            </div>

            <div class="field">
              <label for="d1-model">Modelo</label>
              <select id="d1-model" disabled>
                <option value="">Cargando modelos...</option>
