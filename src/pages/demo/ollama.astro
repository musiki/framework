            <div class="field">
              <label for="d1-eval-id">ID de tarea (evalId)</label>
              <input id="d1-eval-id" value="demo/ollama/d1-texto" />
            </div>

            <div class="actions">
              <button class="primary" id="d1-run-btn">Probar corrección</button>
              <button class="secondary" id="d1-example-btn" type="button">Cargar ejemplo</button>
              <button class="secondary" id="d1-clear-btn" type="button">Limpiar</button>
            </div>

            <p class="hint" id="d1-status-msg">Listo para enviar.</p>
          </article>

          <article class="demo-col">
            <h3 style="margin-top: 0;">Resultado estructurado</h3>
            <div id="d1-result-cards" class="result-grid"></div>
            <h3 style="margin-top: 1rem;">JSON crudo</h3>
            <pre id="d1-raw-json">(sin respuesta)</pre>
            <p class="hint tech-meta" id="d1-tech-meta">(sin datos técnicos)</p>
            <div class="actions" style="margin-top: 0.65rem;">
              <button class="secondary" id="d1-send-tasks-btn" type="button">Enviar a Tareas</button>
              <button class="secondary" id="d1-send-planilla-btn" type="button">Enviar a Planilla</button>
            </div>
            <p class="hint" id="d1-save-status">Aún no guardado.</p>
          </article>
        </div>
      </section>

      <section class="panel demo-section">
        <h2 style="margin-top: 0;">Demo 2: Patch Max/MSP o Pure Data</h2>
        <p class="hint">Compara patch de referencia vs patch del alumno, priorizando objetos y conexiones por encima de la posición visual.</p>
        <div class="demo-grid">
          <article class="demo-col">
            <div class="field">
              <label for="d2-consigna">Consigna (teacher)</label>
              <textarea id="d2-consigna" placeholder="Describe claramente el objetivo lógico del patch..." style="min-height: 90px;"></textarea>
            </div>

            <div class="field">
              <label for="d2-reference">Patch de referencia (copy/paste)</label>
              <textarea id="d2-reference" placeholder="Pega aquí el patch correcto de referencia..."></textarea>
            </div>

            <div class="field">
              <label for="d2-student">Patch del alumno (copy/paste)</label>
              <textarea id="d2-student" placeholder="Pega aquí el patch entregado por el alumno..."></textarea>
            </div>

            <div class="field">
              <label for="d2-prompts">Prompts/criterios de prueba (uno por línea, opcional)</label>
              <textarea id="d2-prompts" placeholder="Ejemplo: Verificar si [metro] dispara [counter] correctamente..." style="min-height: 110px;"></textarea>
            </div>

            <div class="field">
              <label for="d2-provider">Proveedor</label>
              <select id="d2-provider">
                <option value="ollama">Ollama (local)</option>
                <option value="deepseek">DeepSeek (API)</option>
              </select>
            </div>

            <div class="field">
              <label for="d2-model">Modelo</label>
              <select id="d2-model" disabled>
                <option value="">Cargando modelos...</option>
              </select>
            </div>

            <div class="field">
              <label for="d2-eval-id">ID de tarea (evalId)</label>
              <input id="d2-eval-id" value="demo/ollama/d2-patch" />
            </div>

            <div class="actions">
              <button class="primary" id="d2-run-btn">Evaluar patch</button>
              <button class="secondary" id="d2-prompts-btn" type="button">Cargar prompts sugeridos</button>
              <button class="secondary" id="d2-example-btn" type="button">Cargar ejemplo</button>
              <button class="secondary" id="d2-clear-btn" type="button">Limpiar</button>
            </div>

            <p class="hint" id="d2-status-msg">Listo para evaluar patch.</p>
          </article>

          <article class="demo-col">
            <h3 style="margin-top: 0;">Resultado estructurado</h3>
            <div id="d2-result-cards" class="result-grid"></div>
            <h3 style="margin-top: 1rem;">JSON crudo</h3>
            <pre id="d2-raw-json">(sin respuesta)</pre>
            <p class="hint tech-meta" id="d2-tech-meta">(sin datos técnicos)</p>
            <div class="actions" style="margin-top: 0.65rem;">
              <button class="secondary" id="d2-send-tasks-btn" type="button">Enviar a Tareas</button>
              <button class="secondary" id="d2-send-planilla-btn" type="button">Enviar a Planilla</button>
            </div>
            <p class="hint" id="d2-save-status">Aún no guardado.</p>
          </article>
        </div>
      </section>

      <section class="panel demo-section">
        <h2 style="margin-top: 0;">Demo 3: Consigna + referencia textual</h2>
        <p class="hint">Evalúa la respuesta del alumno contra una consigna y una respuesta de referencia del docente.</p>
        <div class="demo-grid">
          <article class="demo-col">
            <div class="field">
              <label for="d3-consigna">Consigna (teacher)</label>
              <textarea id="d3-consigna" placeholder="Define la tarea que el alumno debía responder..." style="min-height: 90px;"></textarea>
            </div>

            <div class="field">
              <label for="d3-reference">Respuesta de referencia (teacher)</label>
              <textarea id="d3-reference" placeholder="Pega una respuesta modelo o ideal para comparar..."></textarea>
            </div>

            <div class="field">
              <label for="d3-student">Respuesta del alumno</label>
              <textarea id="d3-student" placeholder="Pega la respuesta entregada por el alumno..."></textarea>
            </div>

            <div class="field">
              <label for="d3-provider">Proveedor</label>
              <select id="d3-provider">
                <option value="ollama">Ollama (local)</option>
                <option value="deepseek">DeepSeek (API)</option>
              </select>
            </div>

            <div class="field">
              <label for="d3-model">Modelo</label>
              <select id="d3-model" disabled>
                <option value="">Cargando modelos...</option>
              </select>
            </div>

            <div class="field">
              <label for="d3-eval-id">ID de tarea (evalId)</label>
              <input id="d3-eval-id" value="demo/ollama/d3-texto-referencia" />
            </div>

            <div class="actions">
              <button class="primary" id="d3-run-btn">Evaluar respuesta</button>
              <button class="secondary" id="d3-example-btn" type="button">Cargar ejemplo</button>
              <button class="secondary" id="d3-clear-btn" type="button">Limpiar</button>
            </div>

            <p class="hint" id="d3-status-msg">Listo para evaluar respuesta.</p>
          </article>

          <article class="demo-col">
            <h3 style="margin-top: 0;">Resultado estructurado</h3>
            <div id="d3-result-cards" class="result-grid"></div>
            <h3 style="margin-top: 1rem;">JSON crudo</h3>
            <pre id="d3-raw-json">(sin respuesta)</pre>
            <p class="hint tech-meta" id="d3-tech-meta">(sin datos técnicos)</p>
            <div class="actions" style="margin-top: 0.65rem;">
              <button class="secondary" id="d3-send-tasks-btn" type="button">Enviar a Tareas</button>
              <button class="secondary" id="d3-send-planilla-btn" type="button">Enviar a Planilla</button>
            </div>
            <p class="hint" id="d3-save-status">Aún no guardado.</p>
          </article>
        </div>
      </section>
    </main>
    <Footer />

    <script>
      const DEFAULT_MODEL = 'llama3.2:latest';
      const GRADE_RULE = 'Asigna una nota de 0 a 10 y justifícala brevemente en JSON en el campo calificacion.';
      const PASSING_SCORE = 6;

      const PATCH_PROMPT_SUGGESTIONS = [
        'Identificar objetos clave del flujo principal y su función.',
        'Verificar conexiones correctas entre objetos críticos.',
        'Detectar conexiones faltantes o conexiones extra incorrectas.',
        'Ignorar diferencias de posición visual de objetos si la lógica se conserva.',
        'Revisar variaciones de argumentos/parámetros que sí cambian el comportamiento.',
      ].join('\n');
      const DEEPSEEK_MODELS = ['deepseek-chat', 'deepseek-reasoner'];

      const PATCH_BASE_RUBRIC = [
        'Detecta tipos de objetos y su rol funcional respecto del patch de referencia',
        'Compara conexiones y clasifica: correctas, faltantes y erróneas',
        'Prioriza lógica de flujo y señal por encima de posición visual XY de objetos',
        'Detecta variaciones graduales de parámetros/argumentos que alteran resultado',
        'Entrega sugerencia concreta para corregir el patch del alumno',
      ];

      const TEXT_REFERENCE_RUBRIC = [
        'Alineación de la respuesta del alumno con la consigna',
        'Cobertura de ideas clave presentes en la respuesta de referencia',
        'Precisión conceptual y solidez argumental',
        'Claridad, estructura y coherencia de la respuesta',
        'Sugerencia concreta para acercarse al nivel de referencia',
      ];

      const ensureText = (value) => (typeof value === 'string' ? value.trim() : '');
      const ensureBool = (value) => {
        if (typeof value === 'boolean') return value;
        if (typeof value === 'string') {
          const t = value.trim().toLowerCase();
          if (['true', 'si', 'sí', 'yes', 'clara', 'claro'].includes(t)) return true;
          if (['false', 'no', 'unclear', 'difusa'].includes(t)) return false;
        }
        return false;
      };
      const clampScore = (n) => Math.min(10, Math.max(0, n));
      const parseScore = (value) => {
        if (typeof value === 'number' && Number.isFinite(value)) return clampScore(value);
        if (typeof value === 'string') {
          const match = value.match(/(\d+(?:[.,]\d+)?)\s*(?:\/\s*10)?/);
          if (!match?.[1]) return null;
          const parsed = Number(match[1].replace(',', '.'));
          if (!Number.isFinite(parsed)) return null;
          return clampScore(parsed);
        }
        return null;
      };
      const ensurePair = (value) => {
        let items = [];
        if (Array.isArray(value)) {
          items = value.map((item) => ensureText(item)).filter(Boolean);
        } else if (typeof value === 'string') {
          items = value
            .split(/\n|;|\u2022|\-/g)
            .map((item) => item.trim())
            .filter(Boolean);
        }
        const out = items.slice(0, 2);
        while (out.length < 2) out.push('');
        return out;
      };

      const cleanupJsonCandidate = (text) => {
        if (typeof text !== 'string') return '';
        return text
          .trim()
          .replace(/^```json/i, '')
          .replace(/^```/i, '')
          .replace(/```$/i, '')
          .replace(/,\s*([}\]])/g, '$1')
          .trim();
      };

      const parseJsonLoosely = (rawText) => {
        const cleaned = cleanupJsonCandidate(rawText);
        const firstBrace = cleaned.indexOf('{');
        if (firstBrace === -1) return null;
        const source = cleaned.slice(firstBrace);

        const tryParse = (candidate) => {
          try {
            return JSON.parse(candidate);
          } catch {
            return null;
          }
        };

        const direct = tryParse(source);
        if (direct) return direct;

        let depth = 0;
        let inString = false;
        let escaped = false;
        let endIndex = -1;

        for (let i = 0; i < source.length; i += 1) {
          const ch = source[i];
          if (inString) {
            if (escaped) {
              escaped = false;
            } else if (ch === '\\') {
              escaped = true;
            } else if (ch === '"') {
              inString = false;
            }
            continue;
          }

          if (ch === '"') {
            inString = true;
            continue;
          }

          if (ch === '{') depth += 1;
          if (ch === '}') depth -= 1;

          if (depth === 0) {
            endIndex = i;
            break;
          }
        }

        if (endIndex !== -1) {
          const balanced = cleanupJsonCandidate(source.slice(0, endIndex + 1));
          const parsedBalanced = tryParse(balanced);
          if (parsedBalanced) return parsedBalanced;
        }

        if (depth > 0) {
          const repaired = cleanupJsonCandidate(`${source}${'}'.repeat(depth)}`);
          const parsedRepaired = tryParse(repaired);
          if (parsedRepaired) return parsedRepaired;
        }

        const lastBrace = source.lastIndexOf('}');
        if (lastBrace !== -1) {
          const sliced = cleanupJsonCandidate(source.slice(0, lastBrace + 1));
          const parsedSliced = tryParse(sliced);
          if (parsedSliced) return parsedSliced;
        }

        return null;
      };

      const estimateScore = ({ tesisClara, fortalezas, debilidades, sugerencia }) => {
        let score = 5;
        score += tesisClara ? 1.5 : -1;
        score += fortalezas.filter(Boolean).length * 1.2;
        score -= debilidades.filter(Boolean).length * 0.8;
        if (ensureText(sugerencia).length >= 30) score += 0.6;
        return Math.round(clampScore(score) * 10) / 10;
      };

      const normalizeEvaluation = (evaluation) => {
        const base = evaluation && typeof evaluation === 'object' ? evaluation : {};
        const recovered = parseJsonLoosely(base.raw || '') || {};

        const baseTesis = base.tesis && typeof base.tesis === 'object' ? base.tesis : {};
        const recoveredTesis = recovered.tesis && typeof recovered.tesis === 'object' ? recovered.tesis : {};
        const baseCalificacion = base.calificacion && typeof base.calificacion === 'object' ? base.calificacion : {};
        const recoveredCalificacion = recovered.calificacion && typeof recovered.calificacion === 'object' ? recovered.calificacion : {};

        const resumen = ensureText(base.resumen) || ensureText(recovered.resumen);
        const tesisClara = ensureBool(baseTesis.clara ?? recoveredTesis.clara ?? base.tesis_clara ?? recovered.tesis_clara);
        const tesisExplicacion = ensureText(baseTesis.explicacion) || ensureText(recoveredTesis.explicacion) || ensureText(base.tesis_explicacion) || ensureText(recovered.tesis_explicacion);
        const fortalezas = ensurePair(base.fortalezas ?? recovered.fortalezas);
        const debilidades = ensurePair(base.debilidades ?? recovered.debilidades);
        const sugerencia = ensureText(base.sugerencia) || ensureText(recovered.sugerencia);

        let nota = parseScore(baseCalificacion.nota ?? recoveredCalificacion.nota ?? base.nota ?? recovered.nota);
        if (nota === null) nota = parseScore(sugerencia);
        if (nota === null) {
          nota = estimateScore({
            tesisClara,
            fortalezas,
            debilidades,
            sugerencia,
          });
        }

        const justificacion = ensureText(baseCalificacion.justificacion)
          || ensureText(recoveredCalificacion.justificacion)
          || `Nota sugerida ${nota}/10 según criterios de la rúbrica.`;

        return {
          resumen,
          tesis: {
            clara: tesisClara,
            explicacion: tesisExplicacion,
          },
          fortalezas,
          debilidades,
          sugerencia,
          calificacion: {
            nota,
            justificacion,
          },
          raw: ensureText(base.raw) || ensureText(recovered.raw),
        };
      };

      const d1TextEl = document.getElementById('d1-texto');
      const d1RubricEl = document.getElementById('d1-rubrica');
      const d1ProviderEl = document.getElementById('d1-provider');
      const d1ModelEl = document.getElementById('d1-model');
      const d1EvalIdEl = document.getElementById('d1-eval-id');
      const d1RunBtn = document.getElementById('d1-run-btn');
      const d1ExampleBtn = document.getElementById('d1-example-btn');
      const d1ClearBtn = document.getElementById('d1-clear-btn');
      const d1SendTasksBtn = document.getElementById('d1-send-tasks-btn');
      const d1SendPlanillaBtn = document.getElementById('d1-send-planilla-btn');
      const d1StatusMsg = document.getElementById('d1-status-msg');
      const d1SaveStatus = document.getElementById('d1-save-status');
      const modelStatusMsg = document.getElementById('model-status');
      const d1RawJson = document.getElementById('d1-raw-json');
      const d1ResultCards = document.getElementById('d1-result-cards');
      const d1TechMeta = document.getElementById('d1-tech-meta');

      const d2ConsignaEl = document.getElementById('d2-consigna');
      const d2ReferenceEl = document.getElementById('d2-reference');
      const d2StudentEl = document.getElementById('d2-student');
      const d2PromptsEl = document.getElementById('d2-prompts');
      const d2ProviderEl = document.getElementById('d2-provider');
      const d2ModelEl = document.getElementById('d2-model');
      const d2EvalIdEl = document.getElementById('d2-eval-id');
      const d2RunBtn = document.getElementById('d2-run-btn');
      const d2PromptsBtn = document.getElementById('d2-prompts-btn');
      const d2ExampleBtn = document.getElementById('d2-example-btn');
      const d2ClearBtn = document.getElementById('d2-clear-btn');
      const d2SendTasksBtn = document.getElementById('d2-send-tasks-btn');
      const d2SendPlanillaBtn = document.getElementById('d2-send-planilla-btn');
      const d2StatusMsg = document.getElementById('d2-status-msg');
      const d2SaveStatus = document.getElementById('d2-save-status');
      const d2RawJson = document.getElementById('d2-raw-json');
      const d2ResultCards = document.getElementById('d2-result-cards');
      const d2TechMeta = document.getElementById('d2-tech-meta');

      const d3ConsignaEl = document.getElementById('d3-consigna');
      const d3ReferenceEl = document.getElementById('d3-reference');
      const d3StudentEl = document.getElementById('d3-student');
      const d3ProviderEl = document.getElementById('d3-provider');
      const d3ModelEl = document.getElementById('d3-model');
      const d3EvalIdEl = document.getElementById('d3-eval-id');
      const d3RunBtn = document.getElementById('d3-run-btn');
      const d3ExampleBtn = document.getElementById('d3-example-btn');
      const d3ClearBtn = document.getElementById('d3-clear-btn');
      const d3SendTasksBtn = document.getElementById('d3-send-tasks-btn');
      const d3SendPlanillaBtn = document.getElementById('d3-send-planilla-btn');
      const d3StatusMsg = document.getElementById('d3-status-msg');
      const d3SaveStatus = document.getElementById('d3-save-status');
      const d3RawJson = document.getElementById('d3-raw-json');
      const d3ResultCards = document.getElementById('d3-result-cards');
      const d3TechMeta = document.getElementById('d3-tech-meta');

      const targetStudentNameEl = document.getElementById('target-student-name');
      const targetStudentEmailEl = document.getElementById('target-student-email');
      const targetCourseIdEl = document.getElementById('target-course-id');
      const targetPageSlugEl = document.getElementById('target-page-slug');

      const providerModelPairs = [
        { providerEl: d1ProviderEl, modelEl: d1ModelEl },
        { providerEl: d2ProviderEl, modelEl: d2ModelEl },
        { providerEl: d3ProviderEl, modelEl: d3ModelEl },
      ];
      const allModelSelects = providerModelPairs.map((item) => item.modelEl);

      let ollamaModelNames = [];

      const latestResults = {
        d1: null,
        d2: null,
        d3: null,
      };

      const renderCards = (container, evaluation) => {
        container.innerHTML = '';
        if (!evaluation) return;

        const makeCard = (title, body) => {
          const card = document.createElement('section');
          card.className = 'result-card';

          const h = document.createElement('h4');
          h.className = 'result-title';
          h.textContent = title;

          const p = document.createElement('p');
          p.className = 'result-body';
          p.textContent = body || '—';

          card.appendChild(h);
          card.appendChild(p);
          container.appendChild(card);
        };

        makeCard('Resumen', evaluation.resumen);
        makeCard('Tesis clara', evaluation.tesis?.clara ? 'Sí' : 'No');
        makeCard('Explicación tesis', evaluation.tesis?.explicacion);
        makeCard('Fortalezas', Array.isArray(evaluation.fortalezas) ? evaluation.fortalezas.join(' | ') : '—');
        makeCard('Debilidades', Array.isArray(evaluation.debilidades) ? evaluation.debilidades.join(' | ') : '—');
        makeCard('Sugerencia', evaluation.sugerencia);
        makeCard('Calificación sugerida', typeof evaluation.calificacion?.nota === 'number' ? `${evaluation.calificacion.nota}/10` : '—');
        makeCard('Justificación nota', evaluation.calificacion?.justificacion);
      };

      const renderTechMeta = (el, data) => {
        if (!el) return;
        if (!data || typeof data !== 'object') {
          el.textContent = '(sin datos técnicos)';
          return;
        }

        const timing = data.timing_ms && typeof data.timing_ms === 'object' ? data.timing_ms : {};
        const usage = data.token_usage && typeof data.token_usage === 'object' ? data.token_usage : {};

        el.textContent = [
          `model: ${data.model || '-'}`,
          `created: ${data.created_at || '-'}`,
          `timing(ms): total=${timing.total ?? '-'} load=${timing.load ?? '-'} prompt=${timing.prompt_eval ?? '-'} eval=${timing.eval ?? '-'}`,
          `tokens: prompt=${usage.prompt_eval_count ?? '-'} eval=${usage.eval_count ?? '-'}`,
        ].join(' | ');
      };

      const setBusy = (button, busy, idleText) => {
        button.disabled = busy;
        button.textContent = busy ? 'Procesando...' : idleText;
      };

      const setStatus = (el, text) => {
        el.textContent = text;
      };

      const setModelStatus = (text) => {
        modelStatusMsg.textContent = text;
      };

      const setModelValue = (selectEl, preferredModel = DEFAULT_MODEL) => {
        const hasPreferred = Array.from(selectEl.options).some((option) => option.value === preferredModel);
        selectEl.value = hasPreferred ? preferredModel : (selectEl.options[0]?.value || '');
      };

      const setModelOptions = (selectEl, modelNames) => {
        selectEl.innerHTML = '';
        if (!Array.isArray(modelNames) || modelNames.length === 0) {
          const option = document.createElement('option');
          option.value = '';
          option.textContent = 'Sin modelos disponibles';
          selectEl.appendChild(option);
          selectEl.disabled = true;
          return;
        }
        modelNames.forEach((name) => {
          const option = document.createElement('option');
          option.value = name;
          option.textContent = name;
          selectEl.appendChild(option);
        });
        selectEl.disabled = modelNames.length === 0;
      };

      const getModelsByProvider = (provider) => (provider === 'deepseek' ? DEEPSEEK_MODELS : ollamaModelNames);

      const syncProviderModelSelect = ({ providerEl, modelEl }) => {
        const provider = providerEl?.value || 'ollama';
        const names = getModelsByProvider(provider);
        const current = modelEl.value;
        setModelOptions(modelEl, names);
        if (names.length > 0) {
          setModelValue(modelEl, current);
        } else {
          modelEl.value = '';
        }
      };

      const parseLines = (text) => text
        .split('\n')
        .map((line) => line.trim())
        .filter(Boolean);

      const withGradeRubric = (rubricaText) => {
        const base = ensureText(rubricaText);
        return base ? `${base}; ${GRADE_RULE}` : '';
      };

      const runEvaluation = async ({
        key,
        texto,
        rubrica,
        requestBody = null,
        provider,
        model,
        runBtn,
        runLabel,
        statusEl,
        rawEl,
        cardsEl,
        techEl,
      }) => {
        if (!texto && !(requestBody && typeof requestBody === 'object')) {
          setStatus(statusEl, 'Debes completar los campos requeridos para evaluar.');
          return null;
        }

        setBusy(runBtn, true, runLabel);
        setStatus(statusEl, 'Enviando solicitud al backend...');

        try {
          const fullRubric = withGradeRubric(rubrica);
          const body = requestBody && typeof requestBody === 'object'
            ? {
                ...requestBody,
                model: model || requestBody.model || undefined,
                provider: provider || requestBody.provider || 'ollama',
              }
            : {
                texto,
                rubrica: fullRubric || undefined,
                model: model || undefined,
                provider: provider || 'ollama',
              };
          const response = await fetch('/api/ai/correct', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify(body),
          });

          const data = await response.json();
          rawEl.textContent = JSON.stringify(data, null, 2);
          renderTechMeta(techEl, data);

          if (!response.ok || !data?.ok) {
            setStatus(statusEl, `Error ${response.status}: revisa JSON crudo`);
            renderCards(cardsEl, null);
            latestResults[key] = null;
            return null;
          }

          const normalizedEvaluation = normalizeEvaluation(data.evaluation || {});
          renderCards(cardsEl, normalizedEvaluation);
          setStatus(statusEl, 'Corrección completada.');

          const result = { data, evaluation: normalizedEvaluation };
          latestResults[key] = result;
          return result;
        } catch (error) {
          rawEl.textContent = String(error);
          renderCards(cardsEl, null);
          renderTechMeta(techEl, null);
          setStatus(statusEl, 'Fallo de red o backend no disponible.');
          latestResults[key] = null;
          return null;
        } finally {
          setBusy(runBtn, false, runLabel);
        }
      };

      const saveSubmission = async ({ key, mode, evalIdEl, saveStatusEl, buildAnswer }) => {
        const last = latestResults[key];
        if (!last) {
          setStatus(saveStatusEl, 'Primero ejecuta la evaluación para generar una calificación.');
          return;
        }

        const evalId = ensureText(evalIdEl.value);
        if (!evalId) {
          setStatus(saveStatusEl, 'Define un evalId para guardar la entrega.');
          return;
        }

        const targetStudentName = ensureText(targetStudentNameEl.value);
        const targetStudentEmail = ensureText(targetStudentEmailEl.value).toLowerCase();
        const courseId = ensureText(targetCourseIdEl.value) || 'demo-ollama';
        const pageSlug = ensureText(targetPageSlugEl.value) || 'demo/ollama';

        const score = parseScore(last.evaluation?.calificacion?.nota);
        const answerPayload = buildAnswer(last);
        const isPlanillaMode = mode === 'planilla';

        const payload = {
          type: `demo-${key}`,
          createdAt: new Date().toISOString(),
          answer: answerPayload,
          provider: last.data?.provider || 'ollama',
          aiEvaluation: last.evaluation,
          aiMeta: {
            provider: last.data?.provider || 'ollama',
            model: last.data?.model,
            created_at: last.data?.created_at,
            timing_ms: last.data?.timing_ms || null,
            token_usage: last.data?.token_usage || null,
          },
        };

        setStatus(saveStatusEl, 'Guardando entrega en LMS...');

        try {
          const response = await fetch('/api/eval/submit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              evalId,
              answer: answerPayload,
              payload,
              isCorrect: typeof score === 'number' ? score >= PASSING_SCORE : undefined,
              score: isPlanillaMode ? (score ?? undefined) : undefined,
              feedback: last.evaluation?.calificacion?.justificacion || last.evaluation?.sugerencia || '',
              courseId,
              pageSlug,
              targetStudentName: targetStudentName || undefined,
              targetStudentEmail: targetStudentEmail || undefined,
              markAsGraded: isPlanillaMode,
              ensureEnrollment: isPlanillaMode,
            }),
          });

          const data = await response.json();
          if (!response.ok || !data?.success) {
            setStatus(saveStatusEl, `Error al guardar (${response.status}): ${data?.error || 'sin detalle'}`);
            return;
          }

          setStatus(
            saveStatusEl,
            `${isPlanillaMode ? 'Enviado a planilla' : 'Enviado a tareas'}: ${data?.targetUser?.name || targetStudentName || 'estudiante'} | score ${data?.score ?? '-'} | submission ${data?.submissionId || '-'}${data?.enrolledInCourse ? ' | enrollment OK' : ''}`,
          );
        } catch (error) {
          setStatus(saveStatusEl, `Fallo al guardar entrega: ${String(error)}`);
        }
      };

      const loadInstalledModels = async () => {
        allModelSelects.forEach((selectEl) => {
          selectEl.disabled = true;
          selectEl.innerHTML = '<option value="">Cargando modelos...</option>';
        });

        try {
          const response = await fetch('/api/ai/models');
          const data = await response.json();
          const modelNames = Array.isArray(data?.models)
            ? data.models
                .map((item) => (typeof item?.name === 'string' ? item.name.trim() : ''))
                .filter(Boolean)
            : [];

          if (!response.ok || !data?.ok) {
            throw new Error('No available models');
          }

          ollamaModelNames = modelNames;
          providerModelPairs.forEach(syncProviderModelSelect);
          if (modelNames.length > 0) {
            setModelStatus(`Ollama: ${modelNames.length} modelos | DeepSeek: ${DEEPSEEK_MODELS.join(', ')}`);
          } else {
            setModelStatus(`Ollama: sin modelos locales | DeepSeek: ${DEEPSEEK_MODELS.join(', ')}`);
          }
          return;
        } catch {
          ollamaModelNames = [];
          providerModelPairs.forEach(syncProviderModelSelect);
          setModelStatus(`No se pudieron listar modelos de Ollama. DeepSeek disponible: ${DEEPSEEK_MODELS.join(', ')}`);
        }
      };

      d1ExampleBtn.addEventListener('click', () => {
        d1TextEl.value = 'La música generativa usa reglas y azar, pero me cuesta explicar cuándo el azar aporta creatividad y cuándo solo genera ruido conceptual. Creo que la semilla permite repetir procesos para analizar variaciones.';
        d1RubricEl.value = 'Claridad de tesis; precisión conceptual; uso de ejemplos; propuesta de mejora.';
        setModelValue(d1ModelEl, DEFAULT_MODEL);
        setStatus(d1StatusMsg, 'Ejemplo cargado.');
      });

      d1ClearBtn.addEventListener('click', () => {
        d1TextEl.value = '';
        d1RubricEl.value = '';
        setModelValue(d1ModelEl, DEFAULT_MODEL);
        d1RawJson.textContent = '(sin respuesta)';
        d1ResultCards.innerHTML = '';
        d1TechMeta.textContent = '(sin datos técnicos)';
        setStatus(d1StatusMsg, 'Formulario limpio.');
        setStatus(d1SaveStatus, 'Aún no guardado.');
        latestResults.d1 = null;
      });

      d1RunBtn.addEventListener('click', async () => {
        await runEvaluation({
          key: 'd1',
          texto: d1TextEl.value.trim(),
          rubrica: d1RubricEl.value.trim(),
          provider: d1ProviderEl.value,
          model: d1ModelEl.value,
          runBtn: d1RunBtn,
          runLabel: 'Probar corrección',
          statusEl: d1StatusMsg,
          rawEl: d1RawJson,
          cardsEl: d1ResultCards,
          techEl: d1TechMeta,
        });
      });

      d1SendTasksBtn.addEventListener('click', async () => {
        await saveSubmission({
          key: 'd1',
          mode: 'tasks',
          evalIdEl: d1EvalIdEl,
          saveStatusEl: d1SaveStatus,
          buildAnswer: () => ({
            provider: d1ProviderEl.value,
            student_text: d1TextEl.value.trim(),
            teacher_rubric: d1RubricEl.value.trim(),
          }),
        });
      });

      d1SendPlanillaBtn.addEventListener('click', async () => {
        await saveSubmission({
          key: 'd1',
          mode: 'planilla',
          evalIdEl: d1EvalIdEl,
          saveStatusEl: d1SaveStatus,
          buildAnswer: () => ({
            provider: d1ProviderEl.value,
            student_text: d1TextEl.value.trim(),
            teacher_rubric: d1RubricEl.value.trim(),
          }),
        });
      });

      d2PromptsBtn.addEventListener('click', () => {
        d2PromptsEl.value = PATCH_PROMPT_SUGGESTIONS;
        setStatus(d2StatusMsg, 'Prompts sugeridos cargados.');
      });

      d2ExampleBtn.addEventListener('click', () => {
        d2ConsignaEl.value = 'Construir un secuenciador simple: [metro 250] dispara [counter 0 7], la salida entra a [select 0 4] para disparar dos eventos distintos.';
        d2ReferenceEl.value = '#N canvas 200 120 820 520 10;\n#X obj 60 60 metro 250;\n#X obj 60 110 counter 0 7;\n#X obj 60 160 select 0 4;\n#X obj 220 160 bang;\n#X obj 300 160 bang;\n#X connect 0 0 1 0;\n#X connect 1 0 2 0;\n#X connect 2 0 3 0;\n#X connect 2 1 4 0;';
        d2StudentEl.value = '#N canvas 230 120 820 520 10;\n#X obj 380 80 metro 250;\n#X obj 380 130 counter 0 7;\n#X obj 380 180 select 0 4;\n#X obj 520 180 bang;\n#X obj 620 180 bang;\n#X connect 0 0 1 0;\n#X connect 1 0 2 0;\n#X connect 2 1 3 0;\n#X connect 2 0 4 0;';
        d2PromptsEl.value = PATCH_PROMPT_SUGGESTIONS;
        setModelValue(d2ModelEl, DEFAULT_MODEL);
        setStatus(d2StatusMsg, 'Ejemplo de patch cargado.');
      });

      d2ClearBtn.addEventListener('click', () => {
        d2ConsignaEl.value = '';
        d2ReferenceEl.value = '';
        d2StudentEl.value = '';
        d2PromptsEl.value = '';
        setModelValue(d2ModelEl, DEFAULT_MODEL);
        d2RawJson.textContent = '(sin respuesta)';
        d2ResultCards.innerHTML = '';
        d2TechMeta.textContent = '(sin datos técnicos)';
        setStatus(d2StatusMsg, 'Formulario de patch limpio.');
        setStatus(d2SaveStatus, 'Aún no guardado.');
        latestResults.d2 = null;
      });

      d2RunBtn.addEventListener('click', async () => {
        const consigna = d2ConsignaEl.value.trim();
        const referencePatch = d2ReferenceEl.value.trim();
        const studentPatch = d2StudentEl.value.trim();

        if (!consigna || !referencePatch || !studentPatch) {
          setStatus(d2StatusMsg, 'Completa consigna, patch de referencia y patch del alumno.');
          return;
        }

        const customPrompts = parseLines(d2PromptsEl.value);

        await runEvaluation({
          key: 'd2',
          requestBody: {
            taskType: 'patch',
            consigna,
            referencePatch,
            studentPatch,
            criteriaPrompts: [...PATCH_BASE_RUBRIC, ...customPrompts],
            evaluationPrompt: 'Ignora toda informacion de posicion de objetos y compara los patches como grafos de objetos y conexiones.',
          },
          provider: d2ProviderEl.value,
          model: d2ModelEl.value,
          runBtn: d2RunBtn,
          runLabel: 'Evaluar patch',
          statusEl: d2StatusMsg,
          rawEl: d2RawJson,
          cardsEl: d2ResultCards,
          techEl: d2TechMeta,
        });
      });

      d2SendTasksBtn.addEventListener('click', async () => {
        await saveSubmission({
          key: 'd2',
          mode: 'tasks',
          evalIdEl: d2EvalIdEl,
          saveStatusEl: d2SaveStatus,
          buildAnswer: () => ({
            provider: d2ProviderEl.value,
            consigna: d2ConsignaEl.value.trim(),
            reference_patch: d2ReferenceEl.value.trim(),
            student_patch: d2StudentEl.value.trim(),
            criteria_prompts: parseLines(d2PromptsEl.value),
          }),
        });
      });

      d2SendPlanillaBtn.addEventListener('click', async () => {
        await saveSubmission({
          key: 'd2',
          mode: 'planilla',
          evalIdEl: d2EvalIdEl,
          saveStatusEl: d2SaveStatus,
          buildAnswer: () => ({
            provider: d2ProviderEl.value,
            consigna: d2ConsignaEl.value.trim(),
            reference_patch: d2ReferenceEl.value.trim(),
            student_patch: d2StudentEl.value.trim(),
            criteria_prompts: parseLines(d2PromptsEl.value),
          }),
        });
      });

      d3ExampleBtn.addEventListener('click', () => {
        d3ConsignaEl.value = 'Explica la diferencia entre aleatoriedad y variación controlada en composición algorítmica, incluyendo un ejemplo breve.';
        d3ReferenceEl.value = 'La aleatoriedad introduce eventos impredecibles sin garantía de forma global. La variación controlada delimita rangos y reglas (por ejemplo, semilla fija, cuantización rítmica o límites armónicos) para producir diversidad con coherencia. Ejemplo: generar melodías con probabilidades, pero restringir notas a una escala y duración máxima de corchea.';
        d3StudentEl.value = 'La aleatoriedad es cuando pasan cosas al azar y la variación es cambiar cosas de a poco. En música se puede usar random para crear ideas nuevas.';
        setModelValue(d3ModelEl, DEFAULT_MODEL);
        setStatus(d3StatusMsg, 'Ejemplo de texto cargado.');
      });

      d3ClearBtn.addEventListener('click', () => {
        d3ConsignaEl.value = '';
        d3ReferenceEl.value = '';
        d3StudentEl.value = '';
        setModelValue(d3ModelEl, DEFAULT_MODEL);
        d3RawJson.textContent = '(sin respuesta)';
        d3ResultCards.innerHTML = '';
        d3TechMeta.textContent = '(sin datos técnicos)';
        setStatus(d3StatusMsg, 'Formulario textual limpio.');
        setStatus(d3SaveStatus, 'Aún no guardado.');
        latestResults.d3 = null;
      });

      d3RunBtn.addEventListener('click', async () => {
        const consigna = d3ConsignaEl.value.trim();
        const referenceText = d3ReferenceEl.value.trim();
        const studentText = d3StudentEl.value.trim();

        if (!consigna || !referenceText || !studentText) {
          setStatus(d3StatusMsg, 'Completa consigna, referencia y respuesta del alumno.');
          return;
        }

        const composedText = [
          'Evaluación de respuesta textual con referencia docente.',
          `Consigna del docente:\n${consigna}`,
          `Respuesta de referencia (teacher):\n${referenceText}`,
          `Respuesta del alumno:\n${studentText}`,
          'Objetivo: medir alineación con consigna, cobertura de ideas clave y calidad argumental.',
        ].join('\n\n');

        await runEvaluation({
          key: 'd3',
          texto: composedText,
          rubrica: TEXT_REFERENCE_RUBRIC.join('; '),
          provider: d3ProviderEl.value,
          model: d3ModelEl.value,
          runBtn: d3RunBtn,
          runLabel: 'Evaluar respuesta',
          statusEl: d3StatusMsg,
          rawEl: d3RawJson,
          cardsEl: d3ResultCards,
          techEl: d3TechMeta,
        });
      });

      d3SendTasksBtn.addEventListener('click', async () => {
        await saveSubmission({
          key: 'd3',
          mode: 'tasks',
          evalIdEl: d3EvalIdEl,
          saveStatusEl: d3SaveStatus,
          buildAnswer: () => ({
            provider: d3ProviderEl.value,
            consigna: d3ConsignaEl.value.trim(),
            reference_text: d3ReferenceEl.value.trim(),
            student_text: d3StudentEl.value.trim(),
          }),
        });
      });

      d3SendPlanillaBtn.addEventListener('click', async () => {
        await saveSubmission({
          key: 'd3',
          mode: 'planilla',
          evalIdEl: d3EvalIdEl,
          saveStatusEl: d3SaveStatus,
          buildAnswer: () => ({
            provider: d3ProviderEl.value,
            consigna: d3ConsignaEl.value.trim(),
            reference_text: d3ReferenceEl.value.trim(),
            student_text: d3StudentEl.value.trim(),
          }),
        });
      });

      providerModelPairs.forEach((pair) => {
        pair.providerEl.addEventListener('change', () => {
          syncProviderModelSelect(pair);
        });
      });

      loadInstalledModels();
    </script>
  </body>
</html>
