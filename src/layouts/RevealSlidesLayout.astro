          if (window.parent === window) return;
          const indices = deck.getIndices?.();
          if (!indices) return;
          window.parent.postMessage(
            {
              type: reason === 'ready' ? 'musiki:reveal-ready' : 'musiki:reveal-slide-state',
              state: {
                indexh: Number(indices.h || 0),
                indexv: Number(indices.v || 0),
                indexf: Number(indices.f || 0),
