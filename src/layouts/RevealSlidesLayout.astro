          }

          if (type === 'musiki:reveal-request-state') {
            emitDeckState('change');
            return;
          }

          if (type === 'musiki:reveal-reset-zoom') {
            setSlidesZoom(1);
            return;
          }

          if (type === 'musiki:reveal-toggle-jump-to-slide') {
            deck.toggleJumpToSlide?.();
            return;
          }

          if (type !== 'musiki:reveal-goto') return;
          const state = payload.state && typeof payload.state === 'object' ? payload.state : null;
          if (!state) return;

          const nextH = Number(state.indexh);
          const nextV = Number(state.indexv);
          const nextF = Number(state.indexf);
          const nextZoom = clampSlidesZoom(state.zoom ?? 1);
          if (!Number.isFinite(nextH) || !Number.isFinite(nextV) || !Number.isFinite(nextF)) return;

          const current = deck.getIndices?.();
          if (
            current &&
            Number(current.h || 0) === Math.round(nextH) &&
            Number(current.v || 0) === Math.round(nextV) &&
            Number(current.f || 0) === Math.round(nextF) &&
            Math.abs(nextZoom - slidesZoom) < 0.001
          ) {
            return;
          }

          if (Math.abs(nextZoom - slidesZoom) >= 0.001) {
            slidesZoom = nextZoom;
            applySlidesZoom();
            persistSlidesZoom();
          }
          deck.slide(Math.max(0, Math.round(nextH)), Math.max(0, Math.round(nextV)), Math.max(0, Math.round(nextF)));
        };

        let speakerOpenPending = false;
        const openSpeakerView = () => {
          const notesPlugin = deck.getPlugin?.('notes');
          if (!notesPlugin || typeof notesPlugin.open !== 'function') {
            speakerOpenPending = true;
            return;
          }
          try {
            notesPlugin.open();
            speakerOpenPending = false;
          } catch (error) {
            console.warn('Speaker view open failed:', error);
          }
        };

        const refreshScrollableState = () => {
          requestAnimationFrame(() => {
            const currentSlide = deck.getCurrentSlide?.();
            if (!(currentSlide instanceof HTMLElement)) return;

            const isMediaOnlySlide = updateSlideMediaState(currentSlide);
            currentSlide.classList.remove('slide-scrollable');
            currentSlide.classList.remove('slide-text-centered');
            currentSlide.scrollTop = 0;

            if (isMediaOnlySlide) {
              return;
            }

            const directMedia = Array.from(
              currentSlide.querySelectorAll(':scope > p > img, :scope > p > video, :scope > img, :scope > video'),
            ).filter((node) => !node.closest('.slide-grid-block'));

            if (directMedia.length > 0) {
              const mediaParents = new Set(
                directMedia.map((node) => node.closest('p, figure, div') || node),
              );
              const nonMediaHeight = Array.from(currentSlide.children).reduce((sum, child) => {
                if (child.matches('aside.notes')) return sum;
                if (mediaParents.has(child)) return sum;
                return sum + child.getBoundingClientRect().height;
              }, 0);
              const available = Math.max(
                140,
                currentSlide.clientHeight - nonMediaHeight - 40,
              );
              const maxEach = Math.max(
                120,
                Math.floor(available / Math.max(1, directMedia.length)),
              );
              directMedia.forEach((mediaNode) => {
                mediaNode.style.maxHeight = `${maxEach}px`;
                mediaNode.style.width = 'auto';
                mediaNode.style.height = 'auto';
              });
            }

            // Grid-based slides are absolutely positioned and should not enter
            // overflow scrolling mode.
            if (currentSlide.querySelector('.slide-grid-block')) {
              return;
            }

            const needsScroll = currentSlide.scrollHeight > (currentSlide.clientHeight + 8);
            if (needsScroll) {
              currentSlide.classList.add('slide-scrollable');
              return;
            }

            if (shouldCenterTextSlide(currentSlide)) {
              currentSlide.classList.add('slide-text-centered');
            }
          });
        };

        deck.on('slidechanged', () => {
          const currentSlide = deck.getCurrentSlide?.();
          if (currentSlide instanceof HTMLElement) {
            rewriteMermaidCodeBlocks(currentSlide);
            renderSlidesMermaid(currentSlide);
            void rewriteLilyCodeBlocks(currentSlide).then(() => {
              hydrateRenderedLilyBlocks(currentSlide);
              deck.layout?.();
            });
          }
          refreshScrollableState();
          emitDeckState('change');
        });

        deck.initialize()
          .then(async () => {
            rewriteMermaidCodeBlocks(slidesRoot);
            renderSlidesMermaid(slidesRoot);
            await rewriteLilyCodeBlocks(slidesRoot);
            hydrateRenderedLilyBlocks(slidesRoot);
            deck.layout?.();
            setTimeout(() => renderSlidesMermaid(slidesRoot), 360);
            refreshScrollableState();
            setTimeout(refreshScrollableState, 220);
            if (speakerOpenPending) {
              openSpeakerView();
            }
            emitDeckState('ready');
          })
          .catch((error) => {
            showFallback(error?.message || 'Reveal initialize failed');
          });

        window.addEventListener('message', handleRevealRoomMessage);

        window.addEventListener('beforeunload', () => {
          unsubscribeLivePolls?.();
          if (livePollTickId) {
            window.clearInterval(livePollTickId);
            livePollTickId = null;
          }
          window.removeEventListener('message', handleRevealRoomMessage);
        });

        window.addEventListener('resize', () => {
          normalizeSlideEmbeds(slidesRoot);
          refreshScrollableState();
        });

        slidesRoot.addEventListener('wheel', (event) => {
          const currentSlide = deck.getCurrentSlide?.();
          if (!(currentSlide instanceof HTMLElement)) return;
          if (!currentSlide.classList.contains('slide-scrollable')) return;
          if (!(event.target instanceof Node) || !currentSlide.contains(event.target)) return;
          event.stopPropagation();
        }, { passive: true });

        zoomShell.addEventListener('wheel', (event) => {
          if (!(event.ctrlKey || event.metaKey)) return;
          event.preventDefault();
          const delta = event.deltaY > 0 ? -0.05 : 0.05;
          nudgeSlidesZoom(delta);
        }, { passive: false });

        zoomShell.addEventListener('touchstart', (event) => {
          if (event.touches.length < 2) return;
          pinchStartDistance = measureTouchDistance(event.touches);
          pinchStartZoom = slidesZoom;
        }, { passive: true });

        zoomShell.addEventListener('touchmove', (event) => {
          if (event.touches.length < 2 || pinchStartDistance <= 0) return;
          event.preventDefault();
          const currentDistance = measureTouchDistance(event.touches);
          if (currentDistance <= 0) return;
          const ratio = currentDistance / pinchStartDistance;
          setSlidesZoom(pinchStartZoom * ratio);
        }, { passive: false });

        zoomShell.addEventListener('touchend', (event) => {
          if (event.touches.length >= 2) {
            pinchStartDistance = measureTouchDistance(event.touches);
            pinchStartZoom = slidesZoom;
            return;
          }
          pinchStartDistance = 0;
        }, { passive: true });

        zoomShell.addEventListener('touchcancel', () => {
          pinchStartDistance = 0;
        }, { passive: true });

        speakerBtn?.addEventListener('click', () => {
          openSpeakerView();
        });

        zoomShell.addEventListener('pointermove', (event) => {
          if (!pointerMode) return;
          pushPointerTrail(event.clientX, event.clientY);
          if (pointerPointerDown) {
            pushPointerMark(event.clientX, event.clientY);
          }
        });

        zoomShell.addEventListener('pointerdown', (event) => {
          if (!pointerMode) return;
          pointerPointerDown = true;
          pushPointerTrail(event.clientX, event.clientY);
          pushPointerMark(event.clientX, event.clientY);
        });

        zoomShell.addEventListener('pointerup', () => {
          pointerPointerDown = false;
        });

        zoomShell.addEventListener('pointerleave', () => {
          pointerPointerDown = false;
        });

        zoomShell.addEventListener('touchmove', (event) => {
          if (!pointerMode || event.touches.length !== 1) return;
          const point = extractPointerPosition(event);
          if (!point) return;
          pushPointerTrail(point.x, point.y);
        }, { passive: true });

        zoomShell.addEventListener('touchstart', (event) => {
          if (!pointerMode || event.touches.length !== 1) return;
          const point = extractPointerPosition(event);
          if (!point) return;
          pushPointerTrail(point.x, point.y);
          pushPointerMark(point.x, point.y);
        }, { passive: true });

        document.addEventListener('keydown', (event) => {
          const key = String(event.key || '').toLowerCase();

          if ((event.metaKey || event.ctrlKey) && !event.altKey && event.code === 'Backslash') {
            event.preventDefault();
            event.stopImmediatePropagation();
            window.parent.postMessage(
              { type: event.shiftKey ? 'musiki:reveal-toggle-sidebar-right' : 'musiki:reveal-toggle-sidebar-left' },
              window.location.origin,
            );
            return;
          }

          if (shouldIgnoreRevealShortcutTarget(event.target)) return;

          if ((event.ctrlKey || event.metaKey) && event.altKey && !event.shiftKey) {
            if (key === 'g') {
              event.preventDefault();
              event.stopImmediatePropagation();
              deck.toggleJumpToSlide?.();
              return;
            }

            if (['1', '2', '3', '4', '5', '6', '7', 'c', 'm', 'n', 'r', 's', 't', 'v', 'y'].includes(key)) {
              event.preventDefault();
              event.stopImmediatePropagation();
              const commandMap = {
                '1': 'layout-full',
                '2': 'layout-share',
                '3': 'layout-presentation',
                '4': 'layout-grid',
                '5': 'toggle-circle',
                '6': 'toggle-invert-video',
                '7': 'open-delegate-session',
                c: 'focus-chat',
                m: 'mute-all',
                n: 'cycle-camera',
                r: 'toggle-record',
                s: 'share-screen',
                t: 'stage-screenshot',
                v: 'toggle-camera',
                y: 'toggle-hand',
              };
              postRoomCommand(commandMap[key]);
              return;
            }
          }

          if (event.shiftKey && !event.altKey && !event.ctrlKey && !event.metaKey) {
            const reactionMap = {
              Digit4: 'reaction:clap',
              Digit5: 'reaction:thumbsup',
              Digit6: 'reaction:heart',
              Digit7: 'reaction:joy',
              Digit8: 'reaction:wow',
              Digit9: 'reaction:tada',
            };
            const reactionCommand = reactionMap[event.code];
            if (reactionCommand) {
              event.preventDefault();
              event.stopImmediatePropagation();
              postRoomCommand(reactionCommand);
              return;
            }
          }

          if ((event.ctrlKey || event.metaKey) && event.shiftKey && !event.altKey) {
            if (key === 'f' || key === 'i' || key === 'n' || key === 'v') {
              event.preventDefault();
              event.stopImmediatePropagation();
              const commandMap = {
                f: 'toggle-fullscreen',
                i: 'copy-invite-link',
                n: 'cycle-camera',
                v: 'toggle-camera',
              };
              postRoomCommand(commandMap[key]);
              return;
            }
          }

          if ((event.ctrlKey || event.metaKey) && !event.shiftKey && !event.altKey && key === 'j') {
            event.preventDefault();
            event.stopImmediatePropagation();
            postRoomCommand('toggle-connect');
            return;
          }

          if (!event.metaKey && !event.ctrlKey && !event.altKey) {
            if (key === 'g') {
              event.preventDefault();
              event.stopImmediatePropagation();
              postRoomCommand('toggle-graph');
              return;
            }

            if (key === 'h') {
              event.preventDefault();
              event.stopImmediatePropagation();
              postRoomCommand('toggle-hand');
              return;
            }

            if (key === 'p') {
              event.preventDefault();
              event.stopImmediatePropagation();
              pointerMode = !pointerMode;
              pointerPointerDown = false;
              if (!pointerMode) {
                pointerTrail = [];
                pointerMarks = [];
                queuePointerRender();
              }
              syncPointerModeUi();
              return;
            }

            if (event.key === ' ' || event.code === 'Space') {
              event.preventDefault();
              event.stopImmediatePropagation();
              postRoomCommand('hold-mic-start');
              return;
            }
          }

          if (event.shiftKey && !event.altKey && !event.ctrlKey && !event.metaKey && event.key === '?') {
            event.preventDefault();
            event.stopImmediatePropagation();
            postRoomCommand('open-search');
            return;
          }

          if (isSpeakerShortcut(event)) {
            if (event.defaultPrevented) return;
            event.preventDefault();
            openSpeakerView();
            return;
          }

          if (isToggleShortcut(event)) {
            if (event.defaultPrevented) return;
            event.preventDefault();
            toggleFullscreen();
            return;
          }

          if ((event.ctrlKey || event.metaKey) && !event.altKey) {
            if (event.key === '-' || event.key === '_') {
              event.preventDefault();
              nudgeSlidesZoom(-0.06);
              return;
            }

            if (event.key === '=' || event.key === '+') {
              event.preventDefault();
              nudgeSlidesZoom(0.06);
              return;
            }

            if (event.key === '0') {
              event.preventDefault();
              setSlidesZoom(1);
              return;
            }
          }

          if (event.key === 'Escape' && !document.fullscreenElement) {
            if (event.defaultPrevented) return;
            event.preventDefault();
            goToNote();
          }
        }, true);

        document.addEventListener('keyup', (event) => {
          if (shouldIgnoreRevealShortcutTarget(event.target)) return;
          if (event.metaKey || event.ctrlKey || event.altKey) return;
          if (event.key !== ' ' && event.code !== 'Space') return;
          event.preventDefault();
          event.stopImmediatePropagation();
          postRoomCommand('hold-mic-end');
        }, true);

        window.addEventListener('blur', () => {
          postRoomCommand('hold-mic-end');
        });
      })();
    </script>
  </body>
</html>
