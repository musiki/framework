---
import BaseHead from '../components/BaseHead.astro';
import 'reveal.js/dist/reveal.css';

const ABSOLUTE_URL_RE = /^[a-z][a-z0-9+.-]*:/i;

type Props = {
  title: string;
  description?: string;
  slideTheme?: string;
  canManageLive?: boolean;
  canonicalCourseId?: string;
};

const {
  title,
  description = '',
  slideTheme = 'zztt',
  canManageLive = false,
  canonicalCourseId = '',
} = Astro.props as Props;

const resolvedSlideTheme =
  typeof slideTheme === 'string' && slideTheme.trim()
    ? slideTheme.startsWith('/') || ABSOLUTE_URL_RE.test(slideTheme)
      ? slideTheme.trim()
      : `/inc/reveal/css-themes/${slideTheme.trim().replace(/^\/+/, '').replace(/\.css$/i, '')}.css`
    : '/inc/reveal/css-themes/zztt.css';
---

<!doctype html>
<html
  lang="es"
  data-can-manage-live={canManageLive ? 'true' : 'false'}
  data-course-id={canonicalCourseId}
>
  <head>
    <BaseHead title={`${title} | Slides`} description={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.22/dist/katex.min.css" />
    <link rel="stylesheet" href={resolvedSlideTheme} />
    <style is:global>
      html.slides-view,
      body.slides-view {
        margin: 0;
        width: 100%;
        height: 100%;
        overflow: hidden;
        background: #000;
      }

      :root {
        --slides-user-zoom: 1;
        --slides-extra-height: 20vh;
      }

      #slides-source {
        display: none;
      }

      .slide-grid-block {
        position: absolute;
        box-sizing: border-box;
        padding: 0.45rem 0.6rem;
        overflow: visible;
      }

      .slide-grid-block.media-only {
        padding: 0.2rem;
        overflow: hidden;
      }

      .slide-grid-block > :first-child {
        margin-top: 0;
      }

      .slide-grid-block > :last-child {
        margin-bottom: 0;
      }

      .slide-grid-block :is(h1, h2, h3, h4, h5, h6, p, ul, ol) {
        max-width: 100%;
        white-space: normal;
        overflow-wrap: anywhere;
        word-break: normal;
      }

      .slide-poll {
        border: 1px solid rgba(255, 255, 255, 0.28);
        border-radius: 12px;
        padding: 0.8rem;
        background: rgba(14, 14, 14, 0.78);
        max-width: min(92vw, 880px);
        margin: 0.6rem auto;
      }

      .slide-poll-prompt {
        margin: 0 0 0.45rem;
        font-size: 1.08rem;
        line-height: 1.25;
      }

      .slide-poll-meta {
        margin: -0.1rem 0 0.35rem;
        font-size: 0.77rem;
        opacity: 0.82;
      }

      .slide-poll-status {
        margin: 0;
        font-size: 0.85rem;
        opacity: 0.9;
      }

      .slide-poll-countdown {
        margin: 0.38rem 0 0;
        font-size: 0.9rem;
        font-variant-numeric: tabular-nums;
      }

      .slide-poll-countdown.is-closing {
        color: #ff8a80;
        font-weight: 700;
      }

      .slide-poll-controls {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        margin-top: 0.62rem;
      }

      .slide-poll-controls button,
      .slide-poll-controls a,
      .slide-poll-submit {
        border: 1px solid rgba(255, 255, 255, 0.32);
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.08);
        color: #f7f7f7;
        font: inherit;
        font-size: 0.78rem;
        padding: 0.4rem 0.62rem;
        text-decoration: none;
        cursor: pointer;
      }

      .slide-poll-controls button[disabled],
      .slide-poll-submit[disabled] {
        opacity: 0.55;
        cursor: not-allowed;
      }

      .slide-poll-form {
        margin-top: 0.62rem;
        display: grid;
        gap: 0.4rem;
      }

      .slide-wordcloud-suggestions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem;
      }

      .slide-wordcloud-chip {
        border: 1px solid rgba(255, 255, 255, 0.24);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.04);
        color: #f7f7f7;
        font: inherit;
        font-size: 0.74rem;
        padding: 0.28rem 0.56rem;
        cursor: pointer;
      }

      .slide-wordcloud-chip.is-active {
        border-color: rgba(110, 235, 166, 0.85);
        color: #6eeba6;
      }

      .slide-word-input {
        width: 100%;
        border: 1px solid rgba(255, 255, 255, 0.28);
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.04);
        color: #f7f7f7;
        font: inherit;
        font-size: 0.8rem;
        padding: 0.5rem 0.62rem;
      }

      .slide-poll-option {
        display: flex;
        align-items: center;
        gap: 0.55rem;
        border: 1px solid rgba(255, 255, 255, 0.24);
        border-radius: 8px;
        padding: 0.48rem 0.55rem;
      }

      .slide-poll-submit {
        margin-top: 0.6rem;
      }

      .slide-poll-feedback {
        margin-top: 0.55rem;
        border: 1px solid rgba(255, 255, 255, 0.24);
        border-radius: 8px;
        padding: 0.42rem 0.55rem;
        font-size: 0.82rem;
      }

      .slide-poll-feedback[data-error='true'] {
        border-color: rgba(255, 138, 128, 0.65);
      }

      .slide-poll-results {
        margin-top: 0.72rem;
        display: grid;
        gap: 0.4rem;
      }

      .slide-wordcloud-results {
        margin-top: 0.72rem;
      }

      .slide-wordcloud-cloud {
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem 0.7rem;
        align-items: baseline;
      }

      .slide-wordcloud-term {
        line-height: 1.05;
      }

      .slide-wordcloud-summary {
        margin: 0.55rem 0 0;
        opacity: 0.82;
        font-size: 0.72rem;
      }

      .slide-poll-result {
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 8px;
        padding: 0.36rem 0.5rem;
        background: rgba(255, 255, 255, 0.03);
      }

      .slide-poll-result-meta {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 0.5rem;
        font-size: 0.76rem;
      }

      .slide-poll-result-track {
        margin-top: 0.3rem;
        width: 100%;
        height: 0.34rem;
        border-radius: 999px;
        overflow: hidden;
        background: rgba(255, 255, 255, 0.18);
      }

      .slide-poll-result-fill {
        width: 0%;
        height: 100%;
        background: linear-gradient(90deg, #2fb667, #71e38f);
      }

      /* Media fit for slides: prevent vertical overflow */
      .reveal .slides img,
      .reveal .slides video,
      .reveal .slides iframe {
        display: block;
        max-width: min(100%, 96vw);
        max-height: min(72vh, calc(100vh - 8rem), 100%);
        width: auto;
        height: auto;
        margin-left: auto;
        margin-right: auto;
        object-fit: contain;
      }

      /* Grid media should be constrained by each grid box */
      .slide-grid-block img,
      .slide-grid-block video,
      .slide-grid-block iframe {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
      }

      /* Center stills vertically in non-grid slides */
      .reveal .slides > section > p:only-child:has(> img:only-child),
      .reveal .slides > section > p:only-child:has(> video:only-child),
      .reveal .slides > section > p:only-child:has(> iframe:only-child) {
        min-height: 82vh;
        margin-top: 0;
        margin-bottom: 0;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .reveal .slides > section.slide-media-only {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 100%;
        height: 100%;
      }

      .reveal .slides > section.slide-media-only > :not(aside.notes) {
        margin-top: 0 !important;
        margin-bottom: 0 !important;
      }

      .reveal .slides > section.slide-media-only > .slide-media-figure,
      .reveal .slides > section.slide-media-only > p:only-child,
      .reveal .slides > section.slide-media-only > :is(img, video, iframe):only-child {
        margin-left: auto;
        margin-right: auto;
      }

      .reveal.ready .slides > section.slide-media-only > :not(aside.notes) {
        transition: opacity 500ms ease;
      }

      .reveal.ready .slides > section.slide-media-only.past > :not(aside.notes),
      .reveal.ready .slides > section.slide-media-only.future > :not(aside.notes) {
        opacity: 0;
      }

      .reveal.ready .slides > section.slide-media-only.present > :not(aside.notes) {
        opacity: 1;
      }

      .slide-grid-block > p:has(> img:only-child),
      .slide-grid-block > p:has(> video:only-child),
      .slide-grid-block > p:has(> iframe:only-child) {
        margin: 0;
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .slide-grid-block.media-only > p:has(> img:only-child),
      .slide-grid-block.media-only > p:has(> video:only-child),
      .slide-grid-block.media-only > p:has(> iframe:only-child) {
        justify-content: flex-start;
      }

      .reveal .slides :is(.lily-score, .lilypond-block) {
        width: min(100%, 96vw);
        margin: 0.6rem auto;
        text-align: center;
      }

      .reveal .slides :is(.lily-score, .lilypond-block) img {
        display: block;
        width: auto;
        max-width: 100%;
        max-height: min(70vh, calc(100vh - 10rem));
        margin: 0 auto;
        object-fit: contain;
      }

      .slide-grid-block :is(.lily-score, .lilypond-block) {
        width: 100%;
        height: 100%;
        margin: 0;
      }

      .slide-grid-block :is(.lily-score, .lilypond-block) img {
        max-width: 100%;
        max-height: 100%;
      }

      .reveal .slides > section.slide-text-centered {
        display: flex;
        flex-direction: column;
        justify-content: center;
        min-height: 100%;
        height: 100%;
      }

      .reveal .slides > section.slide-text-centered > :first-child:not(aside.notes) {
        margin-top: 0 !important;
      }

      .reveal .slides > section.slide-text-centered > :last-child:not(aside.notes) {
        margin-bottom: 0 !important;
      }

      .reveal .slides > section .slide-media-figure {
        margin: 0.2rem auto 1rem;
        width: min(100%, 96vw);
        max-width: min(96vw, 1200px);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.4rem;
      }

      .reveal .slides > section .slide-media-figure > :is(img, video, iframe) {
        display: block;
        width: min(100%, 96vw) !important;
        max-width: 100% !important;
        max-height: min(72vh, calc(100vh - 10rem)) !important;
        height: auto !important;
        margin: 0 auto;
        object-fit: contain;
      }

      .reveal .slides > section .slide-media-figure > iframe {
        height: min(72vh, calc(100vh - 10rem)) !important;
        aspect-ratio: 16 / 9;
      }

      /* Force large responsive embeds even when source injects inline width/height */
      .reveal .slides > section iframe {
        display: block !important;
        width: min(100%, 96vw) !important;
        max-width: min(96vw, 1280px) !important;
        min-height: 320px !important;
        height: clamp(320px, 65vh, 820px) !important;
        max-height: min(72vh, calc(100vh - 10rem)) !important;
        margin-left: auto !important;
        margin-right: auto !important;
        aspect-ratio: auto !important;
      }

      /* Keep embed fit constrained when iframe is used inside custom grid blocks */
      .slide-grid-block iframe {
        width: auto !important;
        height: auto !important;
        max-width: 100% !important;
        max-height: 100% !important;
        aspect-ratio: auto !important;
      }

      .reveal .slides > section .slide-media-figure > figcaption {
        width: min(100%, 92ch);
        text-align: left;
      }

      .slide-grid-block.stretch-column > * {
        width: 100%;
      }

      .slide-grid-block.stretch-row > * {
        height: 100%;
      }

      .slide-grid-block.flex-even > * {
        flex: 1 1 0%;
      }

      /* Allow vertical reading on overflowing slides only */
      .reveal .slides > section.slide-scrollable {
        overflow-y: auto !important;
        overflow-x: hidden !important;
        -webkit-overflow-scrolling: touch;
        max-height: calc(100vh + var(--slides-extra-height) - 2.5rem);
        overscroll-behavior: contain;
        touch-action: pan-y;
        padding-right: 0.45rem;
        padding-bottom: max(0.8rem, calc(var(--slides-extra-height) * 0.35));
        box-sizing: border-box;
      }

      .reveal .slides > section.slide-scrollable::-webkit-scrollbar {
        width: 8px;
      }

      .reveal .slides > section.slide-scrollable::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.32);
        border-radius: 999px;
      }

      .reveal .slides > section.slide-has-grid {
        height: 100%;
        min-height: 100%;
      }

      .slides-controls {
        position: fixed;
        left: 0.8rem;
        bottom: 0.8rem;
        z-index: 10010;
        display: flex;
        gap: 0.45rem;
      }

      .slides-controls button {
        border: 1px solid rgba(255, 255, 255, 0.35);
        background: rgba(17, 17, 17, 0.78);
        color: #f7f7f7;
        border-radius: 999px;
        width: 22px;
        height: 22px;
        min-width: 22px;
        min-height: 22px;
        padding: 0;
        font: inherit;
        font-size: 0.68rem;
        font-weight: 700;
        line-height: 1;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(10px);
      }

      .slides-controls button:hover {
        background: rgba(38, 38, 38, 0.92);
      }

      .slides-controls button[data-active='true'] {
        background: rgba(60, 60, 60, 0.96);
      }

      .slides-controls svg {
        width: 11px;
        height: 11px;
        display: block;
        stroke: currentColor;
        fill: none;
        stroke-width: 1.7;
        stroke-linecap: round;
        stroke-linejoin: round;
        vector-effect: non-scaling-stroke;
      }

      .slides-zoom-shell {
        position: fixed;
        inset: 0;
        overflow: hidden;
        background: #000;
        touch-action: pan-x pan-y;
      }

      .slides-zoom-shell[data-pointer-mode='true'] {
        cursor: crosshair;
      }

      .slides-zoom-shell > .reveal {
        position: absolute;
        inset: 0;
        width: 100%;
        height: calc(100% + var(--slides-extra-height));
        min-height: calc(100% + var(--slides-extra-height));
        padding-top: calc(var(--slides-extra-height) * 0.5);
        padding-bottom: calc(var(--slides-extra-height) * 0.5 + 1.5rem);
        box-sizing: border-box;
        transform: translateY(calc(var(--slides-extra-height) * -0.5)) scale(var(--slides-user-zoom));
        transform-origin: center center;
        will-change: transform;
      }

      .slides-zoom-shell > .reveal .slides {
        min-height: 100%;
        padding-top: calc(var(--slides-extra-height) * 0.5);
        padding-bottom: calc(var(--slides-extra-height) * 0.5 + 1.5rem);
        box-sizing: border-box;
      }

      .slides-pointer-overlay {
        position: fixed;
        inset: 0;
        z-index: 10008;
        width: 100%;
        height: 100%;
        pointer-events: none;
      }

      body.slides-fallback {
        overflow: auto;
      }

      body.slides-fallback .reveal {
        width: min(1180px, 100%);
        margin: 0 auto;
        min-height: auto;
        padding: 3.8rem 1rem 2rem;
        box-sizing: border-box;
      }

      body.slides-fallback .reveal .slides {
        position: static;
        width: 100%;
        height: auto;
      }

      body.slides-fallback .reveal .slides > section {
        display: block !important;
        position: static !important;
        margin: 0 0 2rem 0 !important;
        opacity: 1 !important;
        transform: none !important;
      }
    </style>
  </head>
  <body class="slides-view">
    <div id="slides-source">
      <slot />
    </div>

    <div class="slides-controls" role="toolbar" aria-label="Controles de presentacion">
      <button id="slides-back-btn" type="button" title="Volver a la nota (Esc)" aria-label="Volver a la nota">
        <svg viewBox="0 0 16 16" aria-hidden="true">
          <path d="M4 4l8 8" />
          <path d="M12 4 4 12" />
        </svg>
      </button>
      <button id="slides-speaker-btn" type="button" title="Speaker view (Ctrl+S)" aria-label="Speaker view">S</button>
      <button id="slides-fs-btn" type="button" title="Entrar en fullscreen (Ctrl+E)" aria-label="Entrar en fullscreen">
        <svg viewBox="0 0 16 16" aria-hidden="true">
          <path d="M5 2.5H2.5V5" />
          <path d="M11 2.5h2.5V5" />
          <path d="M13.5 11v2.5H11" />
          <path d="M5 13.5H2.5V11" />
        </svg>
      </button>
    </div>

    <div class="slides-zoom-shell" id="slides-zoom-shell">
      <div class="reveal">
        <div class="slides" id="slides-root"></div>
      </div>
    </div>
    <canvas class="slides-pointer-overlay" id="slides-pointer-overlay" aria-hidden="true"></canvas>

    <script>
      import Reveal from 'reveal.js';
      import RevealNotes from 'reveal.js/plugin/notes/notes.esm.js';
      import RevealHighlight from 'reveal.js/plugin/highlight/highlight.esm.js';
      import RevealMath from 'reveal.js/plugin/math/math.esm.js';
      import RevealMarkdown from 'reveal.js/plugin/markdown/markdown.esm.js';
      import { marked } from 'marked';
      import mermaid from 'mermaid';
      import { subscribeToLive } from '../lib/live/client.mjs';
      import { formatCountdown, getRemainingMs } from '../lib/live/countdown.mjs';

      (() => {
        const source = document.getElementById('slides-source');
        const slidesRoot = document.getElementById('slides-root');
        const zoomShell = document.getElementById('slides-zoom-shell');
        const pointerCanvas = document.getElementById('slides-pointer-overlay');
        const backBtn = document.getElementById('slides-back-btn');
        const speakerBtn = document.getElementById('slides-speaker-btn');
        const fsBtn = document.getElementById('slides-fs-btn');
        const canManageLive = document.documentElement.dataset.canManageLive === 'true';
        let roomSessionControl = {
          enabled: false,
          localIdentity: '',
          localRole: '',
          sessionLeaderIdentity: '',
        };

        if (!source || !slidesRoot || !zoomShell) return;

        const noteUrl = new URL(window.location.href);
        if (noteUrl.pathname.startsWith('/cursos/slides/')) {
          noteUrl.pathname = noteUrl.pathname.replace('/cursos/slides/', '/cursos/');
        }
        noteUrl.searchParams.delete('view');
        noteUrl.searchParams.delete('autofs');

        const goToNote = () => {
          window.location.href = noteUrl.toString();
        };

        const slidesZoomStorageKey = `musiki:slides:zoom:${window.location.pathname}`;
        const clampSlidesZoom = (value) => {
          const numeric = Number(value);
          if (!Number.isFinite(numeric)) return 1;
          return Math.min(1.4, Math.max(0.45, Math.round(numeric * 1000) / 1000));
        };

        let slidesZoom = (() => {
          try {
            return clampSlidesZoom(window.localStorage.getItem(slidesZoomStorageKey) || 1);
          } catch {
            return 1;
          }
        })();

        let pinchStartDistance = 0;
        let pinchStartZoom = slidesZoom;
        let pointerMode = false;
        let pointerAnimationFrame = 0;
        let pointerPointerDown = false;
        let pointerTrail = [];
        let pointerMarks = [];
        let pointerCanvasContext = null;

        const postParentMessage = (payload) => {
          if (window.parent === window) return;
          window.parent.postMessage(payload, window.location.origin);
        };

        const postRoomCommand = (command, detail = {}) => {
          postParentMessage({
            type: 'musiki:room-command',
            command,
            ...detail,
          });
        };

        const shouldIgnoreRevealShortcutTarget = (target) =>
          target instanceof HTMLElement &&
          Boolean(target.closest('input, textarea, select, button, [contenteditable="true"]'));

        const syncPointerModeUi = () => {
          zoomShell.dataset.pointerMode = pointerMode ? 'true' : 'false';
        };

        const resizePointerCanvas = () => {
          if (!(pointerCanvas instanceof HTMLCanvasElement)) return;
          const dpr = Math.max(1, window.devicePixelRatio || 1);
          const nextWidth = Math.max(2, Math.round(window.innerWidth * dpr));
          const nextHeight = Math.max(2, Math.round(window.innerHeight * dpr));
          if (pointerCanvas.width !== nextWidth || pointerCanvas.height !== nextHeight) {
            pointerCanvas.width = nextWidth;
            pointerCanvas.height = nextHeight;
          }
          pointerCanvas.style.width = `${window.innerWidth}px`;
          pointerCanvas.style.height = `${window.innerHeight}px`;
          if (!pointerCanvasContext) {
            pointerCanvasContext = pointerCanvas.getContext('2d');
          }
          if (pointerCanvasContext) {
            pointerCanvasContext.setTransform(1, 0, 0, 1, 0, 0);
            pointerCanvasContext.scale(dpr, dpr);
          }
        };

        const queuePointerRender = () => {
          if (pointerAnimationFrame) return;
          pointerAnimationFrame = window.requestAnimationFrame(() => {
            pointerAnimationFrame = 0;
            if (!pointerCanvasContext) return;
            resizePointerCanvas();
            const now = performance.now();
            const trailLifetime = 500;
            const markLifetime = 1200;
            pointerTrail = pointerTrail.filter((point) => now - point.t <= trailLifetime);
            pointerMarks = pointerMarks.filter((mark) => now - mark.t <= markLifetime);

            pointerCanvasContext.clearRect(0, 0, window.innerWidth, window.innerHeight);

            if (pointerTrail.length > 1) {
              for (let index = 1; index < pointerTrail.length; index += 1) {
                const previous = pointerTrail[index - 1];
                const current = pointerTrail[index];
                const alpha = Math.max(0, 1 - (now - current.t) / trailLifetime);
                pointerCanvasContext.strokeStyle = `rgba(255, 64, 64, ${alpha * 0.95})`;
                pointerCanvasContext.lineWidth = 3;
                pointerCanvasContext.lineCap = 'round';
                pointerCanvasContext.lineJoin = 'round';
                pointerCanvasContext.shadowColor = `rgba(255, 72, 72, ${alpha})`;
                pointerCanvasContext.shadowBlur = 18;
                pointerCanvasContext.beginPath();
                pointerCanvasContext.moveTo(previous.x, previous.y);
                pointerCanvasContext.lineTo(current.x, current.y);
                pointerCanvasContext.stroke();
              }
            }

            pointerMarks.forEach((mark) => {
              const alpha = Math.max(0, 1 - (now - mark.t) / markLifetime);
              pointerCanvasContext.fillStyle = `rgba(255, 52, 52, ${alpha * 0.92})`;
              pointerCanvasContext.strokeStyle = `rgba(255, 0, 0, ${alpha})`;
              pointerCanvasContext.lineWidth = 1.5;
              pointerCanvasContext.shadowColor = `rgba(255, 64, 64, ${alpha})`;
              pointerCanvasContext.shadowBlur = 12;
              pointerCanvasContext.beginPath();
              pointerCanvasContext.arc(mark.x, mark.y, mark.r, 0, Math.PI * 2);
              pointerCanvasContext.fill();
              pointerCanvasContext.stroke();
            });

            if (pointerTrail.length || pointerMarks.length) {
              queuePointerRender();
            }
          });
        };

        const pushPointerTrail = (x, y) => {
          pointerTrail.push({ t: performance.now(), x, y });
          if (pointerTrail.length > 40) {
            pointerTrail = pointerTrail.slice(-40);
          }
          queuePointerRender();
        };

        const pushPointerMark = (x, y) => {
          pointerMarks.push({ r: 6, t: performance.now(), x, y });
          queuePointerRender();
        };

        const extractPointerPosition = (event) => {
          if (event.touches?.length) {
            return { x: event.touches[0].clientX, y: event.touches[0].clientY };
          }
          if (event.changedTouches?.length) {
            return { x: event.changedTouches[0].clientX, y: event.changedTouches[0].clientY };
          }
          if (typeof event.clientX === 'number' && typeof event.clientY === 'number') {
            return { x: event.clientX, y: event.clientY };
          }
          return null;
        };

        const persistSlidesZoom = () => {
          try {
            window.localStorage.setItem(slidesZoomStorageKey, String(slidesZoom));
          } catch {
            // ignore storage failures
          }
        };

        let emitDeckState = () => {};

        const canManageRoomSession = () => {
          if (!roomSessionControl.enabled) return true;
          if (String(roomSessionControl.localRole || '').trim().toLowerCase() !== 'teacher') return true;
          const localIdentity = String(roomSessionControl.localIdentity || '').trim();
          const sessionLeaderIdentity = String(roomSessionControl.sessionLeaderIdentity || '').trim();
          return Boolean(localIdentity) && localIdentity === sessionLeaderIdentity;
        };

        const applySlidesZoom = () => {
          document.documentElement.style.setProperty('--slides-user-zoom', String(slidesZoom));
        };

        const setSlidesZoom = (nextZoom) => {
          const normalized = clampSlidesZoom(nextZoom);
          if (Math.abs(normalized - slidesZoom) < 0.001) return;
          slidesZoom = normalized;
          applySlidesZoom();
          persistSlidesZoom();
          emitDeckState('change');
        };

        const nudgeSlidesZoom = (delta) => {
          setSlidesZoom(slidesZoom + delta);
        };

        const measureTouchDistance = (touches) => {
          if (!touches || touches.length < 2) return 0;
          const [first, second] = [touches[0], touches[1]];
          const dx = first.clientX - second.clientX;
          const dy = first.clientY - second.clientY;
          return Math.hypot(dx, dy);
        };

        backBtn?.addEventListener('click', () => {
          goToNote();
        });

        const isToggleShortcut = (event) => {
          const key = String(event.key || '').toLowerCase();
          const code = String(event.code || '').toLowerCase();
          return (event.ctrlKey || event.metaKey) && !event.altKey && (key === 'e' || code === 'keye');
        };

        const isSpeakerShortcut = (event) => {
          const key = String(event.key || '').toLowerCase();
          const code = String(event.code || '').toLowerCase();
          return (event.ctrlKey || event.metaKey) && !event.altKey && (key === 's' || code === 'keys');
        };

        const setFsButtonLabel = () => {
          if (!fsBtn) return;
          const isActive = Boolean(document.fullscreenElement);
          fsBtn.dataset.active = isActive ? 'true' : 'false';
          fsBtn.title = isActive ? 'Salir de fullscreen (Ctrl+E)' : 'Entrar en fullscreen (Ctrl+E)';
          fsBtn.setAttribute(
            'aria-label',
            isActive ? 'Salir de fullscreen' : 'Entrar en fullscreen',
          );
        };

        applySlidesZoom();

        const isSeparator = (node) =>
          node?.nodeType === Node.ELEMENT_NODE && node.tagName === 'HR';

        const isIgnorableText = (node) =>
          node?.nodeType === Node.TEXT_NODE && !String(node.textContent || '').trim();

        const normalizeNotes = (section) => {
          const nodes = Array.from(section.childNodes);
          const noteStart = nodes.findIndex((node) => {
            if (node.nodeType === Node.TEXT_NODE) {
              return /^note:\s*/i.test(String(node.textContent || '').trim());
            }
            if (node.nodeType === Node.ELEMENT_NODE && node.tagName === 'P') {
              return /^note:\s*/i.test(String(node.textContent || '').trim());
            }
            return false;
          });

          if (noteStart === -1) return;

          const aside = document.createElement('aside');
          aside.className = 'notes';

          while (section.childNodes.length > noteStart) {
            const child = section.childNodes[noteStart];
            if (aside.childNodes.length === 0) {
              if (child.nodeType === Node.TEXT_NODE) {
                const text = String(child.textContent || '').replace(/^note:\s*/i, '').trim();
                child.remove();
                if (!text) {
                  continue;
                }
                const p = document.createElement('p');
                p.textContent = text;
                aside.appendChild(p);
                continue;
              }
              if (child.nodeType === Node.ELEMENT_NODE && child.tagName === 'P') {
                const text = String(child.textContent || '').replace(/^note:\s*/i, '').trim();
                if (!text) {
                  child.remove();
                  continue;
                }
                child.textContent = text;
              }
            }
            aside.appendChild(child);
          }

          if (aside.childNodes.length > 0) {
            section.appendChild(aside);
          }
        };

        const isMediaElement = (node) =>
          node?.nodeType === Node.ELEMENT_NODE &&
          ['IMG', 'VIDEO', 'IFRAME'].includes(node.tagName);

        const hasMeaningfulText = (node) =>
          node?.nodeType === Node.TEXT_NODE && String(node.textContent || '').trim().length > 0;

        const normalizeMediaFigures = (section) => {
          const directParagraphs = Array.from(section.children)
            .filter((child) => child.tagName === 'P');

          directParagraphs.forEach((paragraph) => {
            const nodes = Array.from(paragraph.childNodes);
            const firstMeaningful = nodes.find((node) => {
              if (isIgnorableText(node)) return false;
              if (node.nodeType === Node.ELEMENT_NODE && node.tagName === 'BR') return false;
              return true;
            });

            if (!isMediaElement(firstMeaningful)) return;

            const media = firstMeaningful;
            const mediaIndex = nodes.indexOf(media);
            if (mediaIndex === -1) return;

            const captionNodes = nodes
              .slice(mediaIndex + 1)
              .filter((node) => !isIgnorableText(node) || hasMeaningfulText(node));

            const figure = document.createElement('figure');
            figure.className = 'slide-media-figure';

            media.remove();
            figure.appendChild(media);

            if (captionNodes.length > 0) {
              const caption = document.createElement('figcaption');
              captionNodes.forEach((node) => {
                caption.appendChild(node);
              });
              if (String(caption.textContent || '').trim().length > 0 || caption.children.length > 0) {
                figure.appendChild(caption);
              }
            }

            paragraph.replaceWith(figure);
          });
        };

        const isMediaOnlySlideNode = (node) => {
          if (!(node instanceof HTMLElement)) return false;
          if (node.matches('img, video, iframe')) return true;
          if (node.matches('p')) {
            const meaningfulNodes = Array.from(node.childNodes).filter((child) => {
              if (isIgnorableText(child)) return false;
              if (child.nodeType === Node.ELEMENT_NODE && child.tagName === 'BR') return false;
              return true;
            });
            return meaningfulNodes.length === 1 && isMediaElement(meaningfulNodes[0]);
          }
          if (node.matches('figure.slide-media-figure')) {
            const visualChildren = Array.from(node.children).filter((child) => child.tagName !== 'FIGCAPTION');
            return visualChildren.length === 1 && isMediaElement(visualChildren[0]);
          }
          return false;
        };

        const updateSlideMediaState = (slide) => {
          if (!(slide instanceof HTMLElement)) return false;
          const contentChildren = Array.from(slide.children).filter((child) => !child.matches('aside.notes'));
          const isMediaOnly = contentChildren.length === 1 && isMediaOnlySlideNode(contentChildren[0]);
          slide.classList.toggle('slide-media-only', isMediaOnly);
          return isMediaOnly;
        };

        const shouldCenterTextSlide = (slide) => {
          if (!(slide instanceof HTMLElement)) return false;
          if (slide.querySelector('.slide-grid-block')) return false;
          if (slide.querySelector('.slide-media-figure')) return false;
          if (slide.querySelector('pre, table, canvas, .mermaid, iframe, video, img')) return false;

          const contentChildren = Array.from(slide.children)
            .filter((child) => !child.matches('aside.notes'));
          if (contentChildren.length === 0) return false;

          const allowedTags = new Set(['H1', 'H2', 'H3', 'H4', 'H5', 'H6', 'P', 'UL', 'OL', 'BLOCKQUOTE']);
          if (!contentChildren.every((child) => allowedTags.has(child.tagName))) return false;
          return true;
        };

        let section = document.createElement('section');
        let hasContent = false;
        let slidesMermaidPromise = null;
        let mermaidConfigured = false;
        const slidesLilyRenderCache = new Map();
        const pollWidgetsByEvalId = new Map();
        let unsubscribeLivePolls = null;
        let livePollTickId = null;

        const decodePathPart = (value) => {
          const raw = String(value || '').trim();
          if (!raw) return '';
          try {
            return decodeURIComponent(raw);
          } catch {
            return raw;
          }
        };

        const inferLiveCourseId = () => {
          const canonicalCourseId = decodePathPart(document.documentElement.dataset.courseId || '');
          if (canonicalCourseId) return canonicalCourseId;

          const currentUrl = new URL(window.location.href);
          const explicitCourseId = decodePathPart(currentUrl.searchParams.get('courseId') || '');
          if (explicitCourseId) return explicitCourseId;

          const parts = currentUrl.pathname.split('/').filter(Boolean).map((part) => decodePathPart(part));
          if (parts[0] === 'cursos') {
            // Slides route: /cursos/slides/:courseId/:lesson...
            if (parts[1] === 'slides' && parts[2]) {
              return parts[2];
            }
            // Regular course route: /cursos/:courseId/:lesson...
            if (parts[1]) {
              return parts[1];
            }
          }
          if (parts[0] === 'live' && currentUrl.searchParams.get('courseId')) {
            return decodePathPart(currentUrl.searchParams.get('courseId') || '');
          }
          if (parts[0]) {
            return parts[0];
          }
          return 'global';
        };

        const inferLivePageSlug = () => {
          const parts = window.location.pathname.split('/').filter(Boolean);
          if (parts.length === 0) return '';
          const decodedParts = parts.map((part) => decodePathPart(part));
          if (decodedParts[0] === 'cursos' && decodedParts[1] === 'slides') {
            return decodedParts.slice(2).join('/');
          }
          if (decodedParts[0] === 'cursos') {
            return decodedParts.slice(1).join('/');
          }
          return decodedParts.join('/');
        };

        const ensureLiveClientId = () => {
          try {
            const storageKey = 'live:client-id';
            const existing = window.localStorage.getItem(storageKey);
            if (existing) return existing;
            const created = crypto.randomUUID();
            window.localStorage.setItem(storageKey, created);
            return created;
          } catch {
            return crypto.randomUUID();
          }
        };

        const saveSlideSubmission = async ({ evalId, answer, meta = {} }) => {
          try {
            const response = await fetch('/api/eval/submit', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                evalId,
                answer,
                isCorrect: true,
                payload: {
                  answer,
                  isCorrect: true,
                  ...(meta && typeof meta === 'object' ? meta : {}),
                },
                courseId: inferLiveCourseId(),
                pageSlug: inferLivePageSlug(),
              }),
            });
            return response.ok;
          } catch (error) {
            console.error('Error saving slide submission:', error);
            return false;
          }
        };

        const flushSection = () => {
          if (!hasContent) return;
          normalizeMediaFigures(section);
          normalizeNotes(section);
          updateSlideMediaState(section);
          slidesRoot.appendChild(section);
          section = document.createElement('section');
          hasContent = false;
        };

        const nodes = Array.from(source.childNodes);
        for (const node of nodes) {
          if (isIgnorableText(node)) continue;
          if (isSeparator(node)) {
            flushSection();
            continue;
          }
          section.appendChild(node);
          hasContent = true;
        }
        flushSection();
        source.remove();

        const normalizeSlideEmbeds = (container = slidesRoot) => {
          const embeds = Array.from(container.querySelectorAll('iframe'));
          embeds.forEach((iframe) => {
            if (iframe.closest('.slide-grid-block')) return;

            iframe.removeAttribute('width');
            iframe.removeAttribute('height');
            iframe.setAttribute('loading', 'eager');

            const src = String(iframe.getAttribute('src') || '').trim();
            if (!src) return;

            try {
              const url = new URL(src, window.location.origin);
              const host = url.hostname.toLowerCase();
              const isYouTube = host.includes('youtube.com')
                || host.includes('youtu.be')
                || host.includes('youtube-nocookie.com');

              if (!isYouTube) return;

              if (!url.searchParams.has('vq')) url.searchParams.set('vq', 'hd1080');
              if (!url.searchParams.has('rel')) url.searchParams.set('rel', '0');
              if (!url.searchParams.has('modestbranding')) url.searchParams.set('modestbranding', '1');
              if (!url.searchParams.has('playsinline')) url.searchParams.set('playsinline', '1');

              const nextSrc = url.toString();
              if (nextSrc !== src) {
                iframe.setAttribute('src', nextSrc);
              }
            } catch {
              // Ignore malformed iframe src values.
            }
          });
        };

        const gridAttributeRegex =
          /^(?:(-?\d*(?:px)?)(?:\s*|x)(-?\d*(?:px)?)|(center|top|bottom|left|right|topleft|topright|bottomleft|bottomright))$/i;

        const toRelativeValue = (max, input) => {
          if (typeof input !== 'string') return Number.NaN;
          const value = input.trim().toLowerCase();
          if (!value) return Number.NaN;
          if (value.endsWith('px')) {
            return (Number(value.replace('px', '').trim()) / max) * 100;
          }
          return Number(value);
        };

        const toPixelValue = (max, input) => {
          if (typeof input !== 'string') return Number.NaN;
          const value = input.trim().toLowerCase();
          if (!value) return Number.NaN;
          if (value.endsWith('px')) {
            return Number(value.replace('px', '').trim());
          }
          return (max / 100) * Number(value);
        };

        const getXYof = (name, width, height, maxWidth, maxHeight) => {
          switch (name) {
            case 'topleft':
              return [0, 0];
            case 'topright':
              return [maxWidth - width, 0];
            case 'bottomleft':
              return [0, maxHeight - height];
            case 'bottomright':
              return [maxWidth - width, maxHeight - height];
            case 'left':
              return [0, (maxHeight - height) / 2];
            case 'right':
              return [maxWidth - width, (maxHeight - height) / 2];
            case 'top':
              return [(maxWidth - width) / 2, 0];
            case 'bottom':
              return [(maxWidth - width) / 2, maxHeight - height];
            case 'center':
              return [(maxWidth - width) / 2, (maxHeight - height) / 2];
            default:
              return [0, 0];
          }
        };

        const readGrid = (drag, drop, isAbsolute) => {
          try {
            const dragMatch = gridAttributeRegex.exec(String(drag || '').trim());
            const dropMatch = gridAttributeRegex.exec(String(drop || '').trim());
            if (!dragMatch || !dropMatch) return null;

            const [, widthRaw, heightRaw] = dragMatch;
            const [, xRaw, yRaw, nameRaw] = dropMatch;
            if (!widthRaw || !heightRaw) return null;

            const slideWidth = 960;
            const slideHeight = 700;
            const maxWidth = isAbsolute ? slideWidth : 100;
            const maxHeight = isAbsolute ? slideHeight : 100;
            const valueTransformer = isAbsolute ? toPixelValue : toRelativeValue;

            const width = valueTransformer(slideWidth, widthRaw);
            const height = valueTransformer(slideHeight, heightRaw);
            if (!Number.isFinite(width) || !Number.isFinite(height)) return null;

            // Keep grid dimensions usable even when source markdown passes
            // negative drag values (for example "-5 10").
            const normalizedWidth = width <= 0 ? (maxWidth + width) : width;
            const normalizedHeight = height <= 0 ? (maxHeight + height) : height;
            if (!Number.isFinite(normalizedWidth) || !Number.isFinite(normalizedHeight)) return null;
            if (normalizedWidth <= 0 || normalizedHeight <= 0) return null;

            let x = 0;
            let y = 0;
            if (nameRaw) {
              [x, y] = getXYof(nameRaw.toLowerCase(), normalizedWidth, normalizedHeight, maxWidth, maxHeight);
            } else {
              x = valueTransformer(slideWidth, xRaw);
              y = valueTransformer(slideHeight, yRaw);
            }

            if (!Number.isFinite(x) || !Number.isFinite(y)) return null;

            return {
              x,
              y,
              width: normalizedWidth,
              height: normalizedHeight,
              maxWidth,
              maxHeight,
              unit: isAbsolute ? 'px' : '%',
            };
          } catch (error) {
            return null;
          }
        };

        const leftOf = (gridSpec) => {
          if (gridSpec.x < 0) {
            return gridSpec.maxWidth + gridSpec.x - gridSpec.width;
          }
          return gridSpec.x;
        };

        const topOf = (gridSpec) => {
          if (gridSpec.y < 0) {
            return gridSpec.maxHeight + gridSpec.y - gridSpec.height;
          }
          return gridSpec.y;
        };

        const getAlignment = (input, flow) => {
          const direction = flow ?? 'col';
          switch (input) {
            case 'topleft':
              return direction === 'col'
                ? ['left', 'flex-start', 'flex-start', '']
                : ['left', 'flex-start', 'space-evenly', ''];
            case 'topright':
              return direction === 'col'
                ? ['right', 'flex-end', 'flex-start', '']
                : ['right', 'flex-start', 'space-evenly', ''];
            case 'bottomright':
              return direction === 'col'
                ? ['right', 'flex-end', 'flex-end', '']
                : ['right', 'flex-end', 'space-evenly', ''];
            case 'bottomleft':
              return direction === 'col'
                ? ['left', 'flex-start', 'flex-end', '']
                : ['left', 'flex-end', 'space-evenly', ''];
            case 'left':
              return direction === 'col'
                ? ['left', 'flex-start', 'space-evenly', '']
                : ['left', 'center', 'space-evenly', ''];
            case 'right':
              return direction === 'col'
                ? ['right', 'flex-end', 'space-evenly', '']
                : ['right', 'center', 'space-evenly', ''];
            case 'top':
              return direction === 'col'
                ? ['', 'center', 'flex-start', '']
                : ['', 'flex-start', 'space-evenly', ''];
            case 'bottom':
              return direction === 'col'
                ? ['', 'center', 'flex-end', '']
                : ['', 'flex-end', 'space-evenly', ''];
            case 'stretch':
              return direction === 'col'
                ? ['', 'center', 'space-evenly', 'stretch-column']
                : ['', 'center', 'space-evenly', 'stretch-row'];
            case 'block':
            case 'justify':
              return ['justify', 'center', 'space-evenly', ''];
            case 'center':
            default:
              return ['', 'center', 'center', ''];
          }
        };

        const normalizeGridInnerMarkdown = (rawValue) => {
          return String(rawValue || '')
            .replace(/<br\s*\/?>/gi, '\n')
            .replace(/\u00a0/g, ' ');
        };

        const renderGridMarkdown = (rawValue) => {
          const markdown = normalizeGridInnerMarkdown(rawValue);
          return String(marked.parse(markdown, { gfm: true, breaks: true }));
        };

        const normalizeMermaidSource = (value) =>
          String(value || '')
            .replace(/\u00a0/g, ' ')
            .replace(/\r\n?/g, '\n')
            .trim();

        const rewriteMermaidCodeBlocks = (container = slidesRoot) => {
          const nodes = Array.from(
            container.querySelectorAll('pre > code.language-mermaid, pre > code.lang-mermaid'),
          );
          nodes.forEach((codeNode) => {
            const pre = codeNode.closest('pre');
            if (!pre) return;
            const mermaidNode = document.createElement('div');
            mermaidNode.className = 'mermaid';
            mermaidNode.dataset.mermaidSource = normalizeMermaidSource(codeNode.textContent || '');
            mermaidNode.textContent = mermaidNode.dataset.mermaidSource;
            pre.replaceWith(mermaidNode);
          });
        };

        const rewriteMermaidInGrid = (block) => {
          const nodes = Array.from(
            block.querySelectorAll('pre code.language-mermaid, pre code.lang-mermaid'),
          );
          nodes.forEach((codeNode) => {
            const pre = codeNode.closest('pre');
            if (!pre) return;
            const mermaidNode = document.createElement('div');
            mermaidNode.className = 'mermaid';
            mermaidNode.dataset.mermaidSource = normalizeMermaidSource(codeNode.textContent || '');
            mermaidNode.textContent = mermaidNode.dataset.mermaidSource;
            pre.replaceWith(mermaidNode);
          });
        };

        const LILY_CODE_SELECTOR = [
          'pre > code.language-lily',
          'pre > code.lang-lily',
          'pre > code.language-lilypond',
          'pre > code.lang-lilypond',
          'pre > code.language-ly',
          'pre > code.lang-ly',
        ].join(', ');

        const requestLilySvgUrl = (source) => {
          const normalized = String(source || '');
          if (!normalized.trim()) return Promise.resolve(null);
          if (slidesLilyRenderCache.has(normalized)) {
            return slidesLilyRenderCache.get(normalized);
          }

          const requestPromise = fetch('/api/lily/render', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ code: normalized }),
          })
            .then(async (response) => {
              if (!response.ok) return null;
              const payload = await response.json().catch(() => null);
              if (!payload || payload.success !== true || !payload.url) return null;
              return String(payload.url);
            })
            .catch(() => null);

          slidesLilyRenderCache.set(normalized, requestPromise);
          return requestPromise;
        };

        const rewriteLilyCodeBlocks = (container = slidesRoot) => {
          const nodes = Array.from(container.querySelectorAll(LILY_CODE_SELECTOR));
          if (nodes.length === 0) return Promise.resolve();

          const tasks = nodes.map(async (codeNode) => {
            const pre = codeNode.closest('pre');
            if (!pre || pre.dataset.lilyStatus) return;
            pre.dataset.lilyStatus = 'processing';

            const source = String(codeNode.textContent || '');
            if (!source.trim()) {
              pre.dataset.lilyStatus = 'failed';
              return;
            }

            const svgUrl = await requestLilySvgUrl(source);
            if (!svgUrl || !pre.isConnected) {
              pre.dataset.lilyStatus = 'failed';
              return;
            }

            const score = document.createElement('div');
            score.className = 'lily-score';

            const image = document.createElement('img');
            image.src = svgUrl;
            image.alt = 'LilyPond Score';
            image.loading = 'lazy';
            score.appendChild(image);

            pre.replaceWith(score);
          });

          return Promise.all(tasks).then(() => undefined);
        };

        const hydrateRenderedLilyBlocks = (container = slidesRoot) => {
          const blocks = Array.from(container.querySelectorAll('.lilypond-block, .lily-score'));
          blocks.forEach((block) => {
            if (!(block instanceof HTMLElement)) return;
            const image = block.querySelector('img');
            if (!(image instanceof HTMLImageElement)) return;
            image.loading = 'eager';
            image.decoding = 'async';
            image.referrerPolicy = 'no-referrer';
          });
        };

        const hydrateSlideGrids = (container = slidesRoot) => {
          const grids = Array.from(container.querySelectorAll('grid'));
          if (grids.length === 0) return;

          grids.forEach((grid, gridIndex) => {
            const isAbsolute = grid.getAttribute('absolute') === 'true';
            const defaultDrag = isAbsolute ? '480px 700px' : '50 100';
            const drop = grid.getAttribute('drop');
            const drag = grid.getAttribute('drag') || defaultDrag;
            const bg = String(grid.getAttribute('bg') || '').trim();
            const align = String(grid.getAttribute('align') || '').trim().toLowerCase();
            const flow = String(grid.getAttribute('flow') || 'col').trim().toLowerCase();
            const justifyContentAttr = String(grid.getAttribute('justify-content') || '').trim();

            const block = document.createElement('div');
            block.className = 'slide-grid-block';
            block.style.zIndex = String(100 + gridIndex);

            const hostSection = grid.closest('section');
            if (hostSection) {
              hostSection.classList.add('slide-has-grid');
            }

            if (drop != null) {
              const gridSpec = readGrid(drag, drop, isAbsolute);
              if (gridSpec) {
                block.style.position = 'absolute';
                block.style.left = `${leftOf(gridSpec)}${gridSpec.unit}`;
                block.style.top = `${topOf(gridSpec)}${gridSpec.unit}`;
                block.style.height = `${gridSpec.height}${gridSpec.unit}`;
                block.style.width = `${gridSpec.width}${gridSpec.unit}`;
                if (isAbsolute) {
                  block.style.minHeight = `${gridSpec.height}${gridSpec.unit}`;
                }
              }
            }

            if (bg && bg !== 'transparent') {
              block.style.background = bg;
              block.style.borderRadius = '8px';
            }

            if (align) {
              const [textAlign, alignItems, justifyContent, stretchClass] = getAlignment(align, flow);
              block.style.display = 'flex';
              block.style.flexDirection = flow === 'row' ? 'row' : 'column';
              block.style.alignItems = alignItems;
              block.style.justifyContent = justifyContentAttr || justifyContent;
              if (textAlign) {
                block.style.textAlign = textAlign;
              }
              if (stretchClass) {
                block.classList.add(stretchClass);
              }
            }

            block.innerHTML = renderGridMarkdown(grid.innerHTML);
            rewriteMermaidInGrid(block);

            const blockChildren = Array.from(block.children);
            const mediaInBlock = Array.from(block.querySelectorAll('img, video, iframe'));
            const isMediaOnly =
              mediaInBlock.length > 0 &&
              blockChildren.every((child) => child.matches('p, figure, img, video, iframe'));

            if (isMediaOnly) {
              block.classList.add('media-only');
              if (!align) {
                block.style.display = 'flex';
                block.style.alignItems = 'center';
                block.style.justifyContent = 'flex-start';
              }
            }

            grid.replaceWith(block);
          });
        };

        hydrateSlideGrids(slidesRoot);
        normalizeSlideEmbeds(slidesRoot);
        rewriteMermaidCodeBlocks(slidesRoot);
        void rewriteLilyCodeBlocks(slidesRoot);
        hydrateRenderedLilyBlocks(slidesRoot);

        const ensureSlidesMermaid = () => {
          if (slidesMermaidPromise) return slidesMermaidPromise;
          slidesMermaidPromise = Promise.resolve(mermaid || null)
            .then((api) => {
              if (!api?.render) return null;
              if (!mermaidConfigured) {
                api.initialize({
                  startOnLoad: false,
                  theme: 'dark',
                  securityLevel: 'loose',
                  suppressErrorRendering: false,
                });
                mermaidConfigured = true;
              }
              return api;
            })
            .catch(() => null);

          return slidesMermaidPromise;
        };

        let mermaidRenderSequence = 0;
        const getMermaidSource = (node) => {
          const stored = normalizeMermaidSource(node.dataset.mermaidSource || '');
          if (stored) return stored;
          const inferred = normalizeMermaidSource(node.textContent || '');
          if (inferred) {
            node.dataset.mermaidSource = inferred;
          }
          return inferred;
        };

        const renderSlidesMermaid = (container = slidesRoot, attempt = 0) => {
          const nodes = Array.from(container.querySelectorAll('.mermaid'))
            .filter(
              (node) =>
                node &&
                node.dataset.mermaidRendered !== 'true' &&
                node.dataset.mermaidRendering !== 'true',
            );
          if (nodes.length === 0) return;

          ensureSlidesMermaid()
            .then((mermaid) => {
              if (!mermaid?.render) return;
              try {
                if (!mermaidConfigured) {
                  mermaid.initialize({
                    startOnLoad: false,
                    theme: 'dark',
                    securityLevel: 'loose',
                    suppressErrorRendering: false,
                  });
                  mermaidConfigured = true;
                }

                const renderTasks = nodes.map(async (node) => {
                  const source = getMermaidSource(node);
                  if (!source) return;
                  node.dataset.mermaidRendering = 'true';
                  node.textContent = source;
                  const renderId = `slides-mermaid-${Date.now()}-${mermaidRenderSequence += 1}`;
                  const result = await mermaid.render(renderId, source);
                  node.innerHTML = result?.svg || '';
                  if (typeof result?.bindFunctions === 'function') {
                    result.bindFunctions(node);
                  }
                  delete node.dataset.mermaidRendering;
                  node.dataset.mermaidRendered = 'true';
                });

                Promise.all(renderTasks).catch((error) => {
                  nodes.forEach((node) => {
                    delete node.dataset.mermaidRendering;
                    delete node.dataset.mermaidRendered;
                    const source = getMermaidSource(node);
                    if (source) node.textContent = source;
                  });

                  if (attempt < 3) {
                    const retryDelay = 180 * (attempt + 1);
                    window.setTimeout(() => {
                      renderSlidesMermaid(container, attempt + 1);
                    }, retryDelay);
                  } else {
                    console.error('Slides mermaid render error:', error);
                  }
                });
              } catch (error) {
                nodes.forEach((node) => {
                  delete node.dataset.mermaidRendering;
                  delete node.dataset.mermaidRendered;
                  const source = getMermaidSource(node);
                  if (source) node.textContent = source;
                });
                if (attempt < 3) {
                  const retryDelay = 180 * (attempt + 1);
                  window.setTimeout(() => {
                    renderSlidesMermaid(container, attempt + 1);
                  }, retryDelay);
                } else {
                  console.error('Slides mermaid render error:', error);
                }
              }
            })
            .catch((error) => {
              console.error('Slides mermaid loader error:', error);
            });
        };

        const decodeEvalPayload = (wrapper, index) => {
          const payloadB64 = wrapper.getAttribute('data-eval-b64');
          if (!payloadB64) return null;

          try {
            const binary = atob(payloadB64);
            const bytes = Uint8Array.from(binary, (char) => char.charCodeAt(0));
            const decoded = new TextDecoder().decode(bytes);
            const parsed = JSON.parse(decoded);
            if (!parsed || typeof parsed !== 'object') return null;
            const normalizedType = String(parsed.type || '').trim().toLowerCase();
            if (normalizedType) {
              parsed.type = normalizedType;
            }
            if (!parsed.id) {
              parsed.id = `slide-eval-${index + 1}`;
            }
            return parsed;
          } catch (error) {
            console.warn('Invalid eval payload in slide:', error);
            return null;
          }
        };

        const toArrayAnswer = (value) => {
          if (Array.isArray(value)) return value.map((item) => String(item)).filter(Boolean);
          if (value === undefined || value === null) return [];
          return [String(value)].filter(Boolean);
        };

        const normalizePollOption = (option, index) => {
          if (option && typeof option === 'object') {
            const id = String(option.id || `opt-${index + 1}`).trim();
            const text = String(option.text || option.label || '').trim();
            if (!text) return null;
            return { id: id || `opt-${index + 1}`, text };
          }

          const text = String(option || '').trim();
          if (!text) return null;
          return { id: `opt-${index + 1}`, text };
        };

        const normalizeMcqOption = (option, index) => {
          if (option && typeof option === 'object') {
            const id = String(option.id || `opt-${index + 1}`).trim();
            const text = String(option.text || option.label || '').trim();
            if (!text) return null;
            return {
              id: id || `opt-${index + 1}`,
              text,
              isCorrect: Boolean(option.isCorrect),
            };
          }

          const raw = String(option || '').trim();
          if (!raw) return null;
          const cleaned = raw.replace(/^['"]|['"]$/g, '');
          const markerMatch = cleaned.match(/^\[(x|X|\s)\]\s*(.*)$/);
          if (!markerMatch) {
            return {
              id: `opt-${index + 1}`,
              text: cleaned,
              isCorrect: false,
            };
          }

          return {
            id: `opt-${index + 1}`,
            text: markerMatch[2].trim(),
            isCorrect: markerMatch[1].toLowerCase() === 'x',
          };
        };

        const sanitizeWordCounts = (rawCounts) => {
          if (!rawCounts || typeof rawCounts !== 'object' || Array.isArray(rawCounts)) return {};
          return Object.entries(rawCounts).reduce((acc, [rawWord, rawValue]) => {
            const word = String(rawWord || '').trim().replace(/\s+/g, ' ');
            if (!word) return acc;
            const numeric = Number(rawValue);
            if (!Number.isFinite(numeric) || numeric <= 0) return acc;
            acc[word] = Math.max(1, Math.round(numeric));
            return acc;
          }, {});
        };

        const formatPollStatus = (widget) => {
          if (!widget.state.active) return 'Interacción no activa.';
          if (!widget.state.endsAt) return 'Interacción en vivo.';

          const remainingMs = getRemainingMs(widget.state.endsAt, Date.now());
          if (remainingMs === null) return 'Interacción en vivo.';
          if (remainingMs <= 10_000) return `Cierra en ${formatCountdown(remainingMs)}.`;
          return `Tiempo restante: ${formatCountdown(remainingMs)}.`;
        };

        const setSlidePollFeedback = (widget, message, isError = false) => {
          const node = widget.feedbackNode;
          if (!(node instanceof HTMLElement)) return;
          if (!message) {
            node.hidden = true;
            node.textContent = '';
            node.dataset.error = 'false';
            return;
          }

          node.hidden = false;
          node.textContent = message;
          node.dataset.error = isError ? 'true' : 'false';
        };

        const updateSlidePollCountdown = (widget) => {
          const node = widget.countdownNode;
          if (!(node instanceof HTMLElement)) return;
          if (!widget.state.active || !widget.state.endsAt) {
            node.hidden = true;
            node.classList.remove('is-closing');
            node.textContent = '--:--';
            return;
          }

          const remainingMs = getRemainingMs(widget.state.endsAt, Date.now());
          if (remainingMs === null) {
            node.hidden = true;
            node.classList.remove('is-closing');
            node.textContent = '--:--';
            return;
          }

          node.hidden = false;
          node.classList.toggle('is-closing', remainingMs <= 10_000);
          node.textContent = formatCountdown(remainingMs);
        };

        const syncSlidePollResults = (widget) => {
          const node = widget.resultsNode;
          if (!(node instanceof HTMLElement)) return;
          const canShowResults = widget.canManage
            ? widget.data.showResults && widget.state.active
            : widget.data.showResults && widget.state.active && widget.state.hasSubmitted;
          if (!canShowResults) {
            node.hidden = true;
            node.innerHTML = '';
            return;
          }

          if (widget.data.type === 'wordcloud') {
            const wordCounts = sanitizeWordCounts(widget.state.wordCounts);
            const entries = Object.entries(wordCounts).sort((a, b) => {
              if (b[1] !== a[1]) return b[1] - a[1];
              return a[0].localeCompare(b[0], 'es');
            });
            if (entries.length === 0) {
              node.hidden = true;
              node.innerHTML = '';
              return;
            }

            const maxCount = Math.max(...entries.map(([, count]) => count), 1);
            const minCount = Math.min(...entries.map(([, count]) => count), maxCount);
            const totalResponses = Math.max(0, Number(widget.state.totalResponses || 0));

            const cloud = document.createElement('div');
            cloud.className = 'slide-wordcloud-cloud';
            entries.forEach(([word, count], index) => {
              const ratio = maxCount === minCount
                ? 1
                : (count - minCount) / (maxCount - minCount);
              const sizeRem = 0.95 + ratio * 1.75;
              const hue = (index * 43 + 19) % 360;

              const term = document.createElement('span');
              term.className = 'slide-wordcloud-term';
              term.textContent = word;
              term.style.fontSize = `${sizeRem.toFixed(2)}rem`;
              term.style.color = `hsl(${hue}deg 78% 62%)`;
              term.style.fontWeight = ratio > 0.6 ? '700' : '500';
              term.title = totalResponses > 0
                ? `${word}: ${count} (${Math.round((count / totalResponses) * 100)}%)`
                : `${word}: ${count}`;
              cloud.appendChild(term);
            });

            const summary = document.createElement('p');
            summary.className = 'slide-wordcloud-summary';
            summary.textContent = totalResponses > 0
              ? `${totalResponses} aportes · ${entries.length} términos`
              : `${entries.length} términos`;

            node.hidden = false;
            node.innerHTML = '';
            node.append(cloud, summary);
            return;
          }

          const totalResponses = Math.max(0, Number(widget.state.totalResponses || 0));
          node.hidden = false;
          node.innerHTML = '';

          widget.data.options.forEach((option) => {
            const count = Math.max(0, Number(widget.state.optionCounts?.[option.id] || 0));
            const percentage = totalResponses > 0 ? Math.round((count / totalResponses) * 100) : 0;

            const row = document.createElement('div');
            row.className = 'slide-poll-result';

            const meta = document.createElement('div');
            meta.className = 'slide-poll-result-meta';
            const label = document.createElement('span');
            label.textContent = option.text;
            const value = document.createElement('span');
            value.textContent = `${count} (${percentage}%)`;
            meta.append(label, value);

            const track = document.createElement('div');
            track.className = 'slide-poll-result-track';
            const fill = document.createElement('div');
            fill.className = 'slide-poll-result-fill';
            fill.style.width = `${percentage}%`;
            track.appendChild(fill);

            row.append(meta, track);
            node.appendChild(row);
          });
        };

        const persistSlideWordcloudImage = async (widget, payload) => {
          if (!widget?.canManage || widget?.data?.type !== 'wordcloud' || !payload?.active) return;

          const sessionId = String(payload?.sessionId || '').trim();
          const wordCounts = sanitizeWordCounts(payload?.wordCounts || {});
          if (!sessionId || Object.keys(wordCounts).length === 0) return;

          const saveKey = JSON.stringify([
            sessionId,
            Number(payload?.totalResponses || 0),
            Object.entries(wordCounts).sort((left, right) => left[0].localeCompare(right[0], 'es')),
          ]);

          if (widget.lastSavedWordcloudKey === saveKey) return;
          widget.lastSavedWordcloudKey = saveKey;

          try {
            const response = await fetch('/api/live/wordcloud-image', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                courseId: widget.courseId || inferLiveCourseId(),
                pageSlug: inferLivePageSlug(),
                interactionId: widget.data?.id || '',
                prompt: widget.data?.prompt || '',
                sessionId,
                wordCounts,
              }),
            });

            const exportPayload = await response.json().catch(() => ({}));
            if (!response.ok) {
              widget.lastSavedWordcloudKey = '';
              return;
            }

            widget.lastSavedWordcloudUrl = String(exportPayload?.publicUrl || '').trim();
          } catch {
            widget.lastSavedWordcloudKey = '';
          }
        };

        const renderSlidePollState = (widget) => {
          if (widget.statusNode) {
            widget.statusNode.textContent = formatPollStatus(widget);
          }

          const canManageWidget = widget.canManage && canManageRoomSession();
          const canRespond = widget.state.active;
          const submitted = Boolean(widget.state.hasSubmitted);
          const needsManualSubmit = widget.data.type === 'wordcloud' || Boolean(widget.data.allowMultiple);

          if (widget.formNode) {
            widget.formNode.hidden = !canRespond;
            widget.formNode.querySelectorAll('input, button').forEach((field) => {
              field.disabled = !canRespond;
            });
          }

          if (widget.submitButton) {
            widget.submitButton.hidden = !canRespond || !needsManualSubmit;
            widget.submitButton.disabled = !canRespond;
            widget.submitButton.textContent = widget.data.type === 'wordcloud'
              ? 'Enviar'
              : submitted
                ? 'Actualizar respuesta'
                : 'Enviar respuesta';
          }

          if (widget.startButton) {
            widget.startButton.hidden = !canManageWidget;
            widget.startButton.disabled = !canManageWidget || widget.state.active;
          }
          if (widget.endButton) {
            widget.endButton.hidden = !canManageWidget;
            widget.endButton.disabled = !canManageWidget || !widget.state.active || !widget.state.sessionId;
          }
          if (widget.openLink) {
            if (canManageWidget && widget.state.active && widget.state.sessionId) {
              const url = new URL(`/live/${encodeURIComponent(widget.state.sessionId)}`, window.location.origin);
              if (widget.courseId) url.searchParams.set('courseId', widget.courseId);
              widget.openLink.href = `${url.pathname}${url.search}`;
              widget.openLink.hidden = false;
            } else {
              widget.openLink.hidden = true;
            }
          }

          updateSlidePollCountdown(widget);
          syncSlidePollResults(widget);
        };

        const applyLivePayloadToSlidePolls = (payload, sourceEvent) => {
          if (sourceEvent === 'live.snapshot' && (!payload || !payload.active)) {
            pollWidgetsByEvalId.forEach((widget) => {
              widget.state.active = false;
              widget.state.sessionId = '';
              widget.state.endsAt = null;
              widget.state.totalResponses = 0;
              widget.state.optionCounts = {};
              widget.state.wordCounts = {};
              renderSlidePollState(widget);
            });
            return;
          }

          if (!payload || typeof payload !== 'object') return;

          if (sourceEvent === 'live.ended') {
            const endedInteractionId = String(payload.interactionId || '');
            pollWidgetsByEvalId.forEach((widget) => {
              if (widget.data.id !== endedInteractionId) return;
              widget.state.active = false;
              widget.state.sessionId = '';
              widget.state.endsAt = null;
              widget.state.totalResponses = 0;
              widget.state.optionCounts = {};
              widget.state.wordCounts = {};
              setSlidePollFeedback(widget, 'La interacción fue cerrada.');
              renderSlidePollState(widget);
            });
            return;
          }

          if (!payload.active) return;
          const interactionId = String(payload.interactionId || '');

          pollWidgetsByEvalId.forEach((widget) => {
            const isActiveWidget = widget.data.id === interactionId;
            if (!isActiveWidget && (sourceEvent === 'live.started' || sourceEvent === 'live.snapshot')) {
              widget.state.active = false;
              widget.state.sessionId = '';
              widget.state.endsAt = null;
              widget.state.totalResponses = 0;
              widget.state.optionCounts = {};
              widget.state.wordCounts = {};
            }
            if (!isActiveWidget) {
              renderSlidePollState(widget);
              return;
            }

            const nextSessionId = String(payload.sessionId || '');
            const isNewSession = Boolean(nextSessionId) && nextSessionId !== String(widget.state.sessionId || '');
            if (isNewSession) {
              widget.state.hasSubmitted = false;
              try {
                window.localStorage.removeItem(`live:submitted:${widget.data.id}`);
              } catch {
                // ignore storage restrictions
              }
              if (widget.inputNode instanceof HTMLInputElement) {
                widget.inputNode.value = '';
              }
              if (widget.formNode instanceof HTMLElement) {
                widget.formNode.querySelectorAll('input').forEach((field) => {
                  if (field instanceof HTMLInputElement) {
                    if (field.type === 'checkbox' || field.type === 'radio') {
                      field.checked = false;
                    } else if (field.type !== 'hidden') {
                      field.value = '';
                    }
                  }
                });
              }
              if (typeof widget.syncOptions === 'function') {
                widget.syncOptions(Array.isArray(payload.options) ? payload.options : widget.data.options || []);
              }
            }

            widget.state.active = true;
            widget.state.sessionId = nextSessionId;
            widget.state.endsAt = payload.endsAt || null;
            widget.state.totalResponses = Math.max(0, Number(payload.totalResponses || 0));
            if (widget.data.type === 'wordcloud' && Array.isArray(payload.options) && typeof widget.syncOptions === 'function') {
              widget.syncOptions(payload.options);
            }
            widget.state.optionCounts = payload.optionCounts && typeof payload.optionCounts === 'object'
              ? payload.optionCounts
              : {};
            widget.state.wordCounts = payload.wordCounts && typeof payload.wordCounts === 'object'
              ? payload.wordCounts
              : {};
            renderSlidePollState(widget);
            void persistSlideWordcloudImage(widget, payload);
          });
        };

        const mountLivePollTransport = () => {
          if (pollWidgetsByEvalId.size === 0) return;
          const courseId = inferLiveCourseId();
          unsubscribeLivePolls?.();
          unsubscribeLivePolls = subscribeToLive({
            courseId,
            onEvent: (eventName, payload) => {
              applyLivePayloadToSlidePolls(payload, eventName);
            },
          });

          if (livePollTickId) {
            window.clearInterval(livePollTickId);
          }
          livePollTickId = window.setInterval(() => {
            pollWidgetsByEvalId.forEach((widget) => {
              updateSlidePollCountdown(widget);
            });
          }, 1000);
        };

        const renderUnsupportedEval = (wrapper, evalData) => {
          const container = document.createElement('div');
          container.className = 'slide-poll';
          container.innerHTML = `
            <p class="slide-poll-prompt">${evalData.prompt || 'Actividad'}</p>
            <p class="slide-poll-status">Tipo no soportado en slides: ${evalData.type}</p>
          `;
          wrapper.replaceWith(container);
        };

        const renderSlideMcq = (wrapper, evalData) => {
          const options = Array.isArray(evalData.options)
            ? evalData.options.map((option, index) => normalizeMcqOption(option, index)).filter(Boolean)
            : [];
          if (options.length < 2) {
            renderUnsupportedEval(wrapper, evalData);
            return;
          }

          if (!options.some((option) => option.isCorrect)) {
            options[0].isCorrect = true;
          }

          const correctOptionIds = options
            .filter((option) => option.isCorrect)
            .map((option) => String(option.id))
            .sort();
          const allowMultiple = Boolean(evalData.allowMultiple) || correctOptionIds.length > 1;
          const allowEdit = Boolean(evalData.allowEdit);
          const storageKey = `slides:self-eval:${evalData.id}`;

          let previousAnswers = [];
          let previousCorrect = false;
          try {
            const raw = window.localStorage.getItem(storageKey);
            if (raw) {
              const parsed = JSON.parse(raw);
              previousAnswers = toArrayAnswer(parsed?.answer).map((value) => String(value));
              previousCorrect = Boolean(parsed?.isCorrect);
            }
          } catch {
            previousAnswers = [];
            previousCorrect = false;
          }

          const container = document.createElement('div');
          container.className = 'slide-poll';
          container.dataset.evalId = String(evalData.id || '');

          const prompt = document.createElement('p');
          prompt.className = 'slide-poll-prompt';
          prompt.textContent = String(evalData.prompt || 'Evaluacion');
          container.appendChild(prompt);

          const meta = document.createElement('p');
          meta.className = 'slide-poll-meta';
          const mode = String(evalData.mode || 'self').trim() || 'self';
          meta.textContent = `Modo: ${mode}${allowMultiple ? ' · Multiple choice' : ' · Opcion unica'}`;
          container.appendChild(meta);

          const form = document.createElement('form');
          form.className = 'slide-poll-form';
          options.forEach((option) => {
            const label = document.createElement('label');
            label.className = 'slide-poll-option';
            const input = document.createElement('input');
            input.type = allowMultiple ? 'checkbox' : 'radio';
            input.name = allowMultiple ? `${evalData.id}[]` : String(evalData.id);
            input.value = String(option.id);
            if (previousAnswers.includes(String(option.id))) {
              input.checked = true;
            }
            const text = document.createElement('span');
            text.textContent = option.text;
            label.append(input, text);
            form.appendChild(label);
          });
          container.appendChild(form);

          const submitButton = document.createElement('button');
          submitButton.type = 'button';
          submitButton.className = 'slide-poll-submit';
          submitButton.textContent = previousAnswers.length > 0 && allowEdit ? 'Guardar cambios' : 'Enviar respuesta';
          container.appendChild(submitButton);

          const feedback = document.createElement('div');
          feedback.className = 'slide-poll-feedback';
          feedback.hidden = true;
          container.appendChild(feedback);

          const setFeedback = (message, isError = false) => {
            if (!message) {
              feedback.hidden = true;
              feedback.textContent = '';
              feedback.dataset.error = 'false';
              return;
            }
            feedback.hidden = false;
            feedback.textContent = message;
            feedback.dataset.error = isError ? 'true' : 'false';
          };

          const setLocked = (locked) => {
            form.querySelectorAll('input').forEach((input) => {
              input.disabled = locked;
            });
            submitButton.disabled = locked;
          };

          if (previousAnswers.length > 0) {
            setFeedback(previousCorrect ? '✅ Correcto.' : '❌ Incorrecto. Puedes volver a intentar.');
            if (previousCorrect && !allowEdit) {
              setLocked(true);
            }
          }

          submitButton.addEventListener('click', async () => {
            const selectedIds = Array.from(form.querySelectorAll('input:checked'))
              .map((node) => String(node.value || '').trim())
              .filter(Boolean);
            if (selectedIds.length === 0) {
              setFeedback(allowMultiple ? 'Selecciona al menos una opcion.' : 'Selecciona una opcion.', true);
              return;
            }

            submitButton.disabled = true;
            const normalizedSelected = Array.from(new Set(selectedIds)).sort();
            const isCorrect = normalizedSelected.length === correctOptionIds.length
              && normalizedSelected.every((value, idx) => value === correctOptionIds[idx]);
            const selectedTexts = normalizedSelected
              .map((optionId) => options.find((option) => String(option.id) === optionId)?.text || '')
