        const handleRevealRoomMessage = (event) => {
          if (event.origin !== window.location.origin) return;
          const payload = event.data;
          if (!payload || typeof payload !== 'object') return;

          const type = String(payload.type || '').trim();
          if (type === 'musiki:live-snapshot') {
            const snapshot = payload.snapshot && typeof payload.snapshot === 'object'
              ? payload.snapshot
              : { active: false };
            applyLivePayloadToSlidePolls(snapshot, snapshot?.active ? 'live.updated' : 'live.snapshot');
            return;
          }

          if (type === 'musiki:reveal-session-control') {
            const state = payload.state && typeof payload.state === 'object' ? payload.state : null;
            roomSessionControl = {
              enabled: Boolean(state),
              localIdentity: String(state?.localIdentity || '').trim(),
              localRole: String(state?.localRole || '').trim(),
              sessionLeaderIdentity: String(state?.sessionLeaderIdentity || '').trim(),
            };
            pollWidgetsByEvalId.forEach((widget) => renderSlidePollState(widget));
