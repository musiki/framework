  .conference-mixer-fx-grid {
    display: grid;
    gap: 0.28rem;
  }

  .conference-mixer-fx-grid--two {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.34rem;
  }

  .conference-mixer-fx-grid--stacked {
    grid-template-columns: 1fr;
    gap: 0.34rem;
  }

  .conference-mixer-fx-control--wide {
    grid-column: 1 / -1;
  }

  .conference-mixer-fx-control {
    display: grid;
    gap: 0.16rem;
    margin-top: 0.34rem;
  }

  .conference-mixer-fx-label-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
