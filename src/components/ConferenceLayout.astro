<script>
  import { mountLiveKitRoom } from '../scripts/livekit-room.ts';

  let teardown = null;

  const mount = () => {
    const root = document.querySelector('[data-conference-root]');
    if (!(root instanceof HTMLElement)) return;

    if (typeof teardown === 'function') {
      teardown();
      teardown = null;
    }

    try {
      teardown = mountLiveKitRoom(root);
    } catch (error) {
      console.error('Conference room mount failed:', error);
      root.dataset.mounted = 'false';
      const status = root.querySelector('[data-room-status]');
      if (status instanceof HTMLElement) {
        status.textContent = error instanceof Error ? error.message : 'No fue posible iniciar la sala.';
      }
    }
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', mount, { once: true });
  } else {
    mount();
  }

  document.addEventListener('astro:page-load', mount);
  window.addEventListener('pagehide', () => {
    if (typeof teardown === 'function') teardown();
    teardown = null;
  });
</script>

