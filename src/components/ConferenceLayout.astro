---
import type { RoomPresentationOption } from '../lib/live/presentation-options';

type Props = {
  livekitUrl?: string;
  courseId?: string;
  courseHomeHref?: string;
  defaultIdentity?: string;
  defaultLayout?: 'grid' | 'teacher' | 'presentation' | 'screenshare';
  defaultName?: string;
  defaultPresentation?: string;
  defaultRole?: 'teacher' | 'student';
  defaultRoom?: string;
  inviteCode?: string;
  inviteError?: string;
  inviteLabel?: string;
  inviteMode?: 'none' | 'external' | 'invalid';
  presentationOptions?: RoomPresentationOption[];
};

const {
  livekitUrl = '',
  courseId = '',
  courseHomeHref = '/cursos',
  defaultIdentity = '',
  defaultLayout = 'presentation',
  defaultName = '',
  defaultPresentation = '',
  defaultRole = 'student',
  defaultRoom = 'musiki-stage',
  inviteCode = '',
  inviteError = '',
  inviteLabel = 'Acceso externo',
  inviteMode = 'none',
  presentationOptions = [],
} = Astro.props as Props;

const normalizedPresentationOptions = Array.isArray(presentationOptions)
  ? [...presentationOptions]
  : [];

if (
  defaultPresentation &&
  !normalizedPresentationOptions.some((option) => option.value === defaultPresentation)
) {
  normalizedPresentationOptions.unshift({
    courseId: '',
    label: defaultPresentation,
    lessonId: '',
    theme: '',
    value: defaultPresentation,
  });
}
---

<section
  class="conference-shell"
  data-conference-root
  data-livekit-url={livekitUrl}
  data-course-id={courseId}
  data-gravity-ball="false"
  data-gravity-ball-stage-visible="true"
  data-instruments-open="false"
  data-instruments-allowed="true"
  data-recording-guide-suppressed="false"
  data-recording-guide-visible="false"
  data-invite-code={inviteCode}
  data-invite-error={inviteError}
  data-invite-label={inviteLabel}
  data-invite-mode={inviteMode}
  data-role={defaultRole}
  data-sidebar-collapsed="false"
>
  <aside class="conference-instruments-sidebar" data-instruments-sidebar>
    <div class="conference-instruments-layout">
      <div class="conference-instruments-scroll">
        <section class="conference-sidebar-section conference-sidebar-section--instrument">
          <div class="conference-sidebar-heading">FM SYNTH</div>

        <div class="conference-field conference-field--checkbox conference-field--hand-controls">
          <label class="conference-checkbox-row" for="conference-hand-track-input">
            <input
              id="conference-hand-track-input"
              name="hand-track"
              type="checkbox"
              data-hand-track-input
            />
            <span>Hand track</span>
          </label>
          <label class="conference-ramp-row" for="conference-hand-ramp-input">
            <span>Ramp</span>
            <input
              id="conference-hand-ramp-input"
              name="hand-ramp"
              type="number"
              min="10"
              max="4000"
              step="10"
              value="500"
              data-hand-ramp-input
            />
            <span>ms</span>
          </label>
          <button
            type="button"
            class="conference-ramp-reset"
            data-synth-mapping-reset
            title="Reset mapping"
            aria-label="Reset mapping"
          >
            R
          </button>
        </div>

        <div class="conference-synth-meters">
          <div class="conference-synth-meter">
            <label for="conference-synth-carrier-input">Carrier</label>
            <div class="conference-synth-meter-row">
              <button type="button" class="conference-synth-map-button" data-synth-map-capture="carrier:min" aria-label="Capture carrier minimum"></button>
              <input
                id="conference-synth-carrier-input"
                type="range"
                min="20"
                max="1600"
                step="1"
                value="220"
                data-synth-carrier-input
                disabled
              />
              <button type="button" class="conference-synth-map-button" data-synth-map-capture="carrier:max" aria-label="Capture carrier maximum"></button>
              <output for="conference-synth-carrier-input" data-synth-carrier-output>220 Hz</output>
            </div>
          </div>

          <div class="conference-synth-meter">
            <label for="conference-synth-modulator-input">Modulator</label>
            <div class="conference-synth-meter-row">
              <button type="button" class="conference-synth-map-button" data-synth-map-capture="modulator:min" aria-label="Capture modulator minimum"></button>
              <input
                id="conference-synth-modulator-input"
                type="range"
                min="30"
                max="1600"
                step="1"
                value="110"
                data-synth-modulator-input
                disabled
              />
              <button type="button" class="conference-synth-map-button" data-synth-map-capture="modulator:max" aria-label="Capture modulator maximum"></button>
              <output for="conference-synth-modulator-input" data-synth-modulator-output>110 Hz</output>
            </div>
          </div>

          <div class="conference-synth-meter">
            <label for="conference-synth-gain-input">Thumb gain</label>
            <div class="conference-synth-meter-row">
              <button type="button" class="conference-synth-map-button" data-synth-map-capture="gain:min" aria-label="Capture gain minimum"></button>
              <input
                id="conference-synth-gain-input"
                type="range"
                min="0"
                max="1"
                step="0.01"
                value="0"
                data-synth-gain-input
                disabled
              />
              <button type="button" class="conference-synth-map-button" data-synth-map-capture="gain:max" aria-label="Capture gain maximum"></button>
              <output for="conference-synth-gain-input" data-synth-gain-output>0.00</output>
            </div>
          </div>

          <div class="conference-synth-meter">
            <label for="conference-synth-cutoff-input">Index cutoff</label>
            <div class="conference-synth-meter-row">
              <button type="button" class="conference-synth-map-button" data-synth-map-capture="cutoff:min" aria-label="Capture cutoff minimum"></button>
              <input
                id="conference-synth-cutoff-input"
                type="range"
                min="120"
                max="8000"
                step="1"
                value="800"
                data-synth-cutoff-input
                disabled
              />
              <button type="button" class="conference-synth-map-button" data-synth-map-capture="cutoff:max" aria-label="Capture cutoff maximum"></button>
              <output for="conference-synth-cutoff-input" data-synth-cutoff-output>800 Hz</output>
            </div>
          </div>

          <div class="conference-synth-meter">
            <label for="conference-synth-resonance-input">Ring resonance</label>
            <div class="conference-synth-meter-row">
              <button type="button" class="conference-synth-map-button" data-synth-map-capture="resonance:min" aria-label="Capture resonance minimum"></button>
              <input
                id="conference-synth-resonance-input"
                type="range"
                min="0.5"
                max="20"
                step="0.1"
                value="1"
                data-synth-resonance-input
                disabled
              />
              <button type="button" class="conference-synth-map-button" data-synth-map-capture="resonance:max" aria-label="Capture resonance maximum"></button>
              <output for="conference-synth-resonance-input" data-synth-resonance-output>1.0 Q</output>
            </div>
          </div>

          <div class="conference-synth-meter">
            <label for="conference-synth-waveform-input">Middle wave</label>
            <div class="conference-synth-meter-row">
              <button type="button" class="conference-synth-map-button" data-synth-map-capture="waveformMorph:min" aria-label="Capture waveform minimum"></button>
              <input
                id="conference-synth-waveform-input"
                type="range"
                min="0"
                max="1"
                step="0.01"
                value="0"
                data-synth-waveform-input
                disabled
              />
              <button type="button" class="conference-synth-map-button" data-synth-map-capture="waveformMorph:max" aria-label="Capture waveform maximum"></button>
              <output for="conference-synth-waveform-input" data-synth-waveform-output>SIN</output>
            </div>
          </div>

          <div class="conference-synth-meter">
            <label for="conference-synth-distortion-input" class="conference-synth-meter-label">
              <span>Pinky distortion</span>
              <span class="conference-synth-formula-shell" tabindex="0" aria-label="Distortion formula">
                ƒ
                <span class="conference-synth-formula-tooltip" role="note">
                  <math display="inline">
                    <mfrac>
                      <mrow>
                        <mo>(</mo><mn>3</mn><mo>+</mo><mn>20</mn><mo>)</mo>
                        <mo>&middot;</mo><mi>x</mi><mo>&middot;</mo><mn>57</mn>
                        <mo>&middot;</mo>
                        <mfrac><mn>3</mn><mn>180</mn></mfrac>
                      </mrow>
                      <mrow>
                        <mn>3</mn><mo>+</mo><mn>20</mn><mo>&middot;</mo>
                        <mo>|</mo><mi>x</mi><mo>|</mo>
                      </mrow>
                    </mfrac>
                  </math>
                </span>
              </span>
            </label>
            <div class="conference-synth-meter-row">
              <button type="button" class="conference-synth-map-button" data-synth-map-capture="distortion:min" aria-label="Capture distortion minimum"></button>
              <input
                id="conference-synth-distortion-input"
                type="range"
                min="0"
                max="1"
                step="0.01"
                value="0"
                data-synth-distortion-input
                disabled
              />
              <button type="button" class="conference-synth-map-button" data-synth-map-capture="distortion:max" aria-label="Capture distortion maximum"></button>
              <output for="conference-synth-distortion-input" data-synth-distortion-output>0%</output>
            </div>
          </div>
        </div>
        </section>

        <section class="conference-sidebar-section conference-sidebar-section--instrument">
          <div class="conference-sidebar-heading">GRAVITY BALL</div>

          <div class="conference-field conference-field--checkbox conference-field--hand-controls">
            <label class="conference-checkbox-row" for="conference-gravity-ball-input">
              <input
                id="conference-gravity-ball-input"
                name="gravity-ball"
                type="checkbox"
                data-gravity-ball-input
              />
              <span>Gravity ball</span>
            </label>

            <label class="conference-ramp-row" for="conference-gravity-ball-gravity-input">
              <span>Gravity</span>
              <input
                id="conference-gravity-ball-gravity-input"
                name="gravity-ball-gravity"
                type="number"
                min="1.62"
                max="14.7"
                step="0.01"
                value="9.8"
                data-gravity-ball-gravity-input
              />
              <span>m/s²</span>
            </label>
          </div>
        </section>
      </div>

      <section class="conference-sidebar-section conference-sidebar-section--instrument conference-sidebar-section--mixer">
        <div class="conference-sidebar-heading">MIXER</div>
        <div class="conference-mixer">
          <div class="conference-mixer-channel">
            <div class="conference-mixer-channel-label" data-mixer-reset-scope="synth" title="Double click to reset CH1">
              <strong>CH1</strong>
            </div>
            <div class="conference-mixer-knob-stack">
              <div
                class="conference-mixer-knob-control"
                data-mixer-synth-pan-knob
                role="slider"
                tabindex="0"
                aria-label="FM pan"
                aria-valuemin="-1"
                aria-valuemax="1"
                aria-valuenow="0"
              >
                <span class="conference-mixer-knob-indicator" aria-hidden="true"></span>
              </div>
              <input
                type="range"
                min="-1"
                max="1"
                step="0.01"
                value="0"
                class="conference-mixer-pan-input"
                data-mixer-synth-pan
              />
            </div>
            <div class="conference-mixer-fader-shell">
              <span class="conference-mixer-vumeter" data-mixer-meter="synth" aria-hidden="true"></span>
              <input
                type="range"
                min="0"
                max="1"
                step="0.01"
                value="1"
                class="conference-mixer-fader"
                data-mixer-synth-gain
              />
            </div>
            <button
              type="button"
              class="conference-mixer-channel-toggle"
              data-mixer-synth-mute
              aria-label="Mute FM channel"
              title="Mute FM"
            >
              <span class="conference-mixer-led conference-mixer-led--mute" aria-hidden="true">M</span>
            </button>
          </div>

          <div class="conference-mixer-channel">
            <div class="conference-mixer-channel-label" data-mixer-reset-scope="ball" title="Double click to reset B">
              <strong>CH2</strong>
            </div>
            <div class="conference-mixer-knob-stack">
              <div
                class="conference-mixer-knob-control"
                data-mixer-ball-pan-knob
                role="slider"
                tabindex="0"
                aria-label="Ball pan"
                aria-valuemin="-1"
                aria-valuemax="1"
                aria-valuenow="0"
              >
                <span class="conference-mixer-knob-indicator" aria-hidden="true"></span>
              </div>
              <input
                type="range"
                min="-1"
                max="1"
                step="0.01"
                value="0"
                class="conference-mixer-pan-input"
                data-mixer-ball-pan
              />
            </div>
            <div class="conference-mixer-fader-shell">
              <span class="conference-mixer-vumeter" data-mixer-meter="ball" aria-hidden="true"></span>
              <input
                type="range"
                min="0"
                max="1"
                step="0.01"
                value="1"
                class="conference-mixer-fader"
                data-mixer-ball-gain
              />
            </div>
            <button
              type="button"
              class="conference-mixer-channel-toggle"
              data-mixer-ball-mute
              aria-label="Mute ball channel"
              title="Mute ball"
            >
              <span class="conference-mixer-led conference-mixer-led--mute" aria-hidden="true">M</span>
            </button>
          </div>

          <div class="conference-mixer-channel">
            <div class="conference-mixer-channel-label" data-mixer-reset-scope="incoming" title="Double click to reset IN">
              <strong>IN</strong>
            </div>
            <div class="conference-mixer-knob-stack">
              <div
                class="conference-mixer-knob-control"
                data-mixer-incoming-pan-knob
                role="slider"
                tabindex="0"
                aria-label="Incoming pan"
                aria-valuemin="-1"
                aria-valuemax="1"
                aria-valuenow="0"
              >
                <span class="conference-mixer-knob-indicator" aria-hidden="true"></span>
              </div>
              <input
                type="range"
                min="-1"
                max="1"
                step="0.01"
                value="0"
                class="conference-mixer-pan-input"
                data-mixer-incoming-pan
              />
            </div>
            <div class="conference-mixer-fader-shell">
              <span class="conference-mixer-vumeter" data-mixer-meter="incoming" aria-hidden="true"></span>
              <input
                type="range"
                min="0"
                max="1"
                step="0.01"
                value="1"
                class="conference-mixer-fader"
                data-mixer-incoming-gain
              />
            </div>
            <button
              type="button"
              class="conference-mixer-channel-toggle"
              data-mixer-incoming-mute
              aria-label="Mute incoming channel"
              title="Mute incoming"
            >
              <span class="conference-mixer-led conference-mixer-led--mute" aria-hidden="true">M</span>
            </button>
          </div>

          <div class="conference-mixer-channel">
            <div class="conference-mixer-channel-label" data-mixer-reset-scope="master" title="Double click to reset Master">
              <strong>M</strong>
            </div>
            <div class="conference-mixer-knob-stack">
              <div
                class="conference-mixer-knob-control"
                data-mixer-master-pan-knob
                role="slider"
                tabindex="0"
                aria-label="Master pan"
                aria-valuemin="-1"
                aria-valuemax="1"
                aria-valuenow="0"
              >
                <span class="conference-mixer-knob-indicator" aria-hidden="true"></span>
              </div>
              <input
                type="range"
                min="-1"
                max="1"
                step="0.01"
                value="0"
                class="conference-mixer-pan-input"
                data-mixer-master-pan
              />
            </div>
            <div class="conference-mixer-fader-shell">
              <span class="conference-mixer-vumeter" data-mixer-meter="master" aria-hidden="true"></span>
              <input
                type="range"
                min="0"
                max="1"
                step="0.01"
                value="1"
                class="conference-mixer-fader"
                data-mixer-master-gain
              />
            </div>
            <button
              type="button"
              class="conference-mixer-channel-toggle"
              data-mixer-master-mute
              aria-label="Mute master channel"
              title="Mute master"
            >
              <span class="conference-mixer-led conference-mixer-led--mute" aria-hidden="true">M</span>
            </button>
          </div>

          <div class="conference-mixer-channel conference-mixer-channel--video">
            <div class="conference-mixer-channel-label" data-mixer-reset-scope="video" title="Double click to reset Video">
              <strong>V</strong>
            </div>

            <div class="conference-video-mixer-grid">
              <div class="conference-video-mixer-control">
                <div
                  class="conference-mixer-knob-control conference-mixer-knob-control--plain conference-mixer-knob-control--video"
                  data-mixer-video-luma-knob
                  role="slider"
                  tabindex="0"
                  aria-label="Video luma"
                  aria-valuemin="-1"
                  aria-valuemax="1"
                  aria-valuenow="0"
                >
                  <span class="conference-mixer-knob-indicator" aria-hidden="true"></span>
                </div>
                <input type="range" min="-1" max="1" step="0.01" value="0" class="conference-mixer-pan-input" data-mixer-video-luma />
                <span class="conference-video-mixer-label" data-mixer-reset-control="video:luma" title="Double click to reset Luma">Luma</span>
              </div>

              <div class="conference-video-mixer-control">
                <div
                  class="conference-mixer-knob-control conference-mixer-knob-control--plain conference-mixer-knob-control--video"
                  data-mixer-video-tint-knob
                  role="slider"
                  tabindex="0"
                  aria-label="Video tint"
                  aria-valuemin="-1"
                  aria-valuemax="1"
                  aria-valuenow="0"
                >
                  <span class="conference-mixer-knob-indicator" aria-hidden="true"></span>
                </div>
                <input type="range" min="-1" max="1" step="0.01" value="0" class="conference-mixer-pan-input" data-mixer-video-tint />
                <span class="conference-video-mixer-label" data-mixer-reset-control="video:tint" title="Double click to reset Tint">Tint</span>
              </div>

              <div class="conference-video-mixer-control">
                <div
                  class="conference-mixer-knob-control conference-mixer-knob-control--plain conference-mixer-knob-control--video"
                  data-mixer-video-saturation-knob
                  role="slider"
                  tabindex="0"
                  aria-label="Video saturation"
                  aria-valuemin="-1"
                  aria-valuemax="1"
                  aria-valuenow="0"
                >
                  <span class="conference-mixer-knob-indicator" aria-hidden="true"></span>
                </div>
                <input type="range" min="-1" max="1" step="0.01" value="0" class="conference-mixer-pan-input" data-mixer-video-saturation />
                <span class="conference-video-mixer-label" data-mixer-reset-control="video:saturation" title="Double click to reset Saturation">Sat</span>
              </div>

              <div class="conference-video-mixer-control">
                <div
                  class="conference-mixer-knob-control conference-mixer-knob-control--plain conference-mixer-knob-control--video"
                  data-mixer-video-contrast-knob
                  role="slider"
                  tabindex="0"
                  aria-label="Video contrast"
                  aria-valuemin="-1"
                  aria-valuemax="1"
                  aria-valuenow="0"
                >
                  <span class="conference-mixer-knob-indicator" aria-hidden="true"></span>
                </div>
                <input type="range" min="-1" max="1" step="0.01" value="0" class="conference-mixer-pan-input" data-mixer-video-contrast />
                <span class="conference-video-mixer-label" data-mixer-reset-control="video:contrast" title="Double click to reset Contrast">Cont</span>
              </div>

              <div class="conference-video-mixer-control conference-video-mixer-control--wide">
                <div
                  class="conference-mixer-knob-control conference-mixer-knob-control--plain conference-mixer-knob-control--video"
                  data-mixer-video-brightness-knob
                  role="slider"
                  tabindex="0"
                  aria-label="Video brightness"
                  aria-valuemin="-1"
                  aria-valuemax="1"
                  aria-valuenow="0"
                >
                  <span class="conference-mixer-knob-indicator" aria-hidden="true"></span>
                </div>
                <input type="range" min="-1" max="1" step="0.01" value="0" class="conference-mixer-pan-input" data-mixer-video-brightness />
                <span class="conference-video-mixer-label" data-mixer-reset-control="video:brightness" title="Double click to reset Brightness">Bright</span>
              </div>
            </div>
          </div>
        </div>

        <div class="conference-mixer-fx">
          <article class="conference-mixer-fx-card">
            <div class="conference-mixer-fx-head">
              <h4>REVERB</h4>
              <span class="conference-mixer-fx-badge">FX</span>
            </div>

            <label class="conference-mixer-fx-control" for="conference-synth-reverb-time-input">
              <span class="conference-mixer-fx-label-row">
                <span>Time</span>
                <output for="conference-synth-reverb-time-input" data-synth-reverb-time-output>3.0s</output>
              </span>
              <input
                id="conference-synth-reverb-time-input"
                type="range"
                min="0.4"
                max="8"
                step="0.1"
                value="3"
                data-synth-reverb-time-input
              />
            </label>

            <label class="conference-mixer-fx-control" for="conference-synth-reverb-mix-input">
              <span class="conference-mixer-fx-label-row">
                <span>Mix</span>
                <output for="conference-synth-reverb-mix-input" data-synth-reverb-mix-output>50%</output>
              </span>
              <input
                id="conference-synth-reverb-mix-input"
                type="range"
                min="0"
                max="1"
                step="0.01"
                value="0.5"
                data-synth-reverb-mix-input
              />
            </label>
          </article>

          <div class="conference-mixer-fx-pair">
            <article class="conference-mixer-fx-card">
              <div class="conference-mixer-fx-head">
                <h4>COMP</h4>
                <button
                  type="button"
                  class="conference-mixer-fx-led-toggle"
                  data-synth-comp-toggle
                  aria-label="Toggle compressor"
                  title="Compressor"
                >
                  <span class="conference-mixer-led" aria-hidden="true"></span>
                </button>
              </div>

              <div class="conference-mixer-fx-grid conference-mixer-fx-grid--stacked">
                <label class="conference-mixer-fx-control" for="conference-synth-comp-threshold-input">
                  <span class="conference-mixer-fx-label-row">
                    <span>Thresh</span>
                    <output for="conference-synth-comp-threshold-input" data-synth-comp-threshold-output>-18 dB</output>
                  </span>
                  <input
                    id="conference-synth-comp-threshold-input"
                    type="range"
                    min="-48"
                    max="0"
                    step="1"
                    value="-18"
                    data-synth-comp-threshold-input
                  />
                </label>

                <label class="conference-mixer-fx-control" for="conference-synth-comp-ratio-input">
                  <span class="conference-mixer-fx-label-row">
                    <span>Ratio</span>
                    <output for="conference-synth-comp-ratio-input" data-synth-comp-ratio-output>3.0</output>
                  </span>
                  <input
                    id="conference-synth-comp-ratio-input"
                    type="range"
                    min="1"
                    max="20"
                    step="0.1"
                    value="3"
                    data-synth-comp-ratio-input
                  />
                </label>

                <label class="conference-mixer-fx-control" for="conference-synth-comp-attack-input">
                  <span class="conference-mixer-fx-label-row">
                    <span>Attack</span>
                    <output for="conference-synth-comp-attack-input" data-synth-comp-attack-output>0.003s</output>
                  </span>
                  <input
                    id="conference-synth-comp-attack-input"
                    type="range"
                    min="0.001"
                    max="0.2"
                    step="0.001"
                    value="0.003"
                    data-synth-comp-attack-input
                  />
                </label>

                <label class="conference-mixer-fx-control" for="conference-synth-comp-release-input">
                  <span class="conference-mixer-fx-label-row">
                    <span>Release</span>
                    <output for="conference-synth-comp-release-input" data-synth-comp-release-output>0.25s</output>
                  </span>
                  <input
                    id="conference-synth-comp-release-input"
                    type="range"
                    min="0.02"
                    max="1"
                    step="0.01"
                    value="0.25"
                    data-synth-comp-release-input
                  />
                </label>

                <label class="conference-mixer-fx-control conference-mixer-fx-control--wide" for="conference-synth-comp-knee-input">
                  <span class="conference-mixer-fx-label-row">
                    <span>Knee</span>
                    <output for="conference-synth-comp-knee-input" data-synth-comp-knee-output>12 dB</output>
                  </span>
                  <input
                    id="conference-synth-comp-knee-input"
                    type="range"
                    min="0"
                    max="40"
                    step="0.5"
                    value="12"
                    data-synth-comp-knee-input
                  />
                </label>
              </div>
            </article>

            <article class="conference-mixer-fx-card">
              <div class="conference-mixer-fx-head">
                <h4>LIMITER</h4>
                <button
                  type="button"
                  class="conference-mixer-fx-led-toggle"
                  data-synth-limiter-toggle
                  aria-label="Toggle limiter"
                  title="Limiter"
                >
                  <span class="conference-mixer-led" aria-hidden="true"></span>
                </button>
              </div>

              <div class="conference-mixer-fx-grid conference-mixer-fx-grid--stacked">
                <label class="conference-mixer-fx-control" for="conference-synth-limiter-threshold-input">
                  <span class="conference-mixer-fx-label-row">
                    <span>Thresh</span>
                    <output for="conference-synth-limiter-threshold-input" data-synth-limiter-threshold-output>-1 dB</output>
                  </span>
                  <input
                    id="conference-synth-limiter-threshold-input"
                    type="range"
                    min="-12"
                    max="0"
                    step="0.5"
                    value="-1"
                    data-synth-limiter-threshold-input
                  />
                </label>

                <label class="conference-mixer-fx-control" for="conference-synth-limiter-release-input">
                  <span class="conference-mixer-fx-label-row">
                    <span>Release</span>
                    <output for="conference-synth-limiter-release-input" data-synth-limiter-release-output>0.05s</output>
                  </span>
                  <input
                    id="conference-synth-limiter-release-input"
                    type="range"
                    min="0.01"
                    max="0.5"
                    step="0.01"
                    value="0.05"
                    data-synth-limiter-release-input
                  />
                </label>
              </div>
            </article>
          </div>
        </div>
      </section>
    </div>
  </aside>

  <section class="conference-stage-frame">
    <section class="conference-stage" data-stage data-layout={defaultLayout}>
      <section class="conference-stage-panel conference-stage-panel--presentation" data-panel="presentation">
        <div class="conference-stage-label">Presentation</div>
        <div class="conference-presentation">
          <iframe
            title="Presentation stage"
            data-presentation-frame
            hidden
            loading="lazy"
            allowfullscreen
          ></iframe>
          <div class="conference-empty conference-empty--presentation" data-presentation-placeholder>
            Select a lesson with theme to load Reveal.
          </div>
        </div>
      </section>

      <section class="conference-stage-panel conference-stage-panel--focus" data-panel="teacher">
        <div class="conference-stage-label">Speaker</div>
        <div
          class="conference-slot conference-slot--focus"
          data-slot="teacher"
          data-empty-label="Speaker camera"
        ></div>
      </section>

      <section class="conference-stage-panel conference-stage-panel--screen" data-panel="screen">
        <div class="conference-stage-label">Share Screen</div>
        <div
          class="conference-slot conference-slot--screen"
          data-slot="screen"
          data-empty-label="Screen share"
        ></div>
      </section>

      <section class="conference-stage-panel conference-stage-panel--grid" data-panel="grid">
        <div class="conference-stage-label">Grid</div>
        <div
          class="conference-slot conference-slot--grid"
          data-slot="grid"
          data-empty-label="Participants grid"
        ></div>
      </section>
    </section>
    <div class="conference-recording-guide" data-recording-guide aria-hidden="true"></div>
    <div class="conference-reactions-layer" data-reactions-layer aria-hidden="true"></div>
    <canvas class="conference-gravity-ball-overlay" data-gravity-ball-canvas aria-hidden="true"></canvas>
    <canvas class="conference-hand-overlay conference-hand-overlay--stage" data-stage-hand-overlay aria-hidden="true"></canvas>
  </section>

  <aside class="conference-sidebar">
    <div class="conference-sidebar-scroll">
      <section class="conference-sidebar-section conference-sidebar-section--meta">
        <div class="conference-meta-shell">
          <div class="conference-meta-top">
            <div class="conference-field conference-field--room">
              <label for="conference-room-input">Sala</label>
              <input id="conference-room-input" name="room" type="text" value={defaultRoom} data-room-input />
            </div>

            <div class="conference-self-preview-shell">
              <div
                class="conference-self-preview"
                data-slot="identity-preview"
                data-empty-label="Camera preview"
              ></div>
            </div>
          </div>

          <details class="conference-session-setup" aria-label="Session setup" data-session-setup>
            <summary class="conference-session-setup-summary">
              <span class="conference-sidebar-heading">SETUP SESSION</span>
            </summary>

            <div class="conference-session-setup-body">
              <div class="conference-field">
                <label for="conference-identity-input">Identity</label>
                <input
                  id="conference-identity-input"
                  name="identity"
                  type="text"
                  value={defaultIdentity}
                  data-identity-input
                />
              </div>

              <div class="conference-field">
                <label for="conference-name-input">Nombre</label>
                <div class="conference-name-row">
                  <input id="conference-name-input" name="name" type="text" value={defaultName} data-name-input />
                  <span class="conference-role-tag" data-role-label
                    >{defaultRole === 'teacher' ? 'teacher' : 'student'}</span
                  >
                </div>
                <input type="hidden" name="role" value={defaultRole} data-role-input />
              </div>

              <div class="conference-field">
                <label for="conference-audio-input-select-sidebar">MIC IN</label>
                <select
                  id="conference-audio-input-select-sidebar"
                  name="audio-input-sidebar"
                  data-audio-input-select
                  data-audio-input-select-sidebar
                >
                  <option value="">Selecciona un microfono</option>
                </select>
              </div>

              <div class="conference-field">
                <label for="conference-video-input-select-sidebar">CAM IN</label>
                <select
                  id="conference-video-input-select-sidebar"
                  name="video-input-sidebar"
                  data-video-input-select
                  data-video-input-select-sidebar
                >
                  <option value="">Selecciona una camara</option>
                </select>
              </div>

              <div class="conference-field">
                <label for="conference-circle-zoom-input">Circle preview zoom</label>
                <div class="conference-range-row">
                  <input
                    id="conference-circle-zoom-input"
                    name="circle-preview-zoom"
                    type="range"
                    min="0.8"
                    max="4"
                    step="0.02"
                    value="1"
                    data-preview-zoom-input
                  />
                  <output for="conference-circle-zoom-input" data-preview-zoom-output>1.00x</output>
                </div>
              </div>

              <div class="conference-field conference-field--checkbox">
                <label class="conference-checkbox-row" for="conference-show-circle-input">
                  <input
                    id="conference-show-circle-input"
                    name="show-circle"
                    type="checkbox"
                    checked
                    data-show-circle-input
                  />
                  <span>Show Circle</span>
                </label>
              </div>

              <div class="conference-field conference-field--checkbox">
                <label class="conference-checkbox-row" for="conference-blur-background-input">
                  <input
                    id="conference-blur-background-input"
                    name="blur-background"
                    type="checkbox"
                    data-preview-blur-input
                  />
                  <span>Blur Background</span>
                </label>
              </div>

              <div class="conference-field conference-field--checkbox">
                <label class="conference-checkbox-row" for="conference-invert-video-input">
                  <input
                    id="conference-invert-video-input"
                    name="invert-video"
                    type="checkbox"
                    data-preview-invert-input
                  />
                  <span>Invert Video</span>
                </label>
              </div>

              <div class="conference-field">
                <label for="conference-recording-preset-select">Recording Preset</label>
                <select
                  id="conference-recording-preset-select"
                  name="recording-preset"
                  data-recording-preset-select
                >
                  <option value="landscape-1080">1080p</option>
                  <option value="instagram-story">Instagram Story</option>
                  <option value="tiktok">TikTok</option>
                </select>
              </div>

              <div class="conference-session-controls" data-session-controls-field hidden>
                <div class="conference-session-controls-heading">SESSION CONTROL</div>

                <div class="conference-field" data-session-leader-field>
                  <label for="conference-session-leader-select">DELEGAR SESION</label>
                  <select
                    id="conference-session-leader-select"
                    name="session-leader"
                    data-session-leader-select
                  >
                    <option value="">Sin teachers conectados</option>
                  </select>
                </div>

                <div class="conference-field conference-field--checkbox">
                  <label class="conference-checkbox-row" for="conference-session-allow-instruments-input">
                    <input
                      id="conference-session-allow-instruments-input"
                      name="session-allow-instruments"
                      type="checkbox"
                      checked
                      data-session-allow-instruments-input
                    />
                    <span>Allow instruments</span>
                  </label>
                </div>

                <button
                  type="button"
                  class="conference-session-action"
                  data-session-mute-all-button
                  title="Mute all"
                  aria-label="Mute all"
                >
                  MUTE ALL
                </button>

                <details class="conference-room-invite-panel">
                  <summary class="conference-room-invite-panel-summary">INVITAR</summary>

                  <div class="conference-room-invite-controls">
                    <div class="conference-session-controls-heading">INVITE USERS</div>

                    <div class="conference-field">
                      <label for="conference-external-password-input">Password externos</label>
                      <input
                        id="conference-external-password-input"
                        name="external-password"
                        type="password"
                        value=""
                        autocomplete="new-password"
                        data-external-password-input
                      />
                    </div>

                    <div class="conference-field">
                      <label for="conference-external-expiry-select">Vencimiento</label>
                      <select
                        id="conference-external-expiry-select"
                        name="external-expiry"
                        data-external-expiry-select
                      >
                        <option value="">Sin vencimiento</option>
                        <option value="60">1 hora</option>
                        <option value="1440">24 horas</option>
                        <option value="10080">7 dias</option>
                      </select>
                    </div>

                    <div class="conference-field">
                      <label for="conference-external-invite-link-output">Link users</label>
                      <input
                        id="conference-external-invite-link-output"
                        name="external-invite-link"
                        class="conference-invite-link-output"
                        type="text"
                        value=""
                        readonly
                        placeholder="Crea un link para invitados"
                        data-external-invite-link-output
                      />
                    </div>

                    <div class="conference-session-action-row">
                      <button
                        type="button"
                        class="conference-session-action conference-session-action--compact"
                        data-action="external-invite-create"
                        title="Guardar link"
                        aria-label="Guardar link"
                      >
                        G
                      </button>
                      <button
                        type="button"
                        class="conference-session-action conference-session-action--compact"
                        data-action="external-invite-copy"
                        title="Copiar link"
                        aria-label="Copiar link"
                      >
                        C
                      </button>
                      <button
                        type="button"
                        class="conference-session-action conference-session-action--compact"
                        data-action="external-invite-revoke"
                        title="Revocar link"
                        aria-label="Revocar link"
                      >
                        R
                      </button>
                    </div>

                    <p class="conference-session-note" data-external-invite-status>
                      Genera un link con password para invitados externos sin login.
                    </p>
                  </div>
                </details>

                <div class="conference-room-invite-controls">
                  <div class="conference-session-controls-heading">INVITE ESTUDIANTES</div>

                  <div class="conference-field">
                    <label for="conference-student-expiry-select">Vencimiento</label>
                    <select
                      id="conference-student-expiry-select"
                      name="student-expiry"
                      data-student-expiry-select
                    >
                      <option value="">Sin vencimiento</option>
                      <option value="60">1 hora</option>
                      <option value="1440">24 horas</option>
                      <option value="10080">7 dias</option>
                    </select>
                  </div>

                  <div class="conference-field">
                    <label for="conference-student-invite-link-output">Link estudiantes</label>
                    <input
                      id="conference-student-invite-link-output"
                      name="student-invite-link"
                      class="conference-invite-link-output"
                      type="text"
                      value=""
                      readonly
                      placeholder="Crea un acceso directo para estudiantes"
                      data-student-invite-link-output
                    />
                  </div>

                  <div class="conference-session-action-row conference-session-action-row--triple">
                    <button
                      type="button"
                      class="conference-session-action conference-session-action--compact"
                      data-action="student-invite-create"
                      title="Guardar link"
                      aria-label="Guardar link"
                    >
                      G
                    </button>
                    <button
                      type="button"
                      class="conference-session-action conference-session-action--compact"
                      data-action="student-invite-copy"
                      title="Copiar link"
                      aria-label="Copiar link"
                    >
                      C
                    </button>
                    <button
                      type="button"
                      class="conference-session-action conference-session-action--compact"
                      data-action="student-invite-revoke"
                      title="Revocar link"
                      aria-label="Revocar link"
                    >
                      R
                    </button>
                  </div>

                  <p class="conference-session-note" data-student-invite-status>
                    Link directo para estudiantes sin navegar por curso ni leccion.
                  </p>
                </div>
              </div>
            </div>
          </details>
        </div>

        <p class="conference-statusline" data-room-status>
          Configura la sala y conecta.
        </p>
        <span class="conference-sr-only" data-room-state>Desconectado</span>
      </section>

      <section class="conference-sidebar-section conference-sidebar-section--chat">
        <div class="conference-sidebar-heading conference-sidebar-heading--chat">
          <span>CHAT</span>
          <button
            type="button"
            class="conference-hand-button"
            data-action="raise-hand"
            aria-label="Levantar la mano"
            title="Levantar la mano (M)"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true" class="conference-icon">
              <path
                d="M8.2 11.2V5.9a1.2 1.2 0 1 1 2.4 0v4.3h.8V4.8a1.2 1.2 0 1 1 2.4 0v5.4h.8V6.1a1.2 1.2 0 1 1 2.4 0v5.3h.8V8.3a1.2 1.2 0 1 1 2.4 0v6.2c0 3.3-2.7 6-6 6h-1.4c-1.8 0-3.5-.8-4.6-2.2L5 14.8a1.5 1.5 0 0 1 2.4-1.8l.8 1.1V11.2Z"
                fill="currentColor"
              />
            </svg>
            <span class="conference-sr-only">Raise hand</span>
          </button>
        </div>
        <div class="conference-chat">
          <ul class="conference-chat-list" data-chat-list>
            <li class="conference-chat-empty">No hay mensajes todavia.</li>
          </ul>
          <div class="conference-chat-compose">
            <textarea rows="3" name="chat" placeholder="Escribe un mensaje" data-chat-input></textarea>
            <div class="conference-chat-actions">
              <button type="button" class="conference-chat-send" data-action="chat-send" disabled>
                Send
              </button>
              <button
                type="button"
                class="conference-chat-download"
                data-action="chat-download"
                aria-label="Descargar chat"
                title="Descargar chat"
                disabled
              >
                <svg viewBox="0 0 24 24" aria-hidden="true" class="conference-icon">
                  <path
                    d="M12 4a1 1 0 0 1 1 1v8.59l2.3-2.29 1.4 1.4-4.7 4.7-4.7-4.7 1.4-1.4L11 13.59V5a1 1 0 0 1 1-1Zm-6 14h12v2H6v-2Z"
                    fill="currentColor"
                  />
                </svg>
                <span class="conference-sr-only">Download chat</span>
              </button>
            </div>
          </div>
        </div>
      </section>

      <section class="conference-sidebar-section conference-sidebar-section--grid">
        <div class="conference-sidebar-heading">GRID VIEW</div>
        <div
          class="conference-slot conference-slot--sidebar"
          data-slot="students"
          data-empty-label=""
        ></div>
      </section>
    </div>
  </aside>

  <button
    type="button"
    class="conference-sidebar-toggle"
    data-action="sidebar-toggle"
    aria-label="Plegar sidebar"
    title="Plegar sidebar (Cmd/Ctrl + Shift + /)"
  >
    <svg viewBox="0 0 24 24" aria-hidden="true" class="conference-icon">
      <path
        d="M15.4 6.6 10 12l5.4 5.4-1.4 1.4L7.2 12l6.8-6.8 1.4 1.4Z"
        fill="currentColor"
      />
    </svg>
    <span class="conference-sr-only">Toggle sidebar</span>
  </button>

  <footer class="conference-bottombar">
    <div class="conference-bar-group conference-bar-group--session">
      <button
        type="button"
        class="conference-connect-button"
        data-action="connect-toggle"
        aria-label="Conectar a la sala"
        title="Conectar"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true" class="conference-connect-arrow conference-connect-arrow--in">
          <path d="M4 12h12.2l-3.6-3.6 1.4-1.4L20 13l-6 6-1.4-1.4 3.6-3.6H4z" fill="currentColor"></path>
        </svg>
        <svg viewBox="0 0 24 24" aria-hidden="true" class="conference-connect-arrow conference-connect-arrow--out">
          <path d="M20 12H7.8l3.6 3.6-1.4 1.4L4 11l6-6 1.4 1.4L7.8 10H20z" fill="currentColor"></path>
        </svg>
        <span class="conference-sr-only">Connect</span>
      </button>

      <div class="conference-count-shell">
        <button type="button" class="conference-count-button" aria-label="Participantes conectados">
          <span class="conference-count" data-participant-count data-compact="true">0</span>
        </button>
        <div class="conference-roster-popup">
          <ul class="conference-roster" data-participant-list>
            <li class="conference-roster-empty">Todavia no hay participantes en la sala.</li>
          </ul>
        </div>
      </div>

      <button
        type="button"
        class="conference-live-activity"
        data-live-activity-button
        aria-label="Abrir interacción en vivo"
        title="Abrir interacción en vivo"
        hidden
      >
        <span class="conference-live-led" aria-hidden="true"></span>
        <span class="conference-live-timer" data-live-activity-timer>--:--</span>
      </button>
    </div>

    <div class="conference-bar-group conference-bar-group--instrument">
      <button
        type="button"
        class="conference-layout-button conference-instruments-button"
        data-action="instruments-toggle"
        aria-label="Instruments"
        title="Instruments"
      >
        I
      </button>
    </div>

    <div class="conference-bar-group conference-bar-group--layout">
      <button type="button" class="conference-layout-button" data-layout-choice="teacher">F</button>
      <button type="button" class="conference-layout-button" data-layout-choice="screenshare">S</button>
      <button type="button" class="conference-layout-button" data-layout-choice="presentation">P</button>
      <button type="button" class="conference-layout-button" data-layout-choice="grid">G</button>
      <select class="conference-sr-only" data-layout-input aria-hidden="true" tabindex="-1">
        <option value="teacher" selected={defaultLayout === 'teacher'}>Focus</option>
        <option value="screenshare" selected={defaultLayout === 'screenshare'}>Share</option>
        <option value="presentation" selected={defaultLayout === 'presentation'}>Presentation</option>
        <option value="grid" selected={defaultLayout === 'grid'}>Grid</option>
      </select>
    </div>

    <div class="conference-bar-group conference-bar-group--controls">
      <div class="conference-device-stack">
        <button
          type="button"
          class="conference-icon-button"
          data-action="microphone"
          aria-label="Activar o silenciar microfono"
          title="Microphone. Shift + click para elegir dispositivo."
        >
          <svg viewBox="0 0 24 24" aria-hidden="true" class="conference-icon">
            <path
              d="M12 15.5a3.5 3.5 0 0 0 3.5-3.5V7A3.5 3.5 0 1 0 8.5 7v5a3.5 3.5 0 0 0 3.5 3.5Zm-6-3a1 1 0 1 1 2 0 4 4 0 1 0 8 0 1 1 0 1 1 2 0 6 6 0 0 1-5 5.91V21h2a1 1 0 1 1 0 2H9a1 1 0 1 1 0-2h2v-2.59A6 6 0 0 1 6 12.5Z"
              fill="currentColor"
            />
          </svg>
          <span class="conference-mic-meter" data-mic-meter hidden></span>
          <span class="conference-sr-only">Microphone</span>
        </button>
        <div class="conference-device-panel" data-audio-input-panel hidden>
          <label for="conference-audio-input-select">Microphone</label>
          <select id="conference-audio-input-select" name="audio-input" data-audio-input-select>
            <option value="">Selecciona un microfono</option>
          </select>
        </div>
      </div>

      <div class="conference-device-stack">
        <button
          type="button"
          class="conference-icon-button"
          data-action="camera"
          aria-label="Activar o apagar camara"
          title="Camera. Shift + click para elegir dispositivo."
        >
