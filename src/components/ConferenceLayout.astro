  .conference-stage[data-layout='screenshare'] .conference-stage-panel--grid,
  .conference-stage[data-layout='grid'] .conference-stage-panel--presentation,
  .conference-stage[data-layout='grid'] .conference-stage-panel--focus,
  .conference-stage[data-layout='grid'] .conference-stage-panel--screen {
    display: none;
  }

  .conference-stage-label,
  .conference-sidebar-heading {
    padding: 0.45rem 0.75rem;
    color: var(--conference-muted);
    font-size: 0.66rem;
    line-height: 1;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    border-bottom: 1px solid var(--conference-line);
  }

  .conference-sidebar-heading--chat {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .conference-hand-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    padding: 0;
    border: 0;
    background: transparent;
    color: rgba(245, 247, 251, 0.36);
    cursor: pointer;
    transition: color 440ms ease, opacity 140ms ease;
  }

  .conference-hand-button .conference-icon {
    width: 30px;
    height: 30px;
  }

  .conference-hand-button:hover,
  .conference-hand-button:focus-visible {
    color: rgba(245, 247, 251, 0.62);
    outline: none;
  }

  .conference-hand-button[data-active='true'] {
    color: rgba(245, 247, 251, 0.78);
  }

  .conference-slot,
  .conference-presentation,
  .conference-self-preview {
    min-height: 0;
    position: relative;
    display: grid;
    place-items: stretch;
    overflow: hidden;
    background: #000;
  }

  .conference-slot::before,
  .conference-self-preview::before {
    content: attr(data-empty-label);
    position: absolute;
    left: 0.8rem;
    bottom: 0.7rem;
    color: var(--conference-dim);
    font-size: 0.72rem;
    letter-spacing: 0.02em;
    pointer-events: none;
    z-index: 0;
  }

  .conference-slot:has(.conference-tile)::before,
  .conference-slot:has(.conference-media-frame)::before,
  .conference-self-preview:has(.conference-media-frame)::before {
    content: '';
  }

  .conference-slot--grid {
    padding: 0.8rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    grid-auto-rows: minmax(187px, 1fr);
    gap: 0.8rem;
    align-content: start;
    overflow: auto;
  }

  .conference-slot--sidebar {
    min-height: 15rem;
    max-height: 30vh;
    padding: 0.2rem 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.55rem;
    align-content: start;
    overflow: auto;
  }

  .conference-presentation iframe {
    width: 100%;
    height: 100%;
    border: 0;
    background: #000;
  }

  .conference-empty {
    display: grid;
    place-items: center;
    padding: 1rem;
    color: var(--conference-dim);
    text-align: center;
    line-height: 1.45;
  }

  .conference-empty--tile {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .conference-empty[hidden],
  .conference-presentation > iframe[hidden],
  .conference-presentation > .conference-empty--presentation[hidden] {
    display: none !important;
  }

  .conference-sidebar {
    border-left: 1px solid var(--conference-line);
    min-width: 0;
    overflow: hidden;
  }

  .conference-shell[data-sidebar-collapsed='true'] .conference-sidebar {
    border-left-color: transparent;
  }

  .conference-sidebar-toggle {
    position: absolute;
    top: 50%;
    right: calc(var(--conference-sidebar-size) - 11px);
    transform: translateY(-50%);
    z-index: 8;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 64px;
    padding: 0;
    border: 1px solid var(--conference-line);
    border-right: 0;
    background: rgba(0, 0, 0, 0.92);
    color: var(--conference-muted);
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.03);
    cursor: pointer;
    transition: right 160ms ease, color 140ms ease, border-color 140ms ease, box-shadow 140ms ease;
  }

  .conference-shell[data-sidebar-collapsed='true'] .conference-sidebar-toggle {
    right: 0.4rem;
    width: 28px;
    height: 72px;
    border-right: 1px solid var(--conference-line);
    background: rgba(0, 0, 0, 0.98);
    color: var(--conference-fg);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.06),
      0 8px 20px rgba(0, 0, 0, 0.32);
  }

  .conference-shell[data-sidebar-collapsed='true'] .conference-sidebar-toggle .conference-icon {
    transform: rotate(180deg);
  }

  .conference-sidebar-toggle:hover,
  .conference-sidebar-toggle:focus-visible {
    color: var(--conference-fg);
    border-color: rgba(255, 255, 255, 0.22);
    outline: none;
  }

  .conference-sidebar-scroll {
    height: 100%;
    overflow-y: auto;
    background: transparent;
    overscroll-behavior: contain;
  }

  .conference-sidebar-section--instrument {
    gap: 0.9rem;
  }

  .conference-sidebar-section--meta {
    padding-bottom: 0.42rem;
  }

  .conference-sidebar-section--chat {
    gap: 0.22rem;
    padding-top: 0.16rem;
  }

  .conference-sidebar-section--mixer {
    position: relative;
    z-index: 2;
    gap: 0.58rem;
    min-height: 0;
    max-height: min(52vh, 36rem);
    overflow-y: auto;
    overscroll-behavior: contain;
    scrollbar-gutter: stable;
    scrollbar-width: thin;
    border-top: 1px solid var(--conference-line);
    border-bottom: 0;
    background: transparent;
    box-shadow: none;
  }

  .conference-sidebar-section--mixer > .conference-sidebar-heading {
    position: sticky;
    top: -0.75rem;
    z-index: 3;
    margin: -0.75rem -0.9rem 0;
    padding: 0.75rem 0.9rem 0.55rem;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.98) 0%, rgba(0, 0, 0, 0.9) 100%);
  }

  .conference-sidebar-section {
    display: grid;
    gap: 0.48rem;
    padding: 0.58rem 0.82rem 0.68rem;
    border-bottom: 1px solid var(--conference-line);
  }

  .conference-meta-shell {
    display: grid;
    gap: 0.34rem;
  }

  .conference-meta-top {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 112px;
    gap: 0.52rem 0.72rem;
    align-items: start;
  }

  .conference-self-preview-shell {
    min-width: 0;
  }

  .conference-field {
    display: grid;
    gap: 0.28rem;
  }

  .conference-field label {
    color: var(--conference-muted);
    font-size: 0.66rem;
    line-height: 1;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .conference-field input,
  .conference-field select,
  .conference-chat-compose textarea,
  .conference-chat-compose button,
  .conference-bottombar select,
  .conference-device-panel select {
    font: inherit;
  }

  .conference-field input:not([type='range']):not([type='checkbox']),
  .conference-field select,
  .conference-chat-compose textarea,
  .conference-bottombar select,
  .conference-device-panel select {
    width: 100%;
    border: 0;
    border-bottom: 1px solid var(--conference-line);
    background: transparent;
    color: var(--conference-fg);
    padding: 0.28rem 0 0.32rem;
    outline: none;
    box-shadow: none;
  }

  .conference-sidebar .conference-field select {
    font-size: 0.72rem;
  }

  .conference-field input:focus,
  .conference-field select:focus,
  .conference-chat-compose textarea:focus,
  .conference-bottombar select:focus,
  .conference-device-panel select:focus {
    border-bottom-color: var(--conference-accent);
  }

  .conference-session-setup {
    padding-top: 0.04rem;
  }

  .conference-session-setup-summary {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    cursor: pointer;
    list-style: none;
    color: var(--conference-fg);
  }

  .conference-session-setup-summary .conference-sidebar-heading {
    width: 100%;
    padding: 0;
    border-bottom: 0;
  }

  .conference-session-setup-summary::-webkit-details-marker {
    display: none;
  }

  .conference-session-setup-summary::before {
    content: '';
    width: 0.42rem;
    height: 0.42rem;
    border-right: 1px solid currentColor;
    border-bottom: 1px solid currentColor;
    transform: rotate(-45deg);
    transform-origin: center;
    opacity: 0.72;
    margin-top: 0.08rem;
    transition: transform 140ms ease;
  }

  .conference-session-setup[open] .conference-session-setup-summary::before {
    transform: rotate(45deg);
  }

  .conference-session-setup-body {
    display: grid;
    gap: 0.58rem;
    padding-top: 0.5rem;
  }

  .conference-range-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.75rem;
    align-items: center;
  }

  .conference-range-row input[type='range'] {
    width: 100%;
    margin: 0;
    appearance: none;
    -webkit-appearance: none;
    height: 3px;
    border: 1px solid rgba(255, 255, 255, 0.24);
    background: transparent;
  }

  .conference-range-row input[type='range']::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 8px;
    height: 8px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.88);
    background: #02050b;
    box-shadow: none;
  }

  .conference-range-row input[type='range']::-moz-range-thumb {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.88);
    background: #02050b;
    box-shadow: none;
  }

  .conference-range-row output {
    color: var(--conference-muted);
    font-size: 0.72rem;
    white-space: nowrap;
  }

  .conference-synth-meters {
    display: grid;
    gap: 0.72rem;
  }

  .conference-synth-meter {
    display: grid;
    gap: 0.34rem;
  }

  .conference-synth-meter label {
    display: inline-flex;
    align-items: center;
    gap: 0.34rem;
    color: var(--conference-muted);
    font-size: 0.64rem;
    line-height: 1;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .conference-synth-meter-label {
    justify-content: space-between;
  }

  .conference-synth-formula-shell {
    position: relative;
    display: inline-grid;
    place-items: center;
    width: 1rem;
    height: 1rem;
    color: var(--conference-accent);
    font-size: 0.58rem;
    line-height: 1;
    cursor: help;
    outline: none;
  }

  .conference-synth-formula-tooltip {
    position: absolute;
    right: 0;
    bottom: calc(100% + 0.36rem);
    min-width: 12rem;
    padding: 0.38rem 0.48rem;
    border: 1px solid rgba(143, 227, 255, 0.16);
    background: rgba(0, 0, 0, 0.92);
    color: var(--conference-fg);
    opacity: 0;
    pointer-events: none;
    transform: translateY(0.2rem);
    transition: opacity 140ms ease, transform 140ms ease;
    z-index: 6;
  }

  .conference-synth-formula-shell:hover .conference-synth-formula-tooltip,
  .conference-synth-formula-shell:focus-visible .conference-synth-formula-tooltip {
    opacity: 1;
    transform: translateY(0);
  }

  .conference-synth-formula-tooltip math {
    font-size: 0.76rem;
  }

  .conference-synth-meter-row {
    display: grid;
    grid-template-columns: 0.7rem minmax(0, 1fr) 0.7rem auto;
    gap: 0.38rem;
    align-items: center;
  }

  .conference-synth-map-button {
    width: 0.58rem;
    height: 0.58rem;
    padding: 0;
    border: 1px solid rgba(143, 227, 255, 0.18);
    background: transparent;
    cursor: pointer;
    transition: border-color 140ms ease, background-color 140ms ease;
  }

  .conference-synth-map-button:hover,
  .conference-synth-map-button:focus-visible {
    border-color: rgba(143, 227, 255, 0.5);
    background: rgba(143, 227, 255, 0.08);
    outline: none;
  }

  .conference-synth-meter-row input[type='range'] {
    width: 100%;
    margin: 0;
    appearance: none;
    -webkit-appearance: none;
    height: 3px;
    border: 1px solid rgba(255, 255, 255, 0.24);
    background: transparent;
    pointer-events: none;
    opacity: 0.88;
  }

  .conference-synth-meter-row input[type='range']::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 8px;
    height: 8px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.88);
    background: #02050b;
    box-shadow: none;
  }

  .conference-synth-meter-row input[type='range']::-moz-range-thumb {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.88);
    background: #02050b;
    box-shadow: none;
  }

  .conference-synth-meter-row output {
    color: var(--conference-muted);
    font-size: 0.7rem;
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }

  .conference-mixer {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr)) minmax(72px, 0.72fr);
    gap: 0.45rem;
    align-items: stretch;
    min-height: 0;
  }

  .conference-mixer-channel {
    display: grid;
    justify-items: center;
    grid-template-rows: auto auto 1fr auto;
    gap: 0.28rem;
    min-height: 0;
    padding: 0.28rem 0.22rem 0.22rem;
    border: 0;
    background: transparent;
  }

  .conference-mixer-channel--video {
    align-items: stretch;
    justify-items: stretch;
    grid-template-rows: auto 1fr;
    min-width: 0;
  }

  .conference-mixer-channel-label {
    display: grid;
    gap: 0.1rem;
    justify-items: center;
    color: var(--conference-muted);
    font-size: 0.56rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-align: center;
  }

  .conference-mixer-channel-label strong {
    color: var(--conference-fg);
    font-size: 0.6rem;
  }

  .conference-mixer-fader {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    margin: 0;
    writing-mode: vertical-lr;
    direction: rtl;
    appearance: none;
    -webkit-appearance: none;
    background: transparent;
    border: 0;
  }

  .conference-mixer-fader::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 16px;
    height: 6px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.92);
    background: #02050b;
    box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.24);
  }

  .conference-mixer-fader::-moz-range-thumb {
    width: 16px;
    height: 6px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.92);
    background: #02050b;
    box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.24);
  }

  .conference-mixer-fader-shell {
    position: relative;
    width: 18px;
    height: 5.2rem;
    display: grid;
    place-items: center;
  }

  .conference-mixer-vumeter {
    --conference-meter-level: 0;
    position: absolute;
    inset: 0.05rem 0.35rem;
    border: 0;
    background:
      linear-gradient(
        to top,
        rgba(69, 211, 132, 0.04) 0%,
        rgba(69, 211, 132, 0.04) 58%,
        rgba(255, 216, 77, 0.04) 58%,
        rgba(255, 216, 77, 0.04) 82%,
        rgba(255, 92, 92, 0.04) 82%,
        rgba(255, 92, 92, 0.04) 100%
      );
    overflow: hidden;
    pointer-events: none;
  }

  .conference-mixer-vumeter::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        to top,
        rgba(69, 211, 132, 0.96) 0%,
        rgba(69, 211, 132, 0.96) 58%,
        rgba(255, 216, 77, 0.96) 58%,
        rgba(255, 216, 77, 0.96) 82%,
        rgba(255, 92, 92, 0.96) 82%,
        rgba(255, 92, 92, 0.96) 100%
      );
    transform: scaleY(var(--conference-meter-level));
    transform-origin: bottom center;
    box-shadow: 0 0 10px rgba(143, 227, 255, 0.18);
  }

  .conference-mixer-led {
    display: block;
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: rgba(69, 211, 132, 0.96);
    box-shadow: 0 0 8px rgba(69, 211, 132, 0.42);
    transition: opacity 140ms ease, box-shadow 140ms ease;
  }

  .conference-mixer-led--mute {
    display: grid;
    place-items: center;
    color: #05080d;
    font-size: 0.3rem;
    font-weight: 800;
    line-height: 1;
  }

  .conference-mixer-channel-toggle,
  .conference-mixer-fx-led-toggle {
    border: 0;
    background: transparent;
    color: var(--conference-fg);
    padding: 0;
    margin: 0;
    cursor: pointer;
  }

  .conference-mixer-fx-led-toggle {
    width: 8px;
    height: 8px;
    display: inline-grid;
    place-items: center;
    justify-self: end;
  }

  .conference-mixer-channel-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 12px;
  }

  .conference-mixer-channel-toggle[data-active='false'] .conference-mixer-led,
  .conference-mixer-fx-led-toggle[data-active='false'] .conference-mixer-led {
    opacity: 0.2;
    box-shadow: none;
  }

  .conference-mixer-knob-stack {
    display: grid;
    justify-items: center;
    gap: 0.12rem;
  }

  .conference-mixer-pan-input {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: 0;
    padding: 0;
    opacity: 0;
    pointer-events: none;
  }

  .conference-mixer-knob-control {
    --angle: 0deg;
    position: relative;
    width: 30px;
    height: 30px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.26);
    background: transparent;
    cursor: ns-resize;
    touch-action: none;
    padding: 0;
    box-shadow: none;
  }

  .conference-mixer-knob-control::before {
    content: 'L/R';
    position: absolute;
    left: 50%;
    bottom: -0.62rem;
    transform: translateX(-50%);
    color: var(--conference-muted);
    font-size: 0.42rem;
    line-height: 1;
    letter-spacing: 0.12em;
  }

  .conference-mixer-knob-control--plain::before {
    content: none;
  }

  .conference-mixer-knob-control--video {
    width: 22px;
    height: 22px;
    justify-self: center;
  }

  .conference-mixer-knob-control--video .conference-mixer-knob-indicator {
    height: 6px;
  }

  .conference-video-mixer-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.34rem 0.28rem;
    align-content: start;
    min-height: 0;
  }

  .conference-video-mixer-control {
    display: grid;
    justify-items: center;
    gap: 0.14rem;
    min-width: 0;
  }

  .conference-video-mixer-control--wide {
    grid-column: 1 / -1;
  }

  .conference-video-mixer-label {
    color: var(--conference-muted);
    font-size: 0.42rem;
    line-height: 1;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-align: center;
    white-space: nowrap;
  }

  .conference-mixer-knob-control:hover,
  .conference-mixer-knob-control:focus-visible {
    border-color: rgba(143, 227, 255, 0.34);
    outline: none;
  }

  .conference-mixer-knob-indicator {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 2px;
    height: 9px;
    border-radius: 999px;
    background: var(--conference-accent);
    transform: translate(-50%, -100%) rotate(var(--angle));
    transform-origin: 50% 100%;
    box-shadow: 0 0 8px rgba(143, 227, 255, 0.42);
  }

  .conference-mixer-fx {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 10px;
  }

  .conference-mixer-fx-pair {
    display: flex;
    align-items: flex-start;
    gap: 10px;
  }

  .conference-mixer-fx-card {
    flex: 1 1 0;
    padding: 10px;
    border: 0;
    background: transparent;
  }

  .conference-mixer-fx-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
    padding: 3px 0;
  }

  .conference-mixer-fx-head h4 {
    margin: 0;
    color: var(--conference-accent);
    font-size: 0.58rem;
    line-height: 1;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .conference-mixer-fx-badge {
    color: rgba(255, 226, 107, 0.78);
