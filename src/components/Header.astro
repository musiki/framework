---
import HeaderLink from './HeaderLink.astro';
import Search from './Search.astro';
import GraphModal from './GraphModal.astro';
import { createClient } from '@supabase/supabase-js';
import { getCollection } from 'astro:content';
import { getCourseFrontmatterId, getCourseLegacyCode } from '../lib/course-metadata';

// auth-astro populates Astro.locals.session
const session = Astro.locals.session;
const user = session?.user;
const {
	showPageInfoToggle = false,
	courseId = '',
	activeCourseId = '',
	activeCourseCode = '',
	presentationHref = '',
	performativeRoomHref = '',
	teacherCreateHref = '',
	teacherEditHref = '',
} = Astro.props as {
	showPageInfoToggle?: boolean;
	courseId?: string;
	activeCourseId?: string;
	activeCourseCode?: string;
	presentationHref?: string;
	performativeRoomHref?: string;
	teacherCreateHref?: string;
	teacherEditHref?: string;
};
const hasPresentationLink = typeof presentationHref === 'string' && presentationHref.trim().length > 0;
const normalizedPresentationHref = hasPresentationLink ? presentationHref.trim() : '';
const hasPerformativeRoomLink =
	typeof performativeRoomHref === 'string' && performativeRoomHref.trim().length > 0;
const normalizedPerformativeRoomHref = hasPerformativeRoomLink ? performativeRoomHref.trim() : '';
const currentPathWithQuery = `${Astro.url.pathname}${Astro.url.search}`;
const loginHref =
	currentPathWithQuery.startsWith('/login')
		? '/login'
		: `/login?redirect=${encodeURIComponent(currentPathWithQuery)}`;

const normalizeCourseId = (value: unknown) => String(value || '').trim();
const normalizeCourseIdKey = (value: unknown) => normalizeCourseId(value).toLowerCase();
const normalizeCourseCode = (value: unknown) => String(value || '').trim();
const toCourseAliasSlug = (value: unknown) =>
  String(value || '')
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '');
const encodeCoursePath = (value: unknown) =>
	String(value || '')
		.split('/')
		.map((segment) => encodeURIComponent(segment))
		.join('/');

type HeaderCourseOption = {
	courseId: string;
	title: string;
	code: string;
	pathSegment: string;
};

let enrolledCourses: HeaderCourseOption[] = [];
let inferredCourseIdFromQuery = normalizeCourseId(Astro.url.searchParams.get('course') || '');

if (user?.email) {
	try {
		const supabase = createClient(import.meta.env.SUPABASE_URL, import.meta.env.SUPABASE_KEY);
		const sessionEmail = String(user.email || '').trim();
		const { data: dbUser } = await supabase
			.from('User')
			.select('id')
			.eq('email', sessionEmail)
			.maybeSingle();

		const userId = String(dbUser?.id || '').trim();
		if (userId) {
			const { data: enrollments } = await supabase
				.from('Enrollment')
				.select('courseId')
				.eq('userId', userId);

			const enrolledCourseIds = Array.from(
				new Set(
					(Array.isArray(enrollments) ? enrollments : [])
						.map((row) => normalizeCourseId((row as { courseId?: string | null })?.courseId))
						.filter(Boolean),
				),
			);

			if (enrolledCourseIds.length > 0) {
				const courseEntries = await getCollection('cursos');
				const courseMetaById = new Map<string, { title: string; code: string; pathSegment: string }>();
				const canonicalByAlias = new Map<string, string>();

				for (const entry of courseEntries) {
					if (!entry.id.endsWith('/_index') && !entry.id.endsWith('_index')) continue;
					const nextCourseId = normalizeCourseId(entry.id.replace(/\/_index$/, ''));
					if (!nextCourseId) continue;
					const courseData = entry.data as Record<string, unknown>;
					const code = normalizeCourseCode(getCourseFrontmatterId(courseData, nextCourseId));
					const legacyCode = normalizeCourseCode(getCourseLegacyCode(courseData));
					const pathSegment = toCourseAliasSlug(getCourseFrontmatterId(courseData, nextCourseId)) || toCourseAliasSlug(nextCourseId) || nextCourseId;
					courseMetaById.set(nextCourseId, {
						title: String(entry.data?.title || nextCourseId),
						code,
						pathSegment,
					});
					canonicalByAlias.set(normalizeCourseIdKey(nextCourseId), nextCourseId);
					const slugAlias = toCourseAliasSlug(nextCourseId);
					if (slugAlias) canonicalByAlias.set(slugAlias, nextCourseId);
					if (code) canonicalByAlias.set(normalizeCourseIdKey(code), nextCourseId);
					if (legacyCode) canonicalByAlias.set(normalizeCourseIdKey(legacyCode), nextCourseId);
					const titleAlias = toCourseAliasSlug(entry.data?.title || '');
					if (titleAlias) canonicalByAlias.set(titleAlias, nextCourseId);
				}

				const canonicalCourseIds = Array.from(
					new Set(
						enrolledCourseIds
							.map((enrolledCourseId) =>
								canonicalByAlias.get(normalizeCourseIdKey(enrolledCourseId)) || enrolledCourseId,
							)
							.filter(Boolean),
					),
				);

				enrolledCourses = canonicalCourseIds
					.map((canonicalCourseId) => {
						const meta = courseMetaById.get(canonicalCourseId);
						if (!meta) return null;
						return {
							courseId: canonicalCourseId,
							title: String(meta.title || canonicalCourseId),
							code: normalizeCourseCode(meta.code || ''),
							pathSegment: String(meta.pathSegment || canonicalCourseId),
						};
					})
					.filter((course): course is HeaderCourseOption => Boolean(course))
					.sort((left, right) => left.title.localeCompare(right.title, 'es'));
			}
		}
	} catch (error) {
		console.error('Header enrolled courses lookup failed:', error);
	}
}

const activeCourseIdCandidates = [
	activeCourseId,
	courseId,
	inferredCourseIdFromQuery,
];
const activeCourseIdFromCandidates = activeCourseIdCandidates
	.map((candidate) => normalizeCourseId(candidate))
	.find(Boolean) || '';

const enrolledCourseByKey = new Map(
	enrolledCourses.map((course) => [normalizeCourseIdKey(course.courseId), course]),
);
const activeCourseByEnrollment = enrolledCourseByKey.get(
	normalizeCourseIdKey(activeCourseIdFromCandidates),
);
const resolvedActiveCourse = activeCourseByEnrollment || null;
const resolvedActiveCourseId = normalizeCourseId(
	activeCourseIdFromCandidates || resolvedActiveCourse?.courseId || '',
);
const resolvedActiveCourseLabel = resolvedActiveCourse?.title || '';
const courseMenuLabel = resolvedActiveCourseLabel || 'Cursos';
const showHeaderClassControls = Boolean(user && (resolvedActiveCourseId || hasPerformativeRoomLink));
const normalizedTeacherCreateHref = typeof teacherCreateHref === 'string' ? teacherCreateHref.trim() : '';
const normalizedTeacherEditHref = typeof teacherEditHref === 'string' ? teacherEditHref.trim() : '';
const showTeacherEditorActions = Boolean(user && (normalizedTeacherCreateHref || normalizedTeacherEditHref));

const withActiveCourse = (href: string) => {
	if (!resolvedActiveCourseId) return href;
	try {
		const nextUrl = new URL(href, Astro.url);
		nextUrl.searchParams.set('course', resolvedActiveCourseId);
		return `${nextUrl.pathname}${nextUrl.search}${nextUrl.hash}`;
	} catch {
		return href;
	}
};
---

<header>
	<nav>
		<h2>
			<a
				href="/"
				id="header-brand-link"
				class="brand-link"
				title="musiki26"
				aria-label="musiki26"
				data-build-state="unknown"
			>
				<img src="/logo-musiki.png" alt="musiki26" class="brand-logo" />
			</a>
		</h2>
		<div class="internal-links">
			<HeaderLink href="/">Inicio</HeaderLink>
			<HeaderLink href="/about">Acerca</HeaderLink>
			{user && <HeaderLink href={withActiveCourse('/dashboard')}>Dashboard</HeaderLink>}
			{
				user && enrolledCourses.length > 0 ? (
					<div class="course-menu">
						<button
							type="button"
							class="course-menu-trigger"
							id="course-menu-button"
							aria-haspopup="menu"
							aria-expanded="false"
							aria-label={resolvedActiveCourseLabel ? `Cambiar curso. Curso activo: ${resolvedActiveCourseLabel}` : 'Abrir cursos'}
						>
							<span class="course-menu-trigger-label">{courseMenuLabel}</span>
							<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<polyline points="6 9 12 15 18 9"></polyline>
							</svg>
						</button>
						<div class="course-dropdown" id="course-dropdown" role="menu">
							{enrolledCourses.map((course) => {
								const isCurrent = normalizeCourseIdKey(course.courseId) === normalizeCourseIdKey(resolvedActiveCourseId);
								const courseHref = `/cursos/${encodeCoursePath(course.pathSegment || course.courseId)}?course=${encodeURIComponent(course.courseId)}`;
								return (
									<a href={courseHref} role="menuitem" class:list={['course-dropdown-link', { active: isCurrent }]}>
										<span class="course-dropdown-title">{course.title}</span>
									</a>
								);
							})}
						</div>
					</div>
				) : (
					<HeaderLink href="/cursos">Cursos</HeaderLink>
				)
			}
			{
				user && resolvedActiveCourseId ? (
					<button
						id="header-right-sidebar-toggle"
						type="button"
						class="header-forum-toggle"
						title="Abrir foros (⌘/Ctrl + Shift + \\)"
						aria-label="Abrir foros"
					>
						Foro
					</button>
				) : null
			}
			{
				showTeacherEditorActions ? (
					<div class="header-editor-actions" aria-label="Acciones docentes">
						{
							normalizedTeacherCreateHref ? (
								<a
									href={normalizedTeacherCreateHref}
									class="header-editor-btn"
									title="Crear nota"
									aria-label="Crear nota"
								>
									C
								</a>
							) : null
						}
						{
							normalizedTeacherEditHref ? (
								<a
									href={normalizedTeacherEditHref}
									class="header-editor-btn"
									title="Editar nota"
									aria-label="Editar nota"
								>
									E
								</a>
							) : null
						}
					</div>
				) : null
			}
		</div>
		<Search />
		<div class="social-links">
			{
				hasPresentationLink && (
					<button
						id="presentation-toggle"
						class="presentation-toggle-btn"
						title="Abrir presentacion (Ctrl+E)"
						aria-label="Abrir presentacion"
						data-href={normalizedPresentationHref}
					>
						<svg viewBox="0 0 24 24" aria-hidden="true" width="24" height="24">
							<path
								fill="currentColor"
								d="M3 4.75A1.75 1.75 0 0 1 4.75 3h14.5A1.75 1.75 0 0 1 21 4.75v10.5A1.75 1.75 0 0 1 19.25 17h-5.5l1.2 3h1.8a.75.75 0 0 1 0 1.5h-9.5a.75.75 0 0 1 0-1.5h1.8l1.2-3h-6.5A1.75 1.75 0 0 1 3 15.25V4.75Zm1.5 0v10.5c0 .14.11.25.25.25h14.5a.25.25 0 0 0 .25-.25V4.75a.25.25 0 0 0-.25-.25H4.75a.25.25 0 0 0-.25.25Zm6.36 15.25h2.28l-1-2.5h-.28l-1 2.5Z"
							></path>
						</svg>
					</button>
				)
			}
			{
				user ? (
					<>
					{
						showHeaderClassControls && (
							<>
								<button
									id="header-live-interaction-toggle"
									type="button"
									class="header-activity-led-btn header-activity-led-btn--interaction"
									title="Abrir interacción en vivo"
									aria-label="Abrir interacción en vivo"
									data-course-id={resolvedActiveCourseId}
									hidden
								>
									<span class="header-activity-led-dot header-activity-led-dot--interaction" aria-hidden="true"></span>
									<span class="header-activity-led-timer" data-header-live-timer aria-hidden="true"></span>
								</button>
								<button
									id="performative-room-toggle"
									type="button"
									class="header-activity-led-btn header-activity-led-btn--room"
									title="Abrir sala performativa (Alt+Shift+L)"
									aria-label="Abrir sala performativa"
									data-course-id={resolvedActiveCourseId}
									data-fallback-href={normalizedPerformativeRoomHref}
									data-href={normalizedPerformativeRoomHref}
									hidden
								>
									<span class="header-activity-led-dot header-activity-led-dot--room" aria-hidden="true"></span>
									<span class="performative-room-led-label" aria-hidden="true">LIVE</span>
								</button>
							</>
						)
					}
					</>
				) : null
			}
			       <button id="graph-toggle" class="graph-toggle-btn" title="Mostrar grafo de conocimiento (g)">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
            <path d="M11 19.5a8.5 8.5 0 1 1 5.23-15.52l-1.06 1.06a6.5 6.5 0 1 0-3.17 12.46l-1 1zM12.5 5a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3zm-7 5a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3zm13 0a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3zm-7 7a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3z"/>
          </svg>
        </button>
	

			<button id="theme-toggle" class="theme-toggle" aria-label="Toggle theme">
				<svg class="sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
					<path d="M12 2.25a.75.75 0 01.75.75v2.25a.75.75 0 01-1.5 0V3a.75.75 0 01.75-.75zM7.5 12a4.5 4.5 0 119 0 4.5 4.5 0 01-9 0zM18.894 6.166a.75.75 0 00-1.06-1.06l-1.591 1.59a.75.75 0 101.06 1.061l1.591-1.59zM21.75 12a.75.75 0 01-.75.75h-2.25a.75.75 0 010-1.5H21a.75.75 0 01.75.75zM17.834 18.894a.75.75 0 001.06-1.06l-1.59-1.591a.75.75 0 10-1.061 1.06l1.59 1.591zM12 18a.75.75 0 01.75.75V21a.75.75 0 01-1.5 0v-2.25A.75.75 0 0112 18zM7.758 17.303a.75.75 0 00-1.061-1.06l-1.591 1.59a.75.75 0 001.06 1.061l1.591-1.59zM6 12a.75.75 0 01-.75.75H3a.75.75 0 010-1.5h2.25A.75.75 0 016 12zM6.697 7.757a.75.75 0 001.06-1.06l-1.59-1.591a.75.75 0 00-1.061 1.06l1.59 1.591z"/>
				</svg>
				<svg class="moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
					<path fill-rule="evenodd" d="M9.528 1.718a.75.75 0 01.162.819A8.97 8.97 0 009 6a9 9 0 009 9 8.97 8.97 0 003.463-.69.75.75 0 01.981.98 10.503 10.503 0 01-9.694 6.46c-5.799 0-10.5-4.701-10.5-10.5 0-4.368 2.667-8.112 6.46-9.694a.75.75 0 01.818.162z" clip-rule="evenodd"/>
				</svg>
			</button>
			{showPageInfoToggle && (
				<button
					id="page-info-toggle"
					class="page-info-toggle-btn"
					title="Mostrar informacion de la pagina"
					aria-label="Mostrar informacion de la pagina"
				>
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
						<path fill-rule="evenodd" d="M2.25 12a9.75 9.75 0 1119.5 0 9.75 9.75 0 01-19.5 0zM11.25 10.5a.75.75 0 011.5 0v5.25a.75.75 0 01-1.5 0V10.5zM12 8.25a.937.937 0 100-1.875.937.937 0 000 1.875z" clip-rule="evenodd" />
					</svg>
				</button>
			)}
			<div class="auth-links">
				{user ? (
					<div class="user-menu">
						<button class="user-button" id="user-menu-button">
							{user.image && <img src={user.image} alt={user.name || 'User'} class="user-avatar" />}
							<span>{user.name || user.email}</span>
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<polyline points="6 9 12 15 18 9"></polyline>
							</svg>
						</button>
						<div class="user-dropdown" id="user-dropdown">
							<a href={withActiveCourse('/dashboard')}>Dashboard</a>
							<a href="/api/auth/signout">Cerrar Sesión</a>
						</div>
					</div>
				) : (
					<a href={loginHref}>Login</a>
				)}
			</div>
		</div>
	</nav>
</header>
<GraphModal />
<script>
	declare global {
		interface Window {
			__musikiHeaderKeydownHandler?: (event: KeyboardEvent) => void;
			__musikiHeaderDocClickHandler?: (event: MouseEvent) => void;
			__musikiHeaderResizeHandler?: () => void;
			__musikiHeaderBuildMonitorTeardown?: () => void;
		}
	}

	const setupHeaderControls = () => {
		const syncHeaderHeight = () => {
			const header = document.querySelector('header');
			if (!(header instanceof HTMLElement)) return;
			document.documentElement.style.setProperty('--musiki-header-height', `${Math.ceil(header.offsetHeight)}px`);
		};

		const toggleRightSidebarGlobal = () => {
			const courseRoot = document.querySelector('[data-course-layout-root]');
			if (courseRoot instanceof HTMLElement && courseRoot.dataset.hasRightSidebar === 'true') {
				const open = courseRoot.dataset.rightOpen === 'true';
				const target = courseRoot.querySelector(open ? '[data-sidebar-toggle="right"]' : '[data-sidebar-handle="right"]');
				if (target instanceof HTMLElement) {
					target.click();
					return true;
				}
			}

			const genericTarget = document.querySelector('[data-sidebar-toggle="right"], [data-sidebar-handle="right"]');
			if (genericTarget instanceof HTMLElement) {
				genericTarget.click();
				return true;
			}

			return false;
		};

		const handleThemeToggleClick = () => {
			const element = document.documentElement;
			element.classList.toggle('dark');
			const isDark = element.classList.contains('dark');
			element.dataset.theme = isDark ? 'dark' : 'light';
			localStorage.setItem('theme', isDark ? 'dark' : 'light');
		};

		const themeButton = document.getElementById('theme-toggle');
		if (themeButton && !themeButton.dataset.bound) {
			themeButton.dataset.bound = 'true';
			themeButton.addEventListener('click', handleThemeToggleClick);
		}

		const pageInfoButton = document.getElementById('page-info-toggle');
		if (pageInfoButton && !pageInfoButton.dataset.bound) {
			pageInfoButton.dataset.bound = 'true';
			pageInfoButton.addEventListener('click', () => {
				window.dispatchEvent(new CustomEvent('wiki:toggle-info'));
			});
		}

		const graphToggleButton = document.getElementById('graph-toggle');
		if (graphToggleButton && !graphToggleButton.dataset.bound) {
			graphToggleButton.dataset.bound = 'true';
			graphToggleButton.addEventListener('click', () => {
				window.dispatchEvent(new CustomEvent('graph:toggle'));
			});
		}

		const rightSidebarButton = document.getElementById('header-right-sidebar-toggle');
		if (rightSidebarButton && !rightSidebarButton.dataset.bound) {
			rightSidebarButton.dataset.bound = 'true';
			rightSidebarButton.addEventListener('click', () => {
				toggleRightSidebarGlobal();
			});
		}

		const openPresentation = () => {
			const presentationButton = document.getElementById('presentation-toggle');
			const href = presentationButton?.getAttribute('data-href');
			if (!href) return;
			const nextUrl = new URL(href, window.location.origin);
			window.location.href = nextUrl.toString();
		};

		const openPerformativeRoom = () => {
			const roomButton = document.getElementById('performative-room-toggle');
			const href = roomButton?.getAttribute('data-href');
			if (!href) return;
			const nextUrl = new URL(href, window.location.origin);
			window.location.href = nextUrl.toString();
		};

		const presentationButton = document.getElementById('presentation-toggle');
		if (presentationButton && !presentationButton.dataset.bound) {
			presentationButton.dataset.bound = 'true';
			presentationButton.addEventListener('click', openPresentation);
		}

		const performativeRoomButton = document.getElementById('performative-room-toggle');
		if (performativeRoomButton && !performativeRoomButton.dataset.bound) {
			performativeRoomButton.dataset.bound = 'true';
			performativeRoomButton.addEventListener('click', openPerformativeRoom);
		}

		if (typeof window.__musikiHeaderKeydownHandler === 'function') {
			document.removeEventListener('keydown', window.__musikiHeaderKeydownHandler);
		}

		const keydownHandler = (event: KeyboardEvent) => {
			if (event.defaultPrevented) return;

			const target = event.target;
			const isEditable =
				target instanceof HTMLElement &&
				(target.isContentEditable || /^(INPUT|TEXTAREA|SELECT)$/.test(target.tagName));

			const key = String(event.key || '').toLowerCase();
			const code = String(event.code || '').toLowerCase();

			if (!event.ctrlKey && !event.metaKey && !event.altKey && !event.shiftKey) {
				if (key === 'g' && !isEditable) {
					event.preventDefault();
					window.dispatchEvent(new CustomEvent('graph:toggle'));
				}
				return;
			}

			if (event.altKey && event.shiftKey && !event.ctrlKey && !event.metaKey) {
				if (key !== 'l' || isEditable) return;
				const href = document.getElementById('performative-room-toggle')?.getAttribute('data-href');
				if (!href) return;
				event.preventDefault();
				openPerformativeRoom();
				return;
			}

			if ((event.ctrlKey || event.metaKey) && event.shiftKey && !event.altKey) {
				if (String(event.code || '').toLowerCase() !== 'backslash' || isEditable) return;
				if (toggleRightSidebarGlobal()) {
					event.preventDefault();
				}
				return;
			}

			if (!(event.ctrlKey || event.metaKey) || event.altKey || event.shiftKey) return;
			if (!(key === 'e' || code === 'keye')) return;
			if (isEditable) return;

			const href = document.getElementById('presentation-toggle')?.getAttribute('data-href');
			if (!href) return;

			event.preventDefault();
			openPresentation();
		};

		document.addEventListener('keydown', keydownHandler);
		window.__musikiHeaderKeydownHandler = keydownHandler;

		const userMenuButton = document.getElementById('user-menu-button');
		const userDropdown = document.getElementById('user-dropdown');
		const courseMenuButton = document.getElementById('course-menu-button');
		const courseDropdown = document.getElementById('course-dropdown');

		if (userMenuButton && userDropdown && !userMenuButton.dataset.bound) {
			userMenuButton.dataset.bound = 'true';
			userMenuButton.addEventListener('click', (event) => {
				event.stopPropagation();
				if (courseDropdown) {
					courseDropdown.classList.remove('show');
					courseMenuButton?.setAttribute('aria-expanded', 'false');
				}
				userDropdown.classList.toggle('show');
			});
		}

		if (courseMenuButton && courseDropdown && !courseMenuButton.dataset.bound) {
			courseMenuButton.dataset.bound = 'true';
			courseMenuButton.addEventListener('click', (event) => {
				event.stopPropagation();
				const willOpen = !courseDropdown.classList.contains('show');
				if (userDropdown) userDropdown.classList.remove('show');
				courseDropdown.classList.toggle('show', willOpen);
				courseMenuButton.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
			});
		}

		if (typeof window.__musikiHeaderDocClickHandler === 'function') {
			document.removeEventListener('click', window.__musikiHeaderDocClickHandler);
		}

		const docClickHandler = (_event: MouseEvent) => {
			const dropdown = document.getElementById('user-dropdown');
			dropdown?.classList.remove('show');
			const nextCourseDropdown = document.getElementById('course-dropdown');
			nextCourseDropdown?.classList.remove('show');
			const nextCourseMenuButton = document.getElementById('course-menu-button');
			nextCourseMenuButton?.setAttribute('aria-expanded', 'false');
		};

		document.addEventListener('click', docClickHandler);
		window.__musikiHeaderDocClickHandler = docClickHandler;

		if (typeof window.__musikiHeaderResizeHandler === 'function') {
			window.removeEventListener('resize', window.__musikiHeaderResizeHandler);
		}
		window.__musikiHeaderResizeHandler = syncHeaderHeight;
		syncHeaderHeight();
		window.requestAnimationFrame(syncHeaderHeight);
		window.addEventListener('resize', syncHeaderHeight, { passive: true });
	};

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', setupHeaderControls, { once: true });
	} else {
		setupHeaderControls();
	}

	document.addEventListener('astro:page-load', setupHeaderControls);
</script>
<script>
	const setupHeaderBuildMonitor = () => {
		const globalWindow = window as Window & {
			__musikiHeaderBuildMonitorTeardown?: () => void;
		};

		if (typeof globalWindow.__musikiHeaderBuildMonitorTeardown === 'function') {
			globalWindow.__musikiHeaderBuildMonitorTeardown();
			globalWindow.__musikiHeaderBuildMonitorTeardown = undefined;
		}

		const brandLink = document.getElementById('header-brand-link');
		if (!(brandLink instanceof HTMLAnchorElement)) return;

		const defaultTitle = brandLink.title || 'musiki26';
		let intervalId = 0;
		let controller: AbortController | null = null;

		const formatLocalTimestamp = (value: unknown) => {
			if (!value) return '';

			const date = new Date(String(value));
			if (Number.isNaN(date.getTime())) return '';

			try {
				return new Intl.DateTimeFormat(undefined, {
					year: 'numeric',
					month: '2-digit',
					day: '2-digit',
					hour: '2-digit',
					minute: '2-digit',
					timeZoneName: 'short',
				}).format(date);
			} catch {
				return date.toLocaleString();
			}
		};

		const buildLocalSyncTitle = (payload: Record<string, unknown>) => {
			const state = String(payload.state || 'unknown').trim() || 'unknown';
			const runNumber = payload.runNumber;
			const timestamp = formatLocalTimestamp(payload.updatedAt || payload.createdAt || payload.fetchedAt);
			const suffix = [runNumber ? `run ${runNumber}` : '', timestamp].filter(Boolean).join(' · ');
			const details = suffix ? ` · ${suffix}` : '';

			if (state === 'running') return `Sincronización de contenidos en curso${details}`;
			if (state === 'ok') return `Última sincronización correcta${details}`;
			if (state === 'error') return `Última sincronización con error${details}`;
			if (state === 'idle') return `Sincronización sin cambios${details}`;
			return '';
		};

		const applyPayload = (payload: Record<string, unknown>) => {
			const state = String(payload.state || 'unknown').trim() || 'unknown';
			const title =
				buildLocalSyncTitle(payload)
				|| String(payload.title || defaultTitle).trim()
				|| defaultTitle;

			brandLink.dataset.buildState = state;
			brandLink.title = title;
			brandLink.setAttribute('aria-label', title);
		};

		const applyFallback = () => {
			applyPayload({
				state: 'unknown',
				title: defaultTitle,
			});
		};

		const refresh = async () => {
			if (controller) controller.abort();
			controller = new AbortController();

			try {
				const response = await fetch('/api/internal/build-status', {
					headers: { Accept: 'application/json' },
					signal: controller.signal,
				});

				if (!response.ok) {
					throw new Error(`HTTP ${response.status}`);
				}

				const payload = await response.json();
				applyPayload(payload);
			} catch (error) {
				if (error instanceof DOMException && error.name === 'AbortError') return;
				applyFallback();
			}
		};

		void refresh();
		intervalId = window.setInterval(() => {
			void refresh();
		}, 20_000);

		globalWindow.__musikiHeaderBuildMonitorTeardown = () => {
			if (controller) controller.abort();
			window.clearInterval(intervalId);
		};
	};

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', setupHeaderBuildMonitor, { once: true });
	} else {
		setupHeaderBuildMonitor();
	}

	document.addEventListener('astro:page-load', setupHeaderBuildMonitor);
</script>
<script>
	import { subscribeToClassActivity } from '../lib/class-activity/client.mjs';
	import { selectInteractionBeaconState, selectRoomBeaconState } from '../lib/class-activity/model.mjs';

	const setupHeaderActivityIndicators = () => {
		const globalWindow = window as Window & {
			__musikiHeaderActivityTeardown?: () => void;
		};

		if (typeof globalWindow.__musikiHeaderActivityTeardown === 'function') {
			globalWindow.__musikiHeaderActivityTeardown();
			globalWindow.__musikiHeaderActivityTeardown = undefined;
		}

		const roomButton = document.getElementById('performative-room-toggle');
		const interactionButton = document.getElementById('header-live-interaction-toggle');
		if (!(roomButton instanceof HTMLButtonElement) && !(interactionButton instanceof HTMLButtonElement)) return;

		const courseId = String(
			roomButton?.dataset.courseId
			|| interactionButton?.dataset.courseId
			|| '',
		).trim();
		if (!courseId) return;

		const fallbackRoomHref = String(roomButton?.dataset.fallbackHref || roomButton?.dataset.href || '').trim();
		const interactionTimerNode = interactionButton?.querySelector('[data-header-live-timer]');
		let latestSnapshot = null;

		const openHeaderHref = (button: HTMLButtonElement | null) => {
			if (!(button instanceof HTMLButtonElement)) return;
			const href = String(button.dataset.href || '').trim();
			if (!href) return;
			window.location.href = new URL(href, window.location.origin).toString();
		};

		if (interactionButton instanceof HTMLButtonElement && interactionButton.dataset.boundHeaderActivity !== 'true') {
			interactionButton.dataset.boundHeaderActivity = 'true';
			interactionButton.addEventListener('click', () => openHeaderHref(interactionButton));
		}

		const render = () => {
			const roomState = selectRoomBeaconState(latestSnapshot, {
				courseId,
				fallbackHref: fallbackRoomHref,
			});
			const interactionState = selectInteractionBeaconState(latestSnapshot, {
				courseId,
			});

			if (roomButton instanceof HTMLButtonElement) {
				roomButton.hidden = !roomState.visible;
				roomButton.dataset.href = roomState.href || fallbackRoomHref;
				if (roomState.visible) {
					roomButton.title = roomState.title || 'Clase en vivo';
					roomButton.setAttribute('aria-label', roomState.title || 'Clase en vivo');
				}
			}

			if (interactionButton instanceof HTMLButtonElement) {
				interactionButton.hidden = !interactionState.visible;
				interactionButton.dataset.href = interactionState.href || '';
				if (interactionState.visible) {
					interactionButton.title = interactionState.title || 'Interacción en vivo';
					interactionButton.setAttribute('aria-label', interactionState.title || 'Interacción en vivo');
					if (interactionTimerNode instanceof HTMLElement) {
						interactionTimerNode.textContent = interactionState.timerLabel || '';
					}
				} else if (interactionTimerNode instanceof HTMLElement) {
					interactionTimerNode.textContent = '';
				}
			}
		};

		const unsubscribe = subscribeToClassActivity({
			courseId,
			onEvent: (_eventName, snapshot) => {
				latestSnapshot = snapshot;
				render();
			},
		});

		const tickId = window.setInterval(() => {
			if (!latestSnapshot) return;
			render();
		}, 1000);

		render();

		globalWindow.__musikiHeaderActivityTeardown = () => {
			unsubscribe?.();
			window.clearInterval(tickId);
		};
	};

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', setupHeaderActivityIndicators, { once: true });
	} else {
		setupHeaderActivityIndicators();
	}

	document.addEventListener('astro:page-load', setupHeaderActivityIndicators);
</script>
