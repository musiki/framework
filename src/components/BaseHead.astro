---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/theme.css';
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import FallbackImage from '../assets/universe.png';
import { SITE_TITLE } from '../consts';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const pageURL = canonicalURL.toString();

const { title, description, image = FallbackImage } = Astro.props;
const imageURL = new URL(image.src, canonicalURL).toString();
const gaMeasurementId = String(import.meta.env.PUBLIC_GA_MEASUREMENT_ID || 'G-0NXGW5G7NX').trim();
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" />

<!-- Prevent FOUC: Set dark mode immediately -->
<script is:inline>
	(function() {
		const readStoredTheme = () => {
			try {
				const value = localStorage.getItem('theme');
				return value === 'dark' || value === 'light' ? value : null;
			} catch {
				return null;
			}
		};

		// Use explicit user choice when available; otherwise default to light.
		const theme = readStoredTheme() || 'light';
		const root = document.documentElement;
		root.classList.toggle('dark', theme === 'dark');
		root.dataset.theme = theme;
	})();
</script>
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={pageURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageURL} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={pageURL} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={imageURL} />

<script is:inline define:vars={{ gaMeasurementId }}>
	(() => {
		const measurementId = String(gaMeasurementId || '').trim();
		if (!measurementId) return;

		const allowedHosts = new Set(['musiki.org.ar', 'www.musiki.org.ar']);
		const hostname = String(window.location.hostname || '').toLowerCase();
		if (!allowedHosts.has(hostname)) return;

		window.dataLayer = window.dataLayer || [];
		window.gtag =
			window.gtag ||
			function gtag() {
				window.dataLayer.push(arguments);
			};

		const gtag = window.gtag;
		const pagePath = () => `${window.location.pathname}${window.location.search}`;
		const trackPageView = () => {
			const currentLocation = String(window.location.href || '');
			if (!currentLocation) return;
			if (window.__musikiAnalyticsLastLocation === currentLocation) return;
			window.__musikiAnalyticsLastLocation = currentLocation;
			gtag('event', 'page_view', {
				page_title: document.title,
				page_location: currentLocation,
				page_path: pagePath(),
			});
		};

		if (!window.__musikiAnalyticsInitialized) {
			window.__musikiAnalyticsInitialized = true;

			if (!document.querySelector(`script[data-musiki-ga="${measurementId}"]`)) {
				const script = document.createElement('script');
				script.async = true;
				script.src = `https://www.googletagmanager.com/gtag/js?id=${encodeURIComponent(measurementId)}`;
				script.dataset.musikiGa = measurementId;
				document.head.appendChild(script);
			}

			gtag('js', new Date());
			gtag('config', measurementId, {
				send_page_view: false,
				anonymize_ip: true,
			});

			document.addEventListener('astro:page-load', trackPageView);
			queueMicrotask(trackPageView);
			return;
		}

		trackPageView();
	})();
</script>
